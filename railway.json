{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm install --omit=dev --ignore-scripts"
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/api/managed/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
