          { name: 'purchase - item_sku',       path: 'ecommerce.items.0.sku' },

          // ── add_to_wishlist ──
          { name: 'add_to_wishlist - item_id',    path: 'ecommerce.items.0.item_id' },
          { name: 'add_to_wishlist - item_name',  path: 'ecommerce.items.0.item_name' },
