    /* ── History Panel ───────────────────────────────────────── */
    #historyPanel {
      position: fixed;
      top: 0;
      left: 0;
      width: 380px;
      max-width: 95vw;
      height: 100vh;
      background: #0D1018;
      border-right: 1px solid rgba(70, 241, 197, 0.1);
      z-index: 150;
      display: flex;
      flex-direction: column;
      transform: translateX(-100%);
      transition: transform .35s cubic-bezier(.16, 1, .3, 1);
      box-shadow: 4px 0 40px rgba(0, 0, 0, 0.6);
    }

    #historyPanel.open {
      transform: translateX(0);
    }

    #historyOverlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      z-index: 149;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s;
    }

    #historyOverlay.open {
      opacity: 1;
      pointer-events: all;
    }

    .hp-header {
      padding: 24px 20px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .hp-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 17px;
      color: var(--wht);
      flex: 1;
    }

    .hp-close {
