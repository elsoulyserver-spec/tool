      background: var(--sur3);
      border: 1px solid rgba(255, 255, 255, 0.1);
      overflow: hidden;
    }

    .ub-profile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ══ EASY TRACK SIDEBAR ══════════════════════════════════════════ */
