<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <!-- Prevent browser caching so tool updates always reach the client -->
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Easy Track — Pixel Config Generator</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&family=IBM+Plex+Mono:wght@400;500;700&family=Syne:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      /* ── Easy Track Design System ── */
      --bg: #0B0E14;
      --sur: #10131a;
      --sur2: #191c22;
      --sur3: #272a31;
      --sur4: #32353c;

      /* Primary — teal-green */
      --acc: #46f1c5;
      --acc2: #00d4aa;
      --acc-dim: rgba(70, 241, 197, 0.10);
      --acc-glow: rgba(70, 241, 197, 0.20);

      /* النصوص */
      --wht: #e1e2eb;
      --wht2: #bacac2;
      --mut: #85948d;
      --mut2: #3b4a44;

      /* Status */
      --grn: #46f1c5;
      --red: #ffb4ab;
      --blu: #adc6ff;
      --amber: #f59e0b;

      /* Borders */
      --bdr: rgba(70, 241, 197, 0.18);
      --bdr2: rgba(255, 255, 255, 0.07);
      --bdr3: rgba(255, 255, 255, 0.03);

      /* Legacy aliases */
      --gold: #46f1c5;
      --gdim: rgba(70, 241, 197, 0.10);
      --gglow: rgba(70, 241, 197, 0.20);
      --gold2: #00d4aa;
      --teal: #46f1c5;

      /* ── Typography ── */
      --font-display: 'Plus Jakarta Sans', sans-serif;
      --font-ui: 'Inter', sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;

      /* Size scale */
      --text-xs: 11px;
      --text-sm: 12px;
      --text-base: 14px;
      --text-md: 15px;
      --text-lg: 18px;
      --text-xl: 22px;
      --text-2xl: 28px;
      --text-3xl: 36px;

      /* Line heights */
      --leading-tight: 1.2;
      --leading-snug: 1.4;
      --leading-normal: 1.6;
      --leading-loose: 1.8;

      /* Letter spacing */
      --tracking-tight: -0.4px;
      --tracking-normal: 0px;
      --tracking-wide: 0.5px;
      --tracking-wider: 1.5px;
      --tracking-widest: 3px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      background: var(--bg);
      color: var(--wht2);
      font-family: var(--font-ui);
      font-size: var(--text-base);
      line-height: var(--leading-normal);
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Easy Track ambient glow */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 60% 40% at 80% 0%, rgba(70, 241, 197, .07), transparent 60%),
        radial-gradient(ellipse 40% 30% at 10% 100%, rgba(173, 198, 255, .04), transparent 55%),
        radial-gradient(ellipse 30% 20% at 50% 50%, rgba(70, 241, 197, .02), transparent 60%);
      pointer-events: none;
    }

    /* Hairline grid */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      background-image:
        linear-gradient(rgba(70, 241, 197, .015) 1px, transparent 1px),
        linear-gradient(90deg, rgba(70, 241, 197, .015) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 100%);
    }

    .app {
      position: relative;
      z-index: 1;
    }

    @keyframes gin {
      from {
        opacity: 0;
        transform: scale(.95) translateY(20px)
      }

      to {
        opacity: 1;
        transform: scale(1) translateY(0)
      }
    }

    @keyframes spin {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1)
      }

      50% {
        opacity: .5;
        transform: scale(.75)
      }
    }

    @keyframes pin {
      from {
        opacity: 0;
        transform: translateY(8px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    /* GATE — Easy Track Glass Card */
    #gate {
      position: fixed;
      inset: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    #gate::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(11, 14, 20, .96);
      backdrop-filter: blur(32px);
      pointer-events: none;
    }

    /* ambient glow behind gate */
    #gate::after {
      content: '';
      position: absolute;
      top: 20%;
      left: 50%;
      transform: translateX(-50%);
      width: 500px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(ellipse, rgba(70, 241, 197, .08) 0%, transparent 70%);
      pointer-events: none;
    }

    .gbox {
      position: relative;
      z-index: 10;
      background: rgba(25, 28, 34, 0.9);
      border: 1px solid rgba(70, 241, 197, 0.12);
      border-radius: 24px;
      padding: 44px 40px;
      max-width: 460px;
      width: 100%;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, .03), 0 32px 80px rgba(0, 0, 0, .7), 0 0 60px rgba(70, 241, 197, .04);
      animation: gin .4s cubic-bezier(.16, 1, .3, 1);
      backdrop-filter: blur(16px);
    }

    .geyebrow {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
    }

    .gdot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--acc);
      box-shadow: 0 0 12px var(--acc);
      animation: pulse 2s infinite;
    }

    .geyebrow span {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 3px;
      color: var(--acc);
      text-transform: uppercase;
    }

    .gtitle {
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 800;
      line-height: 1.25;
      margin-bottom: 8px;
      color: var(--wht);
      letter-spacing: -0.5px;
    }

    .gtitle em {
      font-style: normal;
      color: var(--acc);
    }

    .gsub {
      color: var(--mut);
      font-size: 13px;
      line-height: 1.75;
      margin-bottom: 28px;
    }

    .fgroup {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 18px;
    }

    .fwrap {
      position: relative;
    }

    .ficon {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--mut2);
      font-size: 15px;
      pointer-events: none;
      transition: color .15s;
    }

    .finput {
      width: 100%;
      background: rgba(39, 42, 49, 0.6);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 12px;
      padding: 13px 42px 13px 16px;
      color: var(--wht2);
      font-family: var(--font-ui);
      font-size: 14px;
      outline: none;
      transition: all .2s;
      direction: rtl;
    }

    .finput[type=tel] {
      direction: ltr;
      text-align: right;
    }

    .finput:focus {
      border-color: rgba(70, 241, 197, .4);
      background: rgba(70, 241, 197, .04);
      box-shadow: 0 0 0 3px rgba(70, 241, 197, .08);
    }

    .finput:focus+.ficon {
      color: var(--acc);
    }

    .finput::placeholder {
      color: var(--mut2);
    }

    .gerr {
      display: none;
      color: var(--red);
      font-size: 12px;
      margin-bottom: 10px;
      padding: 10px 14px;
      background: rgba(255, 180, 171, .06);
      border: 1px solid rgba(255, 180, 171, .2);
      border-radius: 10px;
    }

    .gcta {
      width: 100%;
      background: var(--acc);
      color: #00382b;
      border: none;
      border-radius: 12px;
      padding: 14px 24px;
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 4px 20px rgba(70, 241, 197, .3);
      letter-spacing: -0.2px;
    }

    .gcta:hover {
      background: var(--acc2);
      transform: translateY(-1px);
      box-shadow: 0 8px 32px rgba(70, 241, 197, .35);
    }

    .gfoot {
      margin-top: 20px;
      padding-top: 18px;
      border-top: 1px solid rgba(255, 255, 255, .05);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }

    .gli {
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      color: var(--mut);
      font-size: 12px;
      transition: color .15s;
    }

    .gli:hover {
      color: var(--wht2);
    }

    .gli svg {
      width: 16px;
      height: 16px;
      fill: #0A66C2;
    }

    .gpriv {
      font-size: 11px;
      color: var(--mut2);
    }

    /* MAIN */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 24px 100px;
    }

    .hdr {
      text-align: center;
      margin-bottom: 56px;
    }

    .hbadge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--acc-dim);
      border: 1px solid var(--bdr);
      border-radius: 100px;
      padding: 6px 16px;
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--acc);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    .hbdot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--acc);
      animation: pulse 2s infinite;
    }

    .hdr h1 {
      font-family: var(--font-display);
      font-size: clamp(28px, 4.5vw, 44px);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 14px;
      color: var(--wht);
      letter-spacing: -1px;
    }

    .hdr h1 em {
      font-style: normal;
      color: var(--acc);
    }

    .hdr p {
      color: var(--mut);
      font-size: 14px;
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.8;
    }

    /* PROGRESS — Easy Track Stepper v2 */
    .ptrack {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 44px;
      padding: 16px 24px;
      background: rgba(25, 28, 34, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 20px;
      backdrop-filter: blur(8px);
    }

    .pstep {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .pcirc {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      color: var(--mut);
      background: var(--sur2);
      transition: all .35s cubic-bezier(.16, 1, .3, 1);
      position: relative;
      z-index: 1;
    }

    .pcirc.on {
      border-color: var(--acc);
      color: var(--acc);
      background: rgba(70, 241, 197, 0.08);
      box-shadow: 0 0 0 5px rgba(70, 241, 197, .08), 0 0 24px rgba(70, 241, 197, .2);
    }

    .pcirc.on::before {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      border: 1.5px solid rgba(70, 241, 197, .2);
      animation: pulsering 2s ease infinite;
    }

    @keyframes pulsering {
      0% {
        transform: scale(1);
        opacity: .6;
      }

      70% {
        transform: scale(1.3);
        opacity: 0;
      }

      100% {
        transform: scale(1);
        opacity: 0;
      }
    }

    .pcirc.done {
      border-color: var(--acc);
      background: var(--acc);
      color: #00382b;
      font-size: 16px;
      box-shadow: 0 0 20px rgba(70, 241, 197, .3), 0 4px 12px rgba(0, 0, 0, .3);
    }

    .plbl {
      font-size: 10px;
      color: var(--mut);
      transition: all .3s;
      white-space: nowrap;
      font-weight: 600;
      font-family: var(--font-ui);
      letter-spacing: .8px;
      text-transform: uppercase;
      opacity: .7;
    }

    .plbl.on {
      color: var(--acc);
      opacity: 1;
      text-shadow: 0 0 12px rgba(70, 241, 197, .4);
    }

    .pcon {
      flex: 1;
      height: 2px;
      max-width: 80px;
      min-width: 24px;
      background: rgba(255, 255, 255, 0.06);
      margin-bottom: 32px;
      transition: background .4s;
      position: relative;
      overflow: hidden;
      border-radius: 2px;
    }

    .pcon::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--acc2), var(--acc));
      transform: scaleX(0);
      transform-origin: right;
      transition: transform .6s cubic-bezier(.16, 1, .3, 1);
      border-radius: 2px;
    }

    .pcon.done::after {
      transform: scaleX(1);
      transform-origin: right;
    }

    /* PANELS — Glass Cards */
    .panel {
      background: #191c22;
      border: 1px solid rgba(133, 148, 141, 0.05);
      border-radius: 24px;
      padding: 32px;
      display: none;
      animation: pin .25s ease;
      box-shadow: 0 4px 20px rgba(0, 0, 0, .2);
    }

    .panel.on {
      display: block;
    }

    .phdr {
      margin-bottom: 28px;
    }

    .pnum {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--acc);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      opacity: .8;
    }

    .pnum::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, rgba(70, 241, 197, .2), transparent);
    }

    .ptitle {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 6px;
      color: var(--wht);
      letter-spacing: -0.5px;
      font-family: var(--font-display);
    }

    .psub {
      color: var(--mut);
      font-size: 13px;
      line-height: 1.7;
    }

    /* CHOICE GRID — Platform Cards */
    .cgrid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: 12px;
    }

    .cbtn {
      background: rgba(39, 42, 49, 0.6);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 16px;
      padding: 20px 14px;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 13px;
      font-weight: 600;
      user-select: none;
      position: relative;
      overflow: hidden;
    }

    .cbtn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(70, 241, 197, .04), transparent);
      opacity: 0;
      transition: opacity .2s;
    }

    .cbtn:hover {
      border-color: rgba(70, 241, 197, .2);
      color: var(--wht2);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, .3);
    }

    .cbtn:hover::before {
      opacity: 1;
    }

    .cbtn.on {
      border-color: rgba(70, 241, 197, .4);
      background: rgba(70, 241, 197, .07);
      color: var(--wht);
      box-shadow: 0 0 0 1px rgba(70, 241, 197, .2), 0 0 20px rgba(70, 241, 197, .08);
    }

    .cbtn.on::before {
      opacity: 1;
    }

    .cicon {
      font-size: 28px;
      line-height: 1;
    }

    .cchk {
      position: absolute;
      top: 10px;
      left: 10px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--acc);
      color: #00382b;
      font-size: 10px;
      display: none;
      align-items: center;
      justify-content: center;
      font-weight: 900;
    }

    .cbtn.on .cchk {
      display: flex;
    }

    .ptags {
      display: flex;
      gap: 3px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .ptag {
      font-size: 9px;
      padding: 2px 6px;
      border-radius: 4px;
      background: rgba(255, 255, 255, .05);
      color: var(--mut);
      font-family: var(--font-mono);
      border: 1px solid var(--bdr3);
    }

    /* CMS Selection Grid (New Design) */
    .cms-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(220px, 1fr));
      gap: 20px;
      max-width: 500px;
      margin: 0 auto;
    }

    .cms-card {
      position: relative;
      background: var(--sur2);
      padding: 32px 24px;
      border-radius: 12px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: all .3s ease;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      box-shadow: 0 4px 20px rgba(0, 0, 0, .4);
      user-select: none;
      overflow: hidden;
    }

    .cms-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(70, 241, 197, .05), transparent);
      opacity: 0;
      transition: opacity .3s;
      z-index: 0;
    }

    .cms-card:hover {
      border-color: rgba(70, 241, 197, .2);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, .5);
    }

    .cms-card:hover::before {
      opacity: 1;
    }

    .cms-card.on {
      border-color: rgba(70, 241, 197, .4);
      background: rgba(70, 241, 197, .05);
      box-shadow: 0 0 0 1px rgba(70, 241, 197, .2), 0 0 24px rgba(70, 241, 197, .08);
    }

    .cms-logo {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--sur3);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      position: relative;
      z-index: 1;
    }

    .cms-logo img {
      width: 40px;
      height: 40px;
      object-fit: contain;
    }

    .cms-logo .material-symbols-outlined {
      font-size: 32px;
      color: var(--acc);
    }

    .cms-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--wht);
      margin-bottom: 8px;
      font-family: var(--font-display);
      position: relative;
      z-index: 1;
    }

    .cms-sub {
      font-size: 13px;
      color: var(--mut);
      font-weight: 500;
      margin-bottom: 32px;
      font-family: var(--font-ui);
      position: relative;
      z-index: 1;
    }

    .cms-sel-btn {
      margin-top: auto;
      width: 100%;
      padding: 12px 24px;
      background: var(--sur3);
      color: var(--acc);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 8px;
      font-weight: 600;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all .3s;
      position: relative;
      z-index: 1;
      font-family: var(--font-ui);
      font-size: 14px;
    }

    .cms-card:hover .cms-sel-btn {
      background: var(--acc);
      color: #00382b;
      border-color: transparent;
    }

    .cms-card.on .cms-sel-btn {
      background: var(--acc);
      color: #00382b;
      border-color: transparent;
    }

    .cms-chk {
      position: absolute;
      top: 12px;
      left: 12px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--acc);
      color: #00382b;
      display: none;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 900;
      z-index: 2;
    }

    .cms-card.on .cms-chk {
      display: flex;
    }

    /* PIXEL INPUTS */
    .pixtabs {
      display: flex;
      gap: 6px;
      margin-bottom: 16px;
      flex-wrap: wrap;
      padding: 4px;
      background: var(--sur2);
      border-radius: 12px;
      border: 1px solid var(--bdr2);
    }

    .pixtab {
      padding: 7px 18px;
      border-radius: 8px;
      border: none;
      background: transparent;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }

    .pixtab.on {
      background: var(--sur4);
      color: var(--wht);
      box-shadow: 0 1px 3px rgba(0, 0, 0, .4);
    }

    .pixwrap {
      display: none;
    }

    .pixwrap.on {
      display: block;
    }

    .pixfield {
      width: 100%;
      background: rgba(39, 42, 49, .5);
      border: 1px solid rgba(255, 255, 255, .07);
      border-radius: 12px;
      padding: 13px 18px;
      color: var(--wht2);
      font-family: var(--font-mono);
      font-size: 13px;
      outline: none;
      transition: all .15s;
      direction: ltr;
    }

    .pixfield:focus {
      border-color: rgba(70, 241, 197, .4);
      box-shadow: 0 0 0 3px rgba(70, 241, 197, .08);
    }

    .pixfield::placeholder {
      color: var(--mut2);
      font-size: 12px;
    }

    .pixhint {
      margin-top: 8px;
      font-size: 11px;
      color: var(--mut);
      line-height: 1.6;
    }

    /* ACTIONS */
    .pacts {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid rgba(255, 255, 255, .04);
      flex-wrap: wrap;
    }

    .bbk {
      background: transparent;
      color: var(--mut);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 10px;
      padding: 11px 22px;
      font-family: var(--font-ui);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }

    .bbk:hover {
      border-color: rgba(255, 255, 255, .15);
      color: var(--wht2);
      background: var(--sur2);
    }

    .bnxt {
      background: var(--acc);
      color: #00382b;
      border: none;
      border-radius: 10px;
      padding: 11px 28px;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: all .15s;
      box-shadow: 0 4px 16px rgba(70, 241, 197, .25);
    }

    .bnxt:hover {
      background: var(--acc2);
      box-shadow: 0 6px 24px rgba(70, 241, 197, .35);
      transform: translateY(-1px);
    }

    .bnxt:disabled {
      opacity: .25;
      cursor: not-allowed;
      box-shadow: none;
      transform: none;
    }

    .bgen {
      background: var(--acc);
      color: #00382b;
      border: none;
      border-radius: 10px;
      padding: 12px 32px;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 4px 16px rgba(70, 241, 197, .3);
    }

    .bgen:hover {
      background: var(--acc2);
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(70, 241, 197, .4);
    }

    /* OUTPUT */
    .outwrap {
      display: none;
    }

    .outwrap.on {
      display: block;
    }

    .sumstrip {
      background: rgba(25, 28, 34, .8);
      border: 1px solid rgba(70, 241, 197, .1);
      border-radius: 18px;
      padding: 20px 24px;
      margin-bottom: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      align-items: center;
      backdrop-filter: blur(8px);
      box-shadow: 0 0 40px rgba(70, 241, 197, .04);
    }

    .sitem {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .slbl {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .sval {
      font-size: 15px;
      font-weight: 800;
      color: var(--wht);
      font-family: var(--font-display);
    }

    .sval.g {
      color: var(--acc);
    }

    /* ── OUTPUT TABS ── */
    .otabs {
      display: flex;
      gap: 4px;
      background: rgba(16, 19, 26, 0.95);
      border: 1px solid rgba(70, 241, 197, 0.08);
      padding: 6px;
      border-radius: 16px;
      margin-bottom: 24px;
      overflow-x: auto;
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
    }

    .otabs::-webkit-scrollbar {
      height: 0;
    }

    .otab {
      padding: 9px 16px;
      border-radius: 11px;
      border: none;
      background: transparent;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 7px;
      letter-spacing: 0.2px;
    }

    .otab:hover {
      color: var(--wht2);
      background: rgba(255, 255, 255, 0.04);
    }

    .otab.on {
      background: rgba(70, 241, 197, 0.1);
      color: var(--acc);
      box-shadow: 0 0 0 1px rgba(70, 241, 197, 0.2), 0 2px 8px rgba(0, 0, 0, 0.4);
      font-weight: 700;
    }

    .otab.on .material-symbols-outlined {
      filter: drop-shadow(0 0 4px rgba(70, 241, 197, 0.5));
    }

    .opane {
      display: none;
    }

    .opane.on {
      display: block;
      animation: pin .25s ease;
    }

    /* Code blocks — Easy Track style */
    .cwrap {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 16px;
      overflow: hidden;
    }

    .ctbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 18px;
      background: rgba(39, 42, 49, .6);
      border-bottom: 1px solid rgba(255, 255, 255, .05);
      backdrop-filter: blur(8px);
    }

    .ctdots {
      display: flex;
      gap: 6px;
    }

    .ctdot {
      width: 11px;
      height: 11px;
      border-radius: 50%;
    }

    .clang {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--mut);
      letter-spacing: 1px;
    }

    .ctacts {
      display: flex;
      gap: 6px;
    }

    .cpybtn {
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .08);
      color: var(--mut);
      border-radius: 8px;
      padding: 5px 14px;
      font-family: var(--font-ui);
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }

    .cpybtn:hover {
      background: var(--acc-dim);
      border-color: var(--bdr);
      color: var(--acc);
    }

    .dlbtn {
      background: rgba(70, 241, 197, .07);
      border: 1px solid rgba(70, 241, 197, .2);
      color: var(--acc);
      border-radius: 8px;
      padding: 5px 14px;
      font-family: var(--font-ui);
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }

    .dlbtn:hover {
      background: rgba(70, 241, 197, .14);
    }

    .cbody {
      padding: 22px 26px;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.9;
      color: #94a3b8;
      overflow-x: auto;
      white-space: pre;
      max-height: 480px;
      overflow-y: auto;
      direction: ltr;
      text-align: left;
      tab-size: 2;
      background: var(--bg);
    }

    .cbody::-webkit-scrollbar {
      width: 5px;
      height: 5px;
    }

    .cbody::-webkit-scrollbar-track {
      background: var(--bg);
    }

    .cbody::-webkit-scrollbar-thumb {
      background: var(--sur3);
      border-radius: 3px;
    }

    /* Info notes */
    .infonote {
      border-radius: 10px;
      padding: 14px 18px;
      margin-bottom: 14px;
      font-size: var(--text-base);
      color: var(--mut);
      line-height: var(--leading-loose);
    }

    .infonote.grn {
      background: rgba(34, 197, 94, .05);
      border: 1px solid rgba(34, 197, 94, .15);
    }

    .infonote.gld {
      background: rgba(124, 58, 237, .06);
      border: 1px solid rgba(124, 58, 237, .15);
    }

    .infonote strong {
      color: var(--wht2);
    }

    .infonote code {
      background: var(--sur2);
      color: var(--acc);
      padding: 1px 6px;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      border: 1px solid var(--bdr2);
    }

    /* GUIDE */
    .gsteps {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .gcard {
      background: var(--sur);
      border: 1px solid var(--bdr2);
      border-radius: 12px;
      padding: 20px;
      display: flex;
      gap: 14px;
    }

    .gnum {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: var(--acc);
      color: #fff;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }


    .gtitl {
      font-size: var(--text-md);
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--wht);
      line-height: var(--leading-snug);
    }

    .gbody {
      color: var(--mut);
      font-size: var(--text-base);
      line-height: var(--leading-loose);
    }

    .gbody code {
      background: var(--sur2);
      color: var(--acc);
      padding: 1px 6px;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-size: 10px;
      border: 1px solid var(--bdr2);
    }

    .gbody strong {
      color: var(--wht2);
    }

    /* SCORE TABLE */
    .sctable {
      width: 100%;
      border-collapse: collapse;
      font-size: 12.5px;
      margin-top: 10px;
    }

    .sctable thead th {
      background: var(--sur2);
      color: var(--mut);
      padding: 10px 14px;
      text-align: right;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 1px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--bdr2);
    }

    .sctable tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--bdr3);
      vertical-align: middle;
    }

    .sctable tbody tr:last-child td {
      border-bottom: none;
    }

    .sctable tbody tr:hover td {
      background: rgba(255, 255, 255, .015);
    }

    .evname {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--grn);
      background: rgba(34, 197, 94, .07);
      padding: 2px 7px;
      border-radius: 4px;
      white-space: nowrap;
      border: 1px solid rgba(34, 197, 94, .12);
    }

    .ppill {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      background: var(--sur2);
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10px;
      color: var(--mut);
      margin: 2px;
      border: 1px solid var(--bdr2);
    }

    .sbarw {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sbar {
      flex: 1;
      height: 4px;
      background: var(--sur3);
      border-radius: 2px;
      overflow: hidden;
      max-width: 72px;
    }

    .sfill {
      height: 100%;
      border-radius: 2px;
    }

    .sfill.h {
      background: var(--grn);
    }

    .sfill.m {
      background: var(--amber);
    }

    .sfill.l {
      background: var(--mut2);
    }

    .snum {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      min-width: 28px;
    }

    .snum.h {
      color: var(--grn);
    }

    .snum.m {
      color: var(--amber);
    }

    .snum.l {
      color: var(--mut);
    }

    .resetrow {
      display: flex;
      justify-content: center;
      margin-top: 32px;
    }

    .brst {
      background: transparent;
      border: 1px solid rgba(239, 68, 68, .2);
      color: rgba(239, 68, 68, .5);
      border-radius: 8px;
      padding: 9px 24px;
      font-family: var(--font-ui);
      font-size: 13px;
      cursor: pointer;
      transition: all .15s;
    }

    .brst:hover {
      border-color: var(--red);
      color: var(--red);
    }

    @media(max-width:768px) {
      .ptitle {
        font-size: var(--text-lg);
      }

      .hdr h1 {
        letter-spacing: -0.2px;
      }
    }

    @media(max-width:640px) {
      .gbox {
        padding: 28px 20px;
      }

      .panel {
        padding: 24px 20px;
      }

      .main {
        padding: 48px 20px 100px;
      }

      .cgrid {
        grid-template-columns: repeat(2, 1fr);
      }

      .pcon {
        max-width: 28px;
        min-width: 14px;
      }

      .hdr h1 {
        font-size: 24px;
      }

      .main {
        padding: 36px 14px 80px;
      }
    }

    .geyebrow svg path,
    .geyebrow svg circle,
    .hbadge svg path,
    .hbadge svg circle {
      opacity: 1 !important;
    }

    /* ── Dashboard Panel — Easy Track Style ── */
    #dashPanel {
      position: fixed;
      top: 0;
      right: -400px;
      width: 380px;
      height: 100vh;
      background: rgba(16, 19, 26, 0.98);
      border-left: 1px solid rgba(70, 241, 197, .08);
      z-index: 500;
      transition: right .35s cubic-bezier(.4, 0, .2, 1);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      backdrop-filter: blur(24px);
    }

    #dashPanel.open {
      right: 0;
    }

    #dashOverlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 499;
      background: rgba(0, 0, 0, .7);
      backdrop-filter: blur(8px);
    }

    #dashOverlay.show {
      display: block;
    }

    .dp-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid rgba(255, 255, 255, .05);
    }

    .dp-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 17px;
      color: var(--wht);
      letter-spacing: -0.3px;
    }

    .dp-close {
      width: 30px;
      height: 30px;
      border-radius: 8px;
      border: 1px solid var(--bdr2);
      background: var(--sur2);
      color: var(--mut);
      cursor: pointer;
      font-size: 14px;
      transition: all .15s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .dp-close:hover {
      color: var(--wht2);
      border-color: rgba(255, 255, 255, .15);
    }

    .dp-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(255, 255, 255, .04);
      border-bottom: 1px solid rgba(255, 255, 255, .05);
    }

    .dp-stat {
      padding: 16px 8px;
      background: var(--bg);
      text-align: center;
    }

    .dp-stat-val {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: 700;
      color: var(--acc);
    }

    .dp-stat-lbl {
      font-size: 9px;
      color: var(--mut);
      margin-top: 3px;
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    #dp-list {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }

    .dp-loading {
      text-align: center;
      padding: 40px;
      color: var(--mut);
      font-size: 11px;
      font-family: var(--font-mono);
    }

    .dp-card {
      background: rgba(39, 42, 49, .5);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 14px;
      padding: 14px 16px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all .15s;
    }

    .dp-card:hover {
      border-color: rgba(70, 241, 197, .2);
      background: rgba(70, 241, 197, .03);
    }

    .dp-card-name {
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 7px;
      color: var(--wht2);
      font-family: var(--font-display);
    }

    .dp-card-tags {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
      margin-bottom: 9px;
    }

    .dp-tag {
      font-family: var(--font-mono);
      font-size: 9px;
      padding: 2px 8px;
      border-radius: 6px;
    }

    .dp-tag.cms {
      background: rgba(70, 241, 197, .08);
      color: var(--acc);
      border: 1px solid rgba(70, 241, 197, .15);
    }

    .dp-tag.plat {
      background: var(--acc-dim);
      color: var(--acc);
      border: 1px solid var(--bdr);
    }

    .dp-tag.evs {
      background: var(--sur3);
      color: var(--mut);
      border: 1px solid var(--bdr2);
    }

    .dp-card-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .dp-card-date {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut);
    }

    .dp-load-btn {
      padding: 5px 14px;
      border-radius: 8px;
      border: none;
      background: var(--acc);
      color: #00382b;
      font-family: var(--font-display);
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      transition: all .15s;
    }

    .dp-load-btn:hover {
      background: var(--acc2);
    }

    .dp-empty {
      text-align: center;
      padding: 40px 20px;
    }

    .dp-empty-icon {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .dp-empty-text {
      color: var(--mut);
      font-size: 12px;
      line-height: 1.6;
    }

    .dp-new-btn {
      margin: 14px;
      padding: 14px;
      border-radius: 12px;
      border: none;
      background: var(--acc);
      color: #00382b;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all .2s;
      flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(70, 241, 197, .25);
    }

    .dp-new-btn:hover {
      background: var(--acc2);
      transform: translateY(-1px);
      box-shadow: 0 6px 24px rgba(70, 241, 197, .35);
    }

    @media(max-width:600px) {
      #dashPanel {
        width: 100%;
        right: -100%;
      }
    }

    /* ── Gate Auth Tabs ── */
    .gate-tabs {
      display: flex;
      background: rgba(39, 42, 49, .5);
      border-radius: 12px;
      padding: 4px;
      margin-bottom: 20px;
      gap: 4px;
      border: 1px solid rgba(255, 255, 255, .06);
    }

    .gate-tab {
      flex: 1;
      padding: 9px;
      border: none;
      border-radius: 9px;
      cursor: pointer;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      background: transparent;
      color: var(--mut);
      transition: all .15s;
    }

    .gate-tab.on {
      background: var(--acc);
      color: #00382b;
      box-shadow: 0 2px 8px rgba(70, 241, 197, .25);
    }

    /* ── Plan limit banner ── */
    #limitBanner {
      background: rgba(25, 28, 34, .95);
      border: 1px solid rgba(70, 241, 197, .15);
      border-radius: 16px;
      backdrop-filter: blur(16px);
    }

    #limitBanner h4 {
      color: var(--amber);
    }

    #limitBanner button {
      background: var(--acc);
      color: #00382b;
      font-family: var(--font-display);
      font-weight: 800;
      border-radius: 10px;
    }

    /* ── Info notes ── */
    .infonote {
      border-radius: 14px;
      padding: 16px 20px;
      margin-bottom: 16px;
      font-size: var(--text-base);
      color: var(--mut);
      line-height: var(--leading-loose);
    }

    .infonote.grn {
      background: rgba(70, 241, 197, .05);
      border: 1px solid rgba(70, 241, 197, .15);
    }

    .infonote.gld {
      background: rgba(70, 241, 197, .06);
      border: 1px solid rgba(70, 241, 197, .15);
    }

    /* ── Score/guide cards ── */
    .gcard {
      background: rgba(39, 42, 49, .5);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 14px;
      padding: 20px;
      display: flex;
      gap: 14px;
    }

    .gnum {
      width: 28px;
      height: 28px;
      border-radius: 8px;
      background: var(--acc);
      color: #00382b;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── Reset button ── */
    .brst {
      background: transparent;
      border: 1px solid rgba(255, 180, 171, .2);
      color: rgba(255, 180, 171, .5);
      border-radius: 10px;
      padding: 10px 26px;
      font-family: var(--font-ui);
      font-size: 13px;
      cursor: pointer;
      transition: all .15s;
    }

    .brst:hover {
      border-color: var(--red);
      color: var(--red);
    }

    /* ── Google Ads pixel inputs ── */
    .pix-google-wrap {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .pixrow {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .pixlabel {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut2);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .pixlabel-hint {
      color: var(--grn);
      font-size: 9px;
      margin-right: 6px;
    }

    .pixfield-wrap {
      position: relative;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pix-valid {
      font-family: var(--font-mono);
      font-size: 11px;
      min-width: 24px;
    }

    .pix-ev-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .pix-ev-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--acc);
      min-width: 140px;
      flex-shrink: 0;
    }

    .pix-ev-input {
      flex: 1;
    }

    .pix-clear-btn {
      width: 20px;
      height: 20px;
      border-radius: 6px;
      border: 1px solid var(--bdr2);
      background: var(--sur2);
      color: var(--mut);
      font-size: 9px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all .15s;
    }

    .pix-clear-btn:hover {
      border-color: var(--red);
      color: var(--red);
    }

    /* ── APP VIEWS ── */
    .app-view {
      display: none;
    }

    .app-view.active {
      display: block;
    }

    /* ── OVERVIEW HERO ── */
    #overviewHero {
      position: relative;
      background: linear-gradient(to bottom right, #191c22, #10131a);
      border: 1px solid rgba(133, 148, 141, 0.1);
      padding: 48px 40px;
      border-radius: 28px;
      overflow: hidden;
      margin-bottom: 32px;
    }

    #overviewHero .hero-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 45%;
      height: 100%;
      opacity: .15;
      pointer-events: none;
      background: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCuZt3mxAnAmZ0v4Sa20qa57tVkNAXfBJ5ZML-2clPfev_eCNiHag0z-xO34nbwManTxWxmYOCfrEz_ANC3YsUnsJRJzQKkeIWjJvdLYjS-ROckjJaOrMlgCSNbsc0CyLADqZkG9_ALLD-_QC5UXNINZXFOi_rszPlRvnl3tA5Rs2BltaQRX5R-BYO1im4Z_YobJUu026hv5quMjX3DojBfSn0QDa4lYbcjRo61d1p7HT-uaDrB2RVY70_As76um9cytUyrCr-inA') no-repeat center/cover;
      transform: scaleX(-1);
    }

    #overviewHero .hero-body {
      position: relative;
      z-index: 1;
      max-width: 600px;
    }

    #overviewHero .hero-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 99px;
      background: var(--acc-dim);
      color: var(--acc);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 20px;
      font-family: var(--font-mono);
    }

    #overviewHero h1 {
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 900;
      font-family: var(--font-display);
      line-height: 1.1;
      margin-bottom: 16px;
      color: var(--wht);
      letter-spacing: -1.5px;
    }

    #overviewHero h1 em {
      font-style: normal;
      color: var(--acc);
    }

    #overviewHero p {
      color: var(--mut);
      font-size: 16px;
      line-height: 1.65;
      margin-bottom: 28px;
      max-width: 520px;
    }

    #overviewHero .hero-btns {
      display: flex;
      gap: 14px;
      align-items: center;
    }

    .hero-btn-primary {
      padding: 14px 28px;
      background: var(--acc);
      color: #00382b;
      border-radius: 12px;
      font-weight: 800;
      font-size: 15px;
      border: none;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(70, 241, 197, 0.3);
      font-family: var(--font-display);
      transition: all .2s;
    }

    .hero-btn-primary:hover {
      transform: scale(1.02);
      box-shadow: 0 8px 28px rgba(70, 241, 197, 0.4);
    }

    .hero-btn-ghost {
      padding: 14px 28px;
      background: rgba(255, 255, 255, 0.06);
      color: var(--wht);
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      cursor: pointer;
      font-family: var(--font-display);
      transition: all .2s;
    }

    .hero-btn-ghost:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    /* ── ACTIVE PIXELS SECTION ── */
    #overviewPixels {
      display: none;
      margin-top: 32px;
    }

    #overviewPixels.show {
      display: block;
    }

    .ov-section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .ov-section-title h3 {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--wht);
    }

    .ov-view-all {
      color: var(--acc);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      border: none;
      background: none;
      transition: opacity .15s;
    }

    .ov-view-all:hover {
      opacity: .7;
    }

    .ov-pixels-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 16px;
    }

    .ov-pixel-card {
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 20px;
      padding: 24px;
      transition: all .2s;
    }

    .ov-pixel-card:hover {
      border-color: rgba(70, 241, 197, .15);
      box-shadow: 0 8px 24px rgba(0, 0, 0, .3);
    }

    .ov-pixel-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .ov-pixel-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }

    .ov-pixel-badge {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 4px;
      letter-spacing: .5px;
      font-family: var(--font-mono);
    }

    .ov-pixel-badge.active {
      background: rgba(70, 241, 197, .1);
      color: var(--acc);
    }

    .ov-pixel-badge.pending {
      background: rgba(245, 158, 11, .1);
      color: var(--amber);
    }

    .ov-pixel-name {
      font-weight: 700;
      font-size: 14px;
      color: var(--wht);
      font-family: var(--font-display);
      margin-bottom: 4px;
    }

    .ov-pixel-id {
      font-size: 11px;
      color: var(--mut);
      font-family: var(--font-mono);
      margin-bottom: 16px;
    }

    .ov-pixel-bar {
      height: 4px;
      background: var(--sur3);
      border-radius: 2px;
      overflow: hidden;
    }

    .ov-pixel-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width .6s ease;
    }

    /* Recent Publishes */
    #overviewBento {
      display: none;
      margin-top: 32px;
    }

    #overviewBento.show {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
    }

    .ov-recent-card {
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 20px;
      padding: 28px;
    }

    .ov-recent-title {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      color: var(--wht);
      margin-bottom: 20px;
    }

    .ov-recent-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 18px;
    }

    .ov-recent-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-top: 4px;
      flex-shrink: 0;
    }

    .ov-recent-dot.green {
      background: var(--acc);
      box-shadow: 0 0 8px var(--acc);
    }

    .ov-recent-dot.dim {
      background: var(--sur4);
    }

    .ov-recent-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--wht2);
    }

    .ov-recent-time {
      font-size: 11px;
      color: var(--mut);
      margin-top: 2px;
    }

    .ov-stat-card {
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 20px;
      padding: 28px;
    }

    /* ── GTM DIRECT PUBLISH UI ── */
    .gtm-layout {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .gtm-publish-panel {
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 20px;
      padding: 24px;
    }

    .gtm-publish-title {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 16px;
      color: var(--wht);
      margin-bottom: 20px;
    }

    .gtm-conn-status {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--sur3);
      border-radius: 12px;
      padding: 12px 16px;
      margin-bottom: 16px;
    }

    .gtm-conn-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--sur4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .gtm-conn-lbl {
      font-size: 11px;
      color: var(--mut);
    }

    .gtm-conn-val {
      font-size: 13px;
      font-weight: 600;
      color: var(--wht2);
    }

    .gtm-connect-btn {
      padding: 12px 20px;
      background: var(--sur3);
      color: var(--wht);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 10px;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .gtm-connect-btn:hover {
      background: var(--sur4);
    }

    .gtm-select-wrap {
      margin-bottom: 0;
    }

    .gtm-select-lbl {
      font-size: 11px;
      color: var(--mut);
      font-weight: 600;
      font-family: var(--font-ui);
      margin-bottom: 6px;
      display: block;
    }

    .gtm-select {
      width: 100%;
      background: var(--sur3);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 8px;
      padding: 10px 14px;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 13px;
      outline: none;
      cursor: pointer;
    }

    .gtm-info-box {
      background: rgba(70, 241, 197, .05);
      border: 1px solid rgba(70, 241, 197, .12);
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 0;
      margin-top: 4px;
      display: flex;
      gap: 10px;
    }

    .gtm-info-icon {
      color: var(--acc);
      flex-shrink: 0;
      margin-top: 1px;
    }

    .gtm-info-text {
      font-size: 12px;
      color: var(--mut);
      line-height: 1.7;
    }

    .gtm-info-text strong {
      color: var(--acc);
    }

    .gtm-deploy-btn {
      padding: 13px 20px;
      background: var(--sur3);
      color: var(--mut);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 10px;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all .2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .gtm-deploy-btn.ready {
      background: var(--acc);
      color: #00382b;
      box-shadow: 0 4px 16px rgba(70, 241, 197, .3);
      border-color: transparent;
    }

    .gtm-deploy-btn.ready:hover {
      filter: brightness(1.1);
      transform: translateY(-1px);
    }

    /* GTM Stepper */
    .gtm-stepper {
      display: flex;
      align-items: center;
      gap: 0;
      margin-bottom: 28px;
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .05);
      border-radius: 16px;
      padding: 16px 20px;
    }

    .gtm-step {
      display: flex;
      align-items: center;
      gap: 10px;
      flex: 1;
    }

    .gtm-step-circle {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 13px;
      flex-shrink: 0;
      transition: all .3s;
    }

    .gtm-step-circle.done {
      background: var(--acc);
      color: #00382b;
      box-shadow: 0 0 12px rgba(70, 241, 197, .3);
    }

    .gtm-step-circle.active {
      background: var(--acc-dim);
      color: var(--acc);
      border: 2px solid var(--acc);
      box-shadow: 0 0 0 3px rgba(70, 241, 197, .1);
    }

    .gtm-step-circle.idle {
      background: var(--sur3);
      color: var(--mut);
      border: 2px solid var(--sur4);
    }

    .gtm-step-label {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .gtm-step-num {
      font-size: 10px;
      color: var(--acc);
      font-family: var(--font-mono);
      font-weight: 700;
      letter-spacing: 1px;
    }

    .gtm-step-name {
      font-size: 12px;
      font-weight: 700;
      font-family: var(--font-display);
      color: var(--mut);
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    .gtm-step-name.active {
      color: var(--wht);
    }

    .gtm-step-line {
      flex: 1;
      height: 1px;
      background: var(--sur4);
      margin: 0 12px;
      max-width: 48px;
    }
  </style>

  <style>
    /* ── TOP NAV BAR ── */
