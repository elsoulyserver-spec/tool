          { name: 'view_item - item_name',     path: 'ecommerce.items.0.item_name' },
          { name: 'view_item - item_category', path: 'ecommerce.items.0.item_category' },
          { name: 'view_item - item_price',    path: 'ecommerce.items.0.price' },
          { name: 'view_item - item_sku',      path: 'ecommerce.items.0.item_sku' },
          { name: 'view_item - currency',      path: 'ecommerce.currency' },
          { name: 'view_item - value',         path: 'ecommerce.value' },

          // ── add_to_cart ──
          { name: 'add_to_cart - item_id',       path: 'ecommerce.items.0.item_id' },
          { name: 'add_to_cart - item_name',     path: 'ecommerce.items.0.item_name' },
          { name: 'add_to_cart - item_category', path: 'ecommerce.items.0.item_category' },
          { name: 'add_to_cart - item_price',    path: 'ecommerce.items.0.price' },
          { name: 'add_to_cart - item_quantity', path: 'ecommerce.items.0.quantity' },
          { name: 'add_to_cart - item_sku',      path: 'ecommerce.items.0.item_sku' },
          { name: 'add_to_cart - currency',      path: 'ecommerce.currency' },
          { name: 'add_to_cart - value',         path: 'ecommerce.value' },

          // ── remove_from_cart ──
          { name: 'remove_from_cart - item_id',       path: 'ecommerce.items.0.item_id' },
          { name: 'remove_from_cart - item_name',     path: 'ecommerce.items.0.item_name' },
          { name: 'remove_from_cart - item_price',    path: 'ecommerce.items.0.price' },
          { name: 'remove_from_cart - item_quantity', path: 'ecommerce.items.0.quantity' },
          { name: 'remove_from_cart - item_sku',      path: 'ecommerce.items.0.item_sku' },
          { name: 'remove_from_cart - currency',      path: 'ecommerce.currency' },
          { name: 'remove_from_cart - value',         path: 'ecommerce.value' },

          // ── view_cart ──
          { name: 'view_cart - item_id',       path: 'ecommerce.items.0.item_id' },
          { name: 'view_cart - item_name',     path: 'ecommerce.items.0.item_name' },
          { name: 'view_cart - item_price',    path: 'ecommerce.items.0.price' },
          { name: 'view_cart - item_quantity', path: 'ecommerce.items.0.quantity' },
          { name: 'view_cart - currency',      path: 'ecommerce.currency' },
          { name: 'view_cart - value',         path: 'ecommerce.value' },

          // ── begin_checkout ──
          { name: 'begin_checkout - item_id',       path: 'ecommerce.items.0.item_id' },
          { name: 'begin_checkout - item_name',     path: 'ecommerce.items.0.item_name' },
          { name: 'begin_checkout - item_price',    path: 'ecommerce.items.0.price' },
          { name: 'begin_checkout - item_quantity', path: 'ecommerce.items.0.quantity' },
          { name: 'begin_checkout - currency',      path: 'ecommerce.currency' },
          { name: 'begin_checkout - value',         path: 'ecommerce.value' },

          // ── purchase ──
          { name: 'purchase - transaction_id', path: 'ecommerce.transaction_id' },
          { name: 'purchase - value',          path: 'ecommerce.value' },
          { name: 'purchase - currency',       path: 'ecommerce.currency' },
          { name: 'purchase - tax',            path: 'ecommerce.tax' },
          { name: 'purchase - shipping',       path: 'ecommerce.shipping' },
          { name: 'purchase - coupon',         path: 'ecommerce.coupon' },
