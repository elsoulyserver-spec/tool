      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      color: var(--mut);
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      font-family: var(--font-display);
      transition: all 0.2s;
      cursor: pointer;
      border: none;
      background: transparent;
      width: 100%;
      text-align: right;
    }

    .sb-link:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--wht);
    }

    .sb-link.active {
      background: rgba(70, 241, 197, 0.1);
      color: var(--acc);
      transform: translateX(-4px);
    }

    .sb-new-btn {
      margin: 12px 0 24px;
      padding: 12px 16px;
      border-radius: 12px;
      border: none;
      background: var(--acc);
      color: #00382b;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      box-shadow: 0 4px 16px rgba(70, 241, 197, 0.25);
    }

    .sb-new-btn:hover {
      filter: brightness(1.1);
      transform: scale(1.02);
    }

    .sb-footer {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .sb-footer-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      color: var(--mut);
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      font-family: var(--font-display);
      transition: all 0.2s;
      border: none;
      background: transparent;
      width: 100%;
      text-align: right;
      cursor: pointer;
    }

    .sb-footer-link:hover {
      background: rgba(255, 255, 255, 0.05);
      color: var(--wht);
    }

    /* Main override for sidebar layout */
    body>*:not(#userBar) {
      padding-top: 0;
    }

    .main {
      margin-right: 256px !important;
      margin-left: 0 !important;
      max-width: 1280px !important;
      padding: 32px !important;
      margin-top: 24px;
    }

    @media (max-width:900px) {
      #et-sidebar {
        display: none;
      }

      .main {
        margin-right: 0 !important;
        padding: 20px !important;
      }
    }

    /* Plan limit banner */
    #limitBanner {
      display: none;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 300;
      background: var(--sur);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 14px 18px;
      max-width: 260px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, .7);
    }

    #limitBanner h4 {
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 5px;
      color: var(--amber);
    }

    #limitBanner p {
      font-size: 11px;
      color: var(--mut);
      line-height: 1.6;
      margin-bottom: 10px;
    }

    #limitBanner button {
      background: var(--acc);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 8px 14px;
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      width: 100%;
    }

    #limitBanner .lb-close {
      position: absolute;
      top: 10px;
      left: 12px;
      background: none;
      border: none;
      color: var(--mut2);
      font-size: 13px;
      cursor: pointer;
      width: auto;
      padding: 0;
    }
  </style>
  <!-- Firebase SDK v10 compat -->
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-firestore-compat.js"></script>
</head>

<body>

  <!-- ═══ USER BAR ═══ -->
  <div id="userBar">
    <div class="ub-left">
      <a href="https://easytrac.io" class="ub-logo" style="gap:12px;">
        <svg viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:32px;height:32px;flex-shrink:0;overflow:visible;">
          <defs>
            <linearGradient id="ubGOuter" x1="0" y1="0" x2="260" y2="260" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#46f1c5" stop-opacity="0.5"/>
              <stop offset="100%" stop-color="#00d4aa" stop-opacity="0.5"/>
            </linearGradient>
            <linearGradient id="ubGMid" x1="0" y1="0" x2="260" y2="260" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#46f1c5" stop-opacity="0.75"/>
              <stop offset="100%" stop-color="#00d4aa" stop-opacity="0.75"/>
            </linearGradient>
            <linearGradient id="ubGArrow" x1="130" y1="148" x2="130" y2="200" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#46f1c5"/>
              <stop offset="100%" stop-color="#00d4aa"/>
            </linearGradient>
            <radialGradient id="ubGDot" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#46f1c5"/>
              <stop offset="100%" stop-color="#00d4aa"/>
            </radialGradient>
            <filter id="ubGlowF" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="8" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <path d="M20 120 C20 57.726 70.726 7 133 7" stroke="url(#ubGOuter)" stroke-width="5" stroke-linecap="round"/>
          <path d="M240 120 C240 57.726 189.274 7 127 7" stroke="url(#ubGOuter)" stroke-width="5" stroke-linecap="round"/>
          <path d="M48 120 C48 79.131 81.131 46 122 46" stroke="url(#ubGMid)" stroke-width="4" stroke-linecap="round"/>
          <path d="M212 120 C212 79.131 178.869 46 138 46" stroke="url(#ubGMid)" stroke-width="4" stroke-linecap="round"/>
          <path d="M78 120 C78 100.118 94.118 84 114 84" stroke="#46f1c5" stroke-width="3.5" stroke-linecap="round"/>
          <path d="M182 120 C182 100.118 165.882 84 146 84" stroke="#46f1c5" stroke-width="3.5" stroke-linecap="round"/>
          <circle cx="130" cy="120" r="30" fill="rgba(70,241,197,0.12)" filter="url(#ubGlowF)"/>
          <circle cx="130" cy="120" r="16" fill="url(#ubGDot)"/>
          <path d="M112 148 L130 192 L148 148" stroke="url(#ubGArrow)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span style="display:flex;flex-direction:column;gap:2px;line-height:1;">
          <span style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;font-size:16px;letter-spacing:-0.5px;color:#e1e2eb;">easy<span style="color:#46f1c5;">TRACK</span></span>
          <span style="font-family:'IBM Plex Mono',monospace;font-size:7px;letter-spacing:2.5px;color:rgba(70,241,197,0.7);text-transform:uppercase;">Pixel Config</span>
        </span>
      </a>
      <div class="ub-nav" style="display:none;">
        <a href="#" class="ub-nav-link active">Dashboard</a>
        <a href="#" class="ub-nav-link">Analytics</a>
      </div>
      <!-- Hidden elements to preserve logic -->
      <span id="projCounter" style="display:none;">مشاريع: <span id="projUsed">0</span>/<span
          id="projMax">1</span></span>
    </div>
    <div class="ub-right">
      <span id="userPlanBadge" class="plan-badge plan-basic" style="display:none;">BASIC</span>
      <span id="userName" style="display:none;"></span>
      <a href="admin.html" id="adminLink" style="display:none;"></a>

      <button class="ar-en-btn">
        <span class="material-symbols-outlined" style="font-size:16px;">language</span>
        <span>AR / EN</span>
      </button>
      <div class="ub-icons">
        <button><span class="material-symbols-outlined">notifications</span></button>
        <button><span class="material-symbols-outlined">help</span></button>
      </div>
      <div class="ub-profile" onclick="toggleHistory()" title="سجل النشاط">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDj6yl2AOM1v07OkjHxEhwA3D3NxxfJGf6J_t02PyuQca57V1XH6I00Rp6qjOnaKFbIXhDWlGDEn3WbaR-NBHQjKdkjXYOgKtJ9dMX8t9EfOOq-CT2ZVQr-B9teg0lekCP08lY6McYWuY6n4O88QojZYsS9hY-PbIflYNW-TprDPgyq8vdWK8NJOoDXXsasyqn4NSKIbyl5svwn92sthixu2gV-8wTqjML-RvosELRK0q1x-k4cg7W8KsqURlaaRw0l1IEhTt1EQQ"
          alt="User profile" style="width:100%;height:100%;object-fit:cover;">
      </div>
    </div>
  </div>


  <!-- ═══ DASHBOARD PANEL ═══ -->
  <div id="dashPanel">
    <div class="dp-header">
      <div class="dp-title">📁 مشاريعي</div>
      <button class="dp-close" onclick="toggleDashboard()">✕</button>
    </div>

    <!-- Stats -->
    <div class="dp-stats">
      <div class="dp-stat">
        <div class="dp-stat-val" id="dp-total">—</div>
        <div class="dp-stat-lbl">مشاريع</div>
      </div>
      <div class="dp-stat">
        <div class="dp-stat-val" id="dp-platforms">—</div>
        <div class="dp-stat-lbl">منصات</div>
      </div>
      <div class="dp-stat">
        <div class="dp-stat-val" id="dp-events">—</div>
        <div class="dp-stat-lbl">Events</div>
      </div>
      <div class="dp-stat">
        <div class="dp-stat-val" id="dp-remain">—</div>
        <div class="dp-stat-lbl">متبقي</div>
      </div>
    </div>

    <!-- Projects List -->
    <div id="dp-list">
      <div class="dp-loading">⏳ جاري التحميل...</div>
    </div>

    <!-- New Project -->
    <button class="dp-new-btn" onclick="startNewProject()">⚡ مشروع جديد</button>
  </div>

  <!-- Overlay -->
  <div id="dashOverlay" onclick="toggleDashboard()"></div>

  <!-- History Overlay -->
  <div id="historyOverlay" onclick="toggleHistory()"></div>

  <!-- History Panel -->
  <div id="historyPanel">
    <div class="hp-header">
      <span class="material-symbols-outlined" style="color:var(--acc);font-size:22px;">history</span>
      <div class="hp-title">سجل النشاط</div>
      <button class="hp-close" onclick="toggleHistory()">
        <span class="material-symbols-outlined" style="font-size:20px;">close</span>
      </button>
    </div>
    <div class="hp-body" id="historyBody">
      <div class="hp-empty" id="historyEmpty">
        <span class="material-symbols-outlined">manage_history</span>
        <p>لم يتم تسجيل أي نشاط بعد.<br>ابدأ بإنشاء مشروع تتبع جديد.</p>
      </div>
      <div id="historyList"></div>
    </div>
  </div>

  <!-- Plan limit banner -->
  <div id="limitBanner">
    <button class="lb-close" onclick="document.getElementById('limitBanner').style.display='none'">✕</button>
    <h4>🔒 وصلت لحد الخطة</h4>
    <p id="limitMsg">الخطة Basic بتسمح بـ 1 مشروع فقط. Upgrade عشان تولّد أكتر.</p>
    <button onclick="window.open('https://wa.me/201552388174?text=مرحباً،%20أريد%20الترقية%20إلى%20خطة%20أعلى%20في%20Easy%20Track','_blank')">💬 تواصل للترقية ↗</button>
  </div>

  <div class="app">

    <!-- GATE -->
    <div id="gate">
      <div class="gbox">
        <!-- Easy Track Logo — Login Screen -->
        <div style="text-align:center;margin-bottom:28px;">
          <!-- SVG + Name stacked vertically like landing page -->
          <div style="display:inline-flex;flex-direction:column;align-items:center;gap:16px;">
            <svg viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg"
              style="width:100px;height:100px;overflow:visible;filter:drop-shadow(0 0 24px rgba(70,241,197,0.3));">
              <defs>
                <linearGradient id="glGOuter" x1="0" y1="0" x2="260" y2="260" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#46f1c5" stop-opacity="0.45"/>
                  <stop offset="100%" stop-color="#00d4aa" stop-opacity="0.45"/>
                </linearGradient>
                <linearGradient id="glGMid" x1="0" y1="0" x2="260" y2="260" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#46f1c5" stop-opacity="0.75"/>
                  <stop offset="100%" stop-color="#00d4aa" stop-opacity="0.75"/>
                </linearGradient>
                <linearGradient id="glGArrow" x1="130" y1="148" x2="130" y2="200" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#46f1c5"/>
                  <stop offset="100%" stop-color="#00d4aa"/>
                </linearGradient>
                <radialGradient id="glGDot" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#46f1c5"/>
                  <stop offset="100%" stop-color="#00d4aa"/>
                </radialGradient>
                <filter id="glGlowF" x="-60%" y="-60%" width="220%" height="220%">
                  <feGaussianBlur stdDeviation="10" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
              </defs>
              <path d="M20 120 C20 57.726 70.726 7 133 7" stroke="url(#glGOuter)" stroke-width="5" stroke-linecap="round"/>
              <path d="M240 120 C240 57.726 189.274 7 127 7" stroke="url(#glGOuter)" stroke-width="5" stroke-linecap="round"/>
              <path d="M48 120 C48 79.131 81.131 46 122 46" stroke="url(#glGMid)" stroke-width="4.5" stroke-linecap="round"/>
              <path d="M212 120 C212 79.131 178.869 46 138 46" stroke="url(#glGMid)" stroke-width="4.5" stroke-linecap="round"/>
              <path d="M78 120 C78 100.118 94.118 84 114 84" stroke="#46f1c5" stroke-width="4" stroke-linecap="round"/>
              <path d="M182 120 C182 100.118 165.882 84 146 84" stroke="#46f1c5" stroke-width="4" stroke-linecap="round"/>
              <circle cx="130" cy="120" r="32" fill="rgba(70,241,197,0.12)" filter="url(#glGlowF)"/>
              <circle cx="130" cy="120" r="18" fill="url(#glGDot)"/>
              <path d="M112 148 L130 196 L148 148" stroke="url(#glGArrow)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <!-- Brand name below icon -->
            <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
              <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;font-size:36px;letter-spacing:-1.2px;color:#e1e2eb;line-height:1;">
                easy<span style="color:#46f1c5;text-shadow:0 0 20px rgba(70,241,197,0.45);">TRACK</span>
              </div>
              <div style="display:flex;align-items:center;gap:8px;">
                <span style="display:inline-block;width:22px;height:1px;background:rgba(70,241,197,0.35);"></span>
                <span style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:3.5px;color:rgba(70,241,197,0.65);text-transform:uppercase;">Pixel Config v3</span>
                <span style="display:inline-block;width:22px;height:1px;background:rgba(70,241,197,0.35);"></span>
              </div>
            </div>
          </div>
        </div>
        <h1 class="gtitle">احصل على <em>Pixel Setup</em> كامل<br>في دقيقتين — مجاناً</h1>
        <!-- Auth Tabs -->
        <!-- Global connectivity error banner -->
        <div id="gGlobalErr" style="display:none;background:rgba(255,100,80,.08);border:1px solid rgba(255,100,80,.25);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:12px;color:#ffb4ab;text-align:center;line-height:1.6;"></div>

        <div class="gate-tabs">
          <button class="gate-tab on" id="gtab-login" onclick="(typeof switchGateTab==='function'?switchGateTab('login'):void 0)">تسجيل دخول</button>
          <button class="gate-tab" id="gtab-signup" onclick="(typeof switchGateTab==='function'?switchGateTab('signup'):void 0)">حساب جديد</button>
        </div>

        <!-- Login Form -->
        <div id="gform-login">
          <div class="fgroup">
            <div class="fwrap">
              <input class="finput" id="gEmail-l" type="email" placeholder="البريد الإلكتروني *"
                style="direction:ltr;text-align:right;">
              <span class="ficon">✉️</span>
            </div>
            <div class="fwrap">
              <input class="finput" id="gPass-l" type="password" placeholder="كلمة المرور *"
                style="direction:ltr;text-align:right;">
              <span class="ficon">🔒</span>
            </div>
          </div>
          <div class="gerr" id="gErr-l"></div>
          <button class="gcta" id="gBtn-l" onclick="(typeof doGateLogin==='function'?doGateLogin():void 0)">دخول ← </button>
          <div style="text-align:center;margin-top:12px;font-size:12px;color:var(--mut);">مش عندك حساب؟ <a href="#"
              onclick="(typeof switchGateTab==='function'?switchGateTab('signup'):void 0)" style="color:var(--gold);text-decoration:none;">سجّل دلوقتي</a></div>
        </div>

        <!-- Signup Form -->
        <div id="gform-signup" style="display:none;">
          <div class="fgroup">
            <div class="fwrap">
              <input class="finput" id="gName-s" type="text" placeholder="اسمك الكريم *">
              <span class="ficon">👤</span>
            </div>
            <div class="fwrap">
              <input class="finput" id="gEmail-s" type="email" placeholder="البريد الإلكتروني *"
                style="direction:ltr;text-align:right;">
              <span class="ficon">✉️</span>
            </div>
            <div class="fwrap">
              <input class="finput" id="gPass-s" type="password" placeholder="كلمة المرور * (6 أحرف على الأقل)"
                style="direction:ltr;text-align:right;">
              <span class="ficon">🔒</span>
            </div>
            <div class="fwrap">
              <select class="finput" id="gCountry-s" style="appearance:none;cursor:pointer;">
                <option value="" disabled selected>اختار البلد *</option>
                <option value="SA">🇸🇦 السعودية</option>
                <option value="EG">🇪🇬 مصر</option>
                <option value="AE">🇦🇪 الإمارات</option>
                <option value="KW">🇰🇼 الكويت</option>
                <option value="QA">🇶🇦 قطر</option>
                <option value="BH">🇧🇭 البحرين</option>
                <option value="OM">🇴🇲 عُمان</option>
                <option value="JO">🇯🇴 الأردن</option>
                <option value="LB">🇱🇧 لبنان</option>
                <option value="IQ">🇮🇶 العراق</option>
                <option value="PS">🇵🇸 فلسطين</option>
                <option value="SY">🇸🇾 سوريا</option>
                <option value="YE">🇾🇪 اليمن</option>
                <option value="LY">🇱🇾 ليبيا</option>
                <option value="TN">🇹🇳 تونس</option>
                <option value="DZ">🇩🇿 الجزائر</option>
                <option value="MA">🇲🇦 المغرب</option>
                <option value="SD">🇸🇩 السودان</option>
                <option value="MR">🇲🇷 موريتانيا</option>
                <option value="SO">🇸🇴 الصومال</option>
                <option value="DJ">🇩🇯 جيبوتي</option>
                <option value="KM">🇰🇲 جزر القمر</option>
                <option value="OTHER">🌍 دولة أخرى</option>
              </select>
              <span class="ficon">🌍</span>
            </div>
            <div class="fwrap">
              <input class="finput" id="gWhatsapp-s" type="tel" placeholder="رقم الواتساب * (مع كود الدولة)"
                style="direction:ltr;text-align:right;">
              <span class="ficon">📱</span>
            </div>
            <div class="fwrap">
              <input class="finput" id="gJob-s" type="text" placeholder="وظيفتك * (مثال: Marketing Manager)">
              <span class="ficon">💼</span>
            </div>
          </div>
          <div class="gerr" id="gErr-s"></div>
          <button class="gcta" id="gBtn-s" onclick="(typeof doGateSignup==='function'?doGateSignup():void 0)">إنشاء حساب ← </button>
          <div style="text-align:center;margin-top:12px;font-size:12px;color:var(--mut);">عندك حساب؟ <a href="#"
              onclick="(typeof switchGateTab==='function'?switchGateTab('login'):void 0)" style="color:var(--gold);text-decoration:none;">سجّل دخول</a></div>
        </div>

        <!-- Approval Pending Panel — shown for new signups + existing pending accounts -->
        <div id="gform-pending" style="display:none;">
          <div style="text-align:center;padding:8px 0 4px;">
            <div style="font-size:54px;margin-bottom:14px;line-height:1;">⏳</div>
            <h2 style="font-family:var(--font-display);font-weight:800;font-size:22px;color:var(--wht);margin:0 0 14px;letter-spacing:-0.4px;">
              حسابك في انتظار الموافقة
            </h2>
            <p style="color:var(--mut);font-size:13.5px;line-height:1.95;margin:0 0 22px;">
              شكراً لتسجيلك في <strong style="color:var(--acc);">Easy Track</strong> 💚<br>
              عشان نفعّل دخولك، ابعت رسالة لـ <strong style="color:var(--acc);">يوسف الصولي</strong> على واتساب
              وقول له إنك سجّلت بالإيميل: <strong id="gate-pending-email" style="color:var(--wht);direction:ltr;display:inline-block;">—</strong><br>
              هيتم تفعيل حسابك خلال ساعات قليلة.
            </p>
            <a id="gate-pending-wa" href="#" target="_blank" rel="noopener" class="gcta"
              style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;">
              💬 تواصل مع يوسف الصولي على واتساب ←
            </a>
            <button type="button"
              onclick="(typeof showGateLogin==='function'?showGateLogin():void 0)"
              style="background:none;border:none;color:var(--mut);cursor:pointer;padding:12px;margin-top:8px;font-size:12.5px;text-decoration:underline;width:100%;">
              ← ارجع لتسجيل الدخول
            </button>
          </div>
        </div>

        <div class="gfoot">
          <a class="gli" href="https://www.linkedin.com/in/youssef-elsouly" target="_blank">
            <svg viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            Easy Track — يوسف
          </a>
          <div class="gpriv">🔒 بياناتك آمنة ولن تُشارك</div>
        </div>
      </div>
    </div>

    <!-- Settings Panel -->
    <div id="settingsPanel"
      style="position:fixed;top:0;left:0;width:400px;max-width:95vw;height:100vh;background:#0D1018;border-right:1px solid rgba(70,241,197,0.1);z-index:150;display:flex;flex-direction:column;transform:translateX(-100%);transition:transform .35s cubic-bezier(.16,1,.3,1);box-shadow:4px 0 40px rgba(0,0,0,0.6);">
      <div
        style="padding:24px 20px 16px;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:12px;">
        <span class="material-symbols-outlined"
          style="color:var(--acc);font-size:22px;font-variation-settings:'FILL' 1;">manage_accounts</span>
        <div style="font-family:var(--font-display);font-weight:800;font-size:17px;color:var(--wht);flex:1;">إعدادات
          الحساب</div>
        <button onclick="toggleSettings()"
          style="background:none;border:none;color:var(--mut);cursor:pointer;padding:6px;border-radius:8px;display:flex;transition:all .15s;">
          <span class="material-symbols-outlined" style="font-size:20px;">close</span>
        </button>
      </div>
      <div style="flex:1;overflow-y:auto;padding:20px;">
        <div
          style="background:linear-gradient(135deg,rgba(70,241,197,0.08),rgba(70,241,197,0.03));border:1px solid rgba(70,241,197,0.2);border-radius:14px;padding:16px 18px;margin-bottom:20px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <span class="material-symbols-outlined"
              style="color:var(--acc);font-size:20px;font-variation-settings:'FILL' 1;">workspace_premium</span>
            <span style="font-weight:700;font-size:15px;color:var(--wht);">الخطة الحالية</span>
          </div>
          <div id="settingsPlanBadge"
            style="display:inline-flex;align-items:center;gap:8px;background:rgba(70,241,197,0.12);border:1px solid rgba(70,241,197,0.3);padding:6px 14px;border-radius:8px;font-family:var(--font-mono);font-size:13px;font-weight:700;color:var(--acc);">
            BASIC</div>
          <div id="settingsPlanLimits" style="margin-top:10px;font-size:12px;color:var(--mut);line-height:1.8;">1 مشروع
            · 3 منصات</div>
        </div>
        <div style="margin-bottom:20px;">
          <div
            style="font-size:11px;letter-spacing:2px;color:var(--mut2);text-transform:uppercase;font-family:var(--font-mono);margin-bottom:12px;">
            معلومات الحساب</div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <div>
              <label style="font-size:11px;color:var(--mut);display:block;margin-bottom:6px;">الاسم</label>
              <input id="settingsName" type="text" placeholder="اسمك"
                style="width:100%;background:rgba(39,42,49,0.6);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:11px 14px;color:var(--wht2);font-family:var(--font-ui);font-size:13px;outline:none;">
            </div>
            <div>
              <label style="font-size:11px;color:var(--mut);display:block;margin-bottom:6px;">البريد الإلكتروني</label>
              <input id="settingsEmail" type="email" readonly placeholder="email@example.com"
                style="width:100%;background:rgba(39,42,49,0.3);border:1px solid rgba(255,255,255,.05);border-radius:10px;padding:11px 14px;color:var(--mut);font-family:var(--font-ui);font-size:13px;outline:none;direction:ltr;text-align:right;">
            </div>
            <div>
              <label style="font-size:11px;color:var(--mut);display:block;margin-bottom:6px;">رقم الهاتف</label>
              <input id="settingsPhone" type="tel" placeholder="+966 5XX XXX XXXX"
                style="width:100%;background:rgba(39,42,49,0.6);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:11px 14px;color:var(--wht2);font-family:var(--font-ui);font-size:13px;outline:none;direction:ltr;text-align:right;">
            </div>
            <div>
              <label style="font-size:11px;color:var(--mut);display:block;margin-bottom:6px;">المنصة الأساسية</label>
              <select id="settingsCms"
                style="width:100%;background:rgba(39,42,49,0.6);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:11px 14px;color:var(--wht2);font-family:var(--font-ui);font-size:13px;outline:none;">
                <option value="">اختار...</option>
                <option value="salla">سلة</option>
                <option value="zid">زد</option>
              </select>
            </div>
          </div>
        </div>
        <button onclick="saveSettings()"
          style="width:100%;background:var(--acc);color:#00382b;border:none;border-radius:12px;padding:13px;font-family:var(--font-display);font-size:14px;font-weight:800;cursor:pointer;transition:all .2s;box-shadow:0 4px 16px rgba(70,241,197,0.2);">
          <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle;">save</span> حفظ
          الإعدادات
        </button>
        <div style="margin-top:16px;text-align:center;">
          <button onclick="logout()"
            style="background:none;border:1px solid rgba(255,82,82,0.2);color:var(--red);border-radius:10px;padding:10px 20px;font-family:var(--font-ui);font-size:13px;cursor:pointer;">
            تسجيل الخروج
          </button>
        </div>
      </div>
    </div>
    <div id="settingsOverlay" onclick="toggleSettings()"
      style="position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:149;opacity:0;pointer-events:none;transition:opacity .3s;">
    </div>

    <!-- ═══ SIDEBAR ═══ -->
    <aside id="et-sidebar">
      <div class="sb-project">
        <div class="sb-project-icon">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dataset</span>
        </div>
        <div>
          <div class="sb-project-name" id="sbUserName">Easy Track</div>
          <div class="sb-project-sub" id="sbUserPlan">Pixel Config Generator</div>
        </div>
      </div>
      <nav class="sb-nav">
        <button class="sb-link active" id="sbOverview" type="button" onclick="switchAppView('overview',this)">
          <span class="material-symbols-outlined" style="font-size:18px;">dashboard</span>
          <span>Overview</span>
        </button>
        <button class="sb-link" id="sbPixels" type="button" onclick="switchAppView('pixels',this)">
          <span class="material-symbols-outlined" style="font-size:18px;">ads_click</span>
          <span>Pixel Config</span>
        </button>
        <button class="sb-link" id="sbGtm" type="button" onclick="switchAppView('gtmview',this)">
          <span class="material-symbols-outlined" style="font-size:18px;">inventory_2</span>
          <span>GTM Container</span>
        </button>
        <button class="sb-link" id="sbProjects" type="button" onclick="switchAppView('projects',this)">
          <span class="material-symbols-outlined" style="font-size:18px;">folder_open</span>
          <span>My Projects</span>
        </button>
        <button class="sb-link" id="sbServerSide" type="button" onclick="switchAppView('serverside',this)">
          <span class="material-symbols-outlined" style="font-size:18px;">dns</span>
          <span>Server-Side Tracking</span>
        </button>
        <button class="sb-link" type="button" onclick="toggleSettings()">
          <span class="material-symbols-outlined" style="font-size:18px;">settings</span>
          <span>Settings</span>
        </button>
      </nav>
      <div class="sb-footer">
        <button class="sb-new-btn" type="button" onclick="startNewProject()">
          <span class="material-symbols-outlined" style="font-size:18px;">add_circle</span>
          <span>New Tracking Pixel</span>
        </button>

        <!-- Quick Guide Section -->
        <div
          style="padding:8px 12px 4px;font-family:var(--font-mono);font-size:9px;letter-spacing:2px;color:var(--mut2);text-transform:uppercase;">
          Quick Guide</div>
        <button class="sb-footer-link" type="button" onclick="showCmsGuide('salla')">
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;flex-shrink:0;">
            <rect x="8" y="8" width="84" height="84" rx="20" stroke="#1B5E5A" stroke-width="7" fill="none"/>
            <path d="M 30 67 Q 50 81 70 67" stroke="#1B5E5A" stroke-width="7" stroke-linecap="round" fill="none"/>
          </svg>
          <span>سلة — Setup Guide</span>
        </button>
        <button class="sb-footer-link" type="button" onclick="showCmsGuide('zid')">
          <img src="https://www.f6s.com/content-resource/profiles/3554028_th1.jpg" style="width:18px;height:18px;border-radius:4px;flex-shrink:0;object-fit:cover;" alt="زد" />
          <span>زد — Setup Guide</span>
        </button>

        <button class="sb-footer-link" type="button" onclick="logout()">
          <span class="material-symbols-outlined" style="font-size:18px;">logout</span>
          <span>Log Out</span>
        </button>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="main">

      <!-- ══════ OVERVIEW VIEW ══════ -->
      <div class="app-view active" id="view-overview">

        <!-- User Welcome Header -->
        <div id="overviewUserHeader"
          style="display:flex;align-items:center;gap:14px;padding:18px 24px;background:rgba(16,19,26,0.8);border:1px solid rgba(255,255,255,0.05);border-radius:18px;margin-bottom:24px;backdrop-filter:blur(12px);">
          <!-- Avatar / Settings opener -->
          <div onclick="toggleSettings()" title="إعدادات الحساب"
            style="cursor:pointer;position:relative;flex-shrink:0;">
            <div
              style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,rgba(70,241,197,0.2),rgba(0,212,170,0.1));border:2px solid rgba(70,241,197,0.3);display:flex;align-items:center;justify-content:center;overflow:hidden;transition:all .2s;"
              id="ovUserAvatar">
              <span class="material-symbols-outlined"
                style="font-size:24px;color:var(--acc);font-variation-settings:'FILL' 1;">person</span>
            </div>
            <div
              style="position:absolute;bottom:0;right:0;width:12px;height:12px;background:var(--acc);border-radius:50%;border:2px solid #0B0E14;box-shadow:0 0 6px var(--acc);">
            </div>
          </div>
          <!-- Name + Plan -->
          <div style="flex:1;min-width:0;">
            <div
              style="font-family:var(--font-display);font-weight:800;font-size:16px;color:var(--wht);line-height:1.2;"
              id="ovWelcomeName">مرحباً...</div>
            <div style="font-size:12px;color:var(--mut);margin-top:3px;">العمل على متجرك</div>
          </div>
          <!-- Plan badge -->
          <div id="ovPlanBadge"
            style="display:flex;align-items:center;gap:6px;background:rgba(70,241,197,0.08);border:1px solid rgba(70,241,197,0.2);border-radius:100px;padding:5px 12px;">
            <span class="material-symbols-outlined"
              style="font-size:13px;color:var(--acc);font-variation-settings:'FILL' 1;">workspace_premium</span>
            <span style="font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--acc);"
              id="ovPlanText">BASIC</span>
          </div>
          <!-- Settings button -->
          <button onclick="toggleSettings()"
            style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:8px 10px;color:var(--mut);cursor:pointer;display:flex;align-items:center;transition:all .2s;"
            title="إعدادات الحساب">
            <span class="material-symbols-outlined" style="font-size:18px;">settings</span>
          </button>
        </div>

        <!-- Hero Section -->
        <div id="overviewHero">
          <div class="hero-bg"></div>
          <div class="hero-body">
            <span class="hero-badge">Automation Engine v3.4</span>
            <h1>Setup your tracking pixels in <em>minutes</em>, not hours</h1>
            <p>Streamline your event tracking across Meta, TikTok, and Google with our one-click GTM deployment. No
              coding required.</p>
            <div class="hero-btns">
              <button class="hero-btn-primary"
                onclick="switchAppView('pixels', document.getElementById('sbPixels'))">Start Free</button>
              <button class="hero-btn-ghost" onclick="switchAppView('pixels', document.getElementById('sbPixels'))">View
                Demo</button>
            </div>
          </div>
        </div>

        <!-- Active Pixels (shown after generate) -->
        <div id="overviewPixels">
          <div class="ov-section-title">
            <h3>Active Pixels</h3>
            <button class="ov-view-all" onclick="switchAppView('pixels', document.getElementById('sbPixels'))">
              View all <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span>
            </button>
          </div>
          <div class="ov-pixels-grid" id="ovPixelsGrid"></div>
        </div>

        <!-- Bento: Recent Publishes + Stats (shown after generate) -->
        <div id="overviewBento">
          <div class="ov-recent-card">
            <div class="ov-recent-title">Setup Summary</div>
            <div class="ov-recent-item">
              <div class="ov-recent-dot green"></div>
              <div>
                <div class="ov-recent-label" id="bentoCmsLabel">—</div>
                <div class="ov-recent-time" id="bentoCmsTime">Selected Platform</div>
              </div>
            </div>
            <div class="ov-recent-item">
              <div class="ov-recent-dot dim"></div>
              <div>
                <div class="ov-recent-label" id="bentoPlatLabel">—</div>
                <div class="ov-recent-time">Ad & Analytics Platforms</div>
              </div>
            </div>
            <div class="ov-recent-item">
              <div class="ov-recent-dot dim"></div>
              <div>
                <div class="ov-recent-label" id="bentoEventsLabel">—</div>
                <div class="ov-recent-time">Tracked Events</div>
              </div>
            </div>
            <button
              style="width:100%;margin-top:16px;padding:11px;border-radius:10px;border:1px solid rgba(255,255,255,.08);color:var(--mut);background:transparent;font-family:var(--font-ui);font-size:13px;cursor:pointer;"
              onclick="switchAppView('gtmview',document.getElementById('sbGtm'))">View GTM Container →</button>
          </div>
          <div class="ov-stat-card" style="display:flex;flex-direction:column;gap:20px;">
            <div>
              <div
                style="font-size:11px;color:var(--mut);font-family:var(--font-mono);letter-spacing:1px;margin-bottom:6px;text-transform:uppercase;">
                Config Status</div>
              <div
                style="font-size:40px;font-weight:900;font-family:var(--font-display);color:var(--acc);letter-spacing:-2px;"
                id="bentoConfigScore">—</div>
              <div style="font-size:12px;color:var(--acc);margin-top:4px;" id="bentoConfigLabel">Ready to Deploy ✓</div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div style="background:var(--sur3);border-radius:12px;padding:14px;">
                <div style="font-size:11px;color:var(--mut);margin-bottom:4px;">Active Platforms</div>
                <div id="bentoTagCount"
                  style="font-size:28px;font-weight:900;font-family:var(--font-display);color:var(--wht);">—</div>
              </div>
              <div style="background:var(--sur3);border-radius:12px;padding:14px;">
                <div style="font-size:11px;color:var(--mut);margin-bottom:4px;">Events</div>
                <div id="bentoEventsCount"
                  style="font-size:28px;font-weight:900;font-family:var(--font-display);color:var(--wht);">—</div>
              </div>
            </div>
          </div>
        </div>

        <!-- GTM Containers Status — always visible, loads on sign-in -->
        <div id="ovGtmStatus" style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:16px;padding:20px;margin-bottom:24px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
            <span class="material-symbols-outlined" style="font-size:17px;color:var(--acc);">code_blocks</span>
            <span style="font-family:var(--font-display);font-size:14px;font-weight:800;color:var(--wht);">GTM Snippets</span>
            <button onclick="switchAppView('serverside',document.getElementById('sbServerSide'))" style="margin-right:auto;background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.2);border-radius:8px;padding:3px 10px;font-size:11px;font-weight:700;color:var(--acc);cursor:pointer;font-family:var(--font-ui);">إعداد ←</button>
          </div>
          <!-- Web + Server GTM IDs -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
            <div style="background:var(--sur);border:1px solid var(--bdr);border-radius:10px;padding:12px;">
              <div style="font-size:10px;color:var(--mut);margin-bottom:4px;font-family:var(--font-mono);letter-spacing:.8px;">WEB GTM (CLIENT-SIDE)</div>
              <div id="ovWebGtmId" style="font-family:var(--font-mono);font-size:13px;font-weight:700;color:var(--wht);">—</div>
              <div id="ovWebGtmBadge" style="font-size:10px;margin-top:4px;color:var(--mut);">غير مُعدّ</div>
            </div>
            <div style="background:var(--sur);border:1px solid var(--bdr);border-radius:10px;padding:12px;">
              <div style="font-size:10px;color:var(--mut);margin-bottom:4px;font-family:var(--font-mono);letter-spacing:.8px;">SERVER GTM (SERVER-SIDE)</div>
              <div id="ovServerGtmId" style="font-family:var(--font-mono);font-size:13px;font-weight:700;color:var(--wht);">—</div>
              <div id="ovServerGtmBadge" style="font-size:10px;margin-top:4px;color:var(--mut);">غير مُعدّ</div>
            </div>
          </div>
          <!-- Web Snippet (shown when available) -->
          <div id="ovWebSnippetWrap" style="display:none;margin-bottom:12px;">
            <div style="font-size:11px;font-weight:600;color:var(--wht2);margin-bottom:4px;">Web GTM Snippet (للـ &lt;head&gt;):</div>
            <div style="position:relative;">
              <pre id="ovWebSnippetCode" style="background:#080b10;border:1px solid var(--bdr);border-radius:8px;padding:10px 12px;font-size:10px;color:#a8d8a8;overflow-x:auto;max-height:90px;overflow-y:auto;margin:0;white-space:pre-wrap;word-break:break-all;"></pre>
              <button onclick="ovCopySnippet('head')" style="position:absolute;top:6px;left:6px;background:rgba(70,241,197,.1);border:1px solid rgba(70,241,197,.2);border-radius:5px;padding:2px 8px;font-size:9px;font-weight:700;color:var(--acc);cursor:pointer;font-family:var(--font-ui);">📋 نسخ</button>
            </div>
          </div>
          <!-- Active Platforms grid -->
          <div id="ovActivePlatforms" style="display:none;">
            <div style="font-size:11px;font-weight:600;color:var(--wht2);margin-bottom:8px;">المنصات الشغالة:</div>
            <div id="ovActivePlatGrid" style="display:flex;flex-wrap:wrap;gap:6px;"></div>
          </div>
          <!-- Placeholder when nothing configured yet -->
          <div id="ovGtmPlaceholder" style="text-align:center;padding:16px 0;color:var(--mut);font-size:12px;">
            <span class="material-symbols-outlined" style="font-size:28px;display:block;margin-bottom:6px;opacity:.4;">dns</span>
            لم يتم إعداد أي GTM Container بعد —
            <button onclick="switchAppView('serverside',document.getElementById('sbServerSide'))" style="background:none;border:none;color:var(--acc);cursor:pointer;font-size:12px;font-family:var(--font-ui);font-weight:700;padding:0 4px;">ابدأ الإعداد ←</button>
          </div>
        </div>

        <!-- URL Scanner (Moved to Overview) -->
        <div
          style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:16px;padding:20px;margin-bottom:24px;">
          <div
            style="font-size:13px;font-weight:700;color:var(--wht);margin-bottom:4px;display:flex;align-items:center;gap:8px;">
            <span class="material-symbols-outlined" style="font-size:17px;color:#adc6ff;">travel_explore</span>
            Pixel Scanner
          </div>
          <div style="font-size:12px;color:var(--mut);margin-bottom:14px;">Enter any website URL to detect all tracking
            pixels installed on it</div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <input id="hmScanUrl" type="url" placeholder="https://example.com"
              onkeydown="if(event.key==='Enter'){event.preventDefault();hmScanSite();}"
              style="flex:1;min-width:220px;background:var(--sur3);border:1px solid var(--bdr2);border-radius:10px;padding:10px 14px;color:var(--wht);font-family:var(--font-ui);font-size:13px;outline:none;" />
            <button id="hmScanBtn" onclick="hmScanSite()"
              style="padding:10px 22px;border-radius:10px;border:none;background:var(--acc);color:#0a0a0a;font-weight:800;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap;">
              <span class="material-symbols-outlined" style="font-size:16px;">radar</span> Scan
            </button>
          </div>
          <div id="hmScanResult" style="margin-top:16px;"></div>
        </div>

      </div>
      <!-- END OVERVIEW VIEW -->

      <!-- ══════ PIXEL CONFIG VIEW ══════ -->
      <div class="app-view" id="view-pixels">

        <!-- ── Server Side Config Card ── -->
        <div class="pc-ss-card" id="pc-ss-card">
          <div class="pc-ss-header">
            <span class="pc-ss-icon">🖥️</span>
            <div class="pc-ss-title-wrap">
              <div class="pc-ss-title">Server Side</div>
              <div class="pc-ss-sub">يتفعّل لو الزبون عنده سيرفر — يدعم CAPI لكل المنصات بدون ad blockers</div>
            </div>
            <button class="pc-ss-toggle" id="pc-ss-toggle-btn" onclick="pcSS_toggle()" aria-label="تفعيل Server Side"></button>
