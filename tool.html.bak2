              Setup Guide
            </button>
            <button class="otab" id="tabPlan" onclick="oTab('plan',this)">
              <span class="material-symbols-outlined"
                style="font-size:15px;font-variation-settings:'FILL' 1;">table_chart</span>
              Tracking Plan
            </button>
          </div>

          <!-- pane-ss-gtm: Server Container output (visible only when SS enabled) -->
          <div class="opane" id="pane-ss-gtm" style="display:none;">
            <div class="pc-ss-out-banner">
              <span class="pc-ss-out-icon">🖥️</span>
              <div style="flex:1;">
                <div style="font-family:var(--font-display);font-weight:700;font-size:14px;color:var(--wht);margin-bottom:3px;">Server Container — sGTM</div>
                <div style="font-size:11px;color:var(--mut);">استورد الـ JSON ده في GTM → Admin → Import Container — ثم انسخ الـ Container Config لـ Stape/Cloud Run</div>
              </div>
            </div>
            <div class="cwrap">
              <div class="ctbar">
                <div class="ctdots">
                  <div class="ctdot" style="background:#ff5f57"></div>
                  <div class="ctdot" style="background:#febc2e"></div>
                  <div class="ctdot" style="background:#28c840"></div>
                </div>
                <span class="clang">sgtm-container.json</span>
                <div class="ctacts">
                  <button class="dlbtn" id="dlSsGtm">⬇️ تحميل</button>
                  <button class="cpybtn" id="cpySsGtm">نسخ</button>
                </div>
              </div>
              <div class="cbody" id="ssGtmBody"></div>
            </div>
            <!-- Container Config section -->
            <div class="pc-ss-config-section" id="pc-ss-config-section">
              <div class="pc-ss-config-header">
                <span class="material-symbols-outlined" style="font-size:16px;color:var(--acc);">key</span>
                <span style="font-family:var(--font-display);font-weight:700;font-size:13px;color:var(--wht);flex:1;">Container Config — للـ Stape / Cloud Run</span>
                <button class="cpybtn" id="cpySsConfig">نسخ</button>
              </div>
              <div class="pc-ss-config-box" id="pc-ss-config-box">
                <span style="color:var(--mut);">سيظهر هنا بعد توليد الـ Container…</span>
              </div>
              <div style="padding:10px 16px;font-size:11px;color:var(--mut);border-top:1px solid var(--bdr2);">
                💡 افتح <strong style="color:var(--wht2);">Stape.io</strong> → New Container → Server GTM → الصق الـ Config هنا
              </div>
            </div>
          </div>

          <!-- pane-json hidden (download only, no tab) -->
          <div style="display:none" id="pane-json">
            <div class="cbody" id="jsonBody"></div>
          </div>

          <div class="opane on" id="pane-gtm">

            <!-- GTM Stepper -->
            <div class="gtm-stepper">
              <div class="gtm-step">
                <div class="gtm-step-circle done">✓</div>
                <div class="gtm-step-label">
                  <div class="gtm-step-num">1</div>
                  <div class="gtm-step-name active">Connect Workspace</div>
                </div>
              </div>
              <div class="gtm-step-line"></div>
              <div class="gtm-step">
                <div class="gtm-step-circle active">2</div>
                <div class="gtm-step-label">
                  <div class="gtm-step-num">2</div>
                  <div class="gtm-step-name active">Import Tags</div>
                </div>
              </div>
              <div class="gtm-step-line"></div>
              <div class="gtm-step">
                <div class="gtm-step-circle idle">3</div>
                <div class="gtm-step-label">
                  <div class="gtm-step-num">3</div>
                  <div class="gtm-step-name">Create Version</div>
                </div>
              </div>
              <div class="gtm-step-line"></div>
              <div class="gtm-step">
                <div class="gtm-step-circle idle">4</div>
                <div class="gtm-step-label">
                  <div class="gtm-step-num">4</div>
                  <div class="gtm-step-name">Publish Live</div>
                </div>
              </div>
            </div>

            <!-- GTM Layout: JSON + Publish Panel -->
            <!-- JSON viewer only — Direct Publish has moved to the GTM Container sidebar view -->
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
              <span class="material-symbols-outlined"
                style="color:var(--acc);font-size:20px;">dashboard_customize</span>
              <span style="font-family:var(--font-display);font-weight:700;font-size:16px;color:var(--wht);">Pixel
                Configuration</span>
              <button onclick="switchAppView('gtmview',document.getElementById('sbGtm'))"
                style="margin-right:auto;background:linear-gradient(135deg,var(--acc),var(--acc2));color:#00382b;border:none;border-radius:8px;padding:6px 14px;font-family:var(--font-ui);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;">
                <span class="material-symbols-outlined" style="font-size:14px;">radar</span> Publish to GTM →
              </button>
            </div>
            <div class="cwrap">
              <div class="ctbar">
                <div class="ctdots">
                  <div class="ctdot" style="background:#ff5f57"></div>
                  <div class="ctdot" style="background:#febc2e"></div>
                  <div class="ctdot" style="background:#28c840"></div>
                </div>
                <span class="clang">gtm-container.json</span>
                <div class="ctacts">
                  <button class="dlbtn" id="dlGtm">⬇️ تحميل</button>
                  <button class="cpybtn" id="cpyGtm">نسخ</button>
                </div>
              </div>
              <div class="cbody" id="gtmBody"></div>
            </div>

          </div>

          <!-- pane-dl hidden (no tab) -->
          <div style="display:none" id="pane-dl">
            <div class="cbody" id="dlBody"></div>
          </div>

          <!-- pane-consent hidden (no tab) -->
          <div style="display:none" id="pane-consent">
            <div id="consentBody"></div>
          </div>

          <div class="opane" id="pane-guide">
            <div class="gsteps" id="guideSteps"></div>
          </div>

          <div class="opane" id="pane-plan">
            <div style="display:flex;gap:8px;padding:12px 0 16px;flex-wrap:wrap;">
              <button class="dlbtn" onclick="downloadPlanExcel()">📥 تحميل Excel</button>
              <button class="dlbtn" onclick="downloadPlanPDF()">🖨️ طباعة / PDF</button>
              <button class="cpybtn" onclick="copyPlan()">📋 نسخ</button>
            </div>
            <div id="planContent"></div>
          </div>

          <!-- pane-bridge hidden (no tab) -->
          <div style="display:none" id="pane-bridge">
            <div id="bridgeBody"></div>
          </div>

          <div class="resetrow"><button class="brst" onclick="resetAll()">🔄 ابدأ من الأول</button></div>
        </div>

      </div><!-- END view-pixels -->

      <!-- ══════ GTM CONTAINER VIEW ══════ -->
      <div class="app-view" id="view-gtmview">
        <div style="margin-bottom:20px;">
          <h2
            style="font-family:var(--font-display);font-size:22px;font-weight:800;color:var(--wht);letter-spacing:-.5px;">
            GTM Container</h2>
          <p style="font-size:13px;color:var(--mut);margin-top:4px;">Preview your config JSON and publish directly to
            Google Tag Manager</p>
        </div>

        <div class="gtm-layout">

          <!-- TOP: Managed Container panel — fully automatic setup -->
          <div class="gtm-publish-panel" id="managedGtmPanel">

            <div class="gtm-publish-title">
              <span class="material-symbols-outlined" style="color:var(--acc);font-size:20px;">auto_awesome</span>
              Managed by Easy Track
            </div>

            <!-- Info box -->
            <div class="gtm-info-box" style="margin-bottom:14px;">
              <span class="gtm-info-icon material-symbols-outlined" style="font-size:18px;">bolt</span>
              <div class="gtm-info-text">
                هننشئ GTM Container تلقائياً في حساب Easy Track ونجهّزه بكل الـ tags والـ triggers. هترجعلك
                <strong>Container ID</strong> جاهز تلصقه على موقعك.
              </div>
            </div>

            <!-- Server-Side toggle -->
            <label for="mgdServerSideChk" style="display:flex;align-items:center;gap:10px;padding:12px 14px;
              border-radius:12px;border:1px solid var(--bdr2);background:var(--sur);margin-bottom:8px;cursor:pointer;">
              <input type="checkbox" id="mgdServerSideChk"
                style="width:18px;height:18px;accent-color:var(--acc);cursor:pointer;flex-shrink:0;">
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:700;color:var(--wht);">
                  🚀 فعّل Server-Side Tracking (مستحسن)
                </div>
                <div style="font-size:11px;color:var(--mut);margin-top:2px;line-height:1.5;">
                  Easy Track هيعمل لك <strong>كل حاجة تلقائياً</strong>: ينشئ sGTM container، ينشره على Stape، ويربطه بالـ web container. مفيش حاجة تعملها انت — هتطلع snippet جاهز يتلصق على الموقع وبس. يتجاوز ad blockers + يدعم Conversions APIs.
                </div>
              </div>
            </label>

            <!-- Publish toggle -->
            <label for="mgdPublishChk" style="display:flex;align-items:center;gap:10px;padding:12px 14px;
              border-radius:12px;border:1px solid var(--bdr2);background:var(--sur);margin-bottom:12px;cursor:pointer;">
              <input type="checkbox" id="mgdPublishChk" checked
                style="width:18px;height:18px;accent-color:var(--acc);cursor:pointer;flex-shrink:0;">
              <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:700;color:var(--wht);">
                  Publish to Live فوراً
                </div>
                <div style="font-size:11px;color:var(--mut);margin-top:2px;line-height:1.5;">
                  لو مفعّل: الـ container يبقى شغال دلوقتي. لو مقفول: بيفضل Draft وانت تراجعه وتنشره بنفسك. <em>(يتم تجاهله لو فعّلت Server-Side — هنعمل publish تلقائي بعد wiring)</em>
                </div>
              </div>
            </label>

            <!-- Progress area -->
            <div id="mgdProgress"
              style="display:none;border-radius:12px;padding:12px 16px;margin-bottom:12px;
              border:1px solid rgba(70,241,197,.2);background:rgba(70,241,197,.05);">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:16px;height:16px;border:2px solid rgba(70,241,197,.3);
                  border-top-color:var(--acc);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0;"></div>
                <div id="mgdProgressText"
                  style="font-size:13px;color:var(--acc);font-weight:600;line-height:1.4;direction:rtl;unicode-bidi:isolate;text-align:right;">
                  جاري إنشاء الـ Container...
                </div>
              </div>
            </div>

            <!-- Action button -->
            <button class="gtm-deploy-btn" id="mgdCreateBtn" onclick="gtmManagedCreate()" style="width:100%;">
              <span class="material-symbols-outlined" style="font-size:18px;">rocket_launch</span>
              Create Managed Container
            </button>

            <!-- Result area (populated after success) -->
            <div id="mgdResult" style="display:none;margin-top:14px;"></div>

          </div>

          <!-- BOTTOM: JSON viewer -->
          <div>
            <div id="gtmEmptyState"
              style="display:none;flex-direction:column;align-items:center;justify-content:center;min-height:280px;text-align:center;padding:40px 20px;">
              <span class="material-symbols-outlined"
                style="font-size:56px;color:rgba(70,241,197,0.2);margin-bottom:16px;">inventory_2</span>
              <div
                style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:20px;color:var(--wht);margin-bottom:8px;">
                GTM Container جاهز للتوليد</div>
              <p style="color:var(--mut);font-size:13px;line-height:1.8;max-width:340px;margin-bottom:20px;">اختار
                المنصة والأحداث من Pixel Config عشان نولّدلك GTM Container كامل.</p>
              <button onclick="switchAppView('pixels',document.getElementById('sbPixels'))"
                style="background:var(--acc);color:#00382b;border:none;border-radius:10px;padding:12px 24px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:14px;cursor:pointer;">ابدأ
                من Pixel Config →</button>
            </div>
            <div id="gtmViewContent"></div>
          </div>

        </div>
      </div>
      <!-- END GTM CONTAINER VIEW -->

      <!-- ══════ MY PROJECTS VIEW ══════ -->
      <div class="app-view" id="view-projects">
        <div
          style="margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
          <div>
            <h2
              style="font-family:var(--font-display);font-size:22px;font-weight:800;color:var(--wht);letter-spacing:-.5px;">
              My Projects</h2>
            <p style="font-size:13px;color:var(--mut);margin-top:4px;">All your saved tracking configurations</p>
          </div>
          <button onclick="loadProjects()"
            style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:10px;padding:8px 16px;color:var(--mut);font-family:var(--font-ui);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;">
            <span class="material-symbols-outlined" style="font-size:15px;">refresh</span> Refresh
          </button>
        </div>
        <div id="projectsViewList">
          <div style="text-align:center;padding:80px 20px;color:var(--mut);">
            <span class="material-symbols-outlined"
              style="font-size:48px;opacity:.3;display:block;margin-bottom:12px;">folder_open</span>
            <p style="font-size:14px;">جاري تحميل مشاريعك...</p>
          </div>
        </div>
      </div>
      <!-- END MY PROJECTS VIEW -->



      <!-- ══════ SERVER-SIDE VIEW ══════ -->
      <div class="app-view" id="view-serverside">

        <div class="page-hdr">
          <div>
            <h2 class="page-title">
              <span class="material-symbols-outlined" style="color:var(--acc);">dns</span>
              Server-Side Tracking
            </h2>
            <p class="page-sub">إعداد هايبريد شامل — Web + Server GTM بالتوازي مع نشر مباشر من الأداة</p>
          </div>
          <button class="btn-ghost-sm" id="ss-hdr-reset-btn" onclick="ss_resetConfig()" style="display:none;color:#f87171;border-color:rgba(248,113,113,.3);">
            <span class="material-symbols-outlined" style="font-size:14px;">delete</span>
            إعادة ضبط
          </button>
        </div>

        <!-- ── Completed Banner ── -->
        <div id="ss-done-banner" style="display:none;margin-bottom:20px;padding:16px 20px;border-radius:14px;background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.25);display:none;align-items:center;gap:12px;">
          <span class="material-symbols-outlined" style="color:var(--acc);font-size:22px;flex-shrink:0;">check_circle</span>
          <div style="flex:1;">
            <div style="font-size:14px;font-weight:700;color:var(--acc);">Server-Side Tracking مفعّل ✓</div>
            <div id="ss-done-url" style="font-size:11px;color:var(--mut);font-family:var(--font-mono);margin-top:2px;"></div>
          </div>
          <button class="btn-ghost-sm" onclick="ss_editSetup()" style="font-size:11px;flex-shrink:0;">تعديل</button>
        </div>

        <!-- ── Step Indicator (rendered by JS) ── -->
        <div class="ss-stepper" id="ss-step-bar"></div>

        <!-- ════ STEP 1: GA4 ════ -->
        <div class="ss-panel" id="ss-panel-1">
          <div class="panel-title">Google Analytics 4</div>
          <div class="panel-sub">أدخل الـ Measurement ID — يُربط الـ Web Container بالـ Server عبر transport_url تلقائياً</div>

          <div class="ss-card">
            <div class="ss-field-label">GA4 Measurement ID</div>
            <input type="text" id="ss-p1-ga4-id" class="ss-inp" placeholder="G-XXXXXXXXXX"
              oninput="ss_onGa4Input()" autocomplete="off" style="letter-spacing:.05em;font-family:var(--font-mono);"/>
            <div id="ss-p1-ga4-hint" style="font-size:11px;color:var(--mut);margin-top:8px;line-height:1.5;"></div>
          </div>

          <div class="ss-notice info">
            💡 <strong>كيف يعمل الهايبريد:</strong> الـ Web Container يرسل الأحداث للـ Server عبر transport_url — ثم الـ Server يرسلها لـ CAPI/API مع SHA-256 hashing
          </div>

          <div class="ss-btn-row">
            <button class="btn-acc-sm" onclick="ss_goToStep(2)">التالي <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_back</span></button>
            <span style="font-size:11px;color:var(--mut);">يمكنك تخطيه وإضافته لاحقاً</span>
          </div>
        </div>

        <!-- ════ STEP 2: E-Commerce Platform ════ -->
        <div class="ss-panel" id="ss-panel-2" style="display:none;">
          <div class="panel-title">منصة التجارة الإلكترونية</div>
          <div class="panel-sub">حدد المنصة — يُولَّد DataLayer Code مخصص لها وتُضبط Triggers أوتوماتيك</div>
          <div id="ss-p2-ecomm-list" style="display:flex;flex-direction:column;gap:8px;margin-bottom:18px;"></div>
          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(1)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" onclick="ss_goToStep(3)">التالي <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_back</span></button>
          </div>
        </div>

        <!-- ════ STEP 3: Pixels + Tokens ════ -->
        <div class="ss-panel" id="ss-panel-3" style="display:none;">
          <div class="panel-title">Pixels + Access Tokens</div>
          <div class="panel-sub">فعّل الـ Pixels وأدخل الـ Access Tokens — لكل منها Tags في <span style="color:var(--blu);">Web</span> و<span style="color:var(--acc);">Server</span> Container</div>
          <div id="ss-p3-px-cards" style="margin-bottom:14px;"></div>
          <div class="ss-notice info" style="margin-bottom:14px;">
            <strong style="color:var(--amber);">⚡ Deduplication:</strong> كل حدث يحصل على <code style="font-family:var(--font-mono);background:var(--sur3);padding:1px 5px;border-radius:3px;">event_id = order_id + "_" + timestamp</code> موحد بين الـ Web والـ Server لمنع التكرار
          </div>
          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(2)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" onclick="ss_goToStep(4)">التالي <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_back</span></button>
          </div>
        </div>

        <!-- ════ STEP 4: Events ════ -->
        <div class="ss-panel" id="ss-panel-4" style="display:none;">
          <div class="panel-title">اختر الأحداث</div>
          <div class="panel-sub">الأحداث المختارة تُتبع في الـ Web Container والـ Server Container معاً مع deduplication تلقائي</div>
          <div id="ss-p4-events-list" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;"></div>
          <div class="ss-notice info" style="margin-bottom:14px;">
            🎯 <strong style="color:var(--acc);">Hybrid Coverage:</strong> كل event له Tag في الـ Web (client-side) والـ Server (CAPI relay)
          </div>
          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(3)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" onclick="ss_goToStep(5)">مراجعة <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_back</span></button>
          </div>
        </div>

        <!-- ════ STEP 5: Review + Parallel Create ════ -->
        <div class="ss-panel" id="ss-panel-5" style="display:none;">
          <div class="panel-title">إنشاء Web + Server Containers بالتوازي</div>
          <div class="panel-sub">راجع الإعدادات ثم اضغط إنشاء — كلا الـ Containers يُبنيان في نفس الوقت</div>

          <!-- Review Summary -->
          <div id="ss-p5-review" style="margin-bottom:16px;"></div>

          <!-- Parallel Dual-Column Progress -->
          <div id="ss-p5-parallel" style="display:none;margin-bottom:16px;">
            <div class="ss-creation-split">

              <!-- Web Container -->
              <div class="ss-prog-card web" id="ss-p5-web-card">
                <div class="ss-prog-hdr">
                  <div>
                    <div class="ss-container-badge web" style="margin-bottom:5px;">WEB CONTAINER</div>
                    <div class="ss-prog-label">GTM Web</div>
                  </div>
                  <div class="ss-prog-pct web" id="ss-p5-web-pct">0%</div>
                </div>
                <div class="ss-prog-bar-wrap">
                  <div class="ss-prog-bar web" id="ss-p5-web-bar" style="width:0%"></div>
                </div>
                <div class="ss-stage-list" id="ss-p5-web-stages"></div>
              </div>

              <!-- Server Container -->
              <div class="ss-prog-card server" id="ss-p5-srv-card">
                <div class="ss-prog-hdr">
                  <div>
                    <div class="ss-container-badge server" style="margin-bottom:5px;">SERVER CONTAINER</div>
                    <div class="ss-prog-label">GTM Server</div>
                  </div>
                  <div class="ss-prog-pct server" id="ss-p5-srv-pct">0%</div>
                </div>
                <div class="ss-prog-bar-wrap">
                  <div class="ss-prog-bar server" id="ss-p5-srv-bar" style="width:0%"></div>
                </div>
                <div class="ss-stage-list" id="ss-p5-srv-stages"></div>
              </div>

            </div>
            <div style="text-align:center;margin-top:10px;font-size:11px;color:var(--mut);font-family:var(--font-mono);" id="ss-p5-stage-msg"></div>
          </div>

          <!-- Result -->
          <div id="ss-p5-result" style="display:none;margin-bottom:16px;">
            <div class="ss-result-grid">
              <div class="ss-result-cell">
                <div class="ss-result-cell-label">🌐 Web Container</div>
                <div class="ss-result-cell-val" id="ss-p5-web-id">—</div>
              </div>
              <div class="ss-result-cell">
                <div class="ss-result-cell-label">🖥️ Server Container</div>
                <div class="ss-result-cell-val" id="ss-p5-server-id">—</div>
              </div>
            </div>
            <div class="ss-notice good" style="margin-top:10px;">✅ تم إنشاء الـ Containers بنجاح — جاهزَين للنشر</div>
          </div>

          <div id="ss-p5-error" style="display:none;" class="ss-notice warn" style="margin-bottom:14px;"></div>

          <div id="ss-p5-btn-wrap" class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(4)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" id="ss-p5-create-btn" onclick="ss_createContainers()">
              <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">play_circle</span>
              إنشاء Web + Server معاً
            </button>
            <span style="font-size:11px;color:var(--mut);">⏱️ 60-120 ثانية</span>
          </div>
          <div id="ss-p5-next-wrap" style="display:none;margin-top:12px;">
            <button class="btn-acc-sm" onclick="ss_goToStep(6)">
              <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">cloud_upload</span>
              التالي — نشر السيرفر ←
            </button>
          </div>
        </div>

        <!-- ════ STEP 6: Deploy Server Container ════ -->
        <div class="ss-panel" id="ss-panel-6" style="display:none;">
          <div class="panel-title">نشر Server Container</div>
          <div class="panel-sub">انسخ الـ Container Config وانشره على Stape أو Cloud Run</div>

          <div class="ss-card" style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div class="ss-field-label" style="margin:0;">Container Config</div>
              <button class="btn-ghost-sm" onclick="ss_copyContainerConfig()" style="font-size:11px;padding:4px 10px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">content_copy</span> نسخ
              </button>
            </div>
            <pre id="ss-p6-config-blob" class="ss-code-block"></pre>
          </div>

          <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;">
            <div class="ss-card">
              <div style="font-weight:700;color:var(--wht);margin-bottom:6px;font-size:13px;">🚀 Stape.io <span style="font-size:11px;color:var(--acc);font-weight:600;">(الأسهل)</span></div>
              <ol style="margin:0;padding-right:16px;line-height:1.9;color:var(--mut);font-size:12px;">
                <li>افتح <a href="https://stape.io" target="_blank" style="color:var(--acc);">stape.io</a> وأنشئ Server Container جديد</li>
                <li>الصق الـ Container Config في حقل "Container Config"</li>
                <li>انسخ الـ Server URL وأدخله في الخطوة التالية</li>
              </ol>
            </div>
            <div class="ss-card">
              <div style="font-weight:700;color:var(--wht);margin-bottom:6px;font-size:13px;">☁️ Google Cloud Run</div>
              <div style="color:var(--mut);font-size:12px;line-height:1.7;">انشر الـ Docker image الرسمي لـ sGTM مع <code style="font-family:var(--font-mono);background:var(--sur3);padding:1px 5px;border-radius:3px;">CONTAINER_CONFIG</code> كـ env var</div>
            </div>
          </div>

          <!-- Stape Direct Deploy -->
          <div class="ss-card" style="margin-bottom:14px;border-color:rgba(70,241,197,.28);background:rgba(70,241,197,.025);">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
              <div style="font-weight:700;color:var(--wht);font-size:13px;">🚀 نشر مباشر على Stape</div>
              <a href="https://stape.io" target="_blank" rel="noopener"
                style="font-size:9px;color:var(--acc);font-weight:700;background:rgba(70,241,197,.1);
                       padding:2px 7px;border-radius:4px;font-family:var(--font-mono);letter-spacing:.5px;
                       text-decoration:none;">stape.io ↗</a>
            </div>
            <div style="color:var(--mut);font-size:11px;margin-bottom:12px;line-height:1.7;">
              أدخل الـ API Key من <strong style="color:var(--wht2);">stape.io → Account Settings → API Keys</strong>
              وسننشر الـ Container تلقائياً ونملأ الـ URL في الخطوة التالية
            </div>

            <!-- Row 1: API Key + region -->
            <div style="display:grid;grid-template-columns:1fr auto;gap:8px;margin-bottom:8px;">
              <div>
                <div class="ss-field-label">Stape API Key</div>
                <div style="position:relative;">
                  <input type="password" id="ss-p6-stape-key" class="ss-inp"
                    placeholder="stape_api_xxxxxxxxxxxx" autocomplete="new-password"
                    style="width:100%;font-family:var(--font-mono);font-size:12px;padding-left:28px;"/>
                  <span class="material-symbols-outlined" onclick="ss_toggleStapeKeyVis()"
                    style="position:absolute;left:8px;top:50%;transform:translateY(-50%);
                           font-size:14px;color:var(--mut);cursor:pointer;" id="ss-p6-stape-eye">visibility</span>
                </div>
              </div>
              <div>
                <div class="ss-field-label">Region</div>
                <select id="ss-p6-stape-region" class="ss-inp"
                  style="font-size:11px;min-width:110px;cursor:pointer;background:var(--sur2);">
                  <option value="us-central">🇺🇸 US Central</option>
                  <option value="eu-west">🇪🇺 EU West</option>
                  <option value="me-central1">🇦🇪 ME Central</option>
                  <option value="asia-east1">🇸🇬 Asia East</option>
                </select>
              </div>
            </div>

            <!-- Row 2: Save key toggle + deploy button -->
            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;user-select:none;">
                <input type="checkbox" id="ss-p6-stape-savekey" style="accent-color:var(--acc);width:13px;height:13px;"/>
                <span style="font-size:11px;color:var(--mut);">احفظ الـ Key مشفّراً لاستخدام لاحق</span>
              </label>
              <button class="btn-acc-sm" id="ss-p6-stape-btn" onclick="ss_deployStape()" style="white-space:nowrap;">
                <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;" id="ss-p6-stape-icon">rocket_launch</span>
                <span id="ss-p6-stape-btn-lbl">نشر على Stape</span>
              </button>
            </div>

            <!-- Status line -->
            <div id="ss-p6-stape-status" style="margin-top:10px;font-size:12px;font-family:var(--font-mono);min-height:20px;line-height:1.6;"></div>
          </div>

          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(5)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" onclick="ss_goToStep(7)">نشرت يدوياً — التالي <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_back</span></button>
          </div>
        </div>

        <!-- ════ STEP 7: Server URL + Wire ════ -->
        <div class="ss-panel" id="ss-panel-7" style="display:none;">
          <div class="panel-title">ربط URL الخادم</div>
          <div class="panel-sub">أدخل URL الخادم — سيتم ربطه في GA4 Config Tag (transport_url) ونشر الـ Containers</div>

          <div class="ss-card" style="margin-bottom:14px;">
            <div class="ss-field-label">Server URL</div>
            <div style="display:flex;gap:8px;align-items:stretch;">
              <input type="url" id="ss-p7-url" class="ss-inp"
                placeholder="https://gtm.yourdomain.com" autocomplete="off"
                onkeydown="if(event.key==='Enter') ss_validateUrl()"
                style="flex:1;"/>
              <button class="btn-ghost-sm" onclick="ss_validateUrl()" id="ss-p7-validate-btn" style="white-space:nowrap;flex-shrink:0;">
                <span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">wifi_tethering</span>
                تحقق
              </button>
            </div>
            <div id="ss-p7-status" style="margin-top:8px;font-size:12px;color:var(--mut);font-family:var(--font-mono);"></div>
          </div>

          <div id="ss-p7-wire-wrap" style="display:none;margin-bottom:16px;">
            <div class="ss-notice good" style="margin-bottom:12px;">
              ✅ الخادم يستجيب — جاهز للربط<br>
              <span style="color:var(--mut);font-size:11px;">سيتم: إضافة transport_url للـ Web Container + إضافة URL للـ Server Container + نشر كلاهما</span>
            </div>
            <button class="btn-acc-sm" id="ss-p7-wire-btn" onclick="ss_wireUrl()">
              <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">cable</span>
              ربط ونشر الـ Containers
            </button>
          </div>

          <div id="ss-p7-error" style="display:none;" class="ss-notice warn" style="margin-bottom:12px;"></div>

          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(6)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
          </div>
        </div>

        <!-- ════ STEP 8: Done ════ -->
        <div class="ss-panel" id="ss-panel-8" style="display:none;">
          <div class="ss-done-hero">
            <div class="ss-done-icon">✅</div>
            <div class="ss-done-title">Server-Side Tracking مفعّل! 🎉</div>
            <div class="ss-done-subtitle">الـ Web Container والـ Server Container منشورَين ومربوطَين — الصق الكود أدناه في موقعك</div>
          </div>

          <div style="margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <div class="ss-sec-label">GTM Snippet — &lt;head&gt;</div>
              <button class="btn-ghost-sm" onclick="ss_copySnippet('head')" style="font-size:11px;padding:4px 10px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">content_copy</span> نسخ
              </button>
            </div>
            <pre id="ss-p8-snippet-head" class="ss-snippet-block"></pre>
          </div>

          <div style="margin-bottom:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <div class="ss-sec-label">GTM Snippet — &lt;body&gt;</div>
              <button class="btn-ghost-sm" onclick="ss_copySnippet('body')" style="font-size:11px;padding:4px 10px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">content_copy</span> نسخ
              </button>
            </div>
            <pre id="ss-p8-snippet-body" class="ss-snippet-block"></pre>
          </div>

          <div style="margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <div class="ss-sec-label" id="ss-p8-dl-label">DataLayer Code</div>
              <button class="btn-ghost-sm" onclick="ss_copyCode('datalayer')" style="font-size:11px;padding:4px 10px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">content_copy</span> نسخ
              </button>
            </div>
            <pre id="ss-p8-datalayer-code" class="ss-snippet-block" style="max-height:220px;color:#a8d8c8;"></pre>
          </div>

          <div id="ss-p8-summary" class="ss-card" style="font-size:11px;color:var(--wht2);line-height:1.8;margin-bottom:16px;"></div>

          <div class="ss-btn-row">
            <button class="btn-ghost-sm" onclick="ss_goToStep(7)"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:middle;">arrow_forward</span> السابق</button>
            <button class="btn-acc-sm" onclick="ss_confirmSetup()">
              <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">check_circle</span>
              حفظ وإنهاء
            </button>
          </div>
          <div id="ss-p8-status" style="font-size:12px;color:var(--mut);font-family:var(--font-mono);margin-top:10px;"></div>
        </div>

      </div>

      <!-- ── Server-Side Wizard CSS ── -->
      <style>
        /* ─── Stepper ─── */
        .ss-stepper{display:flex;align-items:center;gap:0;margin-bottom:24px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none;background:var(--sur2);border:1px solid var(--bdr2);border-radius:14px;padding:12px 16px;}
        .ss-stepper::-webkit-scrollbar{display:none;}
        .ss-step-chip{display:flex;align-items:center;gap:5px;padding:5px 8px;border-radius:8px;cursor:pointer;flex-shrink:0;transition:background .15s;}
        .ss-step-chip:hover{background:var(--sur3);}
        .ss-step-circle{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;font-family:var(--font-mono);flex-shrink:0;transition:all .2s;}
        .ss-step-circle.idle{background:var(--sur3);color:var(--mut);border:1.5px solid var(--bdr2);}
        .ss-step-circle.active{background:var(--acc-dim,rgba(70,241,197,.10));color:var(--acc);border:1.5px solid var(--acc);box-shadow:0 0 10px rgba(70,241,197,.22);}
        .ss-step-circle.done{background:rgba(70,241,197,.18);color:var(--acc);border:1.5px solid rgba(70,241,197,.35);}
        .ss-step-lbl{font-size:10px;font-weight:600;color:var(--mut);white-space:nowrap;}
        .ss-step-lbl.active{color:var(--acc);}
        .ss-step-lbl.done{color:var(--wht2);}
        .ss-step-sep{width:16px;height:1px;background:var(--bdr2);flex-shrink:0;}
        .ss-step-sep.done{background:rgba(70,241,197,.35);}

        /* ─── Panels ─── */
        .ss-panel{background:var(--sur2);border:1px solid var(--bdr2);border-radius:16px;padding:24px;animation:ssFadeUp .22s ease;}
        @keyframes ssFadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        .panel-title{font-family:var(--font-display);font-size:17px;font-weight:800;color:var(--wht);letter-spacing:-.3px;margin-bottom:4px;}
        .panel-sub{font-size:12px;color:var(--mut);margin-bottom:18px;line-height:1.6;}

        /* ─── Cards & inputs ─── */
        .ss-card{background:var(--sur);border:1px solid var(--bdr2);border-radius:var(--r-md,12px);padding:14px 16px;margin-bottom:10px;}
        .ss-field-label{font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:.9px;margin-bottom:6px;display:block;}
        .ss-inp{width:100%;background:var(--sur2);border:1px solid var(--bdr2);border-radius:8px;padding:9px 13px;font-size:13px;color:var(--wht);font-family:var(--font-ui);outline:none;transition:border .15s,box-shadow .15s;box-sizing:border-box;}
        .ss-inp:focus{border-color:var(--acc);box-shadow:0 0 0 3px rgba(70,241,197,.08);}
        .ss-inp::placeholder{color:var(--mut);}

        /* ─── Notices ─── */
        .ss-notice{padding:10px 14px;border-radius:10px;font-size:11px;line-height:1.65;margin-bottom:12px;}
        .ss-notice.info{background:rgba(70,241,197,.04);border:1px solid rgba(70,241,197,.13);color:var(--wht2);}
        .ss-notice.good{background:rgba(70,241,197,.07);border:1px solid rgba(70,241,197,.22);color:var(--acc);}
        .ss-notice.warn{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);color:#f87171;}
        .ss-notice.blue{background:rgba(173,198,255,.05);border:1px solid rgba(173,198,255,.2);color:var(--blu,#adc6ff);}

        /* ─── Button row ─── */
        .ss-btn-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:18px;}

        /* ─── Platform / selection rows ─── */
        .ss-sel-row{display:flex;align-items:center;gap:12px;background:var(--sur);border:1.5px solid var(--bdr2);border-radius:12px;padding:10px 14px;cursor:pointer;transition:border-color .15s;user-select:none;}
        .ss-sel-row:hover{border-color:rgba(70,241,197,.3);}
        .ss-sel-row.selected{border-color:var(--acc);background:rgba(70,241,197,.04);}
        .ss-sel-ico{font-size:20px;width:32px;text-align:center;flex-shrink:0;}
        .ss-sel-info{flex:1;min-width:0;}
        .ss-sel-name{font-family:var(--font-display);font-size:13px;font-weight:700;color:var(--wht);}
        .ss-sel-sub{font-size:11px;color:var(--mut);}
        .ss-sel-check{width:17px;height:17px;border-radius:50%;border:1.5px solid var(--bdr2);display:flex;align-items:center;justify-content:center;margin-right:auto;flex-shrink:0;transition:all .15s;}
        .ss-sel-row.selected .ss-sel-check{background:var(--acc);border-color:var(--acc);}
        .ss-sel-badge{font-size:9px;font-weight:800;padding:2px 7px;border-radius:4px;font-family:var(--font-mono);}
        .ss-sel-badge.rec{background:rgba(70,241,197,.15);color:var(--acc);border:1px solid rgba(70,241,197,.25);}
        .ss-sel-badge.warn{background:rgba(248,113,113,.1);color:#f87171;border:1px solid rgba(248,113,113,.2);}

        /* ─── Pixel cards ─── */
        .ss-px-card{background:var(--sur);border:1.5px solid var(--bdr2);border-radius:12px;margin-bottom:8px;overflow:hidden;transition:border-color .15s;}
        .ss-px-card.active{border-color:rgba(70,241,197,.4);}
        .ss-px-header{display:flex;align-items:center;gap:10px;padding:12px 14px;cursor:pointer;user-select:none;}
        .ss-px-name{font-size:13px;font-weight:700;color:var(--wht);}
        .ss-px-sub{font-size:11px;color:var(--mut);}
        .ss-px-badge{font-size:9px;font-weight:700;letter-spacing:.8px;padding:2px 7px;border-radius:4px;font-family:var(--font-mono);}
        .ss-px-badge.web{background:rgba(173,198,255,.12);color:var(--blu,#adc6ff);}
        .ss-px-badge.server{background:rgba(70,241,197,.1);color:var(--acc);}
        .ss-px-badge.both{background:rgba(245,158,11,.1);color:#fbbf24;}
        .ss-px-toggle{width:34px;height:19px;border-radius:10px;background:var(--sur3);border:none;cursor:pointer;position:relative;transition:background .2s;flex-shrink:0;}
        .ss-px-toggle.on{background:var(--acc);}
        .ss-px-toggle::after{content:'';position:absolute;top:3px;right:3px;width:13px;height:13px;border-radius:50%;background:#fff;transition:transform .2s,right .2s;}
        .ss-px-toggle.on::after{right:auto;left:3px;}
        .ss-px-expand{overflow:hidden;max-height:0;transition:max-height .3s ease,opacity .3s;opacity:0;}
        .ss-px-expand.open{max-height:200px;opacity:1;}

        /* ══════════════════════════════════════════════════
           Pixel Config — Server Side Card & Components
        ══════════════════════════════════════════════════ */
        .pc-ss-card{border:1px solid var(--bdr2);border-radius:12px;background:var(--sur2);margin-bottom:20px;overflow:hidden;}
        .pc-ss-header{display:flex;align-items:center;gap:12px;padding:16px 20px;}
        .pc-ss-icon{font-size:22px;flex-shrink:0;}
        .pc-ss-title-wrap{flex:1;}
        .pc-ss-title{font-family:var(--font-display);font-weight:700;font-size:15px;color:var(--wht);line-height:1.2;}
        .pc-ss-sub{font-size:11px;color:var(--mut);margin-top:2px;}
        .pc-ss-toggle{width:46px;height:25px;border-radius:13px;background:var(--sur3);border:1px solid var(--bdr2);cursor:pointer;position:relative;transition:background .25s,border-color .25s;flex-shrink:0;}
        .pc-ss-toggle.on{background:var(--acc);border-color:var(--acc);}
        .pc-ss-toggle::after{content:'';position:absolute;top:3px;right:3px;width:17px;height:17px;border-radius:50%;background:#fff;transition:right .25s;}
        .pc-ss-toggle.on::after{right:auto;left:3px;}
        .pc-ss-toggle-lbl{font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;min-width:22px;text-align:center;}
        .pc-ss-toggle.on + .pc-ss-toggle-lbl{color:var(--acc);}
        .pc-ss-body{border-top:1px solid var(--bdr2);padding:20px;display:none;}
        .pc-ss-body.open{display:block;}
        /* Section inside body */
        .pc-ss-section{margin-bottom:20px;}
        .pc-ss-section:last-child{margin-bottom:0;}
        .pc-ss-sec-label{font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px;}
        /* Inputs */
        .pc-ss-input{width:100%;background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:10px 14px;font-size:13px;font-family:var(--font-mono);color:var(--wht);outline:none;transition:border-color .2s;direction:ltr;}
        .pc-ss-input:focus{border-color:var(--bdr);}
        .pc-ss-hint{font-size:11px;color:var(--mut);margin-top:5px;}
        .pc-ss-valid{font-size:11px;margin-top:4px;min-height:14px;}
        /* GA4 ID row */
        .pc-ss-ga4-row{display:flex;align-items:center;gap:10px;background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:10px 14px;}
        .pc-ss-ga4-badge{font-size:9px;font-weight:700;background:rgba(70,241,197,0.12);color:var(--acc);padding:2px 6px;border-radius:4px;letter-spacing:1px;font-family:var(--font-mono);flex-shrink:0;}
        .pc-ss-ga4-val{font-family:var(--font-mono);font-size:12px;color:var(--wht);flex:1;word-break:break-all;}
        .pc-ss-ga4-edit{background:none;border:1px solid var(--bdr2);border-radius:6px;padding:4px 9px;font-size:10px;color:var(--mut);cursor:pointer;transition:border-color .15s;}
        .pc-ss-ga4-edit:hover{border-color:var(--bdr);}
        /* Platform cards grid inside SS */
        .pc-ss-plat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px;}
        /* Accordion per platform */
        .pc-ss-acc{border:1px solid var(--bdr2);border-radius:10px;overflow:hidden;margin-bottom:10px;}
        .pc-ss-acc:last-child{margin-bottom:0;}
        .pc-ss-acc-hdr{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;background:var(--sur2);transition:background .15s;user-select:none;}
        .pc-ss-acc-hdr:hover{background:var(--sur3);}
        .pc-ss-acc-name{font-size:13px;font-weight:700;color:var(--wht);flex:1;}
        .pc-ss-acc-arr{font-size:12px;color:var(--mut);transition:transform .2s;font-family:var(--font-mono);}
        .pc-ss-acc.open .pc-ss-acc-arr{transform:rotate(90deg);}
        .pc-ss-acc-body{display:none;border-top:1px solid var(--bdr2);padding:16px;}
        .pc-ss-acc.open .pc-ss-acc-body{display:block;}
        /* Event chips inside accordion */
        .pc-ss-ev-chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
        .pc-ss-ev-chip{border:1px solid var(--bdr2);border-radius:20px;padding:5px 12px;font-size:11px;color:var(--mut);cursor:pointer;transition:all .15s;background:var(--sur3);white-space:nowrap;}
        .pc-ss-ev-chip.on{border-color:var(--acc);color:var(--acc);background:rgba(70,241,197,0.07);}
        .pc-ss-ev-chip.forced{opacity:.65;cursor:default;}
        /* Pixel/token input rows */
        .pc-ss-px-row{margin-bottom:12px;}
        .pc-ss-px-row:last-child{margin-bottom:0;}
        .pc-ss-px-lbl{font-size:11px;color:var(--mut);margin-bottom:5px;font-weight:600;}
        .pc-ss-pw-wrap{position:relative;}
        .pc-ss-pw-wrap .pc-ss-input{padding-left:38px;}
        .pc-ss-eye{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:15px;color:var(--mut);cursor:pointer;transition:color .15s;}
        .pc-ss-eye:hover{color:var(--wht2);}
        /* Gads label sub-rows */
        .pc-ss-label-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
        .pc-ss-label-ev{font-size:11px;color:var(--mut2);min-width:90px;flex-shrink:0;}
        /* Platform group labels in Step 2 */
        .pc-plat-group{grid-column:1/-1;margin-top:12px;margin-bottom:4px;}
        .pc-plat-group:first-child{margin-top:0;}
        .pc-plat-group-lbl{font-size:10px;font-weight:700;color:var(--mut);text-transform:uppercase;letter-spacing:1.5px;padding-bottom:6px;border-bottom:1px solid var(--bdr2);}
        /* Server container output */
        .pc-ss-out-banner{background:rgba(70,241,197,0.04);border:1px solid var(--bdr);border-radius:10px;padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:12px;}
        .pc-ss-out-icon{font-size:24px;flex-shrink:0;}
        .pc-ss-config-section{margin-top:20px;border:1px solid var(--bdr2);border-radius:10px;overflow:hidden;}
        .pc-ss-config-header{display:flex;align-items:center;gap:10px;padding:12px 16px;background:var(--sur3);border-bottom:1px solid var(--bdr2);}
        .pc-ss-config-box{padding:14px;font-family:var(--font-mono);font-size:11px;color:var(--wht2);word-break:break-all;line-height:1.8;max-height:100px;overflow-y:auto;background:var(--sur2);}
        .ss-px-token-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 14px 12px;}
        @media(max-width:540px){.ss-px-token-grid{grid-template-columns:1fr;}}
        .ss-px-token-block{background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:8px 10px;}
        .ss-px-token-label{font-size:9px;font-weight:700;color:var(--mut);letter-spacing:.8px;text-transform:uppercase;margin-bottom:5px;}
        .ss-tok-input{width:100%;box-sizing:border-box;background:var(--sur2);border:1px solid var(--bdr2);border-radius:8px;padding:7px 10px;font-family:var(--font-mono);font-size:11px;color:var(--wht);outline:none;transition:border-color .15s;margin-top:0;}
        .ss-tok-input:focus{border-color:var(--acc);}
        .ss-px-label{font-size:10px;font-weight:700;color:var(--mut);display:block;margin-bottom:4px;letter-spacing:.5px;text-transform:uppercase;}

        /* ─── Event chips ─── */
        .ss-ev-chip{padding:7px 14px;border-radius:20px;border:1.5px solid var(--bdr2);font-size:12px;font-weight:600;font-family:var(--font-mono);cursor:pointer;transition:all .15s;color:var(--wht2);}
        .ss-ev-chip.on{border-color:var(--acc);color:var(--acc);background:rgba(70,241,197,.08);}

        /* ─── Parallel progress ─── */
        .ss-creation-split{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;}
        @media(max-width:600px){.ss-creation-split{grid-template-columns:1fr;}}
        .ss-prog-card{border-radius:14px;padding:18px;border:1.5px solid;position:relative;transition:border-color .3s;}
        .ss-prog-card.web{border-color:rgba(173,198,255,.2);background:rgba(173,198,255,.03);}
        .ss-prog-card.web.done{border-color:rgba(173,198,255,.4);}
        .ss-prog-card.server{border-color:rgba(70,241,197,.2);background:rgba(70,241,197,.03);}
        .ss-prog-card.server.done{border-color:rgba(70,241,197,.45);box-shadow:0 0 24px rgba(70,241,197,.06);}
        .ss-prog-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
        .ss-prog-label{font-size:13px;font-weight:700;color:var(--wht);}
        .ss-prog-pct{font-family:var(--font-mono);font-size:12px;font-weight:700;}
        .ss-prog-pct.web{color:var(--blu,#adc6ff);}
        .ss-prog-pct.server{color:var(--acc);}
        .ss-prog-bar-wrap{height:4px;background:var(--sur3);border-radius:3px;overflow:hidden;margin-bottom:12px;}
        .ss-prog-bar{height:100%;border-radius:3px;transition:width .4s cubic-bezier(.4,0,.2,1);}
        .ss-prog-bar.web{background:linear-gradient(90deg,#6fa8ff,#adc6ff);}
        .ss-prog-bar.server{background:linear-gradient(90deg,var(--acc2,#00d4aa),var(--acc));}
        .ss-container-badge{font-size:9px;font-weight:700;letter-spacing:1px;padding:2px 7px;border-radius:4px;font-family:var(--font-mono);display:inline-block;}
        .ss-container-badge.web{background:rgba(173,198,255,.15);color:var(--blu,#adc6ff);}
        .ss-container-badge.server{background:rgba(70,241,197,.12);color:var(--acc);}
        .ss-stage-list{display:flex;flex-direction:column;gap:5px;}
        .ss-stage-item{display:flex;align-items:center;gap:8px;font-size:11px;}
        .ss-stage-ico{width:15px;height:15px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0;transition:all .25s;}
        .ss-stage-ico.idle{background:var(--sur3);color:var(--mut);}
        .ss-stage-ico.spin{background:rgba(173,198,255,.15);color:var(--blu,#adc6ff);animation:ssSpin .8s linear infinite;}
        .ss-stage-ico.spin-grn{background:rgba(70,241,197,.1);color:var(--acc);animation:ssSpin .8s linear infinite;}
        .ss-stage-ico.done{background:rgba(70,241,197,.18);color:var(--acc);}
        @keyframes ssSpin{to{transform:rotate(360deg)}}
        .ss-stage-txt{color:var(--mut);transition:color .2s;}
        .ss-stage-txt.active{color:var(--wht);}
        .ss-stage-txt.done{color:var(--wht2);}

        /* ─── Result grid ─── */
        .ss-result-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
        .ss-result-cell{background:var(--sur2);border:1px solid var(--bdr2);border-radius:10px;padding:11px 13px;}
        .ss-result-cell-label{font-size:10px;color:var(--mut);margin-bottom:3px;font-family:var(--font-mono);}
        .ss-result-cell-val{font-family:var(--font-mono);font-size:13px;font-weight:700;color:var(--wht);}

        /* ─── Code blocks ─── */
        .ss-code-block{background:#080b10;border:1px solid var(--bdr);border-radius:10px;padding:12px 14px;font-size:9px;color:#a8d8a8;overflow-x:auto;max-height:120px;overflow-y:auto;margin:0;white-space:pre-wrap;word-break:break-all;font-family:var(--font-mono);}
        .ss-snippet-block{background:#060910;border:1px solid var(--bdr);border-radius:10px;padding:12px 14px;font-size:10px;color:#a8d8c8;overflow-x:auto;max-height:100px;overflow-y:auto;margin:0;white-space:pre;line-height:1.65;font-family:var(--font-mono);}
        .ss-sec-label{font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--mut);text-transform:uppercase;margin-bottom:6px;}

        /* ─── Done screen ─── */
        .ss-done-hero{text-align:center;padding:24px 20px 18px;}
        .ss-done-icon{width:64px;height:64px;border-radius:50%;background:rgba(70,241,197,.1);border:2px solid rgba(70,241,197,.3);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:28px;box-shadow:0 0 36px rgba(70,241,197,.12);}
        .ss-done-title{font-family:var(--font-display);font-size:20px;font-weight:800;color:var(--wht);margin-bottom:5px;}
        .ss-done-subtitle{font-size:12px;color:var(--mut);max-width:380px;margin:0 auto;}

        /* ─── Summary / misc ─── */
        .ss-summary-block{background:var(--sur);border:1px solid var(--bdr2);border-radius:12px;padding:14px 16px;margin-bottom:10px;}
        .ss-summary-label{font-size:10px;color:var(--mut);font-family:var(--font-mono);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
        .ss-summary-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--bdr);}
        .ss-summary-row:last-child{border-bottom:none;}
        .ss-summary-key{font-size:12px;color:var(--mut);}
        .ss-summary-val{font-size:12px;color:var(--wht);font-weight:600;font-family:var(--font-ui);text-align:left;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
        /* URL input (keep for compat) */
        .ss-url-input{flex:1;min-width:180px;background:var(--sur2);border:1.5px solid var(--bdr2);border-radius:10px;padding:9px 14px;font-family:var(--font-mono);font-size:12px;color:var(--wht);outline:none;transition:border-color .15s;box-sizing:border-box;}
        .ss-url-input:focus{border-color:var(--acc);}
        /* Spinner compat */
        .ss-spin{width:18px;height:18px;border-radius:50%;border:2px solid rgba(70,241,197,.2);border-top-color:var(--acc);animation:ssSpin 0.7s linear infinite;flex-shrink:0;}
      </style>
      <!-- END SERVER-SIDE VIEW -->


    </div>
  </div>

  <!-- New Component Styles -->
  <style>
    /* ── Page headers ── */
    .page-hdr {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 24px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .page-title {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      color: var(--wht);
      letter-spacing: -.5px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .page-sub {
      font-size: 13px;
      color: var(--mut);
      margin-top: 4px;
    }

    .btn-ghost-sm {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 8px 14px;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
    }

    .btn-ghost-sm:hover {
      color: var(--wht2);
      border-color: rgba(255, 255, 255, .15);
    }

    .btn-acc-sm {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--acc);
      color: #00382b;
      border: none;
      border-radius: 10px;
      padding: 8px 16px;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
      box-shadow: 0 4px 12px rgba(70, 241, 197, .25);
    }

    .btn-acc-sm:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }

    /* ── DataLayer Monitor ── */
    .dlm-controls {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 16px;
      padding: 14px 18px;
      margin-bottom: 16px;
    }

    .dlm-ctrl-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .dlm-label {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut2);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .dlm-toggle-row {
      display: flex;
      gap: 4px;
    }

    .dlm-cms-btn,
    .dlm-mode-btn {
      padding: 5px 12px;
      border-radius: 8px;
      border: 1px solid var(--bdr2);
      background: var(--sur3);
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .dlm-cms-btn.active,
    .dlm-mode-btn.active {
      background: rgba(70, 241, 197, .1);
      border-color: rgba(70, 241, 197, .3);
      color: var(--acc);
    }

    .dlm-select {
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 8px;
      padding: 6px 10px;
      color: var(--mut);
      font-family: var(--font-ui);
      font-size: 12px;
      outline: none;
      cursor: pointer;
    }

    .dlm-live-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--acc);
      box-shadow: 0 0 8px var(--acc);
      animation: pulse 2s infinite;
      flex-shrink: 0;
    }

    .dlm-stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .dlm-stat {
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 12px;
      padding: 14px;
      text-align: center;
    }

    .dlm-stat-val {
      font-family: var(--font-mono);
      font-size: 22px;
      font-weight: 700;
      color: var(--wht);
    }

    .dlm-stat-lbl {
      font-size: 10px;
      color: var(--mut);
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: .5px;
    }

    .dlm-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .dlm-col-title {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      color: var(--wht);
      margin-bottom: 10px;
    }

    .dlm-stream-col,
    .dlm-inspect-col {
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      flex-direction: column;
    }

    .dlm-stream-body {
      flex: 1;
      min-height: 320px;
      max-height: 480px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .dlm-empty-state {
      text-align: center;
      padding: 40px 20px;
      color: var(--mut);
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .dlm-event-row {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--sur3);
      border: 1px solid var(--bdr3);
      border-radius: 10px;
      padding: 10px 12px;
      cursor: pointer;
      transition: all .15s;
    }

    .dlm-event-row:hover {
      border-color: rgba(70, 241, 197, .2);
      background: rgba(70, 241, 197, .03);
    }

    .dlm-event-row.selected {
      border-color: rgba(70, 241, 197, .4);
      background: rgba(70, 241, 197, .06);
    }

    .dlm-ev-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--acc);
      background: rgba(70, 241, 197, .08);
      padding: 2px 7px;
      border-radius: 4px;
      flex-shrink: 0;
    }

    .dlm-ev-id {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut2);
      flex-shrink: 0;
    }

    .dlm-ev-val {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--wht);
      margin-right: auto;
    }

    .dlm-ev-time {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut);
      flex-shrink: 0;
    }

    .dlm-ev-badge {
      font-size: 9px;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-weight: 700;
      flex-shrink: 0;
    }

    .dlm-ev-badge.ok {
      background: rgba(70, 241, 197, .1);
      color: var(--acc);
    }

    .dlm-ev-badge.err {
      background: rgba(255, 180, 171, .1);
      color: var(--red);
    }

    .dlm-inspect-body {
      min-height: 200px;
      overflow-y: auto;
      flex: 1;
      margin-bottom: 0;
    }

    .dlm-delivery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 12px;
    }

    .dlm-delivery-item {
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 10px 8px;
      text-align: center;
    }

    .dlm-delivery-icon {
      font-size: 16px;
      margin-bottom: 4px;
    }

    .dlm-delivery-name {
      font-size: 10px;
      color: var(--mut);
      font-weight: 600;
    }

    .dlm-delivery-status {
      font-size: 11px;
      font-weight: 700;
      margin-top: 2px;
    }

    .dlm-delivery-status.ok {
      color: var(--acc);
    }

    .dlm-delivery-status.err {
      color: var(--red);
    }

    .dlm-delivery-status.wait {
      color: var(--amber);
    }

    .dlm-code-wrap {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 12px;
      overflow: hidden;
    }

    .dlm-code-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 14px;
      background: rgba(39, 42, 49, .6);
      border-bottom: 1px solid rgba(255, 255, 255, .05);
    }

    .dlm-code-body {
      padding: 14px 18px;
      font-family: var(--font-mono);
      font-size: 12px;
      line-height: 1.8;
      color: #94a3b8;
      max-height: 220px;
      overflow: auto;
      white-space: pre;
      direction: ltr;
      tab-size: 2;
      margin: 0;
    }

    /* ── Attribution ── */
    .attr-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .attr-card {
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 16px;
      padding: 20px;
    }

    .attr-card-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 700;
      color: var(--wht);
      margin-bottom: 12px;
    }

    .attr-ids-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .attr-id-row {
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 10px 12px;
    }

    .attr-id-key {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--acc);
      min-width: 60px;
      flex-shrink: 0;
    }

    .attr-id-val {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--wht);
      flex: 1;
      word-break: break-all;
    }

    .attr-id-badge {
      font-size: 9px;
      padding: 2px 6px;
      border-radius: 4px;
      font-weight: 700;
      flex-shrink: 0;
    }

    .attr-id-badge.active {
      background: rgba(70, 241, 197, .1);
      color: var(--acc);
    }

    .attr-id-badge.empty {
      background: rgba(255, 255, 255, .05);
      color: var(--mut);
    }

    .attr-sim-btn {
      padding: 5px 12px;
      border-radius: 8px;
      border: 1px solid var(--bdr2);
      background: var(--sur3);
      color: var(--mut);
      font-family: var(--font-mono);
      font-size: 11px;
      cursor: pointer;
      transition: all .15s;
    }

    .attr-sim-btn:hover {
      border-color: rgba(70, 241, 197, .3);
      color: var(--acc);
    }

    .attr-input-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .attr-input-label {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut2);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .attr-input {
      background: rgba(39, 42, 49, .5);
      border: 1px solid rgba(255, 255, 255, .08);
      border-radius: 10px;
      padding: 10px 14px;
      color: var(--wht);
      font-family: var(--font-ui);
      font-size: 13px;
      outline: none;
      transition: all .15s;
      direction: rtl;
    }

    .attr-input:focus {
      border-color: rgba(70, 241, 197, .4);
      box-shadow: 0 0 0 3px rgba(70, 241, 197, .08);
    }

    .dedupe-sample {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 10px;
      padding: 12px;
      font-family: var(--font-mono);
      font-size: 11px;
      line-height: 1.8;
      color: #94a3b8;
      direction: ltr;
    }

    .attr-cookie-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 10px;
    }

    .attr-cookie-item {
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 12px;
    }

    .attr-cookie-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--wht);
      font-weight: 600;
      margin-bottom: 4px;
    }

    .attr-cookie-val {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--mut);
      word-break: break-all;
    }

    .attr-cookie-exp {
      font-size: 10px;
      color: var(--mut2);
      margin-top: 4px;
    }

    /* ── Server-Side ── */
    .ss-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .ss-config-col,
    .ss-monitor-col {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .ss-card {
      background: var(--sur2);
      border: 1px solid var(--bdr2);
      border-radius: 16px;
      padding: 20px;
    }

    .ss-card-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 700;
      color: var(--wht);
      margin-bottom: 14px;
    }

    .ss-required-badge {
      font-size: 9px;
      background: rgba(245, 158, 11, .1);
      color: var(--amber);
      border: 1px solid rgba(245, 158, 11, .2);
      padding: 2px 7px;
      border-radius: 4px;
      font-weight: 700;
      font-family: var(--font-mono);
      margin-right: auto;
    }

    .ss-conn-status {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
    }

    .ss-conn-status.ok {
      background: rgba(70, 241, 197, .06);
      border: 1px solid rgba(70, 241, 197, .2);
      color: var(--acc);
    }

    .ss-conn-status.err {
      background: rgba(255, 180, 171, .06);
      border: 1px solid rgba(255, 180, 171, .15);
      color: var(--red);
    }

    .ss-conn-status.testing {
      background: rgba(245, 158, 11, .06);
      border: 1px solid rgba(245, 158, 11, .2);
      color: var(--amber);
    }

    .ss-platforms-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .ss-plat-row {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 12px;
      padding: 12px 14px;
    }

    .ss-plat-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .ss-plat-info {
      flex: 1;
      min-width: 0;
    }

    .ss-plat-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--wht2);
    }

    .ss-plat-sub {
      font-size: 11px;
      color: var(--mut);
      margin-top: 2px;
    }

    .ss-plat-input {
      background: var(--sur2);
      border: 1px solid rgba(255, 255, 255, .06);
      border-radius: 8px;
      padding: 6px 10px;
      color: var(--mut);
      font-family: var(--font-mono);
      font-size: 11px;
      outline: none;
      width: 100%;
      margin-top: 6px;
    }

    .ss-toggle {
      position: relative;
      width: 36px;
      height: 20px;
      flex-shrink: 0;
    }

    .ss-toggle input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .ss-toggle-slider {
      position: absolute;
      inset: 0;
      background: var(--sur4);
      border-radius: 10px;
      cursor: pointer;
      transition: .3s;
    }

    .ss-toggle-slider:before {
      content: '';
      position: absolute;
      height: 14px;
      width: 14px;
      left: 3px;
      bottom: 3px;
      background: var(--mut);
      border-radius: 50%;
      transition: .3s;
    }

    .ss-toggle input:checked+.ss-toggle-slider {
      background: rgba(70, 241, 197, .2);
    }

    .ss-toggle input:checked+.ss-toggle-slider:before {
      transform: translateX(16px);
      background: var(--acc);
    }

    .ss-monitor-body {
      min-height: 300px;
      max-height: 400px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .ss-monitor-event {
      background: var(--sur3);
      border: 1px solid var(--bdr2);
      border-radius: 10px;
      padding: 12px 14px;
    }

    .ss-monitor-event-row1 {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .ss-monitor-ev-name {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--acc);
      background: rgba(70, 241, 197, .08);
      padding: 2px 7px;
      border-radius: 4px;
    }

    .ss-monitor-ev-id {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut2);
    }

    .ss-monitor-ev-val {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--wht);
      margin-right: auto;
    }

    .ss-monitor-ev-time {
      font-family: var(--font-mono);
      font-size: 9px;
      color: var(--mut);
      flex-shrink: 0;
    }

    .ss-delivery-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .ss-delivery-badge {
      font-size: 9px;
      padding: 2px 7px;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-weight: 700;
    }

    .ss-delivery-badge.ok {
      background: rgba(70, 241, 197, .1);
      color: var(--acc);
    }

    .ss-delivery-badge.err {
      background: rgba(255, 180, 171, .1);
      color: var(--red);
    }

    .ss-delivery-badge.skip {
      background: rgba(255, 255, 255, .05);
      color: var(--mut);
    }

    .ss-matrix-wrap {
      overflow-x: auto;
    }

    .ss-matrix-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }

    .ss-matrix-table th {
      padding: 8px 10px;
      text-align: right;
      color: var(--mut);
      font-weight: 600;
      border-bottom: 1px solid var(--bdr2);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: .5px;
    }

    .ss-matrix-table td {
      padding: 8px 10px;
      border-bottom: 1px solid var(--bdr3);
      color: var(--wht2);
      vertical-align: middle;
    }

    .ss-matrix-table tr:last-child td {
      border-bottom: none;
    }

    @media(max-width:900px) {

      .dlm-layout,
      .attr-grid,
      .ss-layout {
        grid-template-columns: 1fr;
      }

      .attr-card[style*="grid-column:span 2"] {
        grid-column: span 1 !important;
      }

      .dlm-stats-bar {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <script>
    // ===== STATE =====
    var S = { cms: null, platforms: [], events: [], platformEvents: {}, pixelIds: {}, lead: {} };

    // ===== SERVER SIDE CONFIG STATE =====
    var _pcSS = {
      enabled:    false,           // toggle ON/OFF
      serverUrl:  '',              // sGTM URL
      ga4Id:      '',              // GA4 Measurement ID (auto from S or manual)
      platforms:  [],              // ['meta','gads','snap','tiktok']
      events:     {},              // { meta:['purchase','lead'], gads:['purchase'], ... }
      pixelIds:   {},              // { meta:'XXXXXX', snap:'UUID', tiktok:'CXXX' }
      tokens:     {},              // { meta:'EAAxx', snap:'eyJ', tiktok:'XXX' }
      gadsConvId: '',              // AW-XXXXXXXXXX
      gadsLabels: {},              // { purchase:'AbCd_xxx', lead:'XyZw_xxx' }
      _pxOpen:    {}               // accordion open state per platform key
    };

    // SS platform definitions
    var _pcSS_PLATS = {
      meta:   { label:'Meta CAPI',         icon:'💙', idLabel:'Pixel ID',      tokLabel:'CAPI Access Token',       idPh:'1234567890123456', tokPh:'EAAxxxxx...',    hasToken:true  },
      gads:   { label:'Google Ads',         icon:'🎯', idLabel:'Conversion ID', tokLabel:'',                        idPh:'AW-1234567890',    tokPh:'',               hasToken:false },
      snap:   { label:'Snapchat CAPI',      icon:'👻', idLabel:'Pixel ID',      tokLabel:'CAPI Token',              idPh:'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx', tokPh:'eyJhbGci...', hasToken:true },
      tiktok: { label:'TikTok Events API',  icon:'🎵', idLabel:'Pixel ID',      tokLabel:'Events API Access Token', idPh:'CXXXXXXXXXXXXXXXX', tokPh:'xxxxxxxx...', hasToken:true }
    };

    // SS event definitions
    var _pcSS_EVENTS = [
      { key:'purchase',          label:'Purchase',          icon:'💰', forced:true  },
      { key:'add_to_cart',       label:'Add to Cart',       icon:'🛒', forced:false },
      { key:'initiate_checkout', label:'Initiate Checkout', icon:'💳', forced:false },
      { key:'view_content',      label:'View Content',      icon:'👁️', forced:false },
      { key:'page_view',         label:'Page View',         icon:'📄', forced:false },
      { key:'lead',              label:'Lead',              icon:'📋', forced:false },
      { key:'sign_up',           label:'Sign Up',           icon:'✍️', forced:false },
      { key:'search',            label:'Search',            icon:'🔍', forced:false }
    ];

    // ===== APP VIEW SWITCHING =====
    var APP_VIEWS = { overview: 'view-overview', pixels: 'view-pixels', gtmview: 'view-gtmview', projects: 'view-projects', serverside: 'view-serverside' };

    // Cached GTM JSON string for sidebar view
    var _cachedGtmStr = null;

    function switchAppView(viewKey, btnEl) {
      // Hide all views
      Object.values(APP_VIEWS).forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.classList.remove('active');
      });

      // Show target
      var target = document.getElementById(APP_VIEWS[viewKey]);
      if (target) target.classList.add('active');

      // Update sidebar active state
      document.querySelectorAll('#et-sidebar .sb-link').forEach(function (b) { b.classList.remove('active'); });
      if (btnEl) btnEl.classList.add('active');

      // If going to Health Monitor — render dashboard
      if (viewKey === 'health') { renderHealthDashboard(); }

      // If going to GTM view — show cached JSON or empty state
      if (viewKey === 'gtmview') {
        var gtmViewContent = document.getElementById('gtmViewContent');
        var gtmEmpty = document.getElementById('gtmEmptyState');
        if (_cachedGtmStr) {
          if (gtmEmpty) gtmEmpty.style.display = 'none';
          if (gtmViewContent) renderGtmSidebarView(gtmViewContent, _cachedGtmStr);
        } else {
          if (gtmEmpty) gtmEmpty.style.display = 'flex';
          if (gtmViewContent) gtmViewContent.innerHTML = '';
        }
      }

      // If going to My Projects view — load projects into the sidebar list
      if (viewKey === 'projects') {
        _loadProjectsIntoView();
      }
    }

    // Load projects into the My Projects sidebar view
    async function _loadProjectsIntoView() {
      var el = document.getElementById('projectsViewList');
      if (!el) return;
      el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-family:monospace;font-size:12px;">⏳ جاري التحميل...</div>';

      try {
        var attempts = 0;
        while (!db && attempts < 20) {
          await new Promise(function (r) { setTimeout(r, 300); });
          attempts++;
        }
        if (!db) {
          el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-size:13px;">⚠️ مش متصل بالسيرفر<br><span style="font-size:11px;color:var(--mut2);">تأكد من الإنترنت وحدّث الصفحة</span></div>';
          return;
        }
        if (!currentUser || !currentUser.id) {
          el.innerHTML = '<div style="text-align:center;padding:60px 20px;color:var(--mut);">'
            + '<span class="material-symbols-outlined" style="font-size:40px;opacity:.3;display:block;margin-bottom:10px;">lock</span>'
            + '<p style="font-size:14px;">سجّل دخولك عشان تشوف مشاريعك</p></div>';
          return;
        }

        var snap;
        try {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .orderBy('created_at', 'desc')
            .limit(30)
            .get();
        } catch (ie) {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .limit(30)
            .get();
        }

        if (snap.empty) {
          el.innerHTML = '<div style="text-align:center;padding:60px 20px;color:var(--mut);">'
            + '<span class="material-symbols-outlined" style="font-size:40px;opacity:.3;display:block;margin-bottom:10px;">folder_open</span>'
            + '<p style="font-size:14px;">مفيش مشاريع لحد دلوقتي</p>'
            + '<p style="font-size:12px;margin-top:6px;">اعمل Generate أول مشروع من <button onclick="switchAppView(\'pixels\',document.getElementById(\'sbPixels\'))" style="color:var(--acc);background:none;border:none;font-size:12px;font-weight:600;cursor:pointer;">Pixel Config</button></p>'
            + '</div>';
          return;
        }

        var projects = [];
        snap.forEach(function (doc) { var d = doc.data(); d.id = doc.id; projects.push(d); });
        window._etProjectsSb = projects;

        var html = '<div style="display:flex;flex-direction:column;gap:10px;">';
        projects.forEach(function (p, i) {
          var date = '—';
          try {
            if (p.created_at && typeof p.created_at.toDate === 'function') date = new Date(p.created_at.toDate()).toLocaleDateString('ar-EG');
            else if (p.created_at && p.created_at.seconds) date = new Date(p.created_at.seconds * 1000).toLocaleDateString('ar-EG');
            else if (p.created_at) date = new Date(p.created_at).toLocaleDateString('ar-EG');
          } catch (de) { }
          var platforms = (p.config && p.config.platforms) ? p.config.platforms.join(' · ') : (p.platforms || []).join(' · ') || '—';
          var events = (p.config && p.config.events) ? p.config.events.length + ' events' : (p.events_count || 0) + ' events';
          var cms = (p.config && p.config.cms) ? p.config.cms : (p.cms || '—');
          var hasGtm  = !!(p.gtmPublicId && p.snippetHead);
          var gtmBadge = hasGtm
            ? '<span style="background:rgba(70,241,197,.12);color:var(--acc);font-size:10px;padding:2px 8px;border-radius:5px;font-family:monospace;border:1px solid rgba(70,241,197,.2);">' + p.gtmPublicId + '</span>'
            : '<span style="background:rgba(245,158,11,.08);color:var(--amber);font-size:10px;padding:2px 8px;border-radius:5px;font-family:monospace;border:1px solid rgba(245,158,11,.2);">لم يتم رفعه</span>';
          html += '<div style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:12px;padding:16px 18px;transition:border-color .15s;" '
            + 'onmouseover="this.style.borderColor=\'rgba(70,241,197,.25)\'" '
            + 'onmouseout="this.style.borderColor=\'rgba(255,255,255,.07)\'">';
          html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;cursor:pointer;" onclick="_loadProjectFromSb(' + i + ')">';
          html += '<div style="font-weight:700;font-size:14px;color:var(--wht2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;">' + (p.client_name || p.name || 'Project #' + (i + 1)) + '</div>';
          html += '<div style="font-family:monospace;font-size:10px;color:var(--mut2);white-space:nowrap;">' + date + '</div>';
          html += '</div>';
          html += '<div style="display:flex;gap:5px;flex-wrap:wrap;cursor:pointer;" onclick="_loadProjectFromSb(' + i + ')">';
          html += '<span style="background:rgba(16,185,129,.08);color:var(--grn);font-size:10px;padding:2px 8px;border-radius:5px;font-family:monospace;border:1px solid rgba(16,185,129,.15);">' + cms + '</span>';
          html += '<span style="background:var(--acc-dim);color:var(--acc);font-size:10px;padding:2px 8px;border-radius:5px;font-family:monospace;">' + platforms + '</span>';
          html += '<span style="background:var(--sur3);color:var(--mut);font-size:10px;padding:2px 8px;border-radius:5px;font-family:monospace;">' + events + '</span>';
          html += gtmBadge;
          html += '</div>';
          // ── GTM snippet panel (collapsed by default) ──
          if (hasGtm) {
            html += '<div style="margin-top:10px;display:flex;gap:8px;">';
            html += '<button onclick="_toggleSbSnippet(' + i + ')" id="sb-snip-btn-' + i + '" style="flex:1;background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.25);color:var(--acc);font-family:var(--font-mono);font-size:11px;padding:6px 10px;border-radius:8px;cursor:pointer;">📋 عرض كود GTM</button>';
            html += '<button onclick="_loadProjectFromSb(' + i + ')" style="flex:1;background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-family:var(--font-ui);font-size:11px;padding:6px 10px;border-radius:8px;cursor:pointer;">⚡ تحميل</button>';
            html += '</div>';
            html += '<div id="sb-snip-' + i + '" style="display:none;margin-top:10px;">';
            html += '  <div style="font-size:10px;color:var(--mut);font-family:var(--font-mono);letter-spacing:.5px;margin-bottom:4px;">HEAD — داخل &lt;head&gt;</div>';
            html += '  <pre id="sb-snip-head-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:8px;font-family:var(--font-mono);font-size:10px;color:var(--wht2);max-height:120px;overflow:auto;direction:ltr;text-align:left;margin-bottom:6px;line-height:1.4;white-space:pre;">' + _esc(p.snippetHead || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'sb-snip-head-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:10px;padding:4px 8px;border-radius:6px;cursor:pointer;margin-bottom:10px;">📋 نسخ HEAD</button>';
            html += '  <div style="font-size:10px;color:var(--mut);font-family:var(--font-mono);letter-spacing:.5px;margin-bottom:4px;">BODY — بعد &lt;body&gt;</div>';
            html += '  <pre id="sb-snip-body-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:8px;font-family:var(--font-mono);font-size:10px;color:var(--wht2);max-height:100px;overflow:auto;direction:ltr;text-align:left;margin-bottom:6px;line-height:1.4;white-space:pre;">' + _esc(p.snippetBody || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'sb-snip-body-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:10px;padding:4px 8px;border-radius:6px;cursor:pointer;">📋 نسخ BODY</button>';
            html += '</div>';
          } else {
            html += '<div style="margin-top:10px;font-size:11px;color:var(--mut);cursor:pointer;" onclick="_loadProjectFromSb(' + i + ')">← اضغط لتحميل الكونفيج وإنشاء الـ Container</div>';
          }
          html += '</div>';
        });
        html += '</div>';
        el.innerHTML = html;

      } catch (e) {
        console.error('_loadProjectsIntoView error:', e);
        el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--red);font-size:13px;">خطأ في تحميل المشاريع<br><span style="font-size:11px;color:var(--mut);">' + (e.message || '') + '</span></div>';
      }
    }

    function _loadProjectFromSb(idx) {
      var p = window._etProjectsSb && window._etProjectsSb[idx];
      if (!p || !p.config) return;
      // Reuse the same loadProject logic — proxy through the existing function
      window._etProjects = window._etProjectsSb;
      if (typeof loadProject === 'function') loadProject(idx);
    }

    // Toggle the inline GTM-snippet panel for a sidebar project card.
    // Stops the click from bubbling up to the card's onclick (which loads the
    // project), so just showing code doesn't trigger a full config reload.
    function _toggleSbSnippet(idx) {
      try { if (window.event && window.event.stopPropagation) window.event.stopPropagation(); } catch (_) {}
      var wrap = document.getElementById('sb-snip-' + idx);
      var btn  = document.getElementById('sb-snip-btn-' + idx);
      if (!wrap) return;
      var isOpen = wrap.style.display !== 'none';
      wrap.style.display = isOpen ? 'none' : 'block';
      if (btn) btn.textContent = isOpen ? '📋 عرض كود GTM' : '✖ إخفاء كود GTM';
    }

    // Same toggle for the big "My Projects" main-page cards.
    function _toggleMpSnippet(idx) {
      try { if (window.event && window.event.stopPropagation) window.event.stopPropagation(); } catch (_) {}
      var wrap = document.getElementById('mp-snip-' + idx);
      var btn  = document.getElementById('mp-snip-btn-' + idx);
      if (!wrap) return;
      var isOpen = wrap.style.display !== 'none';
      wrap.style.display = isOpen ? 'none' : 'block';
      if (btn) btn.textContent = isOpen ? '📋 عرض كود GTM' : '✖ إخفاء كود GTM';
    }

    // Toggle the GTM snippet panel on the Dashboard project cards.
    function _toggleDpSnippet(idx) {
      try { if (window.event && window.event.stopPropagation) window.event.stopPropagation(); } catch (_) {}
      var wrap = document.getElementById('dp-snip-' + idx);
      var btn  = document.getElementById('dp-snip-btn-' + idx);
      if (!wrap) return;
      var isOpen = wrap.style.display !== 'none';
      wrap.style.display = isOpen ? 'none' : 'block';
      if (btn) btn.textContent = isOpen ? '📋 كود GTM' : '✖ إخفاء';
    }

    function renderGtmSidebarView(container, jsonStr) {
      if (!container) return;
      container.dataset.filled = jsonStr.length + '';
      var cms = window.S && S.cms ? (window.CMS && CMS[S.cms] ? CMS[S.cms].name : S.cms) : '—';
      var plats = window.S && S.platforms ? S.platforms.map(function (p) { return window.PM && PM[p] ? PM[p].name : p; }).join(' · ') : '—';
      var evCount = window.S && S.events ? S.events.length : 0;
      var lead = window.S && S.lead && S.lead.name ? S.lead.name : '—';
      container.innerHTML =
        '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:20px;">'
        + _pill('Client', lead, '#10b981')
        + _pill('CMS', cms, '#6366f1')
        + _pill('Platforms', plats, '#0ea5e9')
        + _pill('Events', evCount + ' events', '#46f1c5')
        + '</div>'
        + '<div class="cwrap">'
        + '<div class="ctbar"><div class="ctdots"><div class="ctdot" style="background:#ff5f57"></div><div class="ctdot" style="background:#febc2e"></div><div class="ctdot" style="background:#28c840"></div></div>'
        + '<span class="clang">gtm-container.json</span>'
        + '<div class="ctacts"><button class="cpybtn" onclick="(function(){try{navigator.clipboard.writeText(document.getElementById(\'gtmSbBody\').textContent);}catch(e){}})()">نسخ</button>'
        + '<button class="dlbtn" onclick="(function(){var b=new Blob([document.getElementById(\'gtmSbBody\').textContent],{type:\'application/json\'});var a=document.createElement(\'a\');a.href=URL.createObjectURL(b);a.download=\'gtm-container.json\';a.click();})()">⬇️ تحميل</button></div></div>'
        + '<div class="cbody" id="gtmSbBody" style="max-height:460px;overflow:auto;">' + _esc(jsonStr) + '</div>'
        + '</div>';
    }

    function _pill(lbl, val, c) {
      return '<div style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:12px;padding:12px 14px;">'
        + '<div style="font-size:10px;font-family:var(--font-mono);color:var(--mut);letter-spacing:1px;margin-bottom:3px;">' + lbl.toUpperCase() + '</div>'
        + '<div style="font-size:14px;font-weight:800;color:' + c + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + val + '</div>'
        + '</div>';
    }

    function _esc(s) {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ===== SVG ICONS (Official) =====
    var PLATFORM_SVGS = {
      // ── CMS Platforms ─────────────────────────────────────────
      salla: '<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><rect x="8" y="8" width="84" height="84" rx="20" stroke="#1B5E5A" stroke-width="7" fill="none"/><path d="M 30 67 Q 50 81 70 67" stroke="#1B5E5A" stroke-width="7" stroke-linecap="round" fill="none"/></svg>',
      zid: '<img src="https://www.f6s.com/content-resource/profiles/3554028_th1.jpg" style="width:22px;height:22px;border-radius:5px;object-fit:cover;" alt="زد" />',
      // ── Advertising Platforms ──────────────────────────────────
      meta: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><path d="M5 25c0-5.8 1.3-10.2 3.2-13.1C10.1 9 12.5 7.5 15 7.5c2 0 3.8.8 5.5 2.4 1.2 1.1 2.5 2.9 4.5 6.1 2-3.2 3.3-5 4.5-6.1 1.7-1.6 3.5-2.4 5.5-2.4 2.5 0 4.9 1.5 6.8 4.4C43.7 14.8 45 19.2 45 25c0 3.8-.7 7-2 9.4-1.6 2.9-3.9 4.6-6.3 4.6-1.5 0-2.9-.5-4.4-1.5-1.9-1.3-3.8-3.4-6.6-7.6-2.8 4.2-4.7 6.3-6.6 7.6-1.5 1-2.9 1.5-4.4 1.5-2.4 0-4.7-1.7-6.3-4.6C5.7 32 5 28.8 5 25z" fill="#1877F2"/></svg>',
      snapchat: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><rect width="50" height="50" rx="12" fill="#FFFC00"/><path d="M25 8c-5.6 0-9.5 3.8-9.5 9.3v1.5c-.6.3-1.4.4-2.1.2-.3 0-.4.1-.4.4 0 1.2 2.1 1.7 2.5 1.8.4 1.3 1.2 2.4 2.2 3.2-1.6.8-3.9 1.2-4.2 2.3 0 .2.2.4.4.4 2 .3 3.7 1.1 4.9 2.7.1.2.1.3-.1.4-1.5.6-3 .6-3 1.4 0 .5.7.7 1.3.7.9 0 1.8-.3 2.6-.6.5-.2.9-.2 1.3.1.8.6 1 1.7 1 2.7 0 .2.1.4.3.4 1 .1 2.1.1 2.8.1s1.8 0 2.8-.1c.2 0 .3-.2.3-.4 0-1 .2-2.1 1-2.7.4-.3.8-.3 1.3-.1.8.3 1.7.6 2.6.6.6 0 1.3-.2 1.3-.7 0-.8-1.5-.8-3-1.4-.2-.1-.2-.2-.1-.4 1.2-1.6 2.9-2.4 4.9-2.7.2 0 .4-.2.4-.4-.3-1.1-2.6-1.5-4.2-2.3 1-.8 1.8-1.9 2.2-3.2.4-.1 2.5-.6 2.5-1.8 0-.3-.1-.4-.4-.4-.7.2-1.5.1-2.1-.2v-1.5C34.5 11.8 30.6 8 25 8z" fill="#333"/></svg>',
      tiktok: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><rect width="50" height="50" rx="12" fill="#010101"/><path d="M34.5 14.5a7.5 7.5 0 01-7.5-7.5h-5v22.3c0 2.1-1.7 3.7-3.8 3.7a3.75 3.75 0 01-3.7-3.7c0-2.1 1.7-3.7 3.7-3.7.4 0 .7.1 1 .2V20a8.9 8.9 0 00-1-.1c-4.8 0-8.7 3.9-8.7 8.7s3.9 8.7 8.7 8.7 8.7-3.9 8.7-8.7V21.4a12.6 12.6 0 007.5 2.4v-5a7.4 7.4 0 01-4.9-4.3h4.9V14.5z" fill="white"/><path d="M37 14.5a7.5 7.5 0 01-7.5-7.5h-3v22.3c0 2.1-1.7 3.7-3.8 3.7a3.75 3.75 0 01-3.7-3.7c0-2.1 1.7-3.7 3.7-3.7.4 0 .7.1 1 .2V20a8.9 8.9 0 00-1-.1c-4.8 0-8.7 3.9-8.7 8.7s3.9 8.7 8.7 8.7 8.7-3.9 8.7-8.7V21.4a12.6 12.6 0 007.5 2.4v-5a7.6 7.6 0 01-2.9-4.3" fill="#69C9D0"/></svg>',
      google: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><path d="M25 8A17 17 0 1 0 25 42A17 17 0 1 0 25 8Z" fill="white"/><path d="M33.5 20H25v5h4.9c-.4 2.5-2.6 4.3-4.9 4.3a5.8 5.8 0 0 1 0-11.6c1.4 0 2.7.5 3.7 1.4l3.5-3.5A10.5 10.5 0 0 0 25 12.5a12.5 12.5 0 0 0 0 25c7 0 11.5-4.9 11.5-12 0-.8-.1-1.7-.2-2.5H33.5z" fill="#4285F4"/><path d="M14.3 27.9l-4 3.1A12.5 12.5 0 0 0 25 37.5v-5c-4.1 0-7.7-2.3-9.4-5.8l-.3.2z" fill="#34A853"/><path d="M10.3 18.6A12.5 12.5 0 0 0 12.5 31l4-3.1c-.7-1.4-1-3-1-4.9 0-2 .4-3.8 1.1-5.4l-4.1-3.2a12.4 12.4 0 0 0-2.2 4.2z" fill="#FBBC05"/><path d="M25 12.5c2.7 0 5.1 1 6.9 2.5l3.6-3.6A12.4 12.4 0 0 0 25 8a12.5 12.5 0 0 0-10.7 6l4.1 3.2A7.5 7.5 0 0 1 25 12.5z" fill="#EA4335"/></svg>',
      ga4: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><rect width="50" height="50" rx="12" fill="#F9AB0015"/><rect x="10" y="32" width="9" height="10" rx="4.5" fill="#E37400"/><rect x="21" y="22" width="9" height="20" rx="4.5" fill="#F9AB00"/><rect x="32" y="10" width="9" height="32" rx="4.5" fill="#E37400"/></svg>',
      twitter: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:22px;"><rect width="50" height="50" rx="12" fill="#000"/><path d="M28.3 22.5L38.5 11h-2.4l-8.9 10.3L20.3 11H12l10.7 15.5L12 39h2.4l9.3-10.8 7.4 10.8H39L28.3 22.5zm-3.3 3.8l-1.1-1.5L15.1 12.8h3.7l6.9 9.9 1.1 1.5 9 12.9h-3.7l-7.1-10.8z" fill="white"/></svg>'
    };

    // ===== UPDATE OVERVIEW AFTER GENERATE =====
    function refreshOverview() {
      var platMeta = {
        meta: { name: 'Meta Pixel', color: '#1877F2', bar: 85 },
        snapchat: { name: 'Snap Pixel', color: '#FFFC00', bar: 68 },
        tiktok: { name: 'TikTok Pixel', color: '#010101', bar: 92 },
        google: { name: 'Google Ads', color: '#4285F4', bar: 78 },
        ga4: { name: 'GA4', color: '#F9AB00', bar: 95 },
        twitter: { name: 'X / Twitter', color: '#000000', bar: 60 }
      };
      var grid = document.getElementById('ovPixelsGrid');
      if (!grid) return;
      grid.innerHTML = '';
      S.platforms.forEach(function (p) {
        var m = platMeta[p] || { name: p, color: 'var(--acc)', bar: 80 };
        var svgIcon = PLATFORM_SVGS[p] || '<span style="font-size:20px;">📡</span>';
        var rawId = (typeof S.pixelIds[p] === 'object' ? S.pixelIds[p].id : S.pixelIds[p]) || '';
        var isActive = !!(rawId && rawId.trim());
        var pid = isActive ? (rawId.length > 10 ? rawId.substring(0, 10) + '...' : rawId) : '—';
        grid.innerHTML += '<div class="ov-pixel-card">'
          + '<div class="ov-pixel-top">'
          + '<div class="ov-pixel-icon" style="background:' + m.color + '18;display:flex;align-items:center;justify-content:center;">' + svgIcon + '</div>'
          + '<span class="ov-pixel-badge ' + (isActive ? 'active' : 'pending') + '">' + (isActive ? 'ACTIVE' : 'PENDING') + '</span>'
          + '</div>'
          + '<div class="ov-pixel-name">' + m.name + '</div>'
          + '<div class="ov-pixel-id">ID: ' + pid + '</div>'
          + '<div class="ov-pixel-bar"><div class="ov-pixel-bar-fill" style="width:' + m.bar + '%;background:' + m.color + ';"></div></div>'
          + '</div>';
      });
      document.getElementById('overviewPixels').classList.add('show');
      document.getElementById('overviewBento').classList.add('show');

      // Bento counts
      var tagEl = document.getElementById('bentoTagCount');
      if (tagEl) tagEl.textContent = S.platforms.length || 0;
      var evCountEl = document.getElementById('bentoEventsCount');
      if (evCountEl) evCountEl.textContent = S.events.length || 0;

      // Config score (based on how complete the setup is)
      var hasAllIds = S.platforms.every(function (p) { return S.pixelIds[p]; });
      var configScore = hasAllIds ? '100%' : Math.round((Object.keys(S.pixelIds).filter(function (k) { return S.pixelIds[k]; }).length / Math.max(S.platforms.length, 1)) * 100) + '%';
      var scoreEl = document.getElementById('bentoConfigScore');
      if (scoreEl) scoreEl.textContent = configScore;
      var labelEl = document.getElementById('bentoConfigLabel');
      if (labelEl) labelEl.textContent = hasAllIds ? 'Ready to Deploy ✓' : 'Add Pixel IDs to complete setup';

      // Dynamic Config Summary
      var cms = S.cms ? (CMS[S.cms] ? CMS[S.cms].name : S.cms) : '—';
      var platNames = S.platforms.map(function (p) { return PM[p] ? PM[p].name : p; });
      var cmsLbl = document.getElementById('bentoCmsLabel');
      var platLbl = document.getElementById('bentoPlatLabel');
      var evLbl = document.getElementById('bentoEventsLabel');
      if (cmsLbl) cmsLbl.textContent = cms;
      if (platLbl) platLbl.textContent = S.platforms.length + ' منصة' + (platNames.length ? ' — ' + platNames.join(' · ') : '');
      if (evLbl) evLbl.textContent = S.events.length + ' حدث مُعدّ للتتبع';
    }

    // ===== DATA =====
    var CMS = {
      salla: { name: 'سلة', note: 'سلة بتدعم GTM Native وفيها Data Layer تلقائي' },
      zid: { name: 'زد', note: 'زد بتدعم GTM ولديها Data Layer events جاهزة' },
      woocommerce: { name: 'WooCommerce', note: 'محتاج Plugin: GTM4WP أو DataLayer WooCommerce' },
      shopify: { name: 'Shopify', note: 'بتحتاج GTM في theme.liquid أو Elevar App' },
      custom: { name: 'Custom Site', note: 'محتاج Data Layer implementation يدوي في الكود' }
    };

    var GA4 = {
      view_item:        { label: 'View Item (Product Page)', score: 6,  req: ['currency','value','items'], opt: [], ip: ['item_id','item_name','item_brand','item_category','price','quantity'] },
      add_to_cart:      { label: 'Add to Cart',              score: 8,  req: ['currency','value','items'], opt: [], ip: ['item_id','item_name','item_brand','item_category','price','quantity'] },
      begin_checkout:   { label: 'Begin Checkout',           score: 9,  req: ['currency','value','items'], opt: ['coupon'], ip: ['item_id','item_name','price','quantity'] },
      purchase:         { label: 'Purchase',                 score: 10, req: ['transaction_id','currency','value','items'], opt: ['affiliation','coupon','shipping','tax'], ip: ['item_id','item_name','item_brand','item_category','coupon','discount','price','quantity'] },
      remove_from_cart: { label: 'Remove from Cart',         score: 5,  req: ['currency','value','items'], opt: [], ip: ['item_id','item_name','price','quantity'] },
      view_cart:        { label: 'View Cart',                score: 6,  req: ['currency','value'],         opt: [], ip: [] },
      add_to_wishlist:  { label: 'Add to Wishlist',          score: 5,  req: ['currency','value','items'], opt: [], ip: ['item_id','item_name','price'] },
      view_item_list:   { label: 'View Item List',           score: 4,  req: ['items'],                   opt: [], ip: ['item_id','item_name','price'] },
      login:            { label: 'Login / Sign In',          score: 7,  req: [],                          opt: [], ip: [] }
    };

    var PMAP = {
      meta: { view_item: 'ViewContent', add_to_cart: 'AddToCart', remove_from_cart: null, view_cart: null, begin_checkout: 'InitiateCheckout', purchase: 'Purchase', add_to_wishlist: 'AddToWishlist', view_item_list: null, login: null },
      snapchat: { view_item: 'VIEW_CONTENT', add_to_cart: 'ADD_CART', remove_from_cart: null, view_cart: null, begin_checkout: 'START_CHECKOUT', purchase: 'PURCHASE', add_to_wishlist: 'SAVE', view_item_list: null, login: null },
      tiktok: { view_item: 'ViewContent', add_to_cart: 'AddToCart', remove_from_cart: null, view_cart: null, begin_checkout: 'InitiateCheckout', purchase: 'Purchase', add_to_wishlist: 'AddToWishlist', view_item_list: null, login: null },
      google: { view_item: 'view_item', add_to_cart: 'add_to_cart', remove_from_cart: 'remove_from_cart', view_cart: 'view_cart', begin_checkout: 'begin_checkout', purchase: 'purchase', add_to_wishlist: 'add_to_wishlist', view_item_list: 'view_item_list', login: 'login' },
      twitter: { view_item: 'ViewContent', add_to_cart: 'AddToCart', remove_from_cart: null, view_cart: null, begin_checkout: 'InitiateCheckout', purchase: 'Purchase', add_to_wishlist: null, view_item_list: null, login: null }
      ,
      ga4: { view_item: 'view_item', add_to_cart: 'add_to_cart', remove_from_cart: 'remove_from_cart', view_cart: 'view_cart', begin_checkout: 'begin_checkout', purchase: 'purchase', add_to_wishlist: 'add_to_wishlist', view_item_list: 'view_item_list', login: 'login' }
      ,
      // Mixpanel — uses canonical Mixpanel event names (Tracking Plan compliant)
      mixpanel: { view_item: 'Product Viewed', add_to_cart: 'Product Added', remove_from_cart: 'Product Removed', view_cart: 'Cart Viewed', begin_checkout: 'Checkout Started', purchase: 'Order Completed', add_to_wishlist: 'Product Added to Wishlist', view_item_list: 'Product List Viewed', login: 'Signed In' }
    };

    var PM = {
      meta: { name: 'Meta', icon: '📘' },
      snapchat: { name: 'Snapchat', icon: '👻' },
      tiktok: { name: 'TikTok', icon: '🎵' },
      google: { name: 'Google Ads', icon: '🔍' },
      twitter: { name: 'X/Twitter', icon: '𝕏' },
      ga4: { name: 'Google Analytics 4', icon: '📊' },
      mixpanel: { name: 'Mixpanel', icon: '📈' }
    };

    var HINTS = {
      meta: 'Business Manager → Events Manager → Pixel ID',
      snapchat: 'Snap Ads Manager → Assets → Pixels',
      tiktok: 'TikTok Ads Manager → Assets → Events',
      google: 'Google Ads → Goals → Conversions → Conversion ID',
      ga4: 'Google Analytics → Admin → Data Streams → Measurement ID',
      twitter: 'X Ads Manager → Events Manager',
      mixpanel: 'Mixpanel → Project Settings → Project Token (32-char hex)'
    };

    // GTM tag HTML - hardcoded per platform/event to avoid JS syntax errors
    var TAGHTML = {
      meta: {
        ViewContent: "[S]\nfbq('track', 'ViewContent', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_ids: ['{{DL - item_id}}'],\n  content_name: '{{DL - item_name}}',\n  content_type: 'product'\n}, { eventID: '{{DL - event_id}}' });\n[/S]",
        AddToCart: "[S]\nfbq('track', 'AddToCart', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_ids: ['{{DL - item_id}}'],\n  content_name: '{{DL - item_name}}',\n  content_type: 'product'\n}, { eventID: '{{DL - event_id}}' });\n[/S]",
        InitiateCheckout: "[S]\nfbq('track', 'InitiateCheckout', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_type: 'product',\n  num_items: {{DL - num_items}}\n}, { eventID: '{{DL - event_id}}' });\n[/S]",
        AddPaymentInfo: "[S]\nfbq('track', 'AddPaymentInfo', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_type: 'product'\n}, { eventID: '{{DL - event_id}}' });\n[/S]",
        Purchase: "[S]\nfbq('track', 'Purchase', {\n  currency: '{{DL - currency}}',\n  value: {{DL - value}},\n  content_ids: ['{{DL - item_id}}'],\n  content_name: '{{DL - item_name}}',\n  content_type: 'product',\n  num_items: {{DL - num_items}}\n}, {\n  eventID: '{{DL - event_id}}',\n  userData: {\n    em: '{{DL - customer.emailHashed}}',\n    ph: '{{DL - customer.phoneHashed}}',\n    fn: '{{DL - customer.firstNameHashed}}',\n    ln: '{{DL - customer.lastNameHashed}}'\n  }\n});\n[/S]",
        Search: "[S]\nfbq('track', 'Search', {}, { eventID: '{{DL - event_id}}' });\n[/S]",
        AddToWishlist: "[S]\nfbq('track', 'AddToWishlist', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_ids: ['{{DL - item_id}}'],\n  content_name: '{{DL - item_name}}',\n  content_type: 'product'\n}, { eventID: '{{DL - event_id}}' });\n[/S]",
        CompleteRegistration: "[S]\nfbq('track', 'CompleteRegistration', {});\n[/S]"
      },
      snapchat: {
        VIEW_CONTENT: "[S]\nsnaptr('track', 'VIEW_CONTENT', {\n  currency: '{{DL - currency}}',\n  price: {{DL - price}},\n  item_ids: ['{{DL - item_id}}'],\n  item_category: '{{DL - item_category}}',\n  client_dedup_id: '{{DL - event_id}}'\n});\n[/S]",
        ADD_CART: "[S]\nsnaptr('track', 'ADD_CART', {\n  currency: '{{DL - currency}}',\n  price: {{DL - price}},\n  item_ids: ['{{DL - item_id}}'],\n  item_category: '{{DL - item_category}}',\n  number_items: {{DL - num_items}},\n  client_dedup_id: '{{DL - event_id}}'\n});\n[/S]",
        START_CHECKOUT: "[S]\nsnaptr('track', 'START_CHECKOUT', {\n  currency: '{{DL - currency}}',\n  price: {{DL - price}},\n  item_ids: ['{{DL - item_id}}'],\n  number_items: {{DL - num_items}},\n  client_dedup_id: '{{DL - event_id}}'\n});\n[/S]",
        ADD_BILLING: "[S]\nsnaptr('track', 'ADD_BILLING', {\n  currency: '{{DL - currency}}',\n  price: {{DL - price}},\n  client_dedup_id: '{{DL - event_id}}'\n});\n[/S]",
        PURCHASE: "[S]\nsnaptr('track', 'PURCHASE', {\n  currency: '{{DL - currency}}',\n  price: {{DL - value}},\n  transaction_id: '{{DL - transaction_id}}',\n  item_ids: ['{{DL - item_id}}'],\n  number_items: {{DL - num_items}},\n  client_dedup_id: '{{DL - event_id}}'\n});\nsnaptr('set', 'user_hashed_email', '{{DL - customer.emailHashed}}');\nsnaptr('set', 'user_hashed_phone_number', '{{DL - customer.phoneHashed}}');\n[/S]",
        SEARCH: "[S]\nsnaptr('track', 'SEARCH', { client_dedup_id: '{{DL - event_id}}' });\n[/S]",
        SAVE: "[S]\nsnaptr('track', 'SAVE', {\n  currency: '{{DL - currency}}',\n  price: {{DL - price}},\n  item_ids: ['{{DL - item_id}}'],\n  item_category: '{{DL - item_category}}',\n  client_dedup_id: '{{DL - event_id}}'\n});\n[/S]",
        SIGN_UP: "[S]\nsnaptr('track', 'SIGN_UP', {});\n[/S]"
      },
      tiktok: {
        ViewContent: "[S]\nttq.track('ViewContent', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_id: '{{DL - item_id}}',\n  content_name: '{{DL - item_name}}',\n  content_type: 'product',\n  quantity: {{DL - quantity}}\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        AddToCart: "[S]\nttq.track('AddToCart', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_id: '{{DL - item_id}}',\n  content_name: '{{DL - item_name}}',\n  content_type: 'product',\n  quantity: {{DL - quantity}}\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        InitiateCheckout: "[S]\nttq.track('InitiateCheckout', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_type: 'product',\n  quantity: {{DL - num_items}}\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        AddPaymentInfo: "[S]\nttq.track('AddPaymentInfo', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_type: 'product'\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        Purchase: "[S]\nttq.identify({ email: '{{DL - customer.emailHashed}}', phone_number: '{{DL - customer.phoneHashed}}' });\nttq.track('PlaceAnOrder', {\n  currency: '{{DL - currency}}',\n  value: {{DL - value}},\n  content_id: '{{DL - item_id}}',\n  content_name: '{{DL - item_name}}',\n  content_type: 'product',\n  quantity: {{DL - num_items}}\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        Search: "[S]\nttq.track('Search', {}, { event_id: '{{DL - event_id}}' });\n[/S]",
        AddToWishlist: "[S]\nttq.track('AddToWishlist', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  content_id: '{{DL - item_id}}',\n  content_name: '{{DL - item_name}}',\n  content_type: 'product'\n}, { event_id: '{{DL - event_id}}' });\n[/S]",
        CompleteRegistration: "[S]\nttq.track('CompleteRegistration', {});\n[/S]"
      },
      google: {
        view_item: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_view_item}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  transaction_id: '{{DL - event_id}}'\n});\n[/S]",
        add_to_cart: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_add_to_cart}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  transaction_id: '{{DL - event_id}}'\n});\n[/S]",
        remove_from_cart: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        view_cart: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        begin_checkout: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_begin_checkout}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  transaction_id: '{{DL - event_id}}'\n});\n[/S]",
        add_shipping_info: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        add_payment_info: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_add_payment_info}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  transaction_id: '{{DL - event_id}}'\n});\n[/S]",
        purchase: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_purchase}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - value}},\n  transaction_id: '{{DL - transaction_id}}'\n});\n[/S]",
        refund: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        search: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        add_to_wishlist: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_add_to_wishlist}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  transaction_id: '{{DL - event_id}}'\n});\n[/S]",
        view_item_list: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        select_item: "[S]\ngtag('event', 'page_view', {});\n[/S]",
        sign_up: "[S]\ngtag('event', 'conversion', {\n  send_to: '{{DL - google_conversion_id}}/{{DL - google_label_sign_up}}'\n});\n[/S]",
        login: "[S]\ngtag('event', 'page_view', {});\n[/S]"
      },
      ga4: {
        view_item: "[S]\ngtag('event', 'view_item', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        add_to_cart: "[S]\ngtag('event', 'add_to_cart', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        remove_from_cart: "[S]\ngtag('event', 'remove_from_cart', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        view_cart: "[S]\ngtag('event', 'view_cart', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        begin_checkout: "[S]\ngtag('event', 'begin_checkout', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        add_shipping_info: "[S]\ngtag('event', 'add_shipping_info', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  shipping_tier: '{{DL - shipping_tier}}'\n});\n[/S]",
        add_payment_info: "[S]\ngtag('event', 'add_payment_info', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  payment_type: '{{DL - payment_type}}'\n});\n[/S]",
        purchase: "[S]\ngtag('set', 'user_data', {\n  email: '{{DL - customer.emailHashed}}',\n  phone_number: '{{DL - customer.phoneHashed}}'\n});\ngtag('event', 'purchase', {\n  transaction_id: '{{DL - transaction_id}}',\n  currency: '{{DL - currency}}',\n  value: {{DL - value}},\n  items: {{DL - items}},\n  user_id: '{{DL - user_id}}'\n});\n[/S]",
        refund: "[S]\ngtag('event', 'refund', {\n  transaction_id: '{{DL - transaction_id}}',\n  currency: '{{DL - currency}}'\n});\n[/S]",
        search: "[S]\ngtag('event', 'search', {\n  search_term: '{{DL - search_term}}'\n});\n[/S]",
        add_to_wishlist: "[S]\ngtag('event', 'add_to_wishlist', {\n  currency: '{{DL - currency}}',\n  value: {{DL - price}},\n  items: {{DL - items}}\n});\n[/S]",
        view_item_list: "[S]\ngtag('event', 'view_item_list', {\n  item_list_name: '{{DL - item_list_name}}',\n  items: {{DL - items}}\n});\n[/S]",
        select_item: "[S]\ngtag('event', 'select_item', {\n  items: {{DL - items}}\n});\n[/S]",
        sign_up: "[S]\ngtag('event', 'sign_up', {\n  method: '{{DL - method}}'\n});\n[/S]",
        login: "[S]\ngtag('event', 'login', {\n  method: '{{DL - method}}'\n});\n[/S]"
      },
      twitter: {
        ViewContent: "[S]\ntwq('event', 'tw-ViewContent', {\n  value: {{DL - price}},\n  currency: '{{DL - currency}}',\n  conversion_id: '{{DL - event_id}}'\n});\n[/S]",
        AddToCart: "[S]\ntwq('event', 'tw-AddToCart', {\n  value: {{DL - price}},\n  currency: '{{DL - currency}}',\n  conversion_id: '{{DL - event_id}}'\n});\n[/S]",
        InitiateCheckout: "[S]\ntwq('event', 'tw-InitiateCheckout', {\n  value: {{DL - price}},\n  currency: '{{DL - currency}}',\n  conversion_id: '{{DL - event_id}}'\n});\n[/S]",
        Purchase: "[S]\ntwq('event', 'tw-Purchase', {\n  value: {{DL - value}},\n  currency: '{{DL - currency}}',\n  conversion_id: '{{DL - transaction_id}}'\n});\n[/S]",
        Search: "[S]\ntwq('event', 'tw-Search', {});\n[/S]",
        SignUp: "[S]\ntwq('event', 'tw-SignUp', {});\n[/S]"
      },

      // ── Mixpanel — uses external_id as distinct_id, hashed PII via people.set ──
      // ⚠️ Each tag is self-guarded (typeof mixpanel !== 'undefined') so the SDK can be
      //    initialized once via the Mixpanel | Base Code tag. identify+people.set are
      //    only emitted when the user is logged in (external_id present).
      mixpanel: {
        "Product Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  mixpanel.track('Product Viewed', {\n    currency: '{{DL - currency}}',\n    value: {{DL - price}},\n    item_id: '{{DL - item_id}}',\n    item_name: '{{DL - item_name}}',\n    item_brand: '{{DL - item_brand}}',\n    item_category: '{{DL - item_category}}',\n    price: {{DL - price}},\n    external_id: _ext,\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Product Added": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  mixpanel.track('Product Added', {\n    currency: '{{DL - currency}}',\n    value: {{DL - price}},\n    item_id: '{{DL - item_id}}',\n    item_name: '{{DL - item_name}}',\n    quantity: {{DL - quantity}},\n    external_id: _ext,\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Product Removed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product Removed', {\n    currency: '{{DL - currency}}',\n    item_id: '{{DL - item_id}}',\n    quantity: {{DL - quantity}},\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Cart Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Cart Viewed', {\n    currency: '{{DL - currency}}',\n    value: {{DL - price}},\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Checkout Started": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Checkout Started', {\n    currency: '{{DL - currency}}',\n    value: {{DL - price}},\n    num_items: {{DL - num_items}},\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Order Completed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  if (_ext && mixpanel.people) {\n    mixpanel.people.set({\n      $email:              '{{DL - customer.emailHashed}}',\n      $phone:              '{{DL - customer.phoneHashed}}',\n      $first_name_hashed:  '{{DL - customer.firstNameHashed}}',\n      $last_name_hashed:   '{{DL - customer.lastNameHashed}}',\n      external_id:         _ext\n    });\n    mixpanel.people.track_charge({{DL - value}}, { transaction_id: '{{DL - transaction_id}}', currency: '{{DL - currency}}' });\n  }\n  mixpanel.track('Order Completed', {\n    transaction_id: '{{DL - transaction_id}}',\n    currency: '{{DL - currency}}',\n    revenue: {{DL - value}},\n    value: {{DL - value}},\n    num_items: {{DL - num_items}},\n    products: {{DL - items}},\n    external_id: _ext,\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Product Added to Wishlist": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product Added to Wishlist', {\n    currency: '{{DL - currency}}',\n    value: {{DL - price}},\n    item_id: '{{DL - item_id}}',\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Product List Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product List Viewed', {\n    item_list_name: '{{DL - item_list_name}}',\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Products Searched": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Products Searched', {\n    search_term: '{{DL - search_term}}',\n    external_id: '{{Cookie - external_id}}',\n    $insert_id: '{{DL - event_id}}'\n  });\n}\n[/S]",
        "Signed In": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) {\n    mixpanel.identify(_ext);\n    if (mixpanel.people) {\n      mixpanel.people.set({\n        $email:             '{{DL - customer.emailHashed}}',\n        $phone:             '{{DL - customer.phoneHashed}}',\n        $first_name_hashed: '{{DL - customer.firstNameHashed}}',\n        $last_name_hashed:  '{{DL - customer.lastNameHashed}}',\n        external_id:        _ext,\n        $last_login:        new Date().toISOString()\n      });\n    }\n  }\n  mixpanel.track('Signed In', { method: '{{DL - method}}', external_id: _ext });\n}\n[/S]",
        "Signed Up": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) {\n    mixpanel.identify(_ext);\n    mixpanel.alias(_ext);\n    if (mixpanel.people) {\n      mixpanel.people.set({\n        $email:             '{{DL - customer.emailHashed}}',\n        $phone:             '{{DL - customer.phoneHashed}}',\n        external_id:        _ext,\n        $created:           new Date().toISOString()\n      });\n    }\n  }\n  mixpanel.track('Signed Up', { method: '{{DL - method}}', external_id: _ext });\n}\n[/S]"
      }
    };

    // ═══════════════════════════════════════════════════════════════════
    // SALLA_TAGHTML — Platform tags using raw per-event Salla DLV paths
    // ═══════════════════════════════════════════════════════════════════
    // ⚠️ CRITICAL: The Salla bridge pushes the ORIGINAL event FIRST (_origPush(raw))
    //    THEN pushes the GA4-normalized event. This means when a trigger fires on
    //    a native Salla event (addToCart, Product Viewed, ...), ONLY the raw Salla
    //    paths exist in the data layer. Generic vars like {{DL - price}} (ecommerce.price)
    //    do NOT exist yet. These per-event vars fix this by using the correct raw paths.
    // ═══════════════════════════════════════════════════════════════════
    var SALLA_TAGHTML = {

      // ── Meta Pixel ──────────────────────────────────────────────────
      meta: {
        // view_item → Product Viewed → raw path: 0.*
        ViewContent: "[S]\nfbq('track', 'ViewContent', {\n  currency: '{{Product Viewed - product_currency}}',\n  value: {{Product Viewed - product_price}},\n  content_ids: ['{{Product Viewed - product_id}}'],\n  content_name: '{{Product Viewed - product_name}}',\n  content_type: 'product'\n});\n[/S]",
        // add_to_cart → addToCart → raw path: ecommerce.add.products.0.*
        AddToCart: "[S]\nfbq('track', 'AddToCart', {\n  currency: '{{addToCart - currencyCode}}',\n  value: {{addToCart - product_price}},\n  content_ids: ['{{addToCart - product_id}}'],\n  content_name: '{{addToCart - product_name}}',\n  content_type: 'product'\n}, { eventID: '{{addToCart - event_id}}' });\n[/S]",
        // begin_checkout → cart::submitted → no product data in raw push
        InitiateCheckout: "[S]\nfbq('track', 'InitiateCheckout', {\n  content_type: 'product'\n});\n[/S]",
        // purchase → purchase → raw path: ecommerce.purchase.* + customer.*
        Purchase: "[S]\nfbq('track', 'Purchase', {\n  currency: '{{purchase - currencyCode}}',\n  value: {{purchase - actionField_revenue}},\n  content_ids: ['{{purchase - product_id}}'],\n  content_name: '{{purchase - product_name}}',\n  content_type: 'product'\n}, {\n  eventID: '{{purchase - event_id}}',\n  userData: {\n    em: '{{purchase - customer_emailHashed}}',\n    ph: '{{purchase - customer_phoneHashed}}',\n    fn: '{{purchase - customer_firstNameHashed}}',\n    ln: '{{purchase - customer_lastNameHashed}}'\n  }\n});\n[/S]",
        // add_to_wishlist → Product Added to Wishlist → no product data
        AddToWishlist: "[S]\nfbq('track', 'AddToWishlist', {\n  content_type: 'product'\n});\n[/S]",
        // login → Signed In
        CompleteRegistration: "[S]\nfbq('track', 'CompleteRegistration', {});\n[/S]",
        Search: "[S]\nfbq('track', 'Search', {});\n[/S]",
        AddPaymentInfo: "[S]\nfbq('track', 'AddPaymentInfo', {\n  content_type: 'product'\n});\n[/S]"
      },

      // ── Snapchat Pixel ───────────────────────────────────────────────
      snapchat: {
        // view_item → Product Viewed → raw path: 0.*
        VIEW_CONTENT: "[S]\nsnaptr('track', 'VIEW_CONTENT', {\n  currency: '{{Product Viewed - product_currency}}',\n  price: {{Product Viewed - product_price}},\n  item_ids: ['{{Product Viewed - product_id}}'],\n  item_category: '{{Product Viewed - product_category}}'\n});\n[/S]",
        // add_to_cart → addToCart → raw path: ecommerce.add.products.0.*
        ADD_CART: "[S]\nsnaptr('track', 'ADD_CART', {\n  currency: '{{addToCart - currencyCode}}',\n  price: {{addToCart - product_price}},\n  item_ids: ['{{addToCart - product_id}}'],\n  client_dedup_id: '{{addToCart - event_id}}'\n});\n[/S]",
        // begin_checkout → cart::submitted → no product data
        START_CHECKOUT: "[S]\nsnaptr('track', 'START_CHECKOUT', {\n  content_type: 'product'\n});\n[/S]",
        ADD_BILLING: "[S]\nsnaptr('track', 'ADD_BILLING', {\n  content_type: 'product'\n});\n[/S]",
        // purchase → purchase → raw path: ecommerce.purchase.*
        PURCHASE: "[S]\nsnaptr('track', 'PURCHASE', {\n  currency: '{{purchase - currencyCode}}',\n  price: {{purchase - actionField_revenue}},\n  transaction_id: '{{purchase - actionField_id}}',\n  item_ids: ['{{purchase - product_id}}'],\n  client_dedup_id: '{{purchase - event_id}}'\n});\n[/S]",
        // add_to_wishlist → Product Added to Wishlist → no product data
        SAVE: "[S]\nsnaptr('track', 'SAVE', {\n  content_type: 'product'\n});\n[/S]",
        SIGN_UP: "[S]\nsnaptr('track', 'SIGN_UP', {});\n[/S]",
        SEARCH: "[S]\nsnaptr('track', 'SEARCH', {});\n[/S]"
      },

      // ── TikTok Pixel ─────────────────────────────────────────────────
      tiktok: {
        // view_item → Product Viewed → raw path: 0.*
        ViewContent: "[S]\nttq.track('ViewContent', {\n  currency: '{{Product Viewed - product_currency}}',\n  value: {{Product Viewed - product_price}},\n  content_id: '{{Product Viewed - product_id}}',\n  content_name: '{{Product Viewed - product_name}}',\n  content_type: 'product'\n});\n[/S]",
        // add_to_cart → addToCart → raw path: ecommerce.add.products.0.*
        AddToCart: "[S]\nttq.track('AddToCart', {\n  currency: '{{addToCart - currencyCode}}',\n  value: {{addToCart - product_price}},\n  content_id: '{{addToCart - product_id}}',\n  content_name: '{{addToCart - product_name}}',\n  content_type: 'product',\n  quantity: {{addToCart - product_quantity}}\n}, { event_id: '{{addToCart - event_id}}' });\n[/S]",
        // begin_checkout → cart::submitted → no product data
        InitiateCheckout: "[S]\nttq.track('InitiateCheckout', {\n  content_type: 'product'\n});\n[/S]",
        AddPaymentInfo: "[S]\nttq.track('AddPaymentInfo', {\n  content_type: 'product'\n});\n[/S]",
        // purchase → purchase → raw path: ecommerce.purchase.*
        Purchase: "[S]\nttq.track('PlaceAnOrder', {\n  currency: '{{purchase - currencyCode}}',\n  value: {{purchase - actionField_revenue}},\n  content_id: '{{purchase - product_id}}',\n  content_name: '{{purchase - product_name}}',\n  content_type: 'product'\n}, { event_id: '{{purchase - event_id}}' });\n[/S]",
        // add_to_wishlist → Product Added to Wishlist → no product data
        AddToWishlist: "[S]\nttq.track('AddToWishlist', {\n  content_type: 'product'\n});\n[/S]",
        Search: "[S]\nttq.track('Search', {});\n[/S]",
        CompleteRegistration: "[S]\nttq.track('CompleteRegistration', {});\n[/S]"
      },

      // ── Mixpanel — uses Salla raw event paths (Product Viewed, addToCart, purchase) ──
      // ⚠️ external_id في سلة بييجي من customer.external_id (موجود لمّا العميل logged in)
      // ⚠️ كل PII (email/phone/first_name/last_name) سلة بتبعتها هاش جاهز SHA-256
      mixpanel: {
        // view_item → Product Viewed → raw path: 0.*
        "Product Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  mixpanel.track('Product Viewed', {\n    currency: '{{Product Viewed - product_currency}}',\n    value: {{Product Viewed - product_price}},\n    item_id: '{{Product Viewed - product_id}}',\n    item_name: '{{Product Viewed - product_name}}',\n    item_category: '{{Product Viewed - product_category}}',\n    price: {{Product Viewed - product_price}},\n    external_id: _ext\n  });\n}\n[/S]",
        // add_to_cart → addToCart → raw path: ecommerce.add.products.0.*
        "Product Added": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  mixpanel.track('Product Added', {\n    currency: '{{addToCart - currencyCode}}',\n    value: {{addToCart - product_price}},\n    item_id: '{{addToCart - product_id}}',\n    item_name: '{{addToCart - product_name}}',\n    quantity: {{addToCart - product_quantity}},\n    external_id: _ext,\n    $insert_id: '{{addToCart - event_id}}'\n  });\n}\n[/S]",
        // begin_checkout → cart::submitted (no product data in raw push)
        "Checkout Started": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Checkout Started', { external_id: '{{Cookie - external_id}}' });\n}\n[/S]",
        // purchase → purchase → raw path: ecommerce.purchase.* + customer.*
        "Order Completed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{Cookie - external_id}}' || '{{purchase - customer_external_id}}';\n  if (_ext) { mixpanel.identify(_ext); }\n  if (_ext && mixpanel.people) {\n    mixpanel.people.set({\n      $email:              '{{purchase - customer_emailHashed}}',\n      $phone:              '{{purchase - customer_phoneHashed}}',\n      $first_name_hashed:  '{{purchase - customer_firstNameHashed}}',\n      $last_name_hashed:   '{{purchase - customer_lastNameHashed}}',\n      external_id:         _ext\n    });\n    mixpanel.people.track_charge({{purchase - actionField_revenue}}, {\n      transaction_id: '{{purchase - actionField_id}}',\n      currency: '{{purchase - currencyCode}}'\n    });\n  }\n  mixpanel.track('Order Completed', {\n    transaction_id: '{{purchase - actionField_id}}',\n    currency: '{{purchase - currencyCode}}',\n    revenue: {{purchase - actionField_revenue}},\n    value: {{purchase - actionField_revenue}},\n    item_id: '{{purchase - product_id}}',\n    item_name: '{{purchase - product_name}}',\n    external_id: _ext,\n    $insert_id: '{{purchase - event_id}}'\n  });\n}\n[/S]",
        // add_to_wishlist → Product Added to Wishlist (no product data in raw push)
        "Product Added to Wishlist": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product Added to Wishlist', { external_id: '{{Cookie - external_id}}' });\n}\n[/S]",
        // login → Signed In → comes with customer.* hashed identifiers
        "Signed In": "[S]\nif (typeof mixpanel !== 'undefined') {\n  var _ext = '{{login - customer_external_id}}' || '{{Cookie - external_id}}';\n  if (_ext) {\n    mixpanel.identify(_ext);\n    if (mixpanel.people) {\n      mixpanel.people.set({\n        $email:       '{{login - customer_email_hashed}}',\n        $phone:       '{{login - customer_mobile_hashed}}',\n        external_id:  _ext,\n        $last_login:  new Date().toISOString()\n      });\n    }\n  }\n  mixpanel.track('Signed In', { external_id: _ext });\n}\n[/S]",
        "Product List Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product List Viewed', { external_id: '{{Cookie - external_id}}' });\n}\n[/S]",
        "Products Searched": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Products Searched', { search_term: '{{DL - search_term}}', external_id: '{{Cookie - external_id}}' });\n}\n[/S]",
        "Cart Viewed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Cart Viewed', { external_id: '{{Cookie - external_id}}' });\n}\n[/S]",
        "Product Removed": "[S]\nif (typeof mixpanel !== 'undefined') {\n  mixpanel.track('Product Removed', { external_id: '{{Cookie - external_id}}' });\n}\n[/S]"
      }

    };

    // ===== GATE =====

    // ===== CMS GRID =====
    var cmsGrid = document.getElementById('cmsGrid');
    cmsGrid.onclick = function (e) {
      var btn = e.target;
      while (btn && btn.tagName !== 'BUTTON') btn = btn.parentElement;
      if (!btn) return;
      var val = btn.getAttribute('data-val');
      if (!val) return;
      S.cms = val;
      var btns = cmsGrid.querySelectorAll('.cms-card');
      for (var i = 0; i < btns.length; i++) btns[i].classList.remove('on');
      btn.classList.add('on');
      document.getElementById('btn1').disabled = false;
    };

    // ===== PLATFORM GRID =====
    var platGrid = document.getElementById('platGrid');
    platGrid.onclick = function (e) {
      var btn = e.target;
      while (btn && btn.tagName !== 'BUTTON') btn = btn.parentElement;
      if (!btn) return;
      var val = btn.getAttribute('data-val');
      if (!val) return;
      // ── SOON platforms: not activatable ──
      if (btn.classList.contains('cbtn-soon')) return;
      var idx = S.platforms.indexOf(val);
      if (idx === -1) { S.platforms.push(val); btn.classList.add('on'); }
      else { S.platforms.splice(idx, 1); btn.classList.remove('on'); }
      document.getElementById('btn2').disabled = S.platforms.length === 0;
    };

    // ===== STEP NAVIGATION =====
    function goStep(n) {
      if (n === 3) buildEvGrid();
      if (n === 4) buildPixInputs();
      for (var i = 1; i <= 4; i++) {
        document.getElementById('s' + i).classList.remove('on');
      }
      document.getElementById('outWrap').classList.remove('on');
      if (n <= 4) document.getElementById('s' + n).classList.add('on');
      updateProg(n);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateProg(cur) {
      for (var i = 1; i <= 5; i++) {
        var c = document.getElementById('pc' + i);
        var l = document.getElementById('pl' + i);
        c.classList.remove('on', 'done');
        l.classList.remove('on');
        if (i < cur) { c.classList.add('done'); c.textContent = '✓'; }
        else if (i === cur) { c.classList.add('on'); c.textContent = i; l.classList.add('on'); }
        else { c.textContent = i; }
        if (i <= 4) {
          var con = document.getElementById('pcon' + i);
          if (i < cur) con.classList.add('done');
          else con.classList.remove('done');
        }
      }
    }

    // ===== EVENTS GRID — Per-Platform Independent Selection =====
    function buildEvGrid() {
      S.events = [];
      S.platformEvents = {};
      var grid = document.getElementById('evGrid');
      grid.innerHTML = '';

      if (!S.platforms.length) return;

      // Compute union of S.events from platformEvents
      function syncUnion() {
        var u = {};
        Object.keys(S.platformEvents).forEach(function (p) {
          (S.platformEvents[p] || []).forEach(function (e) { u[e] = true; });
        });
        S.events = Object.keys(u);
        document.getElementById('btn3').disabled = S.events.length === 0;
      }

      // Init each platform with 'purchase' forced
      S.platforms.forEach(function (p) {
        S.platformEvents[p] = (PMAP[p] && PMAP[p].purchase) ? ['purchase'] : [];
      });
      syncUnion();

      // Info banner removed

      // Platform tabs
      var tabsDiv = document.createElement('div');
      tabsDiv.className = 'pixtabs';
      tabsDiv.style.marginBottom = '0';
      tabsDiv.style.gridColumn = '1 / -1';
      S.platforms.forEach(function (p, i) {
        var tb = document.createElement('button');
        tb.className = 'pixtab' + (i === 0 ? ' on' : '');
        tb.setAttribute('data-plat', p);
        tb.textContent = PM[p].name;
        tabsDiv.appendChild(tb);
      });
      grid.appendChild(tabsDiv);

      // Per-platform event sections
      S.platforms.forEach(function (p, i) {
        var section = document.createElement('div');
        section.className = 'pixwrap' + (i === 0 ? ' on' : '');
        section.id = 'evSec-' + p;
        section.style.cssText = 'grid-column:1 / -1;padding-top:14px;';

        var evIds = Object.keys(PMAP[p] || {}).filter(function (id) {
          return GA4[id] && PMAP[p][id] != null;
        });

        if (!evIds.length) {
          section.innerHTML = '<div style="padding:20px;color:var(--mut);font-size:13px;text-align:center;">لا توجد أيفنتات متاحة لهذه المنصة</div>';
          grid.appendChild(section);
          return;
        }

        var innerGrid = document.createElement('div');
        innerGrid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:10px;';

        evIds.forEach(function (evId) {
          var ev = GA4[evId];
          var platName = PMAP[p][evId]; // Platform-specific event name
          var isForced = (evId === 'purchase');
          var isSelected = (S.platformEvents[p] || []).indexOf(evId) !== -1;

          var btn = document.createElement('button');
          btn.className = 'cbtn' + ((isForced || isSelected) ? ' on' : '');
          btn.setAttribute('data-evid', evId);
          btn.setAttribute('data-plat', p);
          if (isForced) { btn.style.opacity = '.8'; btn.style.cursor = 'default'; btn.setAttribute('data-forced', '1'); }
          btn.innerHTML = '<div class="cchk">✓</div>'
            + '<span style="font-size:13px;font-weight:700;display:block;margin-bottom:3px;">' + ev.label + '</span>'
            + '<span style="font-family:monospace;font-size:9px;color:var(--mut);word-break:break-all;">' + platName + '</span>';
          innerGrid.appendChild(btn);
        });

        // Click handler scoped to this platform's grid
        innerGrid.addEventListener('click', function (e) {
          var btn = e.target;
          while (btn && btn.tagName !== 'BUTTON') btn = btn.parentElement;
          if (!btn || btn.getAttribute('data-forced')) return;
          var eid = btn.getAttribute('data-evid');
          var plat = btn.getAttribute('data-plat');
          if (!eid || !plat) return;
          var arr = S.platformEvents[plat] || [];
          var idx = arr.indexOf(eid);
          if (idx === -1) { arr.push(eid); btn.classList.add('on'); }
          else { arr.splice(idx, 1); btn.classList.remove('on'); }
          S.platformEvents[plat] = arr;
          syncUnion();
        });

        section.appendChild(innerGrid);
        grid.appendChild(section);
      });

      // Tab switching
      tabsDiv.addEventListener('click', function (e) {
        var tb = e.target;
        if (tb.tagName !== 'BUTTON') return;
        var plat = tb.getAttribute('data-plat');
        tabsDiv.querySelectorAll('.pixtab').forEach(function (b) { b.classList.remove('on'); });
        grid.querySelectorAll('.pixwrap').forEach(function (w) { w.classList.remove('on'); });
        tb.classList.add('on');
        var sec = document.getElementById('evSec-' + plat);
        if (sec) sec.classList.add('on');
      });
    }

    // ===== PIXEL INPUTS =====
    function buildPixInputs() {
      var tabs = document.getElementById('pixTabs');
      var inputs = document.getElementById('pixInputs');
      tabs.innerHTML = '';
      inputs.innerHTML = '';

      for (var i = 0; i < S.platforms.length; i++) {
        var p = S.platforms[i];
        var pm = PM[p];

        // Tab
        var tab = document.createElement('button');
        tab.className = 'pixtab' + (i === 0 ? ' on' : '');
        tab.textContent = pm.name;
        tab.setAttribute('data-plat', p);
        tabs.appendChild(tab);

        // Wrap
        var wrap = document.createElement('div');
        wrap.className = 'pixwrap' + (i === 0 ? ' on' : '');
        wrap.id = 'pw-' + p;

        if (p === 'google') {
          // Google Ads: Conversion ID + Conversion Label per selected event
          var html = '<div class="pix-google-wrap">';

          // Conversion ID (shared)
          html += '<div class="pixrow">';
          html += '<label class="pixlabel">Conversion ID <span class="pixlabel-hint">مشترك لكل الـ events</span></label>';
          html += '<div class="pixfield-wrap">';
          html += '<input class="pixfield" id="pf-google-id" type="text" placeholder="AW-XXXXXXXXXX" dir="ltr">';
          html += '<div class="pix-valid" id="pv-google-id"></div>';
          html += '</div>';
          html += '<div class="pixhint">💡 Google Ads → Tools → Conversions → Settings → Conversion ID</div>';
          html += '</div>';

          // Conversion Label per event
          html += '<div class="pixrow" style="margin-top:16px;">';
          html += '<label class="pixlabel">Conversion Label <span class="pixlabel-hint">لكل event منفصل</span></label>';
          for (var ei = 0; ei < S.events.length; ei++) {
            var ev = S.events[ei];
            var evLabel = GA4[ev] ? GA4[ev].label : ev;
            html += '<div class="pix-ev-row">';
            html += '<span class="pix-ev-name">' + evLabel + '</span>';
            html += '<div class="pixfield-wrap">';
            html += '<input class="pixfield pix-ev-input" id="pf-google-label-' + ev + '" type="text" placeholder="xxxxxxxxxxxxxx (اتركه فاضي لو مش محتاجه)" dir="ltr" data-event="' + ev + '">';
            html += '<button type="button" class="pix-clear-btn" onclick="var el=document.getElementById(\'pf-google-label-' + ev + '\');el.value=\'\';var pv=document.getElementById(\'pv-google-label-' + ev + '\');if(pv)pv.textContent=\'\';" title="مسح">✕</button>';
            html += '<div class="pix-valid" id="pv-google-label-' + ev + '"></div>';
            html += '</div>';
            html += '</div>';
          }
          html += '</div>';

          // Google Ads Remarketing pixel
          html += '<div class="pixrow" style="margin-top:16px;">';
          html += '<label class="pixlabel">Remarketing Tag <span class="pixlabel-hint">اختياري</span></label>';
          html += '<div class="pixfield-wrap">';
          html += '<input class="pixfield" id="pf-google-rmk" type="text" placeholder="AW-XXXXXXXXXX" dir="ltr">';
          html += '</div>';
          html += '<div class="pixhint">💡 نفس الـ Conversion ID في الغالب — أو Audience ID منفصل</div>';
          html += '</div>';

          html += '</div>';
          wrap.innerHTML = html;

          // Live validation for Conversion ID
          wrap.addEventListener('input', function (e) {
            var el = e.target;
            if (!el.classList.contains('pixfield')) return;
            var id = el.id;
            var val = el.value.trim();
            var pvEl = document.getElementById('pv-' + id);
            if (!pvEl) return;
            if (id === 'pf-google-id' || id === 'pf-google-rmk') {
              var ok = !val || /^AW-\d{9,11}$/.test(val);
              pvEl.textContent = val ? (ok ? '✅' : '❌ لازم يكون AW-XXXXXXXXX') : '';
              pvEl.style.color = ok ? '#34d399' : '#f87171';
            } else if (id.startsWith('pf-google-label-')) {
              var ok2 = !val || /^[a-zA-Z0-9_-]{10,20}$/.test(val);
              pvEl.textContent = val ? (ok2 ? '✅' : '❌ format غلط') : '';
              pvEl.style.color = ok2 ? '#34d399' : '#f87171';
            }
          });

        } else {
          // All other platforms: single pixel ID field
          var validPatterns = {
            meta: { rx: /^\d{10,16}$/, hint: 'رقم 10-16 خانة' },
            snapchat: { rx: /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i, hint: 'UUID مثل: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx' },
            tiktok: { rx: /^C[A-Z0-9]{15,20}$/, hint: 'يبدأ بـ C ثم حروف وأرقام' },
            twitter: { rx: /^[a-z0-9]{5,10}$/i, hint: 'حروف وأرقام 5-10 خانات' },
            ga4: { rx: /^G-[A-Z0-9]{8,12}$/, hint: 'يبدأ بـ G-' },
            mixpanel: { rx: /^[a-f0-9]{32}$/i, hint: 'Project Token = 32-char hex (a-f, 0-9)' }
          };
          var vp = validPatterns[p];

          wrap.innerHTML =
            '<div class="pixfield-wrap">' +
            '<input class="pixfield" id="pf-' + p + '" type="text" placeholder="' + pm.name + ' Pixel ID" dir="ltr">' +
            '<div class="pix-valid" id="pv-' + p + '"></div>' +
            '</div>' +
            '<div class="pixhint">💡 ' + HINTS[p] + (vp ? ' — <span style="color:var(--gold)">Format: ' + vp.hint + '</span>' : '') + '</div>';

          if (vp) {
            (function (platId, pattern) {
              wrap.addEventListener('input', function () {
                var val = document.getElementById('pf-' + platId).value.trim();
                var pvEl = document.getElementById('pv-' + platId);
                if (!pvEl) return;
                if (!val) { pvEl.textContent = ''; return; }
                var ok = pattern.rx.test(val);
                pvEl.textContent = ok ? '✅' : '❌ ' + pattern.hint;
                pvEl.style.color = ok ? '#34d399' : '#f87171';
              });
            })(p, vp);
          }
        }

        inputs.appendChild(wrap);
      }

      // Tab switching
      tabs.onclick = function (e) {
        var btn = e.target;
        if (btn.tagName !== 'BUTTON') return;
        var plat = btn.getAttribute('data-plat');
        tabs.querySelectorAll('.pixtab').forEach(function (b) { b.classList.remove('on'); });
        inputs.querySelectorAll('.pixwrap').forEach(function (w) { w.classList.remove('on'); });
        btn.classList.add('on');
        var pw = document.getElementById('pw-' + plat);
        if (pw) pw.classList.add('on');
      };
    }

    // ═══════════════════════════════════════════════════════════
    // ===== SERVER SIDE CONFIG — UI Functions =====
    // ═══════════════════════════════════════════════════════════

    function pcSS_toggle() {
      _pcSS.enabled = !_pcSS.enabled;
      var btn = document.getElementById('pc-ss-toggle-btn');
      var lbl = document.getElementById('pc-ss-toggle-lbl');
      var body = document.getElementById('pc-ss-body');
      if (btn) btn.classList.toggle('on', _pcSS.enabled);
      if (lbl) lbl.textContent = _pcSS.enabled ? 'ON' : 'OFF';
      if (body) body.classList.toggle('open', _pcSS.enabled);
      if (_pcSS.enabled) pcSS_refreshGA4Display();
    }

    function pcSS_validateUrl() {
      var inp = document.getElementById('pc-ss-url');
      var valid = document.getElementById('pc-ss-url-valid');
      if (!inp || !valid) return;
      var v = inp.value.trim();
      _pcSS.serverUrl = v;
      if (!v) { valid.textContent = ''; return; }
      var ok = /^https:\/\/[A-Za-z0-9.\-]+(:\d+)?(\/[A-Za-z0-9._~%\-\/]*)?$/.test(v);
      valid.textContent = ok ? '✅ رابط صحيح' : '❌ لازم يبدأ بـ https:// ويحتوي على domain صحيح';
      valid.style.color = ok ? '#34d399' : '#f87171';
    }

    function pcSS_refreshGA4Display() {
      var el = document.getElementById('pc-ss-ga4-display');
      if (!el) return;
      var id = (S.pixelIds && S.pixelIds['ga4']) ? S.pixelIds['ga4'] : _pcSS.ga4Id;
      if (id) {
        _pcSS.ga4Id = id;
        el.innerHTML = '<div class="pc-ss-ga4-row">'
          + '<span class="pc-ss-ga4-badge">GA4</span>'
          + '<span class="pc-ss-ga4-val">' + id + '</span>'
          + '<button class="pc-ss-ga4-edit" onclick="pcSS_editGA4()">تعديل</button>'
          + '</div>';
      } else {
        el.innerHTML = '<input class="pc-ss-input" id="pc-ss-ga4-manual" type="text" placeholder="G-XXXXXXXXXX" dir="ltr" oninput="pcSS_onGA4Input()" autocomplete="off">'
          + '<div class="pc-ss-hint">💡 GA4 Measurement ID — أضف GA4 في Step 2 أولاً أو اكتبه هنا يدوياً</div>';
      }
    }

    window.pcSS_editGA4 = function() {
      var el = document.getElementById('pc-ss-ga4-display');
      if (!el) return;
      el.innerHTML = '<input class="pc-ss-input" id="pc-ss-ga4-manual" type="text" placeholder="G-XXXXXXXXXX" dir="ltr" value="' + (_pcSS.ga4Id || '') + '" oninput="pcSS_onGA4Input()" autocomplete="off">';
    };

    window.pcSS_onGA4Input = function() {
      var inp = document.getElementById('pc-ss-ga4-manual');
      if (inp) _pcSS.ga4Id = inp.value.trim();
    };

    function pcSS_togglePlatform(key) {
      var btn = document.querySelector('[data-ss-plat="' + key + '"]');
      var idx = _pcSS.platforms.indexOf(key);
      if (idx === -1) {
        _pcSS.platforms.push(key);
        if (btn) btn.classList.add('on');
        if (!_pcSS.events[key]) {
          _pcSS.events[key] = ['purchase']; // purchase forced by default
        }
      } else {
        _pcSS.platforms.splice(idx, 1);
        if (btn) btn.classList.remove('on');
        delete _pcSS._pxOpen[key];
      }
      pcSS_renderAccordions();
    }

    function pcSS_renderAccordions() {
      var wrap = document.getElementById('pc-ss-acc-wrap');
      var container = document.getElementById('pc-ss-accordions');
      if (!wrap || !container) return;
      if (!_pcSS.platforms.length) { wrap.style.display = 'none'; return; }
      wrap.style.display = '';
      container.innerHTML = '';
      _pcSS.platforms.forEach(function(key) {
        var pd = _pcSS_PLATS[key];
        if (!pd) return;
        var isOpen = !!_pcSS._pxOpen[key];
        var acc = document.createElement('div');
        acc.className = 'pc-ss-acc' + (isOpen ? ' open' : '');
        acc.id = 'pc-ss-acc-' + key;

        // Build events chips HTML
        var evChips = _pcSS_EVENTS.map(function(ev) {
          var sel = (_pcSS.events[key] || []).indexOf(ev.key) !== -1;
          return '<span class="pc-ss-ev-chip' + (sel ? ' on' : '') + (ev.forced ? ' forced' : '') + '" '
            + 'onclick="pcSS_toggleEvent(\'' + key + '\',\'' + ev.key + '\')" '
            + 'title="' + ev.label + '">'
            + ev.icon + ' ' + ev.key + '</span>';
        }).join('');

        // Build credentials HTML
        var credsHtml = '';
        if (key === 'gads') {
          // Google Ads: Conversion ID + Labels per event
          credsHtml += '<div class="pc-ss-px-row">'
            + '<div class="pc-ss-px-lbl">Conversion ID <span style="color:var(--mut);font-weight:400;">(مشترك لكل الـ events)</span></div>'
            + '<input class="pc-ss-input" id="pc-ss-px-gads-id" type="text" placeholder="AW-1234567890" dir="ltr" value="' + (_pcSS.gadsConvId||'') + '" oninput="_pcSS.gadsConvId=this.value.trim()" autocomplete="off">'
            + '</div>';
          credsHtml += '<div class="pc-ss-px-row" id="pc-ss-gads-labels-wrap">'
            + '<div class="pc-ss-px-lbl">Conversion Labels <span style="color:var(--mut);font-weight:400;">(لكل event)</span></div>'
            + (_pcSS.events['gads'] || ['purchase']).map(function(ev) {
                return '<div class="pc-ss-label-row">'
                  + '<span class="pc-ss-label-ev">' + ev + '</span>'
                  + '<input class="pc-ss-input" style="flex:1;" id="pc-ss-gads-lbl-' + ev + '" type="text" placeholder="AbCd_xxxxxxxx" dir="ltr" value="' + (_pcSS.gadsLabels[ev]||'') + '" oninput="_pcSS.gadsLabels[\'' + ev + '\']=this.value.trim()" autocomplete="off">'
                  + '</div>';
              }).join('');
          credsHtml += '</div>';
        } else {
          // Meta, Snap, TikTok: Pixel ID + Token
          credsHtml += '<div class="pc-ss-px-row">'
            + '<div class="pc-ss-px-lbl">' + pd.idLabel + '</div>'
            + '<input class="pc-ss-input" id="pc-ss-px-id-' + key + '" type="text" placeholder="' + pd.idPh + '" dir="ltr" value="' + (_pcSS.pixelIds[key]||'') + '" oninput="_pcSS.pixelIds[\'' + key + '\']=this.value.trim()" autocomplete="off">'
            + '</div>';
          if (pd.hasToken) {
            credsHtml += '<div class="pc-ss-px-row">'
              + '<div class="pc-ss-px-lbl">' + pd.tokLabel + '</div>'
              + '<div class="pc-ss-pw-wrap">'
              + '<input class="pc-ss-input" id="pc-ss-px-tok-' + key + '" type="password" placeholder="' + pd.tokPh + '" dir="ltr" value="' + (_pcSS.tokens[key]||'') + '" oninput="_pcSS.tokens[\'' + key + '\']=this.value.trim()" autocomplete="new-password">'
              + '<span class="material-symbols-outlined pc-ss-eye" id="pc-ss-eye-' + key + '" onclick="pcSS_toggleEye(\'' + key + '\')">visibility</span>'
              + '</div></div>';
          }
        }

        acc.innerHTML = '<div class="pc-ss-acc-hdr" onclick="pcSS_toggleAccordion(\'' + key + '\')">'
          + '<span style="font-size:18px;">' + pd.icon + '</span>'
          + '<span class="pc-ss-acc-name">' + pd.label + '</span>'
          + '<span class="pc-ss-acc-arr">▶</span>'
          + '</div>'
          + '<div class="pc-ss-acc-body">'
          + '<div style="font-size:11px;color:var(--mut);margin-bottom:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;">Events</div>'
          + '<div class="pc-ss-ev-chips">' + evChips + '</div>'
          + '<div style="font-size:11px;color:var(--mut);margin-bottom:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;">Credentials</div>'
          + credsHtml
          + '</div>';

        container.appendChild(acc);
      });
    }

    window.pcSS_toggleAccordion = function(key) {
      _pcSS._pxOpen[key] = !_pcSS._pxOpen[key];
      var acc = document.getElementById('pc-ss-acc-' + key);
      if (acc) acc.classList.toggle('open', _pcSS._pxOpen[key]);
    };

    window.pcSS_toggleEvent = function(plat, evKey) {
      var pd = _pcSS_EVENTS.find(function(e){ return e.key === evKey; });
      if (pd && pd.forced) return; // purchase always on
      if (!_pcSS.events[plat]) _pcSS.events[plat] = ['purchase'];
      var arr = _pcSS.events[plat];
      var idx = arr.indexOf(evKey);
      if (idx === -1) arr.push(evKey);
      else arr.splice(idx, 1);
      // Re-render accordion to refresh chips + gads labels
      pcSS_renderAccordions();
      // Re-open the accordion
      _pcSS._pxOpen[plat] = true;
      var acc = document.getElementById('pc-ss-acc-' + plat);
      if (acc) acc.classList.add('open');
    };

    window.pcSS_toggleEye = function(key) {
      var inp = document.getElementById('pc-ss-px-tok-' + key);
      var eye = document.getElementById('pc-ss-eye-' + key);
      if (!inp) return;
      inp.type = inp.type === 'password' ? 'text' : 'password';
      if (eye) eye.textContent = inp.type === 'password' ? 'visibility' : 'visibility_off';
    };

    function pcSS_collect() {
      // URL
      var urlInp = document.getElementById('pc-ss-url');
      if (urlInp) _pcSS.serverUrl = urlInp.value.trim();
      // GA4 ID — prefer S state, then manual input
      var ga4Auto = (S.pixelIds && S.pixelIds['ga4']) ? S.pixelIds['ga4'] : '';
      var ga4Manual = document.getElementById('pc-ss-ga4-manual');
      _pcSS.ga4Id = ga4Auto || (ga4Manual ? ga4Manual.value.trim() : _pcSS.ga4Id);
      // Pixel IDs + tokens — already wired via oninput on each input field
      // Google Ads conv ID
      var gadsIdInp = document.getElementById('pc-ss-px-gads-id');
      if (gadsIdInp) _pcSS.gadsConvId = gadsIdInp.value.trim();
      // Google Ads labels
      (_pcSS.events['gads'] || []).forEach(function(ev) {
        var inp = document.getElementById('pc-ss-gads-lbl-' + ev);
        if (inp) _pcSS.gadsLabels[ev] = inp.value.trim();
      });
    }

    // ═══════════════════════════════════════════════════════════
    // ===== GENERATE =====
    function generate() {
      try {
        // ── Step 1: Collect pixel IDs ──
        for (var i = 0; i < S.platforms.length; i++) {
          var p = S.platforms[i];
          if (p === 'google') {
            var gId = document.getElementById('pf-google-id');
            var gRmk = document.getElementById('pf-google-rmk');
            S.pixelIds['google'] = gId ? gId.value.trim() : '';
            S.pixelIds['google_rmk'] = gRmk ? gRmk.value.trim() : '';
            // Collect per-event conversion labels
            S.pixelIds['google_labels'] = {};
            for (var ei = 0; ei < S.events.length; ei++) {
              var ev = S.events[ei];
              var labelEl = document.getElementById('pf-google-label-' + ev);
              if (labelEl) S.pixelIds['google_labels'][ev] = labelEl.value.trim();
            }
          } else {
            var el = document.getElementById('pf-' + p);
            S.pixelIds[p] = el ? el.value.trim() : '';
          }
        }

        // ── Step 1b: Collect SS config + set window.ET flags ──
        try { pcSS_collect(); } catch(e) { console.warn('pcSS_collect error:', e); }
        window.ET = window.ET || {};
        window.ET.ssEnabled = _pcSS.enabled && !!_pcSS.serverUrl && /^https:\/\//.test(_pcSS.serverUrl);
        window.ET.ssUrl     = _pcSS.serverUrl;
        window.ET.ssGa4Id   = _pcSS.ga4Id;
        window.ET.ssPlats   = _pcSS.platforms;
        window.ET.ssEvents  = _pcSS.events;

        // ── Step 2: Show output panel & wire buttons FIRST so UI never stays blank ──
        for (var i = 1; i <= 4; i++) document.getElementById('s' + i).classList.remove('on');
        document.getElementById('outWrap').classList.add('on');
        var gtmEmpty = document.getElementById('gtmEmptyState');
        if (gtmEmpty) gtmEmpty.style.display = 'none';
        updateProg(5);
        window.scrollTo({ top: 0, behavior: 'smooth' });

        // ── Show/hide Server Container tab ──
        var tabSsEl = document.getElementById('tabSsGtm');
        var paneSsEl = document.getElementById('pane-ss-gtm');
        if (tabSsEl) tabSsEl.style.display = window.ET.ssEnabled ? '' : 'none';
        if (paneSsEl) paneSsEl.style.display = window.ET.ssEnabled ? '' : 'none';

        bindDownloads(); // wire early so buttons are always ready

        // ── Step 3: Build each output panel individually — one crash won't block the rest ──
        try { document.getElementById('jsonBody').textContent = JSON.stringify(buildJSON(), null, 2); }
        catch (e) { console.error('buildJSON error:', e); }

        // ── Build Server Container JSON if SS enabled ──
        if (window.ET.ssEnabled) {
          try {
            var ssContainerResult = buildSSContainer();
            var ssContainerStr = JSON.stringify(ssContainerResult, null, 2);
            var ssBody = document.getElementById('ssGtmBody');
            if (ssBody) ssBody.textContent = ssContainerStr;
            // Container Config: compact version for Stape
            var ssConfigBox = document.getElementById('pc-ss-config-box');
            if (ssConfigBox) ssConfigBox.textContent = JSON.stringify(ssContainerResult);
            // Wire download button
            var dlSsBtn = document.getElementById('dlSsGtm');
            if (dlSsBtn) {
              dlSsBtn.onclick = function() {
                var blob = new Blob([ssContainerStr], { type: 'application/json' });
                var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
                a.download = 'sgtm-container.json'; a.click();
              };
            }
            var cpySsBtn = document.getElementById('cpySsGtm');
            if (cpySsBtn) cpySsBtn.onclick = function() { navigator.clipboard.writeText(ssContainerStr).catch(function(){}); };
            var cpyCfgBtn = document.getElementById('cpySsConfig');
            if (cpyCfgBtn) cpyCfgBtn.onclick = function() { navigator.clipboard.writeText(JSON.stringify(ssContainerResult)).catch(function(){}); };
          } catch(e) {
            console.error('buildSSContainer error:', e);
            var ssBody2 = document.getElementById('ssGtmBody');
            if (ssBody2) ssBody2.innerHTML = '<div style="padding:20px;color:#f87171;font-size:12px;font-family:monospace;">⚠️ خطأ في بناء Server Container: ' + (e.message||String(e)) + '</div>';
          }
        }

        try { document.getElementById('dlBody').textContent = buildDL(); }
        catch (e) { console.error('buildDL error:', e); }

        // Build Salla bridge BEFORE the lazy GTM build so _sallaBridgeCode is ready
        if (S.cms === 'salla') {
          try { buildSallaBridge(); } catch (e) { console.error('buildSallaBridge error:', e); }
        }

        try { document.getElementById('guideSteps').innerHTML = buildGuide(); }
        catch (e) { console.error('buildGuide error:', e); }

        try { document.getElementById('scoreContent').innerHTML = buildScore(); }
        catch (e) { console.error('buildScore error:', e); }

        try { buildHealthCheck(); } catch (e) { console.error('buildHealthCheck error:', e); }
        try { buildPlan(); } catch (e) { console.error('buildPlan error:', e); }
        try { buildSummary(); } catch (e) { console.error('buildSummary error:', e); }

        // Update Overview page with active pixels
        try { refreshOverview(); } catch (roe) { console.warn('refreshOverview error:', roe); }

        // ── Step 4: Lazy GTM build — defer heavy JSON serialization so UI stays responsive ──
        var gtmBodyEl = document.getElementById('gtmBody');
        if (gtmBodyEl) {
          gtmBodyEl.textContent = '';
          gtmBodyEl.innerHTML = '<div style="padding:40px;text-align:center;color:var(--mut);font-size:13px;">'
            + '<span class="material-symbols-outlined" style="font-size:32px;display:block;margin-bottom:8px;animation:spin 1s linear infinite;">sync</span>'
            + 'جاري بناء GTM Container...</div>';
        }
        _cachedGtmStr = null; // reset cache while building
        var _lazyGtm = (typeof requestIdleCallback !== 'undefined') ? requestIdleCallback : function (fn) { setTimeout(fn, 30); };
        _lazyGtm(function () {
          try {
            var gtmResult = buildGTMContainer();
            var gtmStr = JSON.stringify(gtmResult, null, 2);
            _cachedGtmStr = gtmStr; // cache for sidebar view + download
            if (gtmBodyEl) gtmBodyEl.textContent = gtmStr;
            // If sidebar GTM view is currently active, refresh it now
            var gtmViewEl = document.getElementById('view-gtmview');
            if (gtmViewEl && gtmViewEl.classList.contains('active')) {
              var gtmViewContent2 = document.getElementById('gtmViewContent');
              var gtmEmpty2 = document.getElementById('gtmEmptyState');
              if (gtmEmpty2) gtmEmpty2.style.display = 'none';
              if (gtmViewContent2) renderGtmSidebarView(gtmViewContent2, gtmStr);
            }
            bindDownloads(); // re-wire after cache is ready
          } catch (e) {
            console.error('GTM build error:', e);
            if (gtmBodyEl) gtmBodyEl.innerHTML =
              '<div style="padding:24px;color:#f87171;font-family:monospace;font-size:12px;line-height:1.8;">'
              + '<div style="font-size:14px;font-weight:700;margin-bottom:8px;">⚠️ خطأ في بناء الـ GTM Container</div>'
              + '<div style="opacity:.85;">' + (e.message || String(e)) + '</div>'
              + '<div style="margin-top:10px;font-size:11px;opacity:.5;">' + (e.stack ? e.stack.split('\n').slice(0, 3).join('<br>') : '') + '</div>'
              + '</div>';
          }
        });

      } catch (e) {
        console.error('generate() error:', e);
        // Always show the output panel and wire buttons even on unexpected errors
        try { document.getElementById('outWrap').classList.add('on'); } catch (x) { }
        try { bindDownloads(); } catch (x) { }
        var errEl = document.getElementById('gtmBody');
        if (errEl) errEl.innerHTML = '<div style="padding:20px;color:#f87171;font-size:12px;font-family:monospace;">⚠️ خطأ في التوليد: ' + (e.message || String(e)) + '</div>';
      }
    }

    // ===== BUILD JSON =====
    function buildJSON() {
      var platforms = {};
      for (var pi = 0; pi < S.platforms.length; pi++) {
        var p = S.platforms[pi];
        var evList = [];


        for (var ei = 0; ei < S.events.length; ei++) {
          var evId = S.events[ei];
          var ev = GA4[evId];
          var platEv = PMAP[p][evId];
          if (!platEv) continue;
          var params = {};
          for (var ri = 0; ri < ev.req.length; ri++) {
            var r = ev.req[ri];
            if (r === 'items') {
              var item = {};
              for (var ii = 0; ii < ev.ip.length; ii++) item[ev.ip[ii]] = '{{' + ev.ip[ii] + '}}';
              params[r] = [item];
            } else {
              params[r] = '{{' + r + '}}';
            }
          }
          for (var oi = 0; oi < ev.opt.length; oi++) params[ev.opt[oi]] = '{{' + ev.opt[oi] + '}}';
          evList.push({ ga4_event: evId, platform_event: platEv, label: ev.label, event_score: ev.score, parameters: params });
        }
        platforms[p] = { platform_name: PM[p].name, pixel_id: S.pixelIds[p] || 'YOUR_PIXEL_ID', events: evList };
      }
      var result = {
        generated_by: 'Easy Track · Pixel Config Generator',
        generated_at: new Date().toISOString().split('T')[0],
        lead: S.lead || {}, cms: S.cms, cms_name: CMS[S.cms].name, cms_notes: CMS[S.cms].note,
        platforms: platforms
      };
      // Append ss_config when Server Side is enabled
      if (_pcSS.enabled) {
        result.ss_config = {
          enabled:    true,
          server_url: _pcSS.serverUrl,
          ga4_id:     _pcSS.ga4Id,
          platforms:  _pcSS.platforms,
          events:     _pcSS.events,
          gads_conv_id: _pcSS.gadsConvId,
          gads_labels:  _pcSS.gadsLabels
          // tokens ommitted intentionally — sensitive
        };
      } else {
        result.ss_config = { enabled: false };
      }
      return result;
    }

    // ── H3: Server-Side Relay Tag builder ──────────────────────────────────────
    // Builds a Custom HTML tag that forwards events to sGTM via fetch().
    // The sGTM container fans out to CAPI / server-side endpoints from there.
    //
    // ⚠️ All user-controlled inputs (ssUrl, ga4Event, platformEvent, platform) are
    // serialized via JSON.stringify before injection into the generated <script>.
    // This prevents script injection if a malicious ssUrl ever reaches this point.
    // Additionally, ssUrl is validated as a same-origin-style HTTPS URL.
    function buildSSRelayTag(platform, ssUrl, ga4Event, platformEvent) {
      if (!ssUrl) return null;
      // Hard validation — only allow https://host[/path] with no JS-breaking chars
      if (!/^https?:\/\/[A-Za-z0-9.\-]+(:\d+)?(\/[A-Za-z0-9._~%\-\/]*)?$/.test(ssUrl)) {
        return null;
      }
      var endpoint = ssUrl.replace(/\/$/, '') + '/g/collect';
      var evName   = platformEvent || ga4Event;
      // J() = JSON-encoded literal for safe embedding in JS source
      function J(v) { return JSON.stringify(String(v == null ? '' : v)); }
      var html = '[S]\n' +
        '(function(){\n' +
        '  try {\n' +
        '    var d = window.dataLayer || [];\n' +
        '    var last = {};\n' +
        '    var EV = ' + J(ga4Event) + ';\n' +
        '    for (var i = d.length - 1; i >= 0; i--) {\n' +
        '      if (d[i] && d[i].event === EV) { last = d[i]; break; }\n' +
        '    }\n' +
        '    var ec  = last.ecommerce || {};\n' +
        '    var ud  = {};\n' +
        '    try { var _et = JSON.parse(localStorage.getItem("et_identity") || "{}"); ud = { external_id: _et.external_id || "", em: _et.email_hashed || "", ph: _et.phone_hashed || "" }; } catch(e) {}\n' +
        '    var payload = {\n' +
        '      v: "2",\n' +
        '      en: EV,\n' +
        '      ep_platform: ' + J(platform) + ',\n' +
        '      ep_platform_event: ' + J(evName) + ',\n' +
        '      ep_event_id: (ec.event_id || last.event_id || ("ET-SS-" + Date.now().toString(36).toUpperCase())),\n' +
        '      epn_value: String(ec.value || ec.price || 0),\n' +
        '      ep_currency: ec.currency || "SAR",\n' +
        '      ep_transaction_id: ec.transaction_id || "",\n' +
        '      up_external_id: ud.external_id || "",\n' +
        '      up_em: ud.em || "",\n' +
        '      up_ph: ud.ph || ""\n' +
        '    };\n' +
        '    var qs = Object.keys(payload).map(function(k){ return encodeURIComponent(k) + "=" + encodeURIComponent(payload[k]); }).join("&");\n' +
        '    var URL_BASE = ' + J(endpoint) + ';\n' +
        '    if (navigator.sendBeacon) {\n' +
        '      navigator.sendBeacon(URL_BASE + "?" + qs);\n' +
        '    } else {\n' +
        '      fetch(URL_BASE + "?" + qs, { method: "POST", keepalive: true }).catch(function(){});\n' +
        '    }\n' +
        '  } catch(e) {}\n' +
        '})();\n' +
        '[/S]';
      return html.replace(/\[S\]/g, '<scr' + 'ipt>').replace(/\[\/S\]/g, '<\/scr' + 'ipt>');
    }

    // ═══════════════════════════════════════════════════════════════
    // ===== BUILD SERVER CONTAINER (sGTM) =====
    // ═══════════════════════════════════════════════════════════════
    function buildSSContainer() {
      if (!_pcSS.enabled) return null;

      var ts = Date.now();
      function fp(id) { return String(ts + id * 7 + 1000000); }
      function safeName(s) { return String(s).replace(/[:\/\\?*\[\]|<>]/g,'-').trim(); }

      var varId = 1, tagId = 1, triggerId = 1, clientId = 1;
      var variables = [], tags = [], triggers = [], clients = [];

      // ── Helper: Event Data variable ─────────────────────────────
      function evDataVar(name, key) {
        variables.push({
          accountId:'000000000', containerId:'00000000', variableId: varId,
          name: name, type:'gtes',
          parameter:[{ type:'TEMPLATE', key:'varType', value:'event_data' },
                     { type:'TEMPLATE', key:'varName', value: key }],
          fingerprint: fp(varId)
        });
        return varId++;
      }

      // ── Helper: HTTP Request variable ───────────────────────────
      function httpVar(name, key) {
        variables.push({
          accountId:'000000000', containerId:'00000000', variableId: varId,
          name: name, type:'gtes',
          parameter:[{ type:'TEMPLATE', key:'varType', value:'request_header' },
                     { type:'TEMPLATE', key:'varName', value: key }],
          fingerprint: fp(varId)
        });
        return varId++;
      }

      // ── Helper: Query Param variable ─────────────────────────────
      function queryVar(name, key) {
        variables.push({
          accountId:'000000000', containerId:'00000000', variableId: varId,
          name: name, type:'gtes',
          parameter:[{ type:'TEMPLATE', key:'varType', value:'query_parameter' },
                     { type:'TEMPLATE', key:'varName', value: key }],
          fingerprint: fp(varId)
        });
        return varId++;
      }

      // ── 1. GA4 Client ────────────────────────────────────────────
      clients.push({
        accountId:'000000000', containerId:'00000000', clientId: clientId,
        name: 'GA4 Client',
        type: 'google-ga4',
        parameter:[{ type:'TEMPLATE', key:'activationPage', value:'/' }],
        priority: 0,
        fingerprint: fp(clientId)
      });
      clientId++;

      // ── 2. Variables — Event Data ────────────────────────────────
      var vEventName      = evDataVar('SS - event_name',      'event_name');
      var vTransId        = evDataVar('SS - transaction_id',   'transaction_id');
      var vValue          = evDataVar('SS - value',            'value');
      var vCurrency       = evDataVar('SS - currency',         'currency');
      var vEventId        = evDataVar('SS - event_id',         'event_id');
      var vContentIds     = evDataVar('SS - content_ids',      'content_ids');
      var vContentType    = evDataVar('SS - content_type',     'content_type');
      var vNumItems       = evDataVar('SS - num_items',        'num_items');
      var vItems          = evDataVar('SS - items',            'items');
      // User data (forwarded from web as GA4 user_properties)
      var vEm             = evDataVar('SS - user.email_hashed',  'up.em');
      var vPh             = evDataVar('SS - user.phone_hashed',  'up.ph');
      var vFn             = evDataVar('SS - user.first_name',    'up.fn');
      var vLn             = evDataVar('SS - user.last_name',     'up.ln');
      var vExtId          = evDataVar('SS - user.external_id',   'up.external_id');
      // Click IDs & cookies (forwarded as event params)
      var vFbp            = evDataVar('SS - user.fbp',           'up.fbp');
      var vFbc            = evDataVar('SS - user.fbc',           'up.fbc');
      var vFbclid         = evDataVar('SS - fbclid',             'ep.fbclid');
      var vGclid          = evDataVar('SS - gclid',              'ep.gclid');
      var vWbraid         = evDataVar('SS - wbraid',             'ep.wbraid');
      var vGbraid         = evDataVar('SS - gbraid',             'ep.gbraid');
      var vTtp            = evDataVar('SS - user.ttp',           'up.ttp');
      var vTtclid         = evDataVar('SS - ttclid',             'ep.ttclid');
      var vScid           = evDataVar('SS - user.scid',          'up.scid');
      var vScCid          = evDataVar('SS - ScCid',              'ep.sccid');
      var vPageUrl        = evDataVar('SS - page_url',           'page_location');
      var vPageRef        = evDataVar('SS - page_referrer',      'page_referrer');

      // HTTP variables
      var vIp             = httpVar('SS - client_ip',            'X-Forwarded-For');
      var vUa             = httpVar('SS - user_agent',           'User-Agent');

      // ── 3. Triggers — one per selected event (across all platforms) ──
      var allSsEvents = {};
      _pcSS.platforms.forEach(function(plat) {
        (_pcSS.events[plat] || []).forEach(function(ev) { allSsEvents[ev] = true; });
      });

      // Map SS event key → GA4 event name (salla/zid aware)
      var cmsEvMap = (CMS_DL_MAP[S.cms] && CMS_DL_MAP[S.cms].eventNames) || {};
      var ssEvTrigMap = {}; // { ev_key: triggerId }

      // Always add All Events trigger
      var allEvTrigId = triggerId;
      triggers.push({
        accountId:'000000000', containerId:'00000000', triggerId: triggerId,
        name:'All Events', type:'always',
        fingerprint: fp(triggerId)
      });
      triggerId++;

      Object.keys(allSsEvents).forEach(function(evKey) {
        // Map event key to actual GA4 event name in the data layer
        var ga4EvName = cmsEvMap[evKey] || evKey;
        // For Salla, certain events have different names
        // purchase stays as 'purchase', add_to_cart='addToCart', etc.
        // initiate_checkout → 'cart::submitted', view_content → 'Product Viewed' on salla
        var ssEvNameMap = {
          initiate_checkout: S.cms === 'salla' ? 'cart::submitted' : 'begin_checkout',
          view_content:      S.cms === 'salla' ? 'Product Viewed'  : 'view_item',
          page_view:         'page_view',
          sign_up:           'sign_up',
          lead:              'generate_lead'
        };
        var finalEvName = ssEvNameMap[evKey] || ga4EvName || evKey;
        ssEvTrigMap[evKey] = triggerId;
        triggers.push({
          accountId:'000000000', containerId:'00000000', triggerId: triggerId,
          name: safeName('SS Event — ' + evKey),
          type: 'always',
          filter:[{
            type:'EQUALS',
            parameter:[
              { type:'TEMPLATE', key:'arg0', value:'{{SS - event_name}}' },
              { type:'TEMPLATE', key:'arg1', value: finalEvName }
            ]
          }],
          fingerprint: fp(triggerId)
        });
        triggerId++;
      });

      // ── 4. Tags — per enabled SS platform ───────────────────────
      _pcSS.platforms.forEach(function(plat) {
        var platEvents = _pcSS.events[plat] || [];
        var platTrigIds = platEvents.map(function(ev) {
          return ssEvTrigMap[ev] || allEvTrigId;
        });
        if (!platTrigIds.length) platTrigIds = [allEvTrigId];
        // Deduplicate trigger IDs
        platTrigIds = platTrigIds.filter(function(v,i,a){ return a.indexOf(v)===i; });

        if (plat === 'meta') {
          var pixId  = _pcSS.pixelIds['meta'] || 'YOUR_META_PIXEL_ID';
          var token  = _pcSS.tokens['meta']   || 'YOUR_CAPI_ACCESS_TOKEN';
          platEvents.forEach(function(evKey) {
            var metaEvMap = {
              purchase:'Purchase', add_to_cart:'AddToCart', initiate_checkout:'InitiateCheckout',
              view_content:'ViewContent', page_view:'PageView', lead:'Lead', sign_up:'CompleteRegistration',
              search:'Search'
            };
            tags.push({
              accountId:'000000000', containerId:'00000000', tagId: tagId,
              name: safeName('Meta CAPI | ' + evKey),
              type:'siwt', // Custom Tag — using Custom Template slot for CAPI
              parameter:[
                { type:'TEMPLATE', key:'pixelId',      value: pixId   },
                { type:'TEMPLATE', key:'accessToken',  value: token   },
                { type:'TEMPLATE', key:'eventName',    value: metaEvMap[evKey] || 'CustomEvent' },
                { type:'TEMPLATE', key:'eventId',      value:'{{SS - event_id}}' },
                { type:'TEMPLATE', key:'value',        value:'{{SS - value}}' },
                { type:'TEMPLATE', key:'currency',     value:'{{SS - currency}}' },
                { type:'TEMPLATE', key:'contentIds',   value:'{{SS - content_ids}}' },
                { type:'TEMPLATE', key:'contentType',  value:'{{SS - content_type}}' },
                { type:'TEMPLATE', key:'orderId',      value:'{{SS - transaction_id}}' },
                { type:'TEMPLATE', key:'numItems',     value:'{{SS - num_items}}' },
                { type:'TEMPLATE', key:'email',        value:'{{SS - user.email_hashed}}' },
                { type:'TEMPLATE', key:'phone',        value:'{{SS - user.phone_hashed}}' },
                { type:'TEMPLATE', key:'firstName',    value:'{{SS - user.first_name}}' },
                { type:'TEMPLATE', key:'lastName',     value:'{{SS - user.last_name}}' },
                { type:'TEMPLATE', key:'externalId',   value:'{{SS - user.external_id}}' },
                { type:'TEMPLATE', key:'fbp',          value:'{{SS - user.fbp}}' },
                { type:'TEMPLATE', key:'fbc',          value:'{{SS - user.fbc}}' },
                { type:'TEMPLATE', key:'fbclid',       value:'{{SS - fbclid}}' },
                { type:'TEMPLATE', key:'clientIp',     value:'{{SS - client_ip}}' },
                { type:'TEMPLATE', key:'userAgent',    value:'{{SS - user_agent}}' },
                { type:'TEMPLATE', key:'pageUrl',      value:'{{SS - page_url}}' },
                { type:'TEMPLATE', key:'actionSource', value:'website' }
              ],
              firingTriggerId: [ ssEvTrigMap[evKey] || allEvTrigId ],
              notes: 'Meta CAPI — ' + evKey + ' | Pixel: ' + pixId + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
          });

        } else if (plat === 'gads') {
          var convId = (_pcSS.gadsConvId || 'AW-XXXXXXXXXX').replace('AW-','');
          platEvents.forEach(function(evKey) {
            var label = _pcSS.gadsLabels[evKey] || ('LABEL_' + evKey.toUpperCase());
            tags.push({
              accountId:'000000000', containerId:'00000000', tagId: tagId,
              name: safeName('Google Ads SS | ' + evKey),
              type:'siwt',
              parameter:[
                { type:'TEMPLATE', key:'conversionId',    value: convId  },
                { type:'TEMPLATE', key:'conversionLabel', value: label   },
                { type:'TEMPLATE', key:'value',           value:'{{SS - value}}' },
                { type:'TEMPLATE', key:'currency',        value:'{{SS - currency}}' },
                { type:'TEMPLATE', key:'orderId',         value:'{{SS - transaction_id}}' },
                { type:'TEMPLATE', key:'gclid',           value:'{{SS - gclid}}' },
                { type:'TEMPLATE', key:'wbraid',          value:'{{SS - wbraid}}' },
                { type:'TEMPLATE', key:'gbraid',          value:'{{SS - gbraid}}' },
                { type:'TEMPLATE', key:'email',           value:'{{SS - user.email_hashed}}' },
                { type:'TEMPLATE', key:'phone',           value:'{{SS - user.phone_hashed}}' },
                { type:'TEMPLATE', key:'clientIp',        value:'{{SS - client_ip}}' },
                { type:'TEMPLATE', key:'userAgent',       value:'{{SS - user_agent}}' }
              ],
              firingTriggerId: [ ssEvTrigMap[evKey] || allEvTrigId ],
              notes: 'Google Ads SS — ' + evKey + ' | Conv ID: AW-' + convId + ' | Label: ' + label + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
          });

        } else if (plat === 'snap') {
          var snapId  = _pcSS.pixelIds['snap']  || 'YOUR_SNAP_PIXEL_ID';
          var snapTok = _pcSS.tokens['snap']    || 'YOUR_SNAP_CAPI_TOKEN';
          var snapEvMap = {
            purchase:'PURCHASE', add_to_cart:'ADD_CART', initiate_checkout:'START_CHECKOUT',
            view_content:'VIEW_CONTENT', page_view:'PAGE_VIEW', sign_up:'SIGN_UP',
            lead:'SIGN_UP', search:'SEARCH'
          };
          platEvents.forEach(function(evKey) {
            tags.push({
              accountId:'000000000', containerId:'00000000', tagId: tagId,
              name: safeName('Snapchat CAPI | ' + evKey),
              type:'siwt',
              parameter:[
                { type:'TEMPLATE', key:'pixelId',     value: snapId   },
                { type:'TEMPLATE', key:'apiToken',    value: snapTok  },
                { type:'TEMPLATE', key:'eventType',   value: snapEvMap[evKey] || 'CUSTOM' },
                { type:'TEMPLATE', key:'eventId',     value:'{{SS - event_id}}' },
                { type:'TEMPLATE', key:'price',       value:'{{SS - value}}' },
                { type:'TEMPLATE', key:'currency',    value:'{{SS - currency}}' },
                { type:'TEMPLATE', key:'transId',     value:'{{SS - transaction_id}}' },
                { type:'TEMPLATE', key:'contentIds',  value:'{{SS - content_ids}}' },
                { type:'TEMPLATE', key:'email',       value:'{{SS - user.email_hashed}}' },
                { type:'TEMPLATE', key:'phone',       value:'{{SS - user.phone_hashed}}' },
                { type:'TEMPLATE', key:'externalId',  value:'{{SS - user.external_id}}' },
                { type:'TEMPLATE', key:'scClickId',   value:'{{SS - ScCid}}' },
                { type:'TEMPLATE', key:'uuidC1',      value:'{{SS - user.scid}}' },
                { type:'TEMPLATE', key:'clientIp',    value:'{{SS - client_ip}}' },
                { type:'TEMPLATE', key:'userAgent',   value:'{{SS - user_agent}}' },
                { type:'TEMPLATE', key:'pageUrl',     value:'{{SS - page_url}}' }
              ],
              firingTriggerId: [ ssEvTrigMap[evKey] || allEvTrigId ],
              notes: 'Snapchat CAPI — ' + evKey + ' | Pixel: ' + snapId + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
          });

        } else if (plat === 'tiktok') {
          var ttId  = _pcSS.pixelIds['tiktok']  || 'YOUR_TIKTOK_PIXEL_ID';
          var ttTok = _pcSS.tokens['tiktok']    || 'YOUR_TIKTOK_API_TOKEN';
          var ttEvMap = {
            purchase:'CompletePayment', add_to_cart:'AddToCart', initiate_checkout:'InitiateCheckout',
            view_content:'ViewContent', page_view:'Pageview', lead:'SubmitForm',
            sign_up:'CompleteRegistration', search:'Search'
          };
          platEvents.forEach(function(evKey) {
            tags.push({
              accountId:'000000000', containerId:'00000000', tagId: tagId,
              name: safeName('TikTok Events API | ' + evKey),
              type:'siwt',
              parameter:[
                { type:'TEMPLATE', key:'pixelCode',   value: ttId    },
                { type:'TEMPLATE', key:'accessToken', value: ttTok   },
                { type:'TEMPLATE', key:'eventName',   value: ttEvMap[evKey] || 'CustomEvent' },
                { type:'TEMPLATE', key:'eventId',     value:'{{SS - event_id}}' },
                { type:'TEMPLATE', key:'value',       value:'{{SS - value}}' },
                { type:'TEMPLATE', key:'currency',    value:'{{SS - currency}}' },
                { type:'TEMPLATE', key:'contentId',   value:'{{SS - content_ids}}' },
                { type:'TEMPLATE', key:'contentType', value:'{{SS - content_type}}' },
                { type:'TEMPLATE', key:'email',       value:'{{SS - user.email_hashed}}' },
                { type:'TEMPLATE', key:'phone',       value:'{{SS - user.phone_hashed}}' },
                { type:'TEMPLATE', key:'externalId',  value:'{{SS - user.external_id}}' },
                { type:'TEMPLATE', key:'ttclid',      value:'{{SS - ttclid}}' },
                { type:'TEMPLATE', key:'ttp',         value:'{{SS - user.ttp}}' },
                { type:'TEMPLATE', key:'clientIp',    value:'{{SS - client_ip}}' },
                { type:'TEMPLATE', key:'userAgent',   value:'{{SS - user_agent}}' },
                { type:'TEMPLATE', key:'pageUrl',     value:'{{SS - page_url}}' }
              ],
              firingTriggerId: [ ssEvTrigMap[evKey] || allEvTrigId ],
              notes: 'TikTok Events API — ' + evKey + ' | Pixel: ' + ttId + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
          });
        }
      });

      return {
        exportFormatVersion: 2,
        exportTime: new Date().toISOString(),
        containerVersion: {
          containerVersionId: '0',
          container: {
            accountId:    '000000000',
            containerId:  '00000000',
            name:         'Easy Track — Server Container (sGTM)',
            publicId:     'GTM-SS000000',
            usageContext: ['server'],
            notes:        'Generated by Easy Track | sGTM URL: ' + (_pcSS.serverUrl||'') + ' | CMS: ' + (S.cms||'') + ' | Platforms: ' + _pcSS.platforms.join(', ')
          },
          variable: variables,
          trigger:  triggers,
          tag:      tags,
          client:   clients
        }
      };
    }

    // ===== BUILD GTM CONTAINER =====
    // ===== BUILD GTM CONTAINER =====
    function buildGTMContainer() {
      var baseTs = Date.now();
      var d = new Date();
      function pad(n) { return n < 10 ? '0' + n : String(n); }
      function safeName(s) { return String(s).replace(/[:\/\\?*\[\]|<>]/g, "-").trim(); }
      var now = d.getUTCFullYear() + '-' + pad(d.getUTCMonth() + 1) + '-' + pad(d.getUTCDate())
        + ' ' + pad(d.getUTCHours()) + ':' + pad(d.getUTCMinutes()) + ':' + pad(d.getUTCSeconds());

      var tags = [], triggers = [], variables = [];
      var tagId = 1, trigId = 100, varId = 200;
      var trigMap = {};
      // ⚠️ GTM built-in trigger IDs must be STRINGS in v2 export JSON.
      // Passing numbers here leaks into firingTriggerId arrays → int64 deserializer
      // in the GTM UI importer rejects the payload with 500 Internal Server Error.
      var allPagesTrigId = '2147479553';
      var ga4ConfigTagName = null;
      // ⚠️ GTM fingerprint is a 13-digit ms-since-epoch string. Anything wider
      // overflows the backend int64 parser → 500 on UI import.
      function fp(id) { return String(baseTs + (id % 1000)); }
      // ── ID stringifiers — ALL IDs in v2 export are strings, never numbers ──
      function sid(n) { return String(n); }

      // ── 1. VARIABLES ────────────────────────────────────────
      var dlKeys = [
        'currency', 'value', 'price', 'num_items', 'event_id',
        'transaction_id', 'affiliation',
        'coupon', 'shipping', 'tax', 'payment_type',
        'search_term', 'shipping_tier', 'method', 'items', 'user_email',
        'item_id', 'item_name', 'item_sku', 'item_brand', 'item_category',
        'item_variant', 'item_list_name', 'quantity'
      ];
      if (S.platforms.indexOf('google') !== -1) {
        dlKeys.push('google_conversion_id');
        for (var gi = 0; gi < S.events.length; gi++) dlKeys.push('google_label_' + S.events[gi]);
      }
      if (S.platforms.indexOf('ga4') !== -1) dlKeys.push('user_id');

      // سلة: أضف customer variables — purchase دايماً بيحتوي على customer data
      // isGuest بيتبعت مع login (Signed In) وpurchase معاً
      if (S.cms === 'salla') {
        var _sallaCustVars = [
          { name: 'DL - customer.isGuest',         path: 'customer.isGuest' },
          { name: 'DL - customer.emailHashed',      path: 'customer.email_hashed' },
          { name: 'DL - customer.phoneHashed',      path: 'customer.phone_hashed' },
          { name: 'DL - customer.firstNameHashed',  path: 'customer.first_name' },
          { name: 'DL - customer.lastNameHashed',   path: 'customer.last_name' }
        ];
        _sallaCustVars.forEach(function (cv) {
          variables.push({
            accountId: '000000000', containerId: '00000000',
            variableId: varId,
            name: cv.name,
            type: 'v',
            parameter: [
              { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
              { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
              { type: 'TEMPLATE', key: 'name', value: cv.path }
            ],
            fingerprint: fp(varId)
          });
          varId++;
        });
      }

      // زد: أضف customer variables تلقائياً لما login event محدد
      var zidLoginVarId = null;
      if (S.cms === 'zid' && S.events.indexOf('login') !== -1) {
        // Variable: DL - customer.isGuest
        variables.push({
          accountId: '000000000', containerId: '00000000',
          variableId: varId,
          name: 'DL - customer.isGuest',
          type: 'v',
          parameter: [
            { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
            { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
            { type: 'TEMPLATE', key: 'name', value: 'customer.is_guest' }
          ],
          fingerprint: fp(varId)
        });
        zidLoginVarId = varId;
        varId++;
        // Variable: DL - customer.externalId
        variables.push({
          accountId: '000000000', containerId: '00000000',
          variableId: varId,
          name: 'DL - customer.externalId',
          type: 'v',
          parameter: [
            { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
            { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
            { type: 'TEMPLATE', key: 'name', value: 'customer.external_id' }
          ],
          fingerprint: fp(varId)
        });
        varId++;
        // Variable: DL - customer.emailHashed
        variables.push({
          accountId: '000000000', containerId: '00000000',
          variableId: varId,
          name: 'DL - customer.emailHashed',
          type: 'v',
          parameter: [
            { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
            { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
            { type: 'TEMPLATE', key: 'name', value: 'customer.email_hashed' }
          ],
          fingerprint: fp(varId)
        });
        varId++;
        // Variable: DL - customer.mobileHashed
        variables.push({
          accountId: '000000000', containerId: '00000000',
          variableId: varId,
          name: 'DL - customer.mobileHashed',
          type: 'v',
          parameter: [
            { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
            { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
            { type: 'TEMPLATE', key: 'name', value: 'customer.mobile_hashed' }
          ],
          fingerprint: fp(varId)
        });
        varId++;
      }

      // ═══════════════════════════════════════════════════════════════
      // سلة — Optional RAW DLV Variables (debugging / advanced)
      // ═══════════════════════════════════════════════════════════════
      // The canonical DL - * variables already read from the NORMALIZED schema
      // produced by the Salla→Unified Bridge (see CMS_DL_MAP.salla.vars above).
      // These extras expose the RAW Salla fields for debugging or for clients
      // who prefer raw-path tags. Safe to ignore if you use the bridge.
      if (S.cms === 'salla') {
        var sallaPerEventVars = [
          // ══════════════════════════════════════════════════════════════
          // سلة — RAW DLV Variables (per-event, pre-bridge)
          // التسمية: Event_Name - Parameter_Name
          // المسارات مستخرجة مباشرة من توثيق سلة الرسمي
          // القيم الـ null أو الحقول غير الموثقة تم تجاهلها
          // ══════════════════════════════════════════════════════════════

          // ── Product List Viewed — المنتجات في obj.data[] ──
          { name: 'Product List Viewed - data',             path: 'data' },
          { name: 'Product List Viewed - product_id',       path: 'data.0.id' },
          { name: 'Product List Viewed - product_name',     path: 'data.0.name' },
          { name: 'Product List Viewed - product_price',    path: 'data.0.price' },
          { name: 'Product List Viewed - product_currency', path: 'data.0.currency' },
          { name: 'Product List Viewed - product_sku',      path: 'data.0.sku' },
          { name: 'Product List Viewed - product_category', path: 'data.0.category.name' },

          // ── Product Viewed — المنتج في obj[0] ──
          { name: 'Product Viewed - product_id',       path: '0.id' },
          { name: 'Product Viewed - product_name',     path: '0.name' },
          { name: 'Product Viewed - product_price',    path: '0.price' },
          { name: 'Product Viewed - product_category', path: '0.category' },
          { name: 'Product Viewed - product_currency', path: '0.currency' },
          { name: 'Product Viewed - product_sku',      path: '0.sku' },
          { name: 'Product Viewed - image_url',        path: '0.image_url' },
          { name: 'Product Viewed - url',              path: '0.url' },

          // ── addToCart — ecommerce.add.products[] ──
          { name: 'addToCart - currencyCode',       path: 'ecommerce.currencyCode' },
          { name: 'addToCart - event_id',           path: 'ecommerce.event_id' },
          { name: 'addToCart - products',           path: 'ecommerce.add.products' },
          { name: 'addToCart - product_id',         path: 'ecommerce.add.products.0.id' },
          { name: 'addToCart - product_name',       path: 'ecommerce.add.products.0.name' },
          { name: 'addToCart - product_price',      path: 'ecommerce.add.products.0.price' },
          { name: 'addToCart - product_quantity',   path: 'ecommerce.add.products.0.quantity' },
          { name: 'addToCart - product_category',   path: 'ecommerce.add.products.0.category' },
          { name: 'addToCart - product_brand',      path: 'ecommerce.add.products.0.brand' },

          // ── Cart Viewed — obj[0].products[] ──
          { name: 'Cart Viewed - cart_id',           path: '0.cart_id' },
          { name: 'Cart Viewed - products',          path: '0.products' },
          { name: 'Cart Viewed - product_id',        path: '0.products.0.id' },
          { name: 'Cart Viewed - product_name',      path: '0.products.0.name' },
          { name: 'Cart Viewed - product_price',     path: '0.products.0.price' },
          { name: 'Cart Viewed - product_quantity',  path: '0.products.0.quantity' },
          { name: 'Cart Viewed - product_brand',     path: '0.products.0.brand' },
          { name: 'Cart Viewed - product_sku',       path: '0.products.0.sku' },
          { name: 'Cart Viewed - product_currency',  path: '0.products.0.currency' },
          { name: 'Cart Viewed - product_coupon',    path: '0.products.0.coupon' },

          // ── Product Removed — obj[0] ──
          { name: 'Product Removed - product_id',       path: '0.id' },
          { name: 'Product Removed - product_name',     path: '0.name' },
          { name: 'Product Removed - product_price',    path: '0.price' },
          { name: 'Product Removed - product_quantity', path: '0.quantity' },
          { name: 'Product Removed - product_category', path: '0.category' },
          { name: 'Product Removed - product_sku',      path: '0.sku' },
          { name: 'Product Removed - product_currency', path: '0.currency' },
          { name: 'Product Removed - cart_id',          path: '0.cart_id' },

          // ── purchase — ecommerce.purchase.actionField + products[] ──
          { name: 'purchase - currencyCode',          path: 'ecommerce.currencyCode' },
          { name: 'purchase - event_id',              path: 'ecommerce.event_id' },
          { name: 'purchase - actionField_id',        path: 'ecommerce.purchase.actionField.id' },
          { name: 'purchase - actionField_total',     path: 'ecommerce.purchase.actionField.total' },
          { name: 'purchase - actionField_revenue',   path: 'ecommerce.purchase.actionField.revenue' },
          { name: 'purchase - products',              path: 'ecommerce.purchase.products' },
          { name: 'purchase - product_id',            path: 'ecommerce.purchase.products.0.id' },
          { name: 'purchase - product_name',          path: 'ecommerce.purchase.products.0.name' },
          { name: 'purchase - product_price',         path: 'ecommerce.purchase.products.0.price' },
          { name: 'purchase - product_quantity',      path: 'ecommerce.purchase.products.0.quantity' },
          { name: 'purchase - product_category',      path: 'ecommerce.purchase.products.0.category' },
          { name: 'purchase - product_currency',      path: 'ecommerce.purchase.products.0.currency' },

          // ── purchase — customer.* (موجودة فقط في حدث purchase حسب التوثيق) ──
          { name: 'purchase - customer_isGuest',         path: 'customer.isGuest' },
          { name: 'purchase - customer_name',            path: 'customer.name' },
          { name: 'purchase - customer_firstNameHashed', path: 'customer.first_name' },
          { name: 'purchase - customer_lastNameHashed',  path: 'customer.last_name' },
          { name: 'purchase - customer_email',           path: 'customer.email' },
          { name: 'purchase - customer_phone',           path: 'customer.phone' },
          { name: 'purchase - customer_emailHashed',     path: 'customer.email_hashed' },
          { name: 'purchase - customer_phoneHashed',     path: 'customer.phone_hashed' }
        ];
        sallaPerEventVars.forEach(function (v) {
          variables.push({
            accountId: '000000000', containerId: '00000000',
            variableId: varId,
            name: v.name,
            type: 'v',
            parameter: [
              { type: 'INTEGER', key: 'dataLayerVersion', value: '2' },
              { type: 'BOOLEAN', key: 'setDefaultValue', value: 'false' },
              { type: 'TEMPLATE', key: 'name', value: v.path }
            ],
            fingerprint: fp(varId)
          });
          varId++;
        });
      }

      // ═══════════════════════════════════════════════════════════════
      // زد — Extra DLV Variables (per-event specifics)
      // ═══════════════════════════════════════════════════════════════
      if (S.cms === 'zid') {
        var zidExtraVars = [
          // ══════════════════════════════════════════════════════════════
          // زد — RAW DLV Variables (per-event, GA4-compatible schema)
          // التسمية: Event_Name - Parameter_Name
