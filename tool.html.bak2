          { key: 'currency', value: '{{Product Viewed - product_currency}}' },
          { key: 'value',    value: '{{Product Viewed - product_price}}' },
          { key: 'items', value: JSON.stringify([{ item_id: '{{Product Viewed - product_id}}', item_name: '{{Product Viewed - product_name}}', item_category: '{{Product Viewed - product_category}}', price: '{{Product Viewed - product_price}}' }]) }
        ],
        // view_cart → 0.products.0.*
        view_cart: [
          { key: 'currency', value: '{{Cart Viewed - product_currency}}' },
          { key: 'value',    value: '{{Cart Viewed - product_price}}' },
          { key: 'items', value: JSON.stringify([{ item_id: '{{Cart Viewed - product_id}}', item_name: '{{Cart Viewed - product_name}}', price: '{{Cart Viewed - product_price}}', quantity: '{{Cart Viewed - product_quantity}}' }]) }
        ],
        // begin_checkout → cart::submitted (no product data in raw push)
        begin_checkout: [
          { key: 'content_type', value: 'product' }
        ],
        // view_item_list → data.0.*
        view_item_list: [
          { key: 'items', value: JSON.stringify([{ item_id: '{{Product List Viewed - product_id}}', item_name: '{{Product List Viewed - product_name}}', item_category: '{{Product List Viewed - product_category}}', price: '{{Product List Viewed - product_price}}', currency: '{{Product List Viewed - product_currency}}' }]) }
        ],
        // add_to_wishlist → Product Added to Wishlist (no product data)
        add_to_wishlist: [
          { key: 'content_type', value: 'product' }
        ],
        // login → Signed In
        login: [{ key: 'method', value: 'salla' }]
      };

      for (var pi2 = 0; pi2 < S.platforms.length; pi2++) {
        var plat = S.platforms[pi2];
        // Use per-platform event selection — if set, use it; otherwise fall back to union S.events
        var platEvList2 = (S.platformEvents && S.platformEvents[plat] && S.platformEvents[plat].length)
          ? S.platformEvents[plat] : S.events;
        for (var ei2 = 0; ei2 < platEvList2.length; ei2++) {
          var evId2 = platEvList2[ei2];
          var ev2 = GA4[evId2];
          if (!trigMap[evId2]) continue;

          // ── Google Ads: awct ──
          if (plat === 'google') {
            var convP = GOOGLE_CONV_PARAMS[evId2];
            if (!convP) continue;
            var gAdsId2 = S.pixelIds['google'] || 'AW-XXXXXXXXXX';
            // Labels are GTM Constants — reference the constant variable
            var evLblKey = evId2.charAt(0).toUpperCase() + evId2.slice(1).replace(/_/g, ' ');
            var gLabelId = '{{Const - Google Label ' + evLblKey + '}}';
            var convIdNum = parseInt((gAdsId2.replace('AW-', '')).split('/')[0]);
            // ⚠️ Skip awct tag entirely if no valid Conversion ID — conversionId:0 causes GTM "Service unavailable" on import
            if (!convIdNum || convIdNum <= 0) continue;
            var evLbl2 = evLabels[evId2] || evId2;
            // ── Salla: use raw per-event variable paths for awct ──
            var _awctValue    = convP.hasValue ? '{{DL - value}}' : '0';
            var _awctCurrency = '{{DL - currency}}';
            var _awctOrderId  = '{{DL - transaction_id}}';
            if (S.cms === 'salla') {
              var _sAwctValMap = { view_item: '{{Product Viewed - product_price}}', add_to_cart: '{{addToCart - product_price}}', begin_checkout: '0', purchase: '{{purchase - actionField_revenue}}', add_to_wishlist: '0' };
              var _sAwctCurMap = { view_item: '{{Product Viewed - product_currency}}', add_to_cart: '{{addToCart - currencyCode}}', begin_checkout: '', purchase: '{{purchase - currencyCode}}', add_to_wishlist: '' };
              var _sAwctTxMap  = { purchase: '{{purchase - actionField_id}}' };
              _awctValue    = convP.hasValue ? (_sAwctValMap[evId2] || '0') : '0';
              _awctCurrency = _sAwctCurMap[evId2] || '{{DL - currency}}';
              _awctOrderId  = _sAwctTxMap[evId2]  || '';
            }
            var awctParams = [
              { type: 'TEMPLATE', key: 'conversionId', value: String(convIdNum) },
              { type: 'TEMPLATE', key: 'conversionLabel', value: gLabelId },
              { type: 'TEMPLATE', key: 'conversionValue', value: _awctValue },
              { type: 'BOOLEAN', key: 'enableDynamicRemarketing', value: 'false' }
            ];
            if (convP.hasCurrency && _awctCurrency) awctParams.push({ type: 'TEMPLATE', key: 'currencyCode', value: _awctCurrency });
            if (convP.hasTxId && _awctOrderId) awctParams.push({ type: 'TEMPLATE', key: 'orderId', value: _awctOrderId });
            // ── items / contents — products array for Dynamic Remarketing & cart data ──
            var _awctItemsSalla = {
              view_item:      '{{Product Viewed - product_id}}',
              add_to_cart:    '{{addToCart - products}}',
              view_cart:      '{{Cart Viewed - products}}',
              begin_checkout: '{{Cart Viewed - products}}',
              purchase:       '{{purchase - products}}'
            };
            var _awctItemsGeneric = {
              view_item:      '{{DL - items}}',
              add_to_cart:    '{{DL - items}}',
              view_cart:      '{{DL - items}}',
              begin_checkout: '{{DL - items}}',
              purchase:       '{{DL - items}}'
            };
            var _awctItems = S.cms === 'salla'
              ? (_awctItemsSalla[evId2]  || null)
              : (_awctItemsGeneric[evId2] || null);
            if (_awctItems) awctParams.push({ type: 'TEMPLATE', key: 'items', value: _awctItems });
            // NOTE: Enhanced Conversions for Google Ads cannot be configured via 'userProperties'
            // on an 'awct' tag (that parameter belongs to 'gaawe'). On 'awct' tags, EC is configured
            // from the Google Ads UI → Conversions → enable Enhanced Conversions, and the Conversion
            // Linker tag (already added above) handles the rest. Adding unsupported params here causes
            // GTM import to fail with "Service unavailable".
            tags.push({
              accountId: '000000000', containerId: '00000000', tagId: tagId,
              name: safeName('Google Ads | ' + evLbl2),
              type: 'awct',
              parameter: awctParams,
              firingTriggerId: [trigMap[evId2]],
              notes: 'Google Ads Conversion (awct) — eventKey: ' + evId2 + ' | Conversion ID: ' + gAdsId2 + ' | Label: ' + gLabelId + ' | ⚠️ uses conversionId+conversionLabel only — does NOT send a GA4 event. | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
            continue;
          }

          // ── GA4: gaawe ──
          if (plat === 'ga4') {
            var ga4Id2 = S.pixelIds['ga4'] || 'G-XXXXXXXXXX';
            // ── Salla: use SALLA_GA4_EV_PARAMS (raw per-event paths, no bridge dependency) ──
            var ga4Params = (S.cms === 'salla' ? SALLA_GA4_EV_PARAMS[evId2] : GA4_EV_PARAMS[evId2]) || [];
            var evLbl3 = evLabels[evId2] || evId2;
            // ── classic pattern (UI-import safe) ─────────────────────────
            // Using TAG_REFERENCE to the Google Tag causes GTM UI import to
            // return 500 in some workspaces. The plain measurementIdOverride
            // works in both the public API and the UI importer.
            var gaaweP = [
              { type: 'BOOLEAN',  key: 'overrideSettings',      value: 'true' },
              { type: 'TEMPLATE', key: 'measurementIdOverride', value: ga4Id2 },
              { type: 'TEMPLATE', key: 'eventName',             value: evId2 }
            ];
            if (ga4Params.length) {
              gaaweP.push({
                type: 'LIST', key: 'eventParameters',
                list: ga4Params.map(function (p) {
                  return {
                    type: 'MAP', map: [
                      { type: 'TEMPLATE', key: 'name', value: p.key },
                      { type: 'TEMPLATE', key: 'value', value: p.value }
                    ]
                  };
                })
              });
            }
            // H2: SS serverContainerUrl — route gaawe events through sGTM when SS enabled
            if (window.ET && window.ET.ssEnabled && window.ET.ssUrl) {
              gaaweP.push({ type: 'TEMPLATE', key: 'serverContainerUrl', value: window.ET.ssUrl });
            }
            tags.push({
              accountId: '000000000', containerId: '00000000', tagId: tagId,
              name: safeName('GA4 | ' + evLbl3),
              type: 'gaawe',
              parameter: gaaweP,
              firingTriggerId: [trigMap[evId2]],
              notes: 'GA4 Event (gaawe) — eventName: ' + evId2 + ' | Measurement ID: ' + ga4Id2 + (window.ET && window.ET.ssEnabled ? ' | 🔁 sGTM: ' + window.ET.ssUrl : '') + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
            continue;
          }

          // ── Other platforms: HTML ──
          // ⚠️ Salla: use SALLA_TAGHTML (raw per-event paths) instead of generic TAGHTML
          var _tagSrc = (S.cms === 'salla' && SALLA_TAGHTML[plat]) ? SALLA_TAGHTML : TAGHTML;
          var platEv = PMAP[plat] && PMAP[plat][evId2];
          var rawHtml = _tagSrc[plat] && _tagSrc[plat][platEv];
          if (!rawHtml) continue;
          var evLbl4 = evLabels[evId2] || evId2;
          var htmlFinal = rawHtml.replace(/\[S\]/g, '<scr' + 'ipt>').replace(/\[\/S\]/g, '<\/script>');
          tags.push({
            accountId: '000000000', containerId: '00000000', tagId: tagId,
            name: safeName(PM[plat].name + ' | ' + evLbl4),
            type: 'html',
            parameter: [
              { type: 'TEMPLATE', key: 'html', value: htmlFinal },
              { type: 'BOOLEAN', key: 'supportDocumentWrite', value: 'false' }
            ],
            firingTriggerId: [trigMap[evId2]],
            notes: 'Platform: ' + PM[plat].name + ' | GA4: ' + evId2 + ' | Platform event: ' + (platEv || evId2) + ' | Generated by Easy Track',
            fingerprint: fp(tagId)
          });
          tagId++;

          // H3: SS Relay tag — forwards events to sGTM for server-side fan-out
          // Added only when SS is enabled AND this platform has SS activated
          if (window.ET && window.ET.ssEnabled && window.ET.ssUrl &&
              ['meta', 'tiktok', 'snapchat', 'mixpanel'].indexOf(plat) !== -1 &&
              window.ET.ssPlatforms && window.ET.ssPlatforms[plat]) {
            var _ssRelayHtml = buildSSRelayTag(plat, window.ET.ssUrl, evId2, platEv);
            if (_ssRelayHtml) {
              tags.push({
                accountId: '000000000', containerId: '00000000', tagId: tagId,
                name: safeName(PM[plat].name + ' | SS Relay | ' + evLbl4),
                type: 'html',
                parameter: [
                  { type: 'TEMPLATE', key: 'html', value: _ssRelayHtml },
                  { type: 'BOOLEAN', key: 'supportDocumentWrite', value: 'false' }
                ],
                firingTriggerId: [trigMap[evId2]],
                notes: 'Server-Side Relay — forwards ' + plat + ' events to sGTM at ' + window.ET.ssUrl + ' for CAPI/server-side fan-out | Generated by Easy Track',
                fingerprint: fp(tagId)
              });
              tagId++;
            }
          }
        }
      }

      // ── Google Ads Remarketing ──
      if (S.platforms.indexOf('google') !== -1) {
        var rmkId = S.pixelIds['google_rmk'] || S.pixelIds['google'] || 'AW-XXXXXXXXXX';
        var rmkNum = parseInt(rmkId.replace('AW-', ''));
        // ⚠️ Skip remarketing tag if no valid Conversion ID — conversionId:0 causes GTM "Service unavailable"
        if (!rmkNum || rmkNum <= 0) rmkNum = null;
        if (rmkNum) {
          tags.push({
            accountId: '000000000', containerId: '00000000', tagId: tagId,
            name: 'Google Ads | Remarketing',
            type: 'sp',
            parameter: [
              { type: 'TEMPLATE', key: 'conversionId', value: String(rmkNum) },
              { type: 'BOOLEAN', key: 'enableDynamicRemarketing', value: 'true' }
            ],
            firingTriggerId: [allPagesTrigId],
            notes: 'Dynamic Remarketing Tag | Generated by Easy Track',
            fingerprint: fp(tagId)
          });
          tagId++;
        }
      }

      // ── Build Folders ──
      var folders = [];
      var folderId = 10;
      var folderMap = {};

      var folderDefs = [
        { key: 'consent', name: '⚡ Consent Mode v2' },
        { key: 'base', name: '🔌 Base Codes' },
        { key: 'google', name: '📊 Google Ads' },
        { key: 'ga4', name: '📈 Google Analytics 4' },
        { key: 'meta', name: '📘 Meta' },
        { key: 'snapchat', name: '👻 Snapchat' },
        { key: 'tiktok', name: '🎵 TikTok' },
        { key: 'twitter', name: '𝕏 X - Twitter' },
        { key: 'mixpanel', name: '📈 Mixpanel' },
        { key: 'vars', name: '🔧 Variables' }
      ];

      folderDefs.forEach(function (fd) {
        folders.push({
          accountId: '000000000', containerId: '00000000',
          folderId: folderId,
          name: fd.name,
          fingerprint: fp(folderId)
        });
        folderMap[fd.key] = folderId;
        folderId++;
      });

      // Assign tags to folders — ordered from most-specific to least-specific
      tags.forEach(function (tag) {
        var n = tag.name.toLowerCase();
        if (n.indexOf('consent') !== -1) tag.parentFolderId = folderMap['consent'];
        // GA4 tags (Google Tag + Event tags) — check before the generic "google" match
        else if (n.indexOf('ga4') !== -1 || (n.indexOf('google analytics') !== -1)) tag.parentFolderId = folderMap['ga4'];
        // Google Ads — conversion linker, base tag, conversions, remarketing
        else if (n.indexOf('google ads') !== -1 || n.indexOf('remarketing') !== -1 || n.indexOf('conversion linker') !== -1) tag.parentFolderId = folderMap['google'];
        else if (n.indexOf('meta') !== -1) tag.parentFolderId = folderMap['meta'];
        else if (n.indexOf('snapchat') !== -1) tag.parentFolderId = folderMap['snapchat'];
        else if (n.indexOf('tiktok') !== -1) tag.parentFolderId = folderMap['tiktok'];
        else if (n.indexOf('twitter') !== -1 || n.indexOf('x-') !== -1 || n.indexOf('𝕏') !== -1) tag.parentFolderId = folderMap['twitter'];
        else if (n.indexOf('mixpanel') !== -1) tag.parentFolderId = folderMap['mixpanel'];
        // Base / utility tags (Cookie Capture, Base Code, Google Tag fallbacks)
        else if (n.indexOf('base code') !== -1 || n.indexOf('cookie capture') !== -1 || n.indexOf('google tag') !== -1) tag.parentFolderId = folderMap['base'];
        // Safety net: nothing unfoldered
        else tag.parentFolderId = folderMap['base'];
      });

      // Assign variables to vars folder
      variables.forEach(function (v) { v.parentFolderId = folderMap['vars']; });

      // ── SS: Per-Platform × Per-Event Relay Tags ──────────────────────────────
      if (window.ET && window.ET.ssEnabled) {
        var ssUrl = window.ET.ssUrl.replace(/\/$/, '');

        // Helper: build relay payload script for a specific platform+event
        // Reads full user_data from cookies + dataLayer.customer (Salla/Zid aware)
        function buildRelayPayload(plat, ga4EvName, platEvName) {
          // CMS-specific value/currency/transId paths
          var valExpr, curExpr, txExpr, itemsExpr;
          if (S.cms === 'salla') {
            var sallaValMap = {
              purchase:'(ec.purchase&&ec.purchase.actionField&&ec.purchase.actionField.total)||0',
              add_to_cart:'(ec.add&&ec.add.products&&ec.add.products[0]&&ec.add.products[0].price)||0',
              view_item:'(obj&&obj.price)||0',
              initiate_checkout:'0',view_content:'(obj&&obj.price)||0',
              page_view:'0',lead:'0',sign_up:'0',search:'0'
            };
            var sallaCurMap = {
              purchase:'(ec.currencyCode)||"SAR"',
              add_to_cart:'(ec.currencyCode)||"SAR"',
              default:'"SAR"'
            };
            var sallaTxMap = {
              purchase:'(ec.purchase&&ec.purchase.actionField&&ec.purchase.actionField.id)||""'
            };
            var sallaItemsMap = {
              purchase:'JSON.stringify((ec.purchase&&ec.purchase.products)||[])',
              add_to_cart:'JSON.stringify((ec.add&&ec.add.products)||[])',
              default:'JSON.stringify([])'
            };
            valExpr   = sallaValMap[ga4EvName]   || sallaValMap[plat]   || '0';
            curExpr   = sallaCurMap[ga4EvName]   || sallaCurMap['default'];
            txExpr    = sallaTxMap[ga4EvName]    || '""';
            itemsExpr = sallaItemsMap[ga4EvName] || sallaItemsMap['default'];
          } else {
            // Zid / generic GA4 schema
            valExpr   = '(ec.value)||0';
            curExpr   = '(ec.currency)||"SAR"';
            txExpr    = '(ec.transaction_id)||""';
            itemsExpr = 'JSON.stringify((ec.items)||[])';
          }

          return '<script>\n'
            + '(function(){\n'
            + '  try {\n'
            + '    function getCk(n){var m=("; "+document.cookie).split("; "+n+"=");return m.length===2?m.pop().split(";")[0]:""}\n'
            + '    var d=window.dataLayer||[]; var ec={}; var cust={}; var obj={};\n'
            + '    for(var i=d.length-1;i>=0;i--){\n'
            + '      if(d[i]&&d[i].ecommerce&&!ec.currency&&!ec.value){ec=d[i].ecommerce;}\n'
            + '      if(d[i]&&d[i].customer&&!cust.email_hashed){cust=d[i].customer;}\n'
            + '      if(d[i]&&d[i][0]&&!obj.price){obj=d[i][0];}\n'
            + '    }\n'
            + '    var em  = cust.email_hashed||cust.emailHashed||getCk("et_em")||"";\n'
            + '    var ph  = cust.phone_hashed||cust.mobile_hashed||cust.phoneHashed||getCk("et_ph")||"";\n'
            + '    var fn  = cust.first_name||cust.firstName||"";\n'
            + '    var ln  = cust.last_name||cust.lastName||"";\n'
            + '    var xid = cust.external_id||cust.externalId||getCk("external_id")||"";\n'
            + '    var eid = (function(){\n'
            + '      for(var i=d.length-1;i>=0;i--){\n'
            + '        if(d[i]&&(d[i].event_id||(d[i].ecommerce&&d[i].ecommerce.event_id)))\n'
            + '          return String(d[i].event_id||d[i].ecommerce.event_id);\n'
            + '      } return "ET-"+Date.now().toString(36).toUpperCase();\n'
            + '    })();\n'
            + '    var items = (function(){try{return ' + itemsExpr + ';}catch(e){return "[]";}}());\n'
            + '    var contentIds = (function(){\n'
            + '      try{var arr=JSON.parse(items);return arr.map(function(x){return x.item_id||x.id||"";}).join(",");}\n'
            + '      catch(e){return "";}\n'
            + '    })();\n'
            + '    var payload = {\n'
            + '      "v":"2","en":"' + ga4EvName + '","ep_platform":"' + plat + '","ep_platform_event":"' + platEvName + '",\n'
            + '      "ep_event_id":eid,\n'
            + '      "epn_value":String(' + valExpr + '),\n'
            + '      "ep_currency":' + curExpr + ',\n'
            + '      "ep_transaction_id":' + txExpr + ',\n'
            + '      "ep_content_ids":contentIds,\n'
            + '      "ep_fbclid":getCk("_fbp_clid")||"","ep_gclid":getCk("_gclid")||"",\n'
            + '      "ep_ttclid":getCk("_ttclid")||"","ep_sccid":getCk("_ScCid")||"",\n'
            + '      "ep_wbraid":getCk("_wbraid")||"","ep_gbraid":getCk("_gbraid")||"",\n'
            + '      "up_em":em,"up_ph":ph,"up_fn":fn,"up_ln":ln,"up_external_id":xid,\n'
            + '      "up_fbp":getCk("_fbp")||"","up_fbc":getCk("_fbc")||"",\n'
            + '      "up_ttp":getCk("_ttp")||"","up_scid":getCk("_scid")||""\n'
            + '    };\n'
            + '    var qs = Object.keys(payload).filter(function(k){return payload[k]!=="";}).map(function(k){\n'
            + '      return encodeURIComponent(k)+"="+encodeURIComponent(payload[k]);\n'
            + '    }).join("&");\n'
            + '    var endpoint = "' + ssUrl + '/g/collect";\n'
            + '    if(navigator.sendBeacon){navigator.sendBeacon(endpoint+"?"+qs);}\n'
            + '    else{fetch(endpoint+"?"+qs,{method:"POST",keepalive:true}).catch(function(){});}\n'
            + '  }catch(e){}\n'
            + '})();\n'
            + '<\/script>';
        }

        // SS relay event name map (GA4 event → CMS data layer event name)
        var ssRelayEvMap = {
          salla: {
            purchase: 'purchase', add_to_cart: 'addToCart',
            initiate_checkout: 'cart::submitted', view_content: 'Product Viewed',
            page_view: 'page_view', lead: 'generate_lead',
            sign_up: 'sign_up', search: 'search'
          },
          zid: {
            purchase: 'purchase', add_to_cart: 'add_to_cart',
            initiate_checkout: 'begin_checkout', view_content: 'view_item',
            page_view: 'page_view', lead: 'generate_lead',
            sign_up: 'sign_up', search: 'search'
          }
        };
        var ssEvNameForCms = ssRelayEvMap[S.cms] || ssRelayEvMap['zid'];

        // Platform event name map (SS event key → platform-specific name)
        var ssPlEv = {
          meta:   { purchase:'Purchase', add_to_cart:'AddToCart', initiate_checkout:'InitiateCheckout', view_content:'ViewContent', page_view:'PageView', lead:'Lead', sign_up:'CompleteRegistration', search:'Search' },
          gads:   { purchase:'conversion', add_to_cart:'conversion', initiate_checkout:'conversion', view_content:'conversion', lead:'conversion', sign_up:'conversion' },
          snap:   { purchase:'PURCHASE', add_to_cart:'ADD_CART', initiate_checkout:'START_CHECKOUT', view_content:'VIEW_CONTENT', page_view:'PAGE_VIEW', lead:'SIGN_UP', sign_up:'SIGN_UP', search:'SEARCH' },
          tiktok: { purchase:'CompletePayment', add_to_cart:'AddToCart', initiate_checkout:'InitiateCheckout', view_content:'ViewContent', page_view:'Pageview', lead:'SubmitForm', sign_up:'CompleteRegistration', search:'Search' }
        };

        // Build relay tag for each SS platform × event
        _pcSS.platforms.forEach(function(plat) {
          var platEvs = _pcSS.events[plat] || [];
          platEvs.forEach(function(evKey) {
            var ga4Name  = ssEvNameForCms[evKey] || evKey;
            var platName = (ssPlEv[plat] && ssPlEv[plat][evKey]) || evKey;

            // Find matching trigger in trigMap (web container event triggers)
            // trigMap keys are GA4 event keys — match by evKey
            var relayTrigId = trigMap[evKey];
            // If no matching trigger (e.g. view_content / initiate_checkout mapped differently), fall back to all pages
            if (!relayTrigId) {
              // Try view_item for view_content, begin_checkout for initiate_checkout
              var fallback = { view_content:'view_item', initiate_checkout:'begin_checkout', sign_up:'sign_up', lead:'lead', page_view:'page_view' };
              relayTrigId = trigMap[fallback[evKey]] || allPagesTrigId;
            }

            var relayHtml = buildRelayPayload(plat, ga4Name, platName);
            tags.push({
              accountId:'000000000', containerId:'00000000', tagId: tagId,
              name: safeName(
                (plat === 'meta' ? 'Meta' : plat === 'gads' ? 'Google Ads' : plat === 'snap' ? 'Snapchat' : 'TikTok')
                + ' | SS Relay | ' + evKey
              ),
              type: 'html',
              parameter:[
                { type:'TEMPLATE', key:'html', value: relayHtml },
                { type:'BOOLEAN',  key:'supportDocumentWrite', value:'false' }
              ],
              firingTriggerId: [ relayTrigId ],
              notes: plat.toUpperCase() + ' SS Relay — fires on "' + ga4Name + '" → sends to sGTM (' + ssUrl + '). Platform event: ' + platName + ' | CMS: ' + (S.cms||'') + ' | Generated by Easy Track',
              fingerprint: fp(tagId)
            });
            tagId++;
          });
        });

      } // end SS relay tags block

      // ═══════════════════════════════════════════════════════════════
      // POST-PROCESS: normalize everything for GTM UI Import compatibility
      // ═══════════════════════════════════════════════════════════════
      // The UI importer (tagmanager.google.com/api/.../import) is STRICTER than
      // the public Tag Manager API. It rejects numeric IDs, >13-digit fingerprints,
      // and any empty monitoringMetadata / path fields. These fixes guarantee
      // "Import" succeeds without 500 Internal Server Error.

      function normalizeTag(t) {
        t.accountId   = '0';
        t.containerId = '0';
        t.tagId       = sid(t.tagId);
        if (t.parentFolderId != null) t.parentFolderId = sid(t.parentFolderId);
        if (Array.isArray(t.firingTriggerId))  t.firingTriggerId  = t.firingTriggerId.map(sid);
        if (Array.isArray(t.blockingTriggerId)) t.blockingTriggerId = t.blockingTriggerId.map(sid);
        if (!t.tagFiringOption) t.tagFiringOption = 'ONCE_PER_EVENT';
        // ⚠️ DO NOT add empty monitoringMetadata — UI importer rejects empty MAP here.
        if (t.monitoringMetadata && Array.isArray(t.monitoringMetadata.map) && !t.monitoringMetadata.map.length) {
          delete t.monitoringMetadata;
        }
        // ⚠️ gaawe: keep measurementIdOverride (tag needs SOME way to know the GA4
        // property). The GA4 backend lookup only fails on "Service unavailable" when
        // the measurement ID is malformed/placeholder. With a real ID (G-S04FXD56P6)
        // the lookup succeeds, so no stripping needed. Caller must pass a real ID.
        // However REMOVE any empty LIST params (e.g. empty userProperties) — they
        // fail int64 deserialization in the UI importer.
        if (Array.isArray(t.parameter)) {
          t.parameter = t.parameter.filter(function (p) {
            if (p.type === 'LIST' && Array.isArray(p.list) && p.list.length === 0) return false;
            return true;
          });
        }
        return t;
      }
      function normalizeTrigger(tr) {
        tr.accountId   = '0';
        tr.containerId = '0';
        tr.triggerId   = sid(tr.triggerId);
        if (tr.parentFolderId != null) tr.parentFolderId = sid(tr.parentFolderId);
        return tr;
      }
      function normalizeVariable(v) {
        v.accountId   = '0';
        v.containerId = '0';
        v.variableId  = sid(v.variableId);
        if (v.parentFolderId != null) v.parentFolderId = sid(v.parentFolderId);
        return v;
      }
      function normalizeFolder(f) {
        f.accountId   = '0';
        f.containerId = '0';
        f.folderId    = sid(f.folderId);
        return f;
      }
      function normalizeBuiltIn(b) {
        b.accountId   = '0';
        b.containerId = '0';
        return b;
      }

      return {
        exportFormatVersion: 2,
        exportTime: now,
        containerVersion: {
          accountId: '0',
          containerId: '0',
          containerVersionId: '0',
          container: {
            accountId: '0',
            containerId: '0',
            name: safeName('Easy Track - ' + ((S.lead && S.lead.name) || 'Client')),
            publicId: 'GTM-PLACEHLD',
            usageContext: ['WEB'],
            notes: 'Generated by Easy Track | CMS: ' + (S.cms || 'n/a')
              + ' | Platforms: ' + (S.platforms || []).join(',')
              + ' | Events: ' + (S.events || []).join(',')
              + ' | Built: ' + now,
            fingerprint: fp(0)
          },
          tag:      tags.map(normalizeTag),
          trigger:  triggers.map(normalizeTrigger),
          variable: variables.map(normalizeVariable),
          folder:   folders.map(normalizeFolder),
          builtInVariable: [
            // ── Pages ──
            { accountId: '0', containerId: '0', type: 'PAGE_URL', name: 'Page URL' },
            { accountId: '0', containerId: '0', type: 'PAGE_HOSTNAME', name: 'Page Hostname' },
            { accountId: '0', containerId: '0', type: 'PAGE_PATH', name: 'Page Path' },
            { accountId: '0', containerId: '0', type: 'REFERRER', name: 'Referrer' },
            // ── Events ──
            { accountId: '0', containerId: '0', type: 'EVENT', name: 'Event' },
            // ── Clicks ──
            { accountId: '0', containerId: '0', type: 'CLICK_ELEMENT', name: 'Click Element' },
            { accountId: '0', containerId: '0', type: 'CLICK_CLASSES', name: 'Click Classes' },
            { accountId: '0', containerId: '0', type: 'CLICK_ID', name: 'Click ID' },
            { accountId: '0', containerId: '0', type: 'CLICK_TARGET', name: 'Click Target' },
            { accountId: '0', containerId: '0', type: 'CLICK_URL', name: 'Click URL' },
            { accountId: '0', containerId: '0', type: 'CLICK_TEXT', name: 'Click Text' },
            // ── Forms ──
            { accountId: '0', containerId: '0', type: 'FORM_ELEMENT', name: 'Form Element' },
            { accountId: '0', containerId: '0', type: 'FORM_CLASSES', name: 'Form Classes' },
            { accountId: '0', containerId: '0', type: 'FORM_ID', name: 'Form ID' },
            { accountId: '0', containerId: '0', type: 'FORM_TARGET', name: 'Form Target' },
            { accountId: '0', containerId: '0', type: 'FORM_URL', name: 'Form URL' },
            { accountId: '0', containerId: '0', type: 'FORM_TEXT', name: 'Form Text' },
            // ── Utilities (safe, universally supported built-ins) ──
            { accountId: '0', containerId: '0', type: 'DEBUG_MODE', name: 'Debug Mode' },
            { accountId: '0', containerId: '0', type: 'RANDOM_NUMBER', name: 'Random Number' },
            { accountId: '0', containerId: '0', type: 'HTML_ID', name: 'HTML ID' },
            { accountId: '0', containerId: '0', type: 'CONTAINER_ID', name: 'Container ID' },
            { accountId: '0', containerId: '0', type: 'CONTAINER_VERSION', name: 'Container Version' }
            // NOTE: SCROLL_*, ENVIRONMENT_NAME, VIDEO_* intentionally omitted —
            // they cause "Error deserializing enum type [BuiltInVariableType]" on some GTM accounts.
            // Add them back in the GTM UI (Variables → Built-In Variables) if needed.
          ]
        }
      };
    }

    // ===== CMS-SPECIFIC DL VARIABLE MAPS =====
    var CMS_DL_MAP = {
      salla: {
        // سلة بتبعت events بـ UA Enhanced Ecommerce format — محتاج UA→GA4 Bridge
        note: '// ✅ سلة — Real Data Layer Examples\n// ─────────────────────────────────────────────────────────────────\n// ⚠️ سلة بتبعت UA Enhanced Ecommerce format — مش GA4 مباشرة\n// استخدم الـ UA→GA4 Bridge tab عشان تحوّل الـ events لـ GA4 تلقائياً\n// تأكد إن GTM Container ID اتحط في: الإعدادات → التسويق → Google Tag Manager\n\n// ── 1) Product List Viewed — المنتجات في obj.data ──\ndataLayer.push({\n  event: "Product List Viewed",\n  status: 200,\n  data: [\n    { id: "1131050439", name: "فرشاة أورما الكهربائية", price: 155.65, currency: "SAR", sku: "DV58595151", category: { name: "الأجهزة" }, is_available: true },\n    { id: "1503084629", name: "جهاز التنظيف بالبخار",  price: 169.57, currency: "SAR", sku: "OM-DV",      category: { name: "الأجهزة" }, is_available: true },\n    { id: "1597494942", name: "مكنسة تولون برميل 1500 واط", price: 256.52, currency: "SAR", sku: "659465223693", category: { name: "الأجهزة" }, is_available: true }\n  ],\n  title: "3 منتجات",\n  source: "categories"\n});\n\n// ── 2) Product Viewed — المنتج في obj[0] ──\ndataLayer.push({\n  0: { id: 1503084629, name: "جهاز التنظيف بالبخار", category: "الأجهزة", price: 169.57, quantity: 0, currency: "SAR", sku: "OM-DV" },\n  event: "Product Viewed"\n});\n\n// ── 3) Add to Cart — ecommerce.add.products ──\ndataLayer.push({\n  event: "addToCart",\n  ecommerce: {\n    currencyCode: "SAR",\n    exchangeRate: "1",\n    event_id: 2674990342,\n    add: {\n      products: [{ id: 1830680877, name: "بكج التنظيف الشامل", category: "العروض", price: 199.13, quantity: 1, brand: "ORMA" }]\n    }\n  }\n});\n\n// ── 4) Signed In ──\ndataLayer.push({ event: "Signed In" });\n\n// ── 5) Product Added to Wishlist ──\ndataLayer.push({ event: "Product Added to Wishlist" });\n\n// ── 6) Cart Viewed — obj[0].products ──\ndataLayer.push({\n  0: {\n    cart_id: "145778443",\n    products: [\n      { id: 1830680877, name: "بكج التنظيف الشامل", category: "العروض", price: 458, quantity: 2, brand: "ORMA", sku: "orma222", currency: "SAR" },\n      { id: 1503084629, name: "جهاز التنظيف بالبخار",  category: "الأجهزة", price: 975.05, quantity: 5, sku: "OM-DV", currency: "SAR" }\n    ]\n  },\n  event: "Cart Viewed"\n});\n\n// ── 7) Product Removed — obj[0] ──\ndataLayer.push({\n  0: { id: 1503084629, name: "جهاز التنظيف بالبخار", category: "الأجهزة", price: 195.01, quantity: 5, cart_id: "145778443", sku: "OM-DV", currency: "SAR" },\n  event: "Product Removed"\n});\n\n// ── 8) Begin Checkout ──\ndataLayer.push({ event: "cart::submitted", status: 200, success: true });\n\n// ── 9) Purchase — ecommerce.purchase.products ──\ndataLayer.push({\n  event: "purchase",\n  ecommerce: {\n    currencyCode: "SAR",\n    exchangeRate: "1",\n    event_id: 253138256,\n    purchase: {\n      actionField: { id: 253138256, total: 83.86, revenue: 83.86, currency_code: "SAR" },\n      products: [{ id: 462352033, name: "...", category: "المكملات الغذائية", price: 73.85, quantity: 1, currency: "SAR" }]\n    }\n  },\n  customer: { isGuest: false, email_hashed: "sha256...", phone_hashed: "sha256..." }\n});\n\n// ── GTM Variables ──\n// • currency    → ecommerce.currencyCode\n// • transaction → ecommerce.event_id  أو  ecommerce.purchase.actionField.id\n// • value       → ecommerce.purchase.actionField.total\n// • product data → obj[0]  أو  ecommerce.add.products  أو  obj.data\n// • login       → Custom Event "Signed In"',
        vars: {
          // ══════════════════════════════════════════════════════════════
          // ⚠️ IMPORTANT: These paths read from the NORMALIZED Salla dataLayer
          //    AFTER the Salla→Unified Bridge has run.
          //    The bridge converts every raw Salla shape (0.*, data[],
          //    ecommerce.add.products[], ecommerce.purchase.products[], ...)
          //    into ONE consistent schema:
          //      { event, event_id, ecommerce:{ currency, price|value, num_items, items:[...] } }
          //    → that's why one `DL - items` variable now works in EVERY tag.
          // ══════════════════════════════════════════════════════════════

          // ── Top-level ──
          currency:       'ecommerce.currency',           // bridge emits canonical "currency" (not currencyCode)
          value:          'ecommerce.value',              // ONLY purchase has value
          price:          'ecommerce.price',              // view_item / add_to_cart / cart / wishlist — per-event semantics
          num_items:      'ecommerce.num_items',          // sum of quantities across items
          event_id:       'event_id',                     // dedup id (top-level) — Meta/TikTok CAPI
          transaction_id: 'ecommerce.transaction_id',     // purchase only
          affiliation:    'ecommerce.affiliation',
          coupon:         'ecommerce.coupon',
          shipping:       'ecommerce.shipping',
          tax:            'ecommerce.tax',
          item_list_name: 'ecommerce.item_list_name',     // view_item_list only

          // ── Items array (full) — GA4 items param ──
          items:          'ecommerce.items',

          // ── Item-level (index 0) — works for ANY event post-bridge ──
          item_id:        'ecommerce.items.0.item_id',
          item_name:      'ecommerce.items.0.item_name',
          item_brand:     'ecommerce.items.0.item_brand',
          item_category:  'ecommerce.items.0.item_category',
          item_variant:   'ecommerce.items.0.item_variant',
          item_sku:       'ecommerce.items.0.item_id',    // SKU mirrored into item_id by bridge
          quantity:       'ecommerce.items.0.quantity',

          // ── Other ──
          search_term: 'search_term',
          method:      'method',

          // ── Customer (passthrough from Salla raw — the bridge preserves it) ──
          'customer.isGuest':          'customer.isGuest',
          'customer.email':            'customer.email',
          'customer.phone':            'customer.phone',
          'customer.emailHashed':      'customer.email_hashed',
          'customer.phoneHashed':      'customer.phone_hashed',
          'customer.firstNameHashed':  'customer.first_name',
          'customer.lastNameHashed':   'customer.last_name'
        },
        eventNames: {
          view_item_list: 'Product List Viewed',
          view_item: 'Product Viewed',
          add_to_cart: 'addToCart',
          view_cart: 'Cart Viewed',
          remove_from_cart: 'Product Removed',
          add_to_wishlist: 'Product Added to Wishlist',
          begin_checkout: 'cart::submitted',
          purchase: 'purchase',
          search: 'search',
          login: 'Signed In'
        }
      },
      zid: {
        // زد بتبعت events GA4-compatible بشكل كبير
        note: '// ✅ زد بتدعم GTM Data Layer — Events بتتبعت تلقائياً\n// تأكد إن GTM Container ID اتحط في: لوحة التحكم → التسويق → Google Tag Manager\n//\n// ── Login User Trigger (تسجيل دخول العميل) ──\n// زد مفيهاش event اسمه "login" — بدل كدا بتبعت customer.is_guest مع كل event\n// عشان تعمل Trigger للعميل المسجّل دخوله في GTM:\n//   Trigger Type  : Page View\n//   Fires on      : Some Page Views\n//   Condition     : customer.isGuest  |  contains  |  false\n//\n// لما العميل logged in بتيجي البيانات دي في كل event:\n//   customer.is_guest      → false\n//   customer.external_id   → Hash فريد للعميل\n//   customer.email         → إيميل العميل\n//   customer.email_hashed  → إيميل مشفّر (SHA-256)\n//   customer.mobile        → رقم الموبايل\n//   customer.mobile_hashed → موبايل مشفّر (SHA-256)',
        vars: {
          // ── Ecommerce top-level ──
          currency: 'ecommerce.currency',
          value: 'ecommerce.value',
          transaction_id: 'ecommerce.transaction_id',
          // ── Purchase-only fields ──
          tax: 'ecommerce.tax',
          shipping: 'ecommerce.shipping',
          coupon: 'ecommerce.coupon',
          // ── Items array (full) ──
          items: 'ecommerce.items',
          // ── Item-level (index 0) — FIXED: all paths include ecommerce.items.0.* ──
          item_id: 'ecommerce.items.0.item_id',
          item_name: 'ecommerce.items.0.item_name',
          item_brand: 'ecommerce.items.0.item_brand',
          item_category: 'ecommerce.items.0.item_category',
          // item_sku: all events EXCEPT purchase use item_sku
          // purchase uses ecommerce.items.0.sku — see DLV - item_sku (Purchase) variable below
          item_sku: 'ecommerce.items.0.item_sku',
          price: 'ecommerce.items.0.price',
          quantity: 'ecommerce.items.0.quantity',
          // ── Other ──
          search_term: 'ecommerce.search_term',
          method: 'method',
          // ── Customer object ──
          'customer.isGuest': 'customer.is_guest',
          'customer.externalId': 'customer.external_id',
          'customer.email': 'customer.email',
          'customer.emailHashed': 'customer.email_hashed',
          'customer.mobile': 'customer.mobile',
          'customer.mobileHashed': 'customer.mobile_hashed'
        },
        eventNames: {
          view_item: 'view_item',
          add_to_cart: 'add_to_cart',
          remove_from_cart: 'remove_from_cart',
          view_cart: 'view_cart',
          begin_checkout: 'begin_checkout',
          purchase: 'purchase',
          add_to_wishlist: 'add_to_wishlist',
          view_item_list: 'view_item_list',
          search: 'search',
          login: '⚠️ Page View + customer.isGuest = false'
        }
      }
    };

    // ===== BUILD DATALAYER =====
    function buildDL() {
      var lines = [];
      lines.push('// ==============================================');
      lines.push('// GTM Data Layer Code — Easy Track');
      lines.push('// ' + new Date().toISOString().split('T')[0]);
      if (S.cms) lines.push('// CMS: ' + CMS[S.cms].name);
      lines.push('// ==============================================');
      lines.push('');

      // سلة أو زد — اعرض الـ note الخاص بيهم
      var cmsMap = CMS_DL_MAP[S.cms];
      if (cmsMap) {
        lines.push(cmsMap.note);
        lines.push('');
        lines.push('// ── GTM Variables المقابلة لـ ' + CMS[S.cms].name + ' ──');
        lines.push('// استخدم الـ Path دي في GTM → Variables → Data Layer Variable');
        lines.push('//');
        var varKeys = Object.keys(cmsMap.vars);
        for (var vi = 0; vi < varKeys.length; vi++) {
          lines.push('//   DL - ' + varKeys[vi] + '  →  ' + cmsMap.vars[varKeys[vi]]);
        }
        lines.push('');
        lines.push('// ── Event Names في سلة/زد ──');
        lines.push('// استخدم Custom Event Trigger في GTM بالأسماء دي:');
        var evKeys = Object.keys(cmsMap.eventNames);
        for (var ei2 = 0; ei2 < evKeys.length; ei2++) {
          if (evKeys[ei2] === 'login' && S.cms === 'zid') {
            lines.push('//   GA4: login  →  زد: ⚠️ مفيش event — استخدم Page View Trigger');
            lines.push('//         Condition: customer.isGuest  contains  false');
          } else {
            lines.push('//   GA4: ' + evKeys[ei2] + '  →  ' + CMS[S.cms].name + ': ' + cmsMap.eventNames[evKeys[ei2]]);
          }
        }
        lines.push('');
        lines.push('// ── Custom Events (لو محتاج تضيف events مش موجودة) ──');
        lines.push('window.dataLayer = window.dataLayer || [];');
        lines.push('');
      } else {
        lines.push('window.dataLayer = window.dataLayer || [];');
        lines.push('');
      }
      for (var ei = 0; ei < S.events.length; ei++) {
        var evId = S.events[ei];
        var ev = GA4[evId];

        // زد: Login مفيهاش event — بدله Page View Trigger
        if (evId === 'login' && S.cms === 'zid') {
          lines.push('// ── LOGIN USER (تسجيل دخول العميل) ──');
          lines.push('// ⚠️ زد مش بتبعت event اسمه "login"');
          lines.push('// بدل كدا، اعمل في GTM الـ Trigger ده:');
          lines.push('//');
          lines.push('//   Trigger Name : Login User');
          lines.push('//   Trigger Type : Page View');
          lines.push('//   Fires on     : Some Page Views');
          lines.push('//   Condition    : customer.isGuest  |  contains  |  false');
          lines.push('//');
          lines.push('// وعشان تقدر تستخدم الشرط ده، أنشئ Data Layer Variable:');
          lines.push('//   Variable Name : DL - customer.isGuest');
          lines.push('//   DL Variable   : customer.is_guest');
          lines.push('//');
          lines.push('// لما العميل logged in، الـ Data Layer بيبعت:');
          lines.push('// {');
          lines.push('//   "customer": {');
          lines.push('//     "is_guest": false,');
          lines.push('//     "external_id": "hash...",');
          lines.push('//     "email": "user@example.com",');
          lines.push('//     "email_hashed": "sha256...",');
          lines.push('//     "mobile": "+966xxxxxxx",');
          lines.push('//     "mobile_hashed": "sha256..."');
          lines.push('//   }');
          lines.push('// }');
          lines.push('');
          continue;
        }

        lines.push('// ── ' + ev.label.toUpperCase() + ' ──');
        lines.push("window.dataLayer.push({");
        lines.push("  event: '" + evId + "',");
        lines.push("  ecommerce: {");
        for (var ri = 0; ri < ev.req.length; ri++) {
          var r = ev.req[ri];
          if (r === 'items') {
            lines.push("    items: [{");
            for (var ii = 0; ii < ev.ip.length; ii++) lines.push("      " + ev.ip[ii] + ": '',  // TODO");
            lines.push("    }],");
          } else {
            lines.push("    " + r + ": '',  // required");
          }
        }
        for (var oi = 0; oi < ev.opt.length; oi++) lines.push("    " + ev.opt[oi] + ": '',  // optional");
        lines.push("  }");
        lines.push("});");
        lines.push('');
      }
      return lines.join('\n');
    }

    // ===== BUILD GUIDE =====
    function buildGuide() {
      var cms = CMS[S.cms];
      var cmsGuides = {
        salla: {
          title: 'ربط GTM بسلة',
          color: '#e84393',
          icon: '🛍️',
          steps: [
            { icon: 'settings', title: 'فتح إعدادات سلة', body: 'الإعدادات → التسويق → Google Tag Manager' },
            { icon: 'content_paste', title: 'حط الـ Container ID', body: 'انسخ الـ Container ID من GTM (GTM-XXXXXX) وحطه في الحقل' },
            { icon: 'save', title: 'احفظ وتأكد', body: 'اضغط حفظ — سلة هترفع GTM تلقائياً على كل الصفحات' },
            { icon: 'code', title: 'ارفع الـ UA→GA4 Bridge', body: 'سلة بتبعت UA Enhanced Ecommerce format — مش GA4 مباشرة.<br><br>في GTM: <strong>Tags → New → Custom HTML</strong><br>• انسخ كود الـ Bridge من تاب "UA→GA4 Bridge"<br>• Trigger: <strong>All Pages</strong><br>• Priority: <strong>10</strong> (عشان يشتغل قبل أي tag تاني)<br><br>⚠️ بدون الـ Bridge هيفضل فيه data مش بتتبعتش' },
            { icon: 'manage_accounts', title: 'Login Trigger (Signed In)', body: 'الـ Container المولّد بيحتوي على Trigger جاهز للـ Login:<br><br>• Trigger Name: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">CE | Login [سلة — Signed In]</code><br>• Trigger Type: <strong>Custom Event</strong><br>• Event Name: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">Signed In</code><br><br>بيتبعت مع البيانات:<br>• <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">customer.isGuest</code> = false<br>• <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">customer.email_hashed</code> (SHA-256)<br>• <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">customer.phone_hashed</code> (SHA-256)' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ GTM Container المولّد متوافق بالكامل مع سلة — بمجرد رفع الـ Bridge والـ Container هيشتغل تلقائياً.' }
          ]
        },
        zid: {
          title: 'ربط GTM بزد',
          color: '#4f6ef7',
          icon: '⚡',
          steps: [
            { icon: 'settings', title: 'فتح لوحة التحكم', body: 'لوحة التحكم → التسويق → Google Tag Manager' },
            { icon: 'content_paste', title: 'حط الـ Container ID', body: 'انسخ الـ Container ID (GTM-XXXXXX) وحطه في الحقل المخصص' },
            { icon: 'save', title: 'احفظ التغييرات', body: 'زد بتحقن GTM تلقائياً على كل صفحات المتجر' },
            { icon: 'manage_accounts', title: 'Login User Trigger', body: 'زد مفيهاش event اسمه "login" — عشان تتبع العميل المسجّل دخوله:<br><br><strong>GTM → Triggers → New</strong><br>• Trigger Type: <strong>Page View</strong><br>• Fires on: <strong>Some Page Views</strong><br>• Condition: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">customer.isGuest</code> <strong>contains</strong> <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">false</code><br><br>الـ Data Layer Variable المطلوب: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:1px 6px;border-radius:3px;">customer.is_guest</code>' },
            { icon: 'check_circle', title: 'جاهز!', body: 'زد بتبعت الأحداث تلقائياً — الـ GTM Container المولّد هيشتغل فوراً بدون أي تعديل إضافي.' }
          ]
        }
      };

      var platGuides = {
        meta: {
          icon: '📘', name: 'Meta Pixel', color: '#1877F2',
          steps: [
            { icon: 'upload_file', title: 'ارفع الـ Container', body: 'نزّل ملف GTM Container من تاب "GTM Container"، ثم في GTM: <strong>Admin → Import Container → Merge</strong>' },
            { icon: 'key', title: 'Pixel ID', body: 'Pixel ID: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:2px 8px;border-radius:4px;">' + (S.pixelIds.meta || 'YOUR_PIXEL_ID') + '</code><br>هتلاقيه في: Business Manager → Events Manager' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ Container فيه كل الـ Tags والأحداث جاهزة ومربوطة — بس ارفعه واختبره من GTM Preview' }
          ]
        },
        tiktok: {
          icon: '🎵', name: 'TikTok Pixel', color: '#46f1c5',
          steps: [
            { icon: 'upload_file', title: 'ارفع الـ Container', body: 'نزّل ملف GTM Container وارفعه: <strong>Admin → Import Container → Merge</strong>' },
            { icon: 'key', title: 'Pixel ID', body: 'Pixel ID: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:2px 8px;border-radius:4px;">' + (S.pixelIds.tiktok || 'YOUR_PIXEL_ID') + '</code><br>TikTok Ads Manager → Assets → Events' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ Container فيه كل أحداث TikTok جاهزة — اختبرها من GTM Preview قبل النشر' }
          ]
        },
        snapchat: {
          icon: '👻', name: 'Snap Pixel', color: '#FFFC00',
          steps: [
            { icon: 'upload_file', title: 'ارفع الـ Container', body: 'نزّل ملف GTM Container وارفعه: <strong>Admin → Import Container → Merge</strong>' },
            { icon: 'key', title: 'Pixel ID', body: 'Pixel ID: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:2px 8px;border-radius:4px;">' + (S.pixelIds.snapchat || 'YOUR_PIXEL_ID') + '</code><br>Snapchat Ads Manager → Assets → Snap Pixel' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ Container المولّد جاهز لـ Snapchat بالكامل — اختبره من GTM Preview' }
          ]
        },
        google: {
          icon: '🔍', name: 'Google Ads', color: '#4285F4',
          steps: [
            { icon: 'upload_file', title: 'ارفع الـ Container', body: 'نزّل ملف GTM Container وارفعه: <strong>Admin → Import Container → Merge</strong>' },
            { icon: 'key', title: 'Conversion ID', body: 'ID: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:2px 8px;border-radius:4px;">' + (S.pixelIds.google || 'YOUR_CONVERSION_ID') + '</code><br>هتلاقيه في: Google Ads → Goals → Conversions' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ Container فيه Tags جاهزة لتتبع الـ Conversions — اختبرها من GTM Preview' }
          ]
        },
        ga4: {
          icon: '📊', name: 'Google Analytics 4', color: '#F9AB00',
          steps: [
            { icon: 'upload_file', title: 'ارفع الـ Container', body: 'نزّل ملف GTM Container وارفعه: <strong>Admin → Import Container → Merge</strong>' },
            { icon: 'key', title: 'Measurement ID', body: 'ID: <code style="color:var(--acc);background:rgba(70,241,197,0.1);padding:2px 8px;border-radius:4px;">' + (S.pixelIds.ga4 || 'G-XXXXXXXXXX') + '</code><br>هتلاقيه في: GA4 Admin → Data Streams' },
            { icon: 'check_circle', title: 'جاهز!', body: 'الـ Container فيه كل أحداث التحليلات جاهزة — اختبرها من GTM Preview' }
          ]
        }
      };

      var importStep = {
        icon: 'upload_file', title: 'استيراد GTM Container',
        body: '<strong>GTM → Admin → Import Container</strong><br>1. اختار ملف الـ Container اللي نزّلته<br>2. اختار Workspace: Default<br>3. اختار <strong>Merge</strong> (مش Overwrite)<br>4. اضغط Confirm<br><br>هيضيف تلقائياً كل الإعدادات الجاهزة'
      };

      var testStep = {
        icon: 'bug_report', title: 'Test & Verify',
        body: '1. <strong>GTM Preview Mode</strong>: Preview → Enter URL<br>2. تأكد إن كل الـ Events بتتبعت<br>3. افتح الـ Helper Extensions:<br>• ✅ Meta Pixel Helper<br>• ✅ TikTok Pixel Helper<br>• ✅ GA4 DebugView<br><br>4. بعد التأكد: <strong>Submit في GTM</strong>'
      };

      function renderStep(num, step, color) {
        color = color || 'var(--acc)';
        return '<div class="gcard" style="border-right:3px solid ' + color + '33;position:relative;">'
          + '<div class="gnum" style="background:' + color + '20;border:1px solid ' + color + '40;color:' + color + ';font-size:13px;">' + num + '</div>'
          + '<div class="gtxt">'
          + '<div class="gtitl" style="display:flex;align-items:center;gap:8px;">'
          + '<span class="material-symbols-outlined" style="font-size:16px;color:' + color + ';font-variation-settings:\'FILL\' 1;">' + (step.icon || 'radio_button_checked') + '</span>'
          + step.title + '</div>'
          + '<div class="gbody">' + step.body + '</div>'
          + '</div></div>';
      }

      var html = '';
      var stepNum = 1;

      // CMS installation
      var cmsG = cmsGuides[S.cms];
      if (cmsG) {
        html += '<div style="background:' + cmsG.color + '10;border:1px solid ' + cmsG.color + '30;border-radius:16px;padding:16px 18px;margin-bottom:20px;">'
          + '<div style="font-weight:800;font-size:15px;color:var(--wht);margin-bottom:12px;">' + cmsG.icon + ' ' + cmsG.title + '</div>';
        cmsG.steps.forEach(function (s) {
          html += renderStep(stepNum++, s, cmsG.color);
        });
        html += '</div>';
      }

      // Import step
      html += renderStep(stepNum++, importStep, 'var(--acc)');

      // Per-platform guides
      S.platforms.forEach(function (p) {
        var pg = platGuides[p];
        if (!pg) return;
        html += '<div style="background:' + pg.color + '10;border:1px solid ' + pg.color + '30;border-radius:16px;padding:16px 18px;margin-bottom:16px;">'
          + '<div style="font-weight:800;font-size:15px;color:var(--wht);margin-bottom:12px;">' + pg.icon + ' ' + pg.name + ' Setup</div>';
        pg.steps.forEach(function (s) {
          html += renderStep(stepNum++, s, pg.color);
        });
        html += '</div>';
      });

      // Test step
      html += renderStep(stepNum++, testStep, '#22c55e');

      return html;
    }

    // ===== BUILD SCORE =====
    function buildScore() {
      var platReqs = {
        meta: {
          view_item: { req: ['currency', 'value'], imp: 7, tip: 'أضف content_ids و content_type للنتائج الأفضل' },
          add_to_cart: { req: ['currency', 'value'], imp: 8, tip: 'content_ids مهم جداً لـ Catalog Ads' },
          begin_checkout: { req: ['currency', 'value'], imp: 9, tip: 'num_items يحسّن الأداء' },
          add_payment_info: { req: ['currency', 'value'], imp: 7, tip: 'مهم لـ Payment funnel tracking' },
          purchase: { req: ['currency', 'value', 'transaction_id'], imp: 10, tip: 'content_type: product إلزامي للـ Purchase' },
          search: { req: [], imp: 4, tip: 'أضف search_string للدقة' },
          add_to_wishlist: { req: ['currency', 'value'], imp: 5, tip: 'مفيد لـ Retargeting' },
          sign_up: { req: [], imp: 6, tip: 'مهم لقياس Lead Quality' },
          view_cart: { req: ['currency', 'value'], imp: 5, tip: 'مفيد لـ Dynamic Ads' },
          view_item_list: { req: [], imp: 4, tip: 'مهم لـ Collection Ads' }
        },
        tiktok: {
          view_item: { req: ['currency', 'value'], imp: 6, tip: 'أضف contents array للـ Catalog' },
          add_to_cart: { req: ['currency', 'value'], imp: 8, tip: 'contents إلزامي لـ Dynamic Ads' },
          begin_checkout: { req: ['currency', 'value'], imp: 9, tip: 'مهم جداً للـ Purchase funnel' },
          add_payment_info: { req: ['currency', 'value'], imp: 7, tip: 'يساعد في تحسين Bid Strategy' },
          purchase: { req: ['currency', 'value', 'transaction_id'], imp: 10, tip: 'event_id مهم لـ Deduplication' },
          search: { req: [], imp: 3, tip: 'keyword مفيد للـ Search Ads' },
          add_to_wishlist: { req: ['currency', 'value'], imp: 5, tip: 'مفيد لـ Retargeting' },
          sign_up: { req: [], imp: 5, tip: 'مهم لـ Lead Gen campaigns' }
        },
        snapchat: {
          view_item: { req: ['currency', 'price'], imp: 6, tip: 'item_ids مهم لـ Dynamic Ads' },
          add_to_cart: { req: ['currency', 'price'], imp: 7, tip: 'item_ids إلزامي لـ Catalog' },
          begin_checkout: { req: ['currency', 'price'], imp: 8, tip: 'number_items مفيد' },
          add_payment_info: { req: ['currency', 'price'], imp: 7, tip: 'مهم لـ Conversion Optimization' },
          purchase: { req: ['currency', 'price', 'transaction_id'], imp: 10, tip: 'client_dedup_id للـ Deduplication' },
          search: { req: [], imp: 3, tip: 'search_string مفيد' },
          add_to_wishlist: { req: ['currency', 'price'], imp: 4, tip: 'مفيد لـ Retargeting' },
          sign_up: { req: [], imp: 5, tip: 'مهم لـ Lead Ads' }
        },
        google: {
          view_item: { req: ['currency', 'value'], imp: 5, tip: 'مش conversion — لكن مفيد للـ Smart Bidding' },
          add_to_cart: { req: ['currency', 'value'], imp: 7, tip: 'يساعد Target ROAS في التعلم' },
          begin_checkout: { req: ['currency', 'value'], imp: 8, tip: 'إلزامي لـ Checkout Abandonment' },
          add_payment_info: { req: ['currency', 'value'], imp: 7, tip: 'conversion مهم للـ Bid Strategy' },
          purchase: { req: ['currency', 'value', 'transaction_id'], imp: 10, tip: 'الـ Primary Conversion — إلزامي' },
          sign_up: { req: [], imp: 6, tip: 'مهم لـ Lead Gen campaigns' },
          search: { req: ['search_term'], imp: 3, tip: 'مفيد للـ Search term analysis' },
          add_to_wishlist: { req: ['currency', 'value'], imp: 4, tip: 'Secondary conversion مفيد' }
        },
        ga4: {
          view_item: { req: ['currency', 'value', 'items'], imp: 7, tip: 'items array مع item_id إلزامي' },
          add_to_cart: { req: ['currency', 'value', 'items'], imp: 8, tip: 'مهم جداً لـ Funnel Analysis' },
          remove_from_cart: { req: ['currency', 'value', 'items'], imp: 4, tip: 'يكمّل الـ Cart funnel' },
          view_cart: { req: ['currency', 'value', 'items'], imp: 5, tip: 'مهم لـ Cart abandonment analysis' },
          begin_checkout: { req: ['currency', 'value', 'items'], imp: 9, tip: 'إلزامي لـ Checkout funnel' },
          add_shipping_info: { req: ['currency', 'value', 'shipping_tier', 'items'], imp: 7, tip: 'يكشف Shipping abandonment' },
          add_payment_info: { req: ['currency', 'value', 'payment_type', 'items'], imp: 8, tip: 'يكشف Payment abandonment' },
          purchase: { req: ['transaction_id', 'currency', 'value', 'items'], imp: 10, tip: 'Primary goal — إلزامي دايماً' },
          refund: { req: ['transaction_id', 'currency', 'value'], imp: 5, tip: 'مهم لـ Revenue accuracy' },
          search: { req: ['search_term'], imp: 5, tip: 'مهم لـ Site search analysis' },
          add_to_wishlist: { req: ['currency', 'value', 'items'], imp: 4, tip: 'مفيد لـ Demand analysis' },
          view_item_list: { req: ['items'], imp: 5, tip: 'مهم لـ Product list performance' },
          select_item: { req: ['items'], imp: 5, tip: 'يقيس Click-Through Rate' },
          sign_up: { req: ['method'], imp: 6, tip: 'مهم لـ User acquisition' },
          login: { req: ['method'], imp: 3, tip: 'مفيد لـ User engagement' }
        },
        mixpanel: {
          view_item: { req: ['item_id', 'item_name'], imp: 6, tip: 'distinct_id مهم للـ User journey' },
          add_to_cart: { req: ['item_id', 'currency', 'value'], imp: 7, tip: 'مهم لـ Funnel analysis' },
          begin_checkout: { req: ['currency', 'value'], imp: 8, tip: 'أساسي لـ Conversion funnel' },
          purchase: { req: ['transaction_id', 'currency', 'value'], imp: 10, tip: 'Revenue tracking الأساسي' },
          search: { req: ['search_term'], imp: 4, tip: 'مهم لـ Search behavior analysis' },
          sign_up: { req: ['method'], imp: 7, tip: 'أساسي لـ User lifecycle' },
          login: { req: ['method'], imp: 5, tip: 'مهم لـ Retention analysis' }
        }
      };

      var platColors = { meta: '#1877F2', tiktok: '#010101', snapchat: '#FFFC00', google: '#4285F4', ga4: '#F9AB00', mixpanel: '#7856FF', twitter: '#000' };
      var platIcons = {
        meta: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><path d="M5 25c0-5.8 1.3-10.2 3.2-13.1C10.1 9 12.5 7.5 15 7.5c2 0 3.8.8 5.5 2.4 1.2 1.1 2.5 2.9 4.5 6.1 2-3.2 3.3-5 4.5-6.1 1.7-1.6 3.5-2.4 5.5-2.4 2.5 0 4.9 1.5 6.8 4.4C43.7 14.8 45 19.2 45 25c0 3.8-.7 7-2 9.4-1.6 2.9-3.9 4.6-6.3 4.6-1.5 0-2.9-.5-4.4-1.5-1.9-1.3-3.8-3.4-6.6-7.6-2.8 4.2-4.7 6.3-6.6 7.6-1.5 1-2.9 1.5-4.4 1.5-2.4 0-4.7-1.7-6.3-4.6C5.7 32 5 28.8 5 25z" fill="#1877F2"/></svg>',
        tiktok: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><rect width="50" height="50" rx="12" fill="#010101"/><path d="M34.5 14.5a7.5 7.5 0 01-7.5-7.5h-5v22.3c0 2.1-1.7 3.7-3.8 3.7a3.75 3.75 0 01-3.7-3.7c0-2.1 1.7-3.7 3.7-3.7.4 0 .7.1 1 .2V20a8.9 8.9 0 00-1-.1c-4.8 0-8.7 3.9-8.7 8.7s3.9 8.7 8.7 8.7 8.7-3.9 8.7-8.7V21.4a12.6 12.6 0 007.5 2.4v-5a7.4 7.4 0 01-4.9-4.3h4.9V14.5z" fill="white"/><path d="M37 14.5a7.5 7.5 0 01-7.5-7.5h-3v22.3c0 2.1-1.7 3.7-3.8 3.7a3.75 3.75 0 01-3.7-3.7c0-2.1 1.7-3.7 3.7-3.7.4 0 .7.1 1 .2V20a8.9 8.9 0 00-1-.1c-4.8 0-8.7 3.9-8.7 8.7s3.9 8.7 8.7 8.7 8.7-3.9 8.7-8.7V21.4a12.6 12.6 0 007.5 2.4v-5a7.6 7.6 0 01-2.9-4.3" fill="#69C9D0"/></svg>',
        snapchat: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><rect width="50" height="50" rx="12" fill="#FFFC00"/><path d="M25 8c-5.6 0-9.5 3.8-9.5 9.3v1.5c-.6.3-1.4.4-2.1.2-.3 0-.4.1-.4.4 0 1.2 2.1 1.7 2.5 1.8.4 1.3 1.2 2.4 2.2 3.2-1.6.8-3.9 1.2-4.2 2.3 0 .2.2.4.4.4 2 .3 3.7 1.1 4.9 2.7.1.2.1.3-.1.4-1.5.6-3 .6-3 1.4 0 .5.7.7 1.3.7.9 0 1.8-.3 2.6-.6.5-.2.9-.2 1.3.1.8.6 1 1.7 1 2.7 0 .2.1.4.3.4 1 .1 2.1.1 2.8.1s1.8 0 2.8-.1c.2 0 .3-.2.3-.4 0-1 .2-2.1 1-2.7.4-.3.8-.3 1.3-.1.8.3 1.7.6 2.6.6.6 0 1.3-.2 1.3-.7 0-.8-1.5-.8-3-1.4-.2-.1-.2-.2-.1-.4 1.2-1.6 2.9-2.4 4.9-2.7.2 0 .4-.2.4-.4-.3-1.1-2.6-1.5-4.2-2.3 1-.8 1.8-1.9 2.2-3.2.4-.1 2.5-.6 2.5-1.8 0-.3-.1-.4-.4-.4-.7.2-1.5.1-2.1-.2v-1.5C34.5 11.8 30.6 8 25 8z" fill="#333"/></svg>',
        google: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><path d="M25 8A17 17 0 1 0 25 42A17 17 0 1 0 25 8Z" fill="white"/><path d="M33.5 20H25v5h4.9c-.4 2.5-2.6 4.3-4.9 4.3a5.8 5.8 0 0 1 0-11.6c1.4 0 2.7.5 3.7 1.4l3.5-3.5A10.5 10.5 0 0 0 25 12.5a12.5 12.5 0 0 0 0 25c7 0 11.5-4.9 11.5-12 0-.8-.1-1.7-.2-2.5H33.5z" fill="#4285F4"/><path d="M14.3 27.9l-4 3.1A12.5 12.5 0 0 0 25 37.5v-5c-4.1 0-7.7-2.3-9.4-5.8l-.3.2z" fill="#34A853"/><path d="M10.3 18.6A12.5 12.5 0 0 0 12.5 31l4-3.1c-.7-1.4-1-3-1-4.9 0-2 .4-3.8 1.1-5.4l-4.1-3.2a12.4 12.4 0 0 0-2.2 4.2z" fill="#FBBC05"/><path d="M25 12.5c2.7 0 5.1 1 6.9 2.5l3.6-3.6A12.4 12.4 0 0 0 25 8a12.5 12.5 0 0 0-10.7 6l4.1 3.2A7.5 7.5 0 0 1 25 12.5z" fill="#EA4335"/></svg>',
        ga4: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><rect x="10" y="32" width="9" height="10" rx="4.5" fill="#E37400"/><rect x="21" y="22" width="9" height="20" rx="4.5" fill="#F9AB00"/><rect x="32" y="10" width="9" height="32" rx="4.5" fill="#E37400"/></svg>',
        mixpanel: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><rect width="50" height="50" rx="12" fill="#7856FF"/><text x="25" y="34" text-anchor="middle" font-family="Arial" font-weight="900" font-size="26" fill="white">M</text></svg>',
        twitter: '<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;vertical-align:middle;"><rect width="50" height="50" rx="12" fill="#000"/><path d="M28.3 22.5L38.5 11h-2.4l-8.9 10.3L20.3 11H12l10.7 15.5L12 39h2.4l9.3-10.8 7.4 10.8H39L28.3 22.5zm-3.3 3.8l-1.1-1.5L15.1 12.8h3.7l6.9 9.9 1.1 1.5 9 12.9h-3.7l-7.1-10.8z" fill="white"/></svg>'
      };
      var platNames = { meta: 'Meta Pixel', tiktok: 'TikTok Pixel', snapchat: 'Snap Pixel', google: 'Google Ads', ga4: 'GA4', mixpanel: 'Mixpanel', twitter: 'X / Twitter' };

      if (!S.events || !S.events.length) {
        return '<div style="text-align:center;padding:60px;color:var(--mut)"><span class="material-symbols-outlined" style="font-size:48px;display:block;margin-bottom:12px;opacity:.3">star</span><p>اختار الأحداث من Pixel Config الأول.</p></div>';
      }

      var activePlats = S.platforms.filter(function (p) { return platReqs[p]; });

      // Summary header
      var totalScore = 0, maxScore = 0;
      S.events.forEach(function (evId) {
        activePlats.forEach(function (p) {
          var pr = platReqs[p] && platReqs[p][evId];
          if (pr) { totalScore += pr.imp; maxScore += 10; }
          else maxScore += 10;
        });
      });
      var coveragePct = maxScore ? Math.round((totalScore / maxScore) * 100) : 0;

      var html = '<div style="background:linear-gradient(135deg,rgba(70,241,197,0.08),rgba(70,241,197,0.03));border:1px solid rgba(70,241,197,0.2);border-radius:16px;padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;">'
        + '<div style="flex:1;min-width:200px;">'
        + '<div style="font-family:var(--font-display);font-weight:800;font-size:18px;color:var(--wht);margin-bottom:4px;">Tracking Coverage Score</div>'
        + '<div style="font-size:13px;color:var(--mut);">بناءً على requirements كل منصة — ' + S.events.length + ' event · ' + activePlats.length + ' platform</div>'
        + '</div>'
        + '<div style="text-align:center;">'
        + '<div style="font-family:var(--font-mono);font-size:42px;font-weight:700;color:' + (coveragePct >= 80 ? 'var(--acc)' : coveragePct >= 50 ? 'var(--amber)' : 'var(--red)') + ';line-height:1;">' + coveragePct + '%</div>'
        + '<div style="font-size:11px;color:var(--mut);letter-spacing:2px;text-transform:uppercase;">' + (coveragePct >= 80 ? '✅ Excellent' : coveragePct >= 50 ? '⚠️ Good' : '❌ Needs Work') + '</div>'
        + '</div></div>';

      // Per-event table
      html += '<div style="display:flex;flex-direction:column;gap:16px;">';
      S.events.forEach(function (evId) {
        var ev = GA4[evId];
        if (!ev) return;
        var evScore = ev.score;
        var scoreCls = evScore >= 8 ? '#46f1c5' : evScore >= 5 ? 'var(--amber)' : 'var(--mut)';

        html += '<div style="background:var(--sur);border:1px solid rgba(255,255,255,0.06);border-radius:14px;overflow:hidden;">';
        // Event header
        html += '<div style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(255,255,255,0.04);">'
          + '<div style="font-family:var(--font-mono);font-size:12px;background:rgba(70,241,197,0.08);color:var(--acc);padding:4px 10px;border-radius:6px;border:1px solid rgba(70,241,197,0.15);">' + evId + '</div>'
          + '<div style="font-weight:700;color:var(--wht);font-size:14px;">' + ev.label + '</div>'
          + '<div style="margin-right:auto;display:flex;align-items:center;gap:6px;">'
          + '<span style="font-size:11px;color:var(--mut);">GA4 Score</span>'
          + '<div style="background:rgba(255,255,255,0.06);border-radius:100px;width:80px;height:6px;overflow:hidden;"><div style="width:' + (evScore * 10) + '%;height:100%;background:' + scoreCls + ';border-radius:100px;"></div></div>'
          + '<span style="font-family:var(--font-mono);font-size:12px;font-weight:700;color:' + scoreCls + ';">' + evScore + '/10</span>'
          + '</div></div>';

        // Platform rows
        html += '<div style="padding:12px 18px;display:flex;flex-direction:column;gap:8px;">';
        activePlats.forEach(function (p) {
          var pr = platReqs[p] && platReqs[p][evId];
          var pMap = PMAP[p] && PMAP[p][evId];
          var isSupported = !!pMap;
          var imp = pr ? pr.imp : (isSupported ? 5 : 0);
          var tip = pr ? pr.tip : (isSupported ? '' : 'هذه المنصة لا تدعم هذا الحدث');
          var impColor = imp >= 8 ? '#46f1c5' : imp >= 5 ? 'var(--amber)' : imp > 0 ? 'var(--mut)' : '#ff5252';

          html += '<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;background:rgba(255,255,255,0.02);">'
            + '<span style="font-size:15px;">' + (platIcons[p] || '📡') + '</span>'
            + '<span style="font-size:12px;font-weight:600;color:var(--wht2);min-width:90px;">' + (platNames[p] || p) + '</span>'
            + '<span style="font-size:11px;padding:2px 8px;border-radius:100px;background:' + (isSupported ? 'rgba(70,241,197,0.08)' : 'rgba(255,82,82,0.08)') + ';color:' + (isSupported ? 'var(--acc)' : '#ff5252') + ';border:1px solid ' + (isSupported ? 'rgba(70,241,197,0.2)' : 'rgba(255,82,82,0.2)') + ';">' + (isSupported ? '✓ ' + (pMap || evId) : '✗ غير مدعوم') + '</span>';

          if (pr && pr.req && pr.req.length) {
            html += '<span style="font-size:10px;color:var(--mut);font-family:var(--font-mono);">req: ' + pr.req.join(', ') + '</span>';
          }
          if (tip) {
            html += '<span style="margin-right:auto;font-size:10px;color:var(--mut);font-style:italic;text-align:left;">💡 ' + tip + '</span>';
          }
          if (isSupported) {
            html += '<div style="display:flex;align-items:center;gap:4px;margin-right:' + (tip ? '0' : 'auto') + ';">'
              + '<div style="background:rgba(255,255,255,0.06);border-radius:100px;width:50px;height:4px;overflow:hidden;"><div style="width:' + (imp * 10) + '%;height:100%;background:' + impColor + ';border-radius:100px;"></div></div>'
              + '<span style="font-family:var(--font-mono);font-size:10px;color:' + impColor + ';">' + imp + '</span>'
              + '</div>';
          }
          html += '</div>';
        });
        html += '</div></div>';
      });
      html += '</div>';
      return html;
    }

    // ===== BUILD HEALTH CHECK =====
    function buildHealthCheck() {
      var platReqMap = {
        meta: {
          name: 'Meta Pixel', icon: '📘', color: '#1877F2',
          events: { view_item: ['currency', 'value'], add_to_cart: ['currency', 'value'], begin_checkout: ['currency', 'value'], purchase: ['currency', 'value', 'transaction_id'], add_payment_info: ['currency', 'value'] }
        },
        tiktok: {
          name: 'TikTok Pixel', icon: '🎵', color: '#46f1c5',
          events: { view_item: ['currency', 'value'], add_to_cart: ['currency', 'value'], begin_checkout: ['currency', 'value'], purchase: ['currency', 'value', 'transaction_id'] }
        },
        snapchat: {
          name: 'Snap Pixel', icon: '👻', color: '#FFFC00',
          events: { view_item: ['currency', 'price'], add_to_cart: ['currency', 'price'], begin_checkout: ['currency', 'price'], purchase: ['currency', 'price', 'transaction_id'] }
        },
        google: {
          name: 'Google Ads', icon: '🔍', color: '#4285F4',
          events: { view_item: ['currency', 'value'], add_to_cart: ['currency', 'value'], begin_checkout: ['currency', 'value'], purchase: ['currency', 'value', 'transaction_id'] }
        },
        ga4: {
          name: 'GA4', icon: '📊', color: '#F9AB00',
          events: { view_item: ['currency', 'value', 'items'], add_to_cart: ['currency', 'value', 'items'], begin_checkout: ['currency', 'value', 'items'], purchase: ['transaction_id', 'currency', 'value', 'items'], add_shipping_info: ['currency', 'value', 'shipping_tier'], add_payment_info: ['currency', 'value', 'payment_type'] }
        },
        mixpanel: {
          name: 'Mixpanel', icon: '🔮', color: '#7856FF',
          events: { view_item: ['item_id'], add_to_cart: ['item_id', 'currency', 'value'], purchase: ['transaction_id', 'currency', 'value'], sign_up: ['method'] }
        }
      };

      var dlAvail = ['currency', 'value', 'transaction_id', 'items', 'search_term', 'shipping_tier', 'payment_type', 'method', 'item_id', 'item_name', 'affiliation', 'coupon', 'shipping', 'tax'];
      var activePlats = S.platforms.filter(function (p) { return platReqMap[p]; });
      if (!activePlats.length) return;

      var html = '<div style="display:flex;flex-direction:column;gap:16px;">';

      // Overall health score
      var totalPassed = 0, totalChecks = 0;
      activePlats.forEach(function (p) {
        var pr = platReqMap[p];
        S.events.forEach(function (evId) {
          var reqs = pr.events[evId];
          if (!reqs) return;
          reqs.forEach(function (r) { totalChecks++; if (dlAvail.indexOf(r) !== -1) totalPassed++; });
        });
      });
      var healthPct = totalChecks ? Math.round((totalPassed / totalChecks) * 100) : 100;
      var healthColor = healthPct >= 90 ? '#46f1c5' : healthPct >= 70 ? 'var(--amber)' : 'var(--red)';
      var healthLabel = healthPct >= 90 ? '🟢 صحة ممتازة' : healthPct >= 70 ? '🟡 صحة جيدة' : '🔴 تحتاج تحسين';

      html += '<div style="background:linear-gradient(135deg,rgba(70,241,197,0.08),transparent);border:1px solid rgba(70,241,197,0.15);border-radius:16px;padding:20px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap;">'
        + '<div style="flex:1;">'
        + '<div style="font-family:var(--font-display);font-weight:800;font-size:17px;color:var(--wht);">Pixel Health Score</div>'
        + '<div style="font-size:12px;color:var(--mut);margin-top:4px;">' + healthLabel + ' — ' + totalPassed + '/' + totalChecks + ' parameter مغطى</div>'
        + '</div>'
        + '<div style="font-family:var(--font-mono);font-size:44px;font-weight:700;color:' + healthColor + ';line-height:1;">' + healthPct + '%</div>'
        + '</div>';

      // Per platform
      activePlats.forEach(function (p) {
        var pr = platReqMap[p];
        var passed = 0, failed = [], total = 0;
        var evIssues = [];

        S.events.forEach(function (evId) {
          var reqs = pr.events[evId];
          if (!reqs) return;
          var evFailed = [];
          reqs.forEach(function (r) {
            total++;
            if (dlAvail.indexOf(r) !== -1) { passed++; }
            else { failed.push(r); evFailed.push(r); }
          });
          if (evFailed.length) evIssues.push({ ev: evId, missing: evFailed });
        });

        var pct = total ? Math.round((passed / total) * 100) : 100;
        var pColor = pct >= 90 ? '#46f1c5' : pct >= 70 ? 'var(--amber)' : 'var(--red)';

        html += '<div style="background:var(--sur);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:16px 18px;">';
        html += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">'
          + '<span style="font-size:20px;">' + pr.icon + '</span>'
          + '<span style="font-weight:700;font-size:15px;color:var(--wht);">' + pr.name + '</span>'
          + '<div style="margin-right:auto;display:flex;align-items:center;gap:8px;">'
          + '<div style="background:rgba(255,255,255,0.06);border-radius:100px;width:100px;height:6px;overflow:hidden;"><div style="width:' + pct + '%;height:100%;background:' + pColor + ';border-radius:100px;transition:width .5s;"></div></div>'
          + '<span style="font-family:var(--font-mono);font-size:12px;color:' + pColor + ';font-weight:700;">' + pct + '%</span>'
          + '</div></div>';

        if (evIssues.length) {
          evIssues.forEach(function (issue) {
            html += '<div style="display:flex;align-items:flex-start;gap:8px;padding:8px 10px;background:rgba(255,82,82,0.04);border-radius:8px;margin-bottom:6px;border:1px solid rgba(255,82,82,0.1);">'
              + '<span style="color:var(--red);font-size:12px;">⚠️</span>'
              + '<div>'
              + '<span style="font-family:var(--font-mono);font-size:11px;color:var(--acc);">' + issue.ev + '</span>'
              + '<span style="font-size:11px;color:var(--mut);"> — missing: </span>'
              + '<span style="font-family:var(--font-mono);font-size:11px;color:var(--red);">' + issue.missing.join(', ') + '</span>'
              + '</div></div>';
          });
        } else {
          html += '<div style="color:var(--acc);font-size:12px;">✅ كل الـ Parameters المطلوبة متوفرة</div>';
        }
        html += '</div>';
      });

      html += '</div>';
      document.getElementById('healthConfigCheck').innerHTML = html;
    }

    // ===== BUILD TRACKING PLAN =====
    function buildPlan() {
      var planEl = document.getElementById('planContent');
      if (!planEl) return;

      var platColors = { meta: '#1877F2', tiktok: '#46f1c5', snapchat: '#FFFC00', google: '#4285F4', ga4: '#F9AB00', twitter: '#1D9BF0', mixpanel: '#7856FF' };
      var platNames = { meta: 'Meta Pixel', tiktok: 'TikTok', snapchat: 'Snapchat', google: 'Google Ads', ga4: 'GA4', twitter: 'X/Twitter', mixpanel: 'Mixpanel' };

      var html = '<div style="margin-bottom:16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">'
        + '<div style="font-family:var(--font-display);font-weight:800;font-size:17px;color:var(--wht);">Tracking Plan</div>'
        + '<div style="font-size:12px;color:var(--mut);">— ' + S.events.length + ' event · ' + S.platforms.length + ' platform · CMS: ' + (CMS[S.cms] ? CMS[S.cms].name : S.cms) + '</div>'
        + '</div>';

      // Summary chips
      html += '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;">';
      S.platforms.forEach(function (p) {
        html += '<span style="background:' + (platColors[p] || 'var(--acc)') + '18;color:' + (platColors[p] || 'var(--acc)') + ';border:1px solid ' + (platColors[p] || 'var(--acc)') + '30;padding:4px 12px;border-radius:100px;font-size:12px;font-weight:700;">'
          + (PM[p] ? PM[p].icon + ' ' + PM[p].name : p) + '</span>';
      });
      html += '</div>';

      // Table
      html += '<div style="overflow-x:auto;">'
        + '<table style="width:100%;border-collapse:collapse;font-size:13px;">'
        + '<thead><tr style="background:rgba(255,255,255,0.03);">'
        + '<th style="padding:12px 14px;text-align:right;color:var(--mut);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);">GA4 Event</th>'
        + '<th style="padding:12px 14px;text-align:right;color:var(--mut);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);">الوصف</th>'
        + '<th style="padding:12px 14px;text-align:right;color:var(--mut);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);">Parameters</th>'
        + '<th style="padding:12px 14px;text-align:center;color:var(--mut);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);">المنصات</th>'
        + '<th style="padding:12px 14px;text-align:center;color:var(--mut);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.06);">Score</th>'
        + '</tr></thead><tbody>';

      S.events.forEach(function (evId, idx) {
        var ev = GA4[evId];
        if (!ev) return;
        var sc = ev.score;
        var scColor = sc >= 8 ? '#46f1c5' : sc >= 5 ? 'var(--amber)' : 'var(--mut)';
        var rowBg = idx % 2 === 0 ? 'rgba(255,255,255,0.01)' : 'transparent';

        // Which platforms support this event
        var platCells = '';
        S.platforms.forEach(function (p) {
          var mapped = PMAP[p] && PMAP[p][evId];
          platCells += '<span style="display:inline-block;margin:2px;padding:2px 6px;border-radius:4px;font-size:10px;background:' + (mapped ? (platColors[p] || 'var(--acc)') + '20' : 'rgba(255,255,255,0.04)') + ';color:' + (mapped ? (platColors[p] || 'var(--acc)') : 'rgba(255,255,255,0.15)') + ';font-weight:700;">'
            + (PM[p] ? PM[p].icon : p) + '</span>';
        });

        // Required params
        var params = ev.req.map(function (r) {
          return '<span style="font-family:var(--font-mono);font-size:10px;background:rgba(70,241,197,0.06);color:var(--acc);padding:1px 5px;border-radius:3px;margin:1px;display:inline-block;">' + r + '</span>';
        }).join('') + (ev.opt.length ? ev.opt.map(function (r) {
          return '<span style="font-family:var(--font-mono);font-size:10px;background:rgba(255,255,255,0.04);color:var(--mut);padding:1px 5px;border-radius:3px;margin:1px;display:inline-block;">' + r + '</span>';
        }).join('') : '');

        html += '<tr style="background:' + rowBg + ';border-bottom:1px solid rgba(255,255,255,0.03);">'
          + '<td style="padding:10px 14px;"><code style="color:var(--acc);font-size:11px;">' + evId + '</code></td>'
          + '<td style="padding:10px 14px;color:var(--wht2);font-weight:600;">' + ev.label + '</td>'
          + '<td style="padding:10px 14px;">' + params + '</td>'
          + '<td style="padding:10px 14px;text-align:center;">' + platCells + '</td>'
          + '<td style="padding:10px 14px;text-align:center;"><span style="font-family:var(--font-mono);font-weight:700;font-size:13px;color:' + scColor + ';">' + sc + '</span></td>'
          + '</tr>';
      });

      html += '</tbody></table></div>';
      planEl.innerHTML = html;
    }

    // ===== BUILD SUMMARY =====
    function buildSummary() {
      var platNames = [];
      for (var i = 0; i < S.platforms.length; i++) platNames.push(PM[S.platforms[i]].name);
      document.getElementById('sumStrip').innerHTML =
        '<div class="sitem"><span class="slbl">Client</span><span class="sval">' + (S.lead && S.lead.name || '—') + '</span></div>' +
        '<div class="sitem"><span class="slbl">Location</span><span class="sval">' + (S.lead && S.lead.location || '—') + '</span></div>' +
        '<div class="sitem"><span class="slbl">CMS</span><span class="sval">' + CMS[S.cms].name + '</span></div>' +
        '<div class="sitem"><span class="slbl">Platforms</span><span class="sval">' + platNames.join(' · ') + '</span></div>' +
        '<div class="sitem"><span class="slbl">Events</span><span class="sval">' + S.events.length + ' events</span></div>';
    }

    // ===== OUTPUT TABS =====

    // ═══ TRACKING PLAN ═══════════════════════════════════════
    window.ETD_API_URL = 'https://easy-track-excel-api-production.up.railway.app';

    function oTab(id, btn) {
      if (id === 'plan') buildTrackingPlan();
      if (id === 'health') { document.getElementById('healthResults').innerHTML = ''; }
      var tabs = document.querySelectorAll('.otab');
      var panes = document.querySelectorAll('.opane');
      for (var i = 0; i < tabs.length; i++)  tabs[i].classList.remove('on');
      for (var i = 0; i < panes.length; i++) panes[i].classList.remove('on');
      btn.classList.add('on');
      document.getElementById('pane-' + id).classList.add('on');
    }


    // ===== BUILD CONSENT CODE =====

    // ===== PIXEL HEALTH CHECKER =====
    async function runHealthCheck() {
      var url = (document.getElementById('healthUrl').value || '').trim();
      var resEl = document.getElementById('healthResults');
      if (!url) { resEl.innerHTML = '<div class="infonote" style="background:rgba(248,113,113,.08);border-color:rgba(248,113,113,.2);color:var(--red)">⚠️ حط URL الموقع الأول</div>'; return; }
      if (!/^https?:\/\//i.test(url)) url = 'https://' + url;

      resEl.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-family:monospace;font-size:12px">⏳ جاري الفحص...</div>';

      // Pixel signatures to detect in HTML
      var SIGS = {
        meta: { name: 'Meta Pixel', icon: '📘', patterns: [/fbq\s*\(\s*['"]init['"]\s*,\s*['"](\d{10,20})['"]/g, /connect\.facebook\.net/] },
        tiktok: { name: 'TikTok Pixel', icon: '🎵', patterns: [/ttq\.load\s*\(\s*['"]([A-Z0-9]{16,})['"]/g, /analytics\.tiktok\.com/] },
        snapchat: { name: 'Snapchat Pixel', icon: '👻', patterns: [/snaptr\s*\(\s*['"]init['"]\s*,\s*['"]([a-f0-9\-]{30,})['"]/g, /sc-static\.net/] },
        ga4: { name: 'Google Analytics', icon: '📊', patterns: [/gtag\s*\(\s*['"]config['"]\s*,\s*['"]G-([A-Z0-9]+)['"]/g, /googletagmanager\.com\/gtag/] },
        google: { name: 'Google Ads', icon: '🔍', patterns: [/gtag\s*\(\s*['"]config['"]\s*,\s*['"]AW-(\d+)['"]/g, /googleadservices\.com/] },
        gtm: { name: 'Google Tag Manager', icon: '📦', patterns: [/GTM-([A-Z0-9]+)/g, /googletagmanager\.com\/gtm/] },
        twitter: { name: 'X/Twitter Pixel', icon: '𝕏', patterns: [/twq\s*\(\s*['"]config['"]\s*,\s*['"]([a-z0-9]+)['"]/g, /static\.ads-twitter\.com/] }
      };

      var CONSENT_SIGS = [/gtag\s*\(\s*['"]consent['"]\s*,\s*['"]default['"]/, /cookiebot/i, /onetrust/i, /iubenda/i, /complianz/i];

      try {
        // Use a CORS proxy to fetch the page HTML


        // Multi-proxy fallback — try 3 proxies in order
        var proxies = [
          { url: 'https://api.allorigins.win/get?url=' + encodeURIComponent(url), type: 'json', extract: function (d) { return d.contents || ''; } },
          { url: 'https://corsproxy.io/?' + encodeURIComponent(url), type: 'text', extract: function (d) { return d; } },
          { url: 'https://api.codetabs.com/v1/proxy?quest=' + encodeURIComponent(url), type: 'text', extract: function (d) { return d; } }
        ];
        var html = '';
        var lastErr = '';
        for (var px = 0; px < proxies.length; px++) {
          try {
            resEl.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-family:monospace;font-size:12px">⏳ جاري الفحص (محاولة ' + (px + 1) + '/' + proxies.length + ')...</div>';
            var pResp = await fetch(proxies[px].url, { signal: AbortSignal.timeout(10000) });
            if (!pResp.ok) { lastErr = 'HTTP ' + pResp.status; continue; }
            var pRaw = proxies[px].type === 'json' ? await pResp.json() : await pResp.text();
            var pHtml = proxies[px].extract(pRaw);
            if (typeof pHtml !== 'string') pHtml = JSON.stringify(pHtml);
            if (pHtml && pHtml.length > 200) { html = pHtml; break; }
            lastErr = 'الصفحة فاضية';
          } catch (pe) {
            lastErr = pe.name === 'TimeoutError' ? 'timeout' : pe.message;
          }
        }
        if (!html) throw new Error('فشل الفحص بعد ' + proxies.length + ' محاولات — ' + lastErr);

        // Run detection
        var results = {};
        var platKeys = Object.keys(SIGS);
        for (var i = 0; i < platKeys.length; i++) {
          var pid = platKeys[i];
          var sig = SIGS[pid];
          var found = false;
          var detectedId = null;

          for (var pi = 0; pi < sig.patterns.length; pi++) {
            var pat = sig.patterns[pi];
            if (pat.global) {
              pat.lastIndex = 0;
              var m = pat.exec(html);
              if (m) { found = true; if (m[1]) detectedId = m[1]; break; }
            } else {
              if (pat.test(html)) { found = true; break; }
            }
          }

          // Compare with user's pixel ID
          var userPid = S.pixelIds[pid] || '';
          var isInPlan = S.platforms.indexOf(pid) !== -1;
          var match = detectedId && userPid && (html.indexOf(userPid) !== -1);

          results[pid] = { found: found, detectedId: detectedId, userPid: userPid, isInPlan: isInPlan, match: match };
        }

        // Consent check
        var hasConsent = CONSENT_SIGS.some(function (p) { return p.test(html); });
        var hasGTM = results.gtm && results.gtm.found;

        // Build report HTML
        var h = '';
        h += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:20px;">';

        platKeys.forEach(function (pid) {
          var r = results[pid];
          var sig = SIGS[pid];
          if (pid === 'gtm') return; // show GTM separately

          var status, statusColor, statusBg, statusIcon;
          if (!r.isInPlan && !r.found) {
            status = 'مش في الخطة'; statusColor = 'var(--mut)'; statusBg = 'rgba(255,255,255,.03)'; statusIcon = '—';
          } else if (r.isInPlan && r.found && r.match) {
            status = 'شغّال ✓'; statusColor = 'var(--grn)'; statusBg = 'rgba(52,211,153,.06)'; statusIcon = '✅';
          } else if (r.isInPlan && r.found && !r.match) {
            status = 'موجود — ID مختلف'; statusColor = 'var(--gold)'; statusBg = 'rgba(232,184,75,.06)'; statusIcon = '⚠️';
          } else if (r.isInPlan && !r.found) {
            status = 'ناقص ❌'; statusColor = 'var(--red)'; statusBg = 'rgba(248,113,113,.06)'; statusIcon = '❌';
          } else if (!r.isInPlan && r.found) {
            status = 'موجود (مش في الخطة)'; statusColor = 'var(--blu)'; statusBg = 'rgba(96,165,250,.06)'; statusIcon = 'ℹ️';
          } else {
            status = '—'; statusColor = 'var(--mut)'; statusBg = 'rgba(255,255,255,.03)'; statusIcon = '—';
          }

          h += '<div style="background:' + statusBg + ';border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px 18px;">';
          h += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">';
          h += '<span style="font-size:15px;font-weight:700;">' + sig.icon + ' ' + sig.name + '</span>';
          h += '<span style="font-size:18px;">' + statusIcon + '</span>';
          h += '</div>';
          h += '<div style="font-size:12px;font-weight:700;color:' + statusColor + ';margin-bottom:6px;">' + status + '</div>';
          if (r.detectedId) {
            h += '<div style="font-family:monospace;font-size:10px;color:var(--mut);background:rgba(0,0,0,.3);padding:4px 8px;border-radius:6px;word-break:break-all;">';
            h += 'Detected: ' + r.detectedId;
            if (r.userPid && r.detectedId !== r.userPid) h += '<br>Expected: ' + r.userPid;
            h += '</div>';
          } else if (r.userPid && r.isInPlan) {
            h += '<div style="font-family:monospace;font-size:10px;color:var(--mut2);">Expected: ' + r.userPid + '</div>';
          }
          h += '</div>';
        });
        h += '</div>';

        // Summary bar
        var totalInPlan = S.platforms.filter(function (p) { return p !== 'gtm'; }).length;
        var totalOk = S.platforms.filter(function (p) { var r = results[p]; return r && r.found && (r.match || !r.userPid); }).length;
        var totalWarn = S.platforms.filter(function (p) { var r = results[p]; return r && r.found && r.userPid && !r.match; }).length;
        var totalMiss = S.platforms.filter(function (p) { var r = results[p]; return r && !r.found && r.isInPlan; }).length;
        var score = totalInPlan > 0 ? Math.round((totalOk / totalInPlan) * 100) : 0;
        var scoreColor = score >= 80 ? 'var(--grn)' : score >= 50 ? 'var(--gold)' : 'var(--red)';

        h = '<div style="background:linear-gradient(135deg,rgba(232,184,75,.08),rgba(52,211,153,.04));border:1px solid rgba(232,184,75,.15);border-radius:16px;padding:16px 20px;margin-bottom:16px;display:flex;flex-wrap:wrap;gap:20px;align-items:center;">'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;text-transform:uppercase;">Health Score</div>'
          + '<div style="font-size:28px;font-weight:900;color:' + scoreColor + ';">' + score + '%</div></div>'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;margin-bottom:2px;">✅ شغّال</div><div style="font-size:18px;font-weight:700;color:var(--grn);">' + totalOk + '</div></div>'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;margin-bottom:2px;">⚠️ ID مختلف</div><div style="font-size:18px;font-weight:700;color:var(--gold);">' + totalWarn + '</div></div>'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;margin-bottom:2px;">❌ ناقص</div><div style="font-size:18px;font-weight:700;color:var(--red);">' + totalMiss + '</div></div>'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;margin-bottom:2px;">GTM</div>'
          + '<div style="font-size:18px;font-weight:700;color:' + (hasGTM ? 'var(--grn)' : 'var(--red)') + ';">' + (hasGTM ? '✅' : '❌') + '</div></div>'
          + '<div><div style="font-size:10px;color:var(--mut);font-family:monospace;letter-spacing:1px;margin-bottom:2px;">Privacy</div>'
          + '<div style="font-size:18px;font-weight:700;color:' + (hasConsent ? 'var(--grn)' : 'var(--red)') + ';">' + (hasConsent ? '✅' : '❌') + '</div></div>'
          + '</div>' + h;

        // GTM detected ID
        if (hasGTM && results.gtm.detectedId) {
          h += '<div class="infonote grn" style="margin-top:4px">📦 GTM Container ID: <code>' + results.gtm.detectedId + '</code></div>';
        }
        if (!hasConsent) {
          h += '<div class="infonote" style="background:rgba(248,113,113,.06);border-color:rgba(248,113,113,.2);margin-top:8px">⚠️ <strong style="color:var(--red)">Privacy Consent مش موجود</strong> — Google بيطلبه من مارس 2024 لتشغيل الإعلانات بشكل صحيح.</div>';
        }

        resEl.innerHTML = h;

      } catch (err) {
        var msg = err.name === 'TimeoutError' ? 'انتهت المهلة — الموقع بطيء أو مش متاح' : (err.message || 'خطأ في الفحص');
        resEl.innerHTML = '<div class="infonote" style="background:rgba(248,113,113,.08);border-color:rgba(248,113,113,.2);color:var(--red)">❌ ' + msg + '<br><span style="font-size:11px;color:var(--mut)">تأكد إن الـ URL صح وإن الموقع شغّال.</span></div>';
      }
    }

    function buildConsent() {
      var el = document.getElementById('consentBody');
      if (!el) return;

      var lines2 = [];
      lines2.push('// =====================================================');
      lines2.push('// Consent Mode v2 — Easy Track');
      lines2.push('// حطه في <head> قبل GTM snippet');
      lines2.push('// =====================================================');
      lines2.push('');
      lines2.push('window.dataLayer = window.dataLayer || [];');
      lines2.push('function gtag(){dataLayer.push(arguments);}');
      lines2.push('');
      lines2.push("gtag('consent', 'default', {");
      lines2.push("  'ad_storage':             'denied',   // إعلانات");
      lines2.push("  'ad_user_data':           'denied',   // بيانات المستخدم للإعلانات");
      lines2.push("  'ad_personalization':     'denied',   // تخصيص الإعلانات");
      lines2.push("  'analytics_storage':      'denied',   // Analytics");
      lines2.push("  'functionality_storage':  'denied',   // وظائف الموقع");
      lines2.push("  'personalization_storage':'denied',   // تخصيص المحتوى");
      lines2.push("  'security_storage':       'granted',  // أمان (مطلوب دايماً)");
      lines2.push("  'wait_for_update':         500        // انتظر 500ms للـ CMP");
      lines2.push('});');
      lines2.push('');
      lines2.push('// URL passthrough — يحسن attribution بدون cookies');
      lines2.push("gtag('set', 'url_passthrough', true);");
      lines2.push('');
      lines2.push('// Ads data redaction — يحمي بيانات المستخدم');
      lines2.push("gtag('set', 'ads_data_redaction', true);");
      lines2.push('');
      lines2.push('// =====================================================');
      lines2.push('// Consent Update — الـ CMP بيبعته بعد اختيار المستخدم');
      lines2.push('// (ده بيتشغّل تلقائياً من الـ CMP — مش محتاج تكتبه)');
      lines2.push('// =====================================================');
      lines2.push("// gtag('consent', 'update', {");
      lines2.push("//   'ad_storage':         'granted',");
      lines2.push("//   'ad_user_data':       'granted',");
      lines2.push("//   'ad_personalization': 'granted',");
      lines2.push("//   'analytics_storage':  'granted'");
      lines2.push('// });');

      el.textContent = lines2.join('\n');

      // bind copy button
      var cpyBtn = document.getElementById('cpyConsent');
      if (cpyBtn) {
        cpyBtn.onclick = function () { copyEl('consentBody', this); };
      }
    }

    function buildTrackingPlan() {
      var el = document.getElementById('planContent');
      if (!el) return;
      var name = (S.lead && S.lead.name) || 'Client';
      var today = new Date().toLocaleDateString('ar-EG');
      var cmsName = S.cms ? (CMS[S.cms] ? CMS[S.cms].name : S.cms) : '';
      var html = '<div style="font-family:Cairo,sans-serif;direction:rtl;">';
      // Header
      html += '<div style="background:#0b1628;border:1px solid rgba(232,184,75,.2);border-radius:14px;padding:20px;margin-bottom:14px;">';
      html += '<div style="font-weight:900;font-size:18px;margin-bottom:6px;">' + name + '</div>';
      html += '<div style="display:flex;gap:10px;flex-wrap:wrap;font-size:12px;color:#5a7090;">';
      html += '<span>📅 ' + today + '</span><span>🛍 ' + cmsName + '</span>';
      html += '<span>📊 ' + S.events.length + ' events</span><span>📡 ' + S.platforms.length + ' platforms</span>';
      html += '</div></div>';
      // Platforms
      S.platforms.forEach(function (p) {
        var pm = PM[p]; var pid = S.pixelIds[p] || '—';
        html += '<div style="background:#0f1e35;border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:14px;margin-bottom:10px;">';
        html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">';
        html += '<span style="font-weight:700;">' + pm.icon + ' ' + pm.name + '</span>';
        html += '<span style="font-family:monospace;font-size:11px;color:#e8b84b;background:rgba(232,184,75,.1);padding:2px 8px;border-radius:5px;">' + pid + '</span>';
        html += '</div><table style="width:100%;border-collapse:collapse;font-size:12px;">';
        html += '<tr style="color:#5a7090;"><th style="text-align:right;padding:5px;">GA4 Event</th><th style="text-align:right;padding:5px;">Platform Event</th><th style="text-align:center;padding:5px;">Score</th></tr>';
        S.events.forEach(function (ev) {
          var mapped = PMAP[p] && PMAP[p][ev];
          html += '<tr style="border-top:1px solid rgba(255,255,255,.04);">';
          html += '<td style="padding:6px;font-family:monospace;font-size:11px;">' + ev + '</td>';
          html += '<td style="padding:6px;color:' + (mapped ? '#0ecfb0' : '#f87171') + ';">' + (mapped || '—') + '</td>';
          html += '<td style="padding:6px;text-align:center;color:#e8b84b;">' + (GA4[ev] ? GA4[ev].score : 0) + '</td>';
          html += '</tr>';
        });
        html += '</table></div>';
      });
      html += '</div>';
      el.innerHTML = html;
    }

    function downloadPlanExcel() {
      buildTrackingPlan();
      if (!S.platforms || !S.platforms.length) { alert('اعمل Generate الأول'); return; }
      var API = window.ETD_API_URL + '/generate-excel';
      var today = new Date().toISOString().split('T')[0];
      var ga4Data = {};
      S.events.forEach(function (ev) {
        if (GA4[ev]) ga4Data[ev] = { label: GA4[ev].label || ev, score: GA4[ev].score || 0, req: GA4[ev].req || [], opt: GA4[ev].opt || [], ip: GA4[ev].ip || [] };
      });
      var pmapData = {};
      S.platforms.forEach(function (p) {
        pmapData[p] = {};
        S.events.forEach(function (ev) { if (PMAP[p] && PMAP[p][ev]) pmapData[p][ev] = PMAP[p][ev]; });
      });
      var pmData = {};
      S.platforms.forEach(function (p) { if (PM[p]) pmData[p] = { name: PM[p].name, icon: PM[p].icon || '' }; });
      var payload = {
        client_name: (S.lead && S.lead.name) || 'Client',
        client_phone: (S.lead && S.lead.phone) || '',
        client_location: (S.lead && S.lead.location) || '',
        cms_name: S.cms ? (CMS[S.cms] ? CMS[S.cms].name : S.cms) : '',
        platforms: S.platforms, events: S.events,
        pixel_ids: S.pixelIds, ga4_data: ga4Data,
        pmap: pmapData, pm: pmData
      };
      var btn = document.querySelector('[onclick="downloadPlanExcel()"]');
      var orig = btn ? btn.textContent : '';
      if (btn) { btn.textContent = '⏳ جاري...'; btn.disabled = true; }
      fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
        .then(function (r) { if (!r.ok) throw new Error('API Error'); return r.blob(); })
        .then(function (blob) {
          var name = ((S.lead && S.lead.name) || 'client').replace(/\s+/g, '-');
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'tracking-plan-' + name + '-' + today + '.xlsx';
          document.body.appendChild(a); a.click(); document.body.removeChild(a);
          if (btn) { btn.textContent = '✅ تم!'; btn.disabled = false; }
          setTimeout(function () { if (btn) btn.textContent = orig; }, 2500);
        })
        .catch(function () {
          if (btn) { btn.textContent = orig; btn.disabled = false; }
          downloadPlanCSV(payload, today);
        });
    }

    function downloadPlanCSV(payload, today) {
      var name = (payload.client_name || 'client').replace(/\s+/g, '-');
      var rows = [['GA4 Event', 'Score', 'Platform Event', 'Platform']];
      payload.events.forEach(function (ev) {
        payload.platforms.forEach(function (p) {
          var mapped = payload.pmap[p] && payload.pmap[p][ev];
          rows.push([ev, payload.ga4_data[ev] ? payload.ga4_data[ev].score : 0, mapped || '—', payload.pm[p] ? payload.pm[p].name : p]);
        });
      });
      var csv = rows.map(function (r) { return r.join(','); }).join('\r\n');
      var a = document.createElement('a');
      a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
      a.download = 'tracking-plan-' + name + '-' + today + '.csv';
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }

    function downloadPlanPDF() {
      buildTrackingPlan();
      var content = document.getElementById('planContent');
      if (!content) return;
      var w = window.open('', '_blank');
      w.document.write('<html><head><meta charset="UTF-8"><style>body{background:#05090f;color:#f0f4ff;font-family:Cairo,sans-serif;padding:24px;}table{width:100%;border-collapse:collapse;}td,th{padding:8px;border:1px solid rgba(255,255,255,.1);}</style></head><body>');
      w.document.write(content.innerHTML);
      w.document.write(`
  <!-- ══ WHATSAPP WIDGET ══ -->
  <script>
  (function () {
    var whatsappNumber = "201552388174";
    var options = {
      whatsapp: whatsappNumber,
      call_to_action: "\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0644\u062e\u062f\u0645\u062a\u0643",
      position: "left",
      preFilledMessage: "\u0645\u0631\u062d\u0628\u064b\u0627\u060c \u0623\u0631\u064a\u062f \u0627\u0644\u062a\u0631\u0642\u064a\u0629 \u0625\u0644\u0649 \u062e\u0637\u0629 \u0623\u0639\u0644\u0649 \u0641\u064a Easy Track."
    };
    var proto = document.location.protocol, host = "getbutton.io";
    var s = document.createElement("script");
    s.type = "text/javascript"; s.async = true;
    s.src = proto + "//static." + host + "/widget-send-button/js/init.js";
    s.onload = function () {
      if (typeof WhWidgetSendButton !== "undefined") {
        WhWidgetSendButton.init(host, proto, options);
      }
    };
    document.head.appendChild(s);
  })();
  <\/script>
</body></html>`);
      w.document.close(); w.print();
    }

    function copyPlan() {
      var content = document.getElementById('planContent');
      if (!content) return;
      navigator.clipboard.writeText(content.innerText).then(function () {
        var btn = document.querySelector('[onclick="copyPlan()"]');
        if (btn) { var t = btn.textContent; btn.textContent = '✅ تم'; setTimeout(function () { btn.textContent = t; }, 2000); }
      });
    }

    // ===== SALLA UA→GA4 BRIDGE =====
    function buildSallaBridge() {
      var el = document.getElementById('bridgeBody');
      if (!el) return;
      var code = [
        '<script>',
        '// ============================================================',
        '// Salla \u2192 Unified DataLayer Bridge v2 (GA4 + Meta + TikTok)',
        '// GTM Custom HTML Tag | Trigger: Consent Initialization - All Pages',
        '// Normalizes ANY Salla dataLayer shape into a clean GA4 schema:',
        '//   { event, event_id, ecommerce: { currency, value|price, items:[] } }',
        '//',
        '// FIXES vs v1:',
        '//   \u2022 brand is an object in Product List Viewed \u2192 now extracted via .name',
        '//   \u2022 item_sku field added to normalized items',
        '//   \u2022 begin_checkout (cart::submitted) has no products \u2192 uses cached cart',
        '//   \u2022 add_to_wishlist has no products \u2192 uses cached last viewed product',
        '//   \u2022 Cart Viewed currency also checked from slot0.products[0].currency',
        '// ============================================================',
        '(function () {',
        '  if (window._etSallaBridge) return; // run once',
        '  window._etSallaBridge = true;',
        '',
        '  // ── Salla event names \u2192 standard (GA4) names ──────────',
        '  var EVENT_MAP = {',
        "    'Product Viewed':            'view_item',",
        "    'Product List Viewed':       'view_item_list',",
        "    'addToCart':                 'add_to_cart',",
        "    'Cart Viewed':               'view_cart',",
        "    'Product Removed':           'remove_from_cart',",
        "    'Product Added to Wishlist': 'add_to_wishlist',",
        "    'cart::submitted':           'begin_checkout',",
        "    'purchase':                  'purchase',",
        "    'search':                    'search',",
        "    'Signed In':                 'login'",
        '  };',
        '',
        '  // ── State cache ─────────────────────────────────────────',
        '  // Salla\'s cart::submitted and Product Added to Wishlist fire with NO product data.',
        '  // We cache the last known cart (view_cart/add_to_cart) and last product (view_item)',
        '  // and use them as fallbacks so these events still fire with real data.',
        '  var _lastCart    = null;  // { items, price, currency } from view_cart or add_to_cart',
        '  var _lastProduct = null;  // { items, price, currency } from view_item',
        '',
        '  // ── Helpers ─────────────────────────────────────────────',
        '  function toNum(v){ var n = parseFloat(v); return isNaN(n) ? 0 : n; }',
        '  function toInt(v){ var n = parseInt(v, 10); return isNaN(n) ? 0 : n; }',
        '  function round2(n){ return Math.round((n + Number.EPSILON) * 100) / 100; }',
        '  function hasKeys(o){ return o && typeof o === "object" && !Array.isArray(o); }',
        '  // FIX: extract string from an object field (handles brand/category as objects)',
        '  function strField(v, keys){',
        '    if (!v) return \'\';',
        '    if (typeof v === \'string\') return v;',
        '    if (typeof v === \'object\') {',
        '      for (var ki = 0; ki < keys.length; ki++) if (v[keys[ki]]) return String(v[keys[ki]]);',
        '    }',
        '    return \'\';',
        '  }',
        '',
        '  // event_id: reuse if present, else derive (order_id + ts), else timestamp+rand.',
        '  function genEventId(raw, mapped){',
        '    var ec = raw.ecommerce || {};',
        '    if (ec.event_id)  return String(ec.event_id);',
        '    if (raw.event_id) return String(raw.event_id);',
        '    var af = (ec.purchase && ec.purchase.actionField) || {};',
        "    if (af.id)        return String(af.id) + '_' + Date.now();",
        "    if (raw.order_id) return String(raw.order_id) + '_' + Date.now();",
        "    return (mapped || 'evt') + '_' + Date.now() + '_' + Math.floor(Math.random() * 1e6);",
        '  }',
        '',
        '  // Dynamic product extraction — scans every known Salla shape by MEANING.',
        '  function extractProducts(raw){',
        '    var out = [];',
        '    var ec  = raw.ecommerce || {};',
        "    var slot0 = raw[0] || raw['0'];",
        '',
        '    // 1) Enhanced Ecommerce containers (addToCart, purchase, etc.)',
        '    [ec.add, ec.remove, ec.purchase, ec.checkout, ec.detail].forEach(function(box){',
        '      if (box && Array.isArray(box.products) && box.products.length) out.push(box.products);',
        '    });',
        '    if (Array.isArray(ec.impressions) && ec.impressions.length) out.push(ec.impressions);',
        '',
        '    // 2) Top-level arrays (Product List Viewed uses raw.data)',
        '    if (Array.isArray(raw.data)     && raw.data.length)    out.push(raw.data);',
        '    if (Array.isArray(raw.items)    && raw.items.length)   out.push(raw.items);',
        '    if (Array.isArray(raw.products) && raw.products.length) out.push(raw.products);',
        '',
        '    // 3) Numeric-indexed wrapper raw[0] — Salla idiom for Product Viewed,',
        '    //    Cart Viewed ({ cart_id, products:[] }), Product Removed, etc.',
        '    if (hasKeys(slot0)) {',
        '      if (Array.isArray(slot0.products) && slot0.products.length) out.push(slot0.products);',
        '      else if (slot0.id || slot0.sku || slot0.name)               out.push([slot0]);',
        '    }',
        '',
        '    // 4) Last resort: any numeric-indexed key that looks like a product',
        '    if (!out.length) {',
        '      Object.keys(raw).forEach(function(k){',
        '        if (/^\\d+$/.test(k) && raw[k] && (raw[k].id || raw[k].sku || raw[k].name)) out.push([raw[k]]);',
        '      });',
        '    }',
        '',
        '    for (var i = 0; i < out.length; i++) if (out[i] && out[i].length) return out[i];',
        '    return [];',
        '  }',
        '',
        '  // Normalize any product-ish object into strict GA4 item schema.',
        '  // FIX v2: brand and category are handled as objects (Salla Product List Viewed',
        '  //         sends brand as { id, url, name } — NOT a plain string).',
        '  function normalizeItems(products, listName){',
        '    return (products || []).map(function(p, i){',
        '      if (!p || typeof p !== \'object\') return null;',
        '      var item = {',
        "        item_id:       String(p.id || p.sku || p.product_id || ''),",
        "        item_name:     p.name || p.title || '',",
        '        // FIX: category & brand can be objects — extract .name',
        "        item_category: strField(p.category, ['name','title']),",
        "        item_brand:    strField(p.brand,    ['name']),",
        "        item_variant:  strField(p.variant || p.variation, ['name']) || (typeof (p.variant || p.variation) === 'string' ? (p.variant || p.variation) : ''),",
        '        // FIX: include item_sku for clients who track SKU separately from product ID',
        "        item_sku:      p.sku || p.item_sku || String(p.id || ''),",
        '        price:         round2(toNum(p.price || p.amount || p.unit_price || p.value)),',
        '        quantity:      toInt(p.quantity || p.qty) || 1,',
        '        index:         i',
        '      };',
        '      if (listName) item.item_list_name = listName;',
        '      return item;',
        '    }).filter(function(x){ return x && x.item_id; });',
        '  }',
        '',
        '  // FIX v2: also try slot0.products[0].currency (Cart Viewed has no currency at slot0 level)',
        '  function extractCurrency(raw){',
        '    var ec = raw.ecommerce || {};',
        '    var af = (ec.purchase && ec.purchase.actionField) || {};',
        "    var slot0 = raw[0] || raw['0'] || {};",
        '    var prodCur = (Array.isArray(slot0.products) && slot0.products[0]) ? slot0.products[0].currency : null;',
        '    return ec.currencyCode || ec.currency || af.currency_code ||',
        "           slot0.currency || prodCur || (raw.data && raw.data[0] && raw.data[0].currency) || 'SAR';",
        '  }',
        '',
        '  function extractRevenue(raw){',
        '    var ec = raw.ecommerce || {};',
        '    var af = (ec.purchase && ec.purchase.actionField) || {};',
        '    return toNum(af.revenue || af.total || ec.revenue || ec.value);',
        '  }',
        '',
        '  function extractTransactionId(raw){',
        '    var ec = raw.ecommerce || {};',
        '    var af = (ec.purchase && ec.purchase.actionField) || {};',
        "    return String(af.id || ec.transaction_id || raw.order_id || ec.event_id || '');",
        '  }',
        '',
        '  function sumLineItems(items){',
        '    return round2(items.reduce(function(s, it){ return s + (it.price * it.quantity); }, 0));',
        '  }',
        '  function sumQty(items){',
        '    return items.reduce(function(s, it){ return s + (parseInt(it.quantity,10)||0); }, 0);',
        '  }',
        '',
        '  // ── Hook dataLayer.push ────────────────────────────────',
        '  window.dataLayer = window.dataLayer || [];',
        '  var _origPush = Array.prototype.push.bind(window.dataLayer);',
        '',
        '  window.dataLayer.push = function(raw){',
        '    _origPush(raw);',
        '    if (!raw || typeof raw !== \'object\' || !raw.event) return;',
        '    if (raw.__et_normalized) return;',
        '',
        '    var mapped = EVENT_MAP[raw.event];',
        '    if (!mapped) return;',
        '',
        "    var listName = (mapped === 'view_item_list' && raw.title)",
        "      ? String(raw.title).replace(/<[^>]+>/g, '').trim() : '';",
        '',
        '    var products = extractProducts(raw);',
        "    var items    = normalizeItems(products, mapped === 'view_item_list' ? listName : '');",
        '    var currency = extractCurrency(raw);',
        '    var eventId  = genEventId(raw, mapped);',
        '',
        '    // FIX v2: begin_checkout (cart::submitted) fires with NO product data.',
        '    // Use cached cart state from the last view_cart or add_to_cart event.',
        "    if (mapped === 'begin_checkout' && items.length === 0 && _lastCart) {",
        '      items    = _lastCart.items;',
        '      currency = _lastCart.currency || currency;',
        '    }',
        '',
        '    // FIX v2: add_to_wishlist fires with NO product data.',
        '    // Use cached last viewed product from view_item.',
        "    if (mapped === 'add_to_wishlist' && items.length === 0 && _lastProduct) {",
        '      items    = _lastProduct.items;',
        '      currency = _lastProduct.currency || currency;',
        '    }',
        '',
        '    // GA4 best practice: clear previous ecommerce object before pushing a new one.',
        '    _origPush({ ecommerce: null, __et_normalized: true });',
        '',
        '    // Monetary semantics (per-event):',
        '    //   purchase         → ecommerce.value  (order total from actionField.revenue)',
        '    //   view_item        → ecommerce.price  (single product price)',
        '    //   add_to_wishlist  → ecommerce.price  (single product price — fallback from cache)',
        '    //   add_to_cart      → ecommerce.price  (unit price × qty)',
        '    //   remove_from_cart → ecommerce.price  (line total)',
        '    //   view_cart        → ecommerce.price  (sum of all line items)',
        '    //   begin_checkout   → ecommerce.price  (from cached cart)',
        '    //   view_item_list   → (no monetary field)',
        '    var ecBlock = { currency: currency, items: items };',
        "    if (mapped === 'purchase') {",
        '      ecBlock.value     = round2(extractRevenue(raw) || sumLineItems(items));',
        '      ecBlock.num_items = sumQty(items);',
        "    } else if (mapped === 'view_item' || mapped === 'add_to_wishlist') {",
        '      ecBlock.price     = round2(items[0] ? items[0].price : 0);',
        '      ecBlock.num_items = items.length ? (parseInt(items[0].quantity, 10) || 1) : 0;',
        "    } else if (mapped === 'add_to_cart' || mapped === 'remove_from_cart') {",
        '      ecBlock.price     = round2(sumLineItems(items));',
        '      ecBlock.num_items = sumQty(items);',
        "    } else if (mapped === 'view_cart' || mapped === 'begin_checkout') {",
        '      ecBlock.price     = round2(sumLineItems(items));',
        '      ecBlock.num_items = sumQty(items);',
        '    }',
        '',
        '    var payload = {',
        '      event:           mapped,',
        '      event_id:        eventId,',
        '      __et_normalized: true,',
        '      ecommerce:       ecBlock',
        '    };',
        '',
        "    if (mapped === 'purchase') {",
        '      var txId = extractTransactionId(raw) || eventId;',
        '      payload.ecommerce.transaction_id = txId;',
        '      var af = (raw.ecommerce && raw.ecommerce.purchase && raw.ecommerce.purchase.actionField) || {};',
        '      payload.ecommerce.tax      = round2(toNum(af.tax));',
        '      payload.ecommerce.shipping = round2(toNum(af.shipping));',
        "      payload.ecommerce.coupon   = af.coupon || '';",
        '    }',
        "    if (mapped === 'view_item_list') {",
        '      payload.ecommerce.item_list_name = listName;',
        '    }',
        "    if (mapped === 'search') {",
        "      payload.search_term = raw.searchTerm || raw.search_term || '';",
        '    }',
        "    if (mapped === 'login') {",
        '      delete payload.ecommerce;',
        "      payload.method = 'salla';",
        '    }',
        '',
        '    // Customer passthrough — hashed email/phone for Meta CAPI / GA4 User-ID.',
        '    if (raw.customer) payload.customer = raw.customer;',
        '',
        '    _origPush(payload);',
        '',
        '    // ── Update state cache AFTER pushing ──────────────────',
        '    // Cache cart state for the next begin_checkout event.',
        "    if ((mapped === 'view_cart' || mapped === 'add_to_cart') && items.length) {",
        '      _lastCart = { items: items, price: ecBlock.price, currency: currency };',
        '    }',
        '    // Cache last product for the next add_to_wishlist event.',
        "    if (mapped === 'view_item' && items.length) {",
        '      _lastProduct = { items: items, price: ecBlock.price, currency: currency };',
        '    }',
        '  };',
        '})();',
        '<\/script>'
      ].join('\n');
      el.textContent = code;
      window._sallaBridgeCode = code;
    }

    function dlBridgeFile() {
      var code = window._sallaBridgeCode || document.getElementById('bridgeBody').textContent;
      var today = new Date().toISOString().split('T')[0];
      dlFile(code, 'salla-ua-ga4-bridge-' + today + '.js', 'text/javascript');
    }

    // ===== AUDIT REPORT =====
    function buildAuditReport() {
      var el = document.getElementById('auditContent');
      if (!el) return;
      var name = (S.lead && S.lead.name) || 'Client';
      var loc = (S.lead && S.lead.location) || '';
      var today = new Date().toLocaleDateString('ar-EG');
      var cmsName = S.cms ? (CMS[S.cms] ? CMS[S.cms].name : S.cms) : '—';
      var totalEvents = S.events.length;
      var totalPlat = S.platforms.length;

      // Coverage score
      var covered = 0, total = 0;
      S.platforms.forEach(function (p) {
        S.events.forEach(function (ev) {
          total++;
          if (PMAP[p] && PMAP[p][ev]) covered++;
        });
      });
      var coveragePct = total > 0 ? Math.round((covered / total) * 100) : 0;
      var scoreColor = coveragePct >= 80 ? '#10b981' : coveragePct >= 50 ? '#f59e0b' : '#f43f5e';

      var h = '';
      // Header
      h += '<div style="background:linear-gradient(135deg,rgba(14,165,233,.12),rgba(16,185,129,.06));border:1px solid rgba(14,165,233,.2);border-radius:16px;padding:24px 28px;margin-bottom:16px;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">';
      h += '<div>';
      h += '<div style="font-size:10px;font-family:var(--font-mono);letter-spacing:2px;color:var(--mut);text-transform:uppercase;margin-bottom:4px;">Easy Track · Audit Report</div>';
      h += '<div style="font-size:22px;font-weight:900;color:var(--wht);margin-bottom:2px;">' + name + '</div>';
      h += '<div style="font-size:12px;color:var(--mut);">' + (loc ? loc + ' · ' : '') + today + '</div>';
      h += '</div>';
      h += '<div style="text-align:center;background:rgba(0,0,0,.3);border-radius:12px;padding:14px 20px;">';
      h += '<div style="font-size:10px;font-family:var(--font-mono);letter-spacing:1px;color:var(--mut);margin-bottom:4px;">COVERAGE SCORE</div>';
      h += '<div style="font-size:32px;font-weight:900;color:' + scoreColor + ';">' + coveragePct + '%</div>';
      h += '</div>';
      h += '</div>';

      // Summary pills
      h += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:16px;">';
      var pills = [
        { lbl: 'CMS', val: cmsName, c: '#10b981' },
        { lbl: 'Platforms', val: totalPlat, c: '#0ea5e9' },
        { lbl: 'Events', val: totalEvents, c: '#6366f1' }
      ];
      pills.forEach(function (p) {
        h += '<div style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:12px;padding:14px 16px;">';
        h += '<div style="font-size:10px;font-family:var(--font-mono);color:var(--mut);letter-spacing:1px;margin-bottom:4px;">' + p.lbl.toUpperCase() + '</div>';
        h += '<div style="font-size:18px;font-weight:900;color:' + p.c + ';">' + p.val + '</div>';
        h += '</div>';
      });
      h += '</div>';

      // Platform coverage table
      h += '<div style="font-size:11px;font-family:var(--font-mono);letter-spacing:1.5px;color:var(--mut);text-transform:uppercase;margin-bottom:8px;">Platform Coverage</div>';
      h += '<div style="overflow-x:auto;margin-bottom:16px;"><table style="width:100%;border-collapse:collapse;font-size:12px;">';
      h += '<thead><tr style="border-bottom:1px solid var(--bdr2);">';
      h += '<th style="text-align:right;padding:10px 12px;color:var(--mut);font-weight:600;">Platform</th>';
      h += '<th style="text-align:center;padding:10px 12px;color:var(--mut);font-weight:600;">Pixel ID</th>';
      h += '<th style="text-align:center;padding:10px 12px;color:var(--mut);font-weight:600;">Events</th>';
      h += '<th style="text-align:center;padding:10px 12px;color:var(--mut);font-weight:600;">Coverage</th>';
      h += '</tr></thead><tbody>';
      S.platforms.forEach(function (p) {
        var pm = PM[p];
        var pid = S.pixelIds[p] || '—';
        var mappedCount = 0;
        S.events.forEach(function (ev) { if (PMAP[p] && PMAP[p][ev]) mappedCount++; });
        var pct = totalEvents > 0 ? Math.round((mappedCount / totalEvents) * 100) : 0;
        var pCol = pct >= 80 ? '#10b981' : pct >= 50 ? '#f59e0b' : '#f43f5e';
        h += '<tr style="border-bottom:1px solid rgba(255,255,255,.04);">';
        h += '<td style="padding:10px 12px;font-weight:700;">' + pm.icon + ' ' + pm.name + '</td>';
        h += '<td style="padding:10px 12px;text-align:center;font-family:var(--font-mono);font-size:11px;color:var(--acc);">' + pid + '</td>';
        h += '<td style="padding:10px 12px;text-align:center;">' + mappedCount + ' / ' + totalEvents + '</td>';
        h += '<td style="padding:10px 12px;text-align:center;font-weight:700;color:' + pCol + ';">' + pct + '%</td>';
        h += '</tr>';
      });
      h += '</tbody></table></div>';

      // Events table
      h += '<div style="font-size:11px;font-family:var(--font-mono);letter-spacing:1.5px;color:var(--mut);text-transform:uppercase;margin-bottom:8px;">Events Matrix</div>';
      h += '<div style="overflow-x:auto;margin-bottom:16px;"><table style="width:100%;border-collapse:collapse;font-size:11px;">';
      h += '<thead><tr style="border-bottom:1px solid var(--bdr2);">';
      h += '<th style="text-align:right;padding:8px 12px;color:var(--mut);">GA4 Event</th>';
      h += '<th style="text-align:center;padding:8px 12px;color:var(--mut);">Score</th>';
      S.platforms.forEach(function (p) { h += '<th style="text-align:center;padding:8px 12px;color:var(--mut);">' + PM[p].icon + '</th>'; });
      h += '</tr></thead><tbody>';
      S.events.forEach(function (ev) {
        var evData = GA4[ev];
        var sc = evData ? evData.score : 0;
        var scCol = sc >= 8 ? '#10b981' : sc >= 4 ? '#f59e0b' : '#f43f5e';
        h += '<tr style="border-bottom:1px solid rgba(255,255,255,.03);">';
        h += '<td style="padding:8px 12px;font-family:var(--font-mono);">' + ev + '</td>';
        h += '<td style="padding:8px 12px;text-align:center;font-weight:700;color:' + scCol + ';">' + sc + '</td>';
        S.platforms.forEach(function (p) {
          var mapped = PMAP[p] && PMAP[p][ev];
          h += '<td style="padding:8px 12px;text-align:center;">' + (mapped ? '<span style="color:#10b981">✓</span>' : '<span style="color:rgba(255,255,255,.15)">—</span>') + '</td>';
        });
        h += '</tr>';
      });
      h += '</tbody></table></div>';

      // Recommendations
      var recs = [];
      if (S.cms === 'salla') recs.push({ icon: '🏗️', title: 'Salla UA→GA4 Bridge', body: 'سلة بتبعت UA Enhanced Ecommerce format — استخدم الـ Bridge tab عشان تحوّل الـ events لـ GA4 تلقائياً.' });
      if (S.platforms.indexOf('ga4') === -1) recs.push({ icon: '📊', title: 'GA4 غير مُضاف', body: 'GA4 مش موجود في الخطة — يُنصح بإضافته عشان تقدر تبني Custom Audiences وتتابع الـ conversions.' });
      S.events.forEach(function (ev) { if (GA4[ev] && GA4[ev].score >= 8) { var allMapped = S.platforms.every(function (p) { return PMAP[p] && PMAP[p][ev]; }); if (!allMapped) recs.push({ icon: '⚠️', title: ev + ' — غير مُغطى في كل المنصات', body: 'الـ event ده score ' + GA4[ev].score + '/10 — مهم جداً. تأكد من ربطه في كل المنصات.' }); } });
      if (recs.length) {
        h += '<div style="font-size:11px;font-family:var(--font-mono);letter-spacing:1.5px;color:var(--mut);text-transform:uppercase;margin-bottom:8px;">Recommendations</div>';
        h += '<div style="display:flex;flex-direction:column;gap:8px;">';
        recs.forEach(function (r) {
          h += '<div style="background:rgba(248,113,113,.06);border:1px solid rgba(248,113,113,.15);border-radius:10px;padding:12px 16px;">';
          h += '<div style="font-weight:700;margin-bottom:4px;">' + r.icon + ' ' + r.title + '</div>';
          h += '<div style="font-size:12px;color:var(--mut2);">' + r.body + '</div>';
          h += '</div>';
        });
        h += '</div>';
      }

      el.innerHTML = h;
    }

    function printAuditReport() {
      buildAuditReport();
      var content = document.getElementById('auditContent');
      if (!content) return;
      var w = window.open('', '_blank');
      var name = (S.lead && S.lead.name) || 'Client';
      w.document.write('<html><head><meta charset="UTF-8"><title>Audit Report — ' + name + '</title>');
      w.document.write('<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">');
      w.document.write('<style>*{margin:0;padding:0;box-sizing:border-box;}body{background:#080808;color:#d4d4d4;font-family:Cairo,sans-serif;padding:32px;-webkit-print-color-adjust:exact;print-color-adjust:exact;}@media print{body{padding:16px;}}</style>');
      w.document.write('</head><body>');
      w.document.write(content.innerHTML);
      w.document.write('</body></html>');
      w.document.close();
      setTimeout(function () { w.print(); }, 600);
    }

    function copyAuditReport() {
      var content = document.getElementById('auditContent');
      if (!content) return;
      navigator.clipboard.writeText(content.innerText).then(function () {
        var btn = document.querySelector('[onclick="copyAuditReport()"]');
        if (btn) { var t = btn.textContent; btn.textContent = '✅ تم'; setTimeout(function () { btn.textContent = t; }, 2000); }
      });
    }

    // ===== MULTI-STORE =====
    function _getStores() {
      try { return JSON.parse(localStorage.getItem('et_stores') || '[]'); } catch (e) { return []; }
    }
    function _saveStores(arr) {
      localStorage.setItem('et_stores', JSON.stringify(arr));
    }

    function saveStore() {
      var nameEl = document.getElementById('storeNameInput');
      var storeName = nameEl ? nameEl.value.trim() : '';
      if (!storeName) { storeName = (S.lead && S.lead.name) || 'متجر جديد'; }
      if (!S.cms && !S.platforms.length) { alert('اعمل Generate الأول عشان يكون فيه config تحفظه.'); return; }
      var stores = _getStores();
      stores.unshift({
        name: storeName,
        savedAt: new Date().toISOString(),
        cms: S.cms,
        platforms: S.platforms.slice(),
        events: S.events.slice(),
        pixelIds: JSON.parse(JSON.stringify(S.pixelIds)),
        lead: S.lead ? JSON.parse(JSON.stringify(S.lead)) : {}
      });
      if (stores.length > 20) stores = stores.slice(0, 20); // max 20 stores
      _saveStores(stores);
      if (nameEl) nameEl.value = '';
      renderStoresList();
      // Toast
      var t = document.createElement('div');
      t.textContent = '✅ تم حفظ المتجر: ' + storeName;
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#6366f1;color:#fff;padding:12px 20px;border-radius:12px;font-family:Cairo,sans-serif;font-weight:700;font-size:14px;z-index:9999;';
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }

    function loadStore(idx) {
      var stores = _getStores();
      var store = stores[idx];
      if (!store) return;
      if (store.cms) S.cms = store.cms;
      if (store.platforms) S.platforms = store.platforms;
      if (store.events) S.events = store.events;
      if (store.pixelIds) S.pixelIds = store.pixelIds;
      if (store.lead) S.lead = store.lead;
      generate();
      var t = document.createElement('div');
      t.textContent = '⚡ تم تحميل: ' + store.name;
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0ecfb0;color:#05090f;padding:12px 20px;border-radius:12px;font-family:Cairo,sans-serif;font-weight:700;font-size:14px;z-index:9999;';
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 2500);
    }

    function deleteStore(idx) {
      var stores = _getStores();
      stores.splice(idx, 1);
      _saveStores(stores);
      renderStoresList();
    }

    function renderStoresList() {
      var el = document.getElementById('storesList');
      if (!el) return;
      var stores = _getStores();
      if (!stores.length) {
        el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-size:13px;">مفيش متاجر محفوظة لحد دلوقتي<br><span style="font-size:11px;color:var(--mut2);">اعمل Generate لمشروع وبعدين احفظه كمتجر</span></div>';
        return;
      }
      var h = '<div style="display:flex;flex-direction:column;gap:10px;">';
      stores.forEach(function (s, i) {
        var date = '—';
        try { date = new Date(s.savedAt).toLocaleDateString('ar-EG'); } catch (e) { }
        var cms = s.cms ? (CMS[s.cms] ? CMS[s.cms].name : s.cms) : '—';
        var plats = (s.platforms || []).map(function (p) { return PM[p] ? PM[p].icon : p; }).join(' ');
        h += '<div style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:12px;padding:14px 18px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">';
        h += '<div style="flex:1;min-width:140px;">';
        h += '<div style="font-weight:700;font-size:14px;color:var(--wht2);margin-bottom:4px;">' + s.name + '</div>';
        h += '<div style="display:flex;gap:6px;flex-wrap:wrap;">';
        h += '<span style="background:rgba(16,185,129,.08);color:var(--grn);font-size:11px;padding:2px 8px;border-radius:5px;font-family:monospace;border:1px solid rgba(16,185,129,.15);">' + cms + '</span>';
        h += '<span style="background:var(--acc-dim);color:var(--acc);font-size:13px;padding:2px 8px;border-radius:5px;border:1px solid rgba(14,165,233,.15);">' + plats + '</span>';
        h += '<span style="background:var(--sur3);color:var(--mut);font-size:11px;padding:2px 8px;border-radius:5px;font-family:monospace;border:1px solid var(--bdr2);">' + (s.events || []).length + ' events</span>';
        h += '</div>';
        h += '<div style="font-family:monospace;font-size:10px;color:var(--mut2);margin-top:5px;">' + date + '</div>';
        h += '</div>';
        h += '<div style="display:flex;gap:6px;">';
        h += '<button onclick="loadStore(' + i + ')" style="background:var(--acc);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-family:var(--font-ui);font-size:12px;font-weight:700;cursor:pointer;">⚡ تحميل</button>';
        h += '<button onclick="deleteStore(' + i + ')" style="background:rgba(248,113,113,.1);color:var(--red);border:1px solid rgba(248,113,113,.2);border-radius:8px;padding:8px 12px;font-family:var(--font-ui);font-size:12px;cursor:pointer;">🗑️</button>';
        h += '</div>';
        h += '</div>';
      });
      h += '</div>';
      el.innerHTML = h;
    }

    // ══════════════════════════════════════════════════════════════════════
    // MANAGED GTM FLOW
    // Creates a GTM container in Easy Track's managed account (server-side),
    // no OAuth needed. Calls /api/managed/create-container.
    // ══════════════════════════════════════════════════════════════════════
    function _mgdProgress(msg, show) {
      var el  = document.getElementById('mgdProgress');
      var txt = document.getElementById('mgdProgressText');
      if (!el) return;
      if (show === false) { el.style.display = 'none'; return; }
      el.style.display = 'block';
      if (txt && msg) txt.textContent = msg;
    }

    function _mgdShowError(msg, hint) {
      var box = document.getElementById('mgdResult');
      if (!box) return;
      box.style.display = 'block';
      box.innerHTML =
        '<div style="background:rgba(255,180,171,.08);border:1px solid rgba(255,180,171,.3);' +
        'border-radius:12px;padding:14px 16px;color:#ffb4ab;">' +
          '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;font-weight:700;">' +
            '<span class="material-symbols-outlined" style="font-size:18px;">error</span>' +
            'فشل إنشاء الـ Container' +
          '</div>' +
          '<div style="font-size:13px;line-height:1.6;direction:rtl;unicode-bidi:isolate;">' +
            String(msg || 'حدث خطأ غير متوقع').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') +
          '</div>' +
          (hint ? '<div style="font-size:11px;margin-top:8px;color:var(--mut);">' + String(hint).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div>' : '') +
        '</div>';
    }

    // ── Link the managed-container GTM snippet back to the `projects` doc
    // the user just created, so My Projects can render the real code.
    // Safe: no-ops if db / currentUser / the project ref aren't available.
    async function _etAttachSnippetToProject(data) {
      try {
        if (!db || !currentUser || !currentUser.id || !data || !data.gtmPublicId) return;
        var payload = {
          gtmPublicId:   data.gtmPublicId || null,
          gtmAccountId:  data.gtmAccountId || null,
          gtmContainerId: data.gtmContainerId || null,
          gtmWorkspaceId: data.gtmWorkspaceId || null,
          gtmVersionId:   data.gtmVersionId || null,
          gtmPublished:   !!data.published,
          snippetHead:    data.snippetHead || '',
          snippetBody:    data.snippetBody || '',
          containerName:  data.containerName || null,
          updated_at:     firebase.firestore.FieldValue.serverTimestamp()
        };
        // Preferred path — update the exact project the user just generated.
        if (window._etLastProjectDocId) {
          try {
            await db.collection('projects').doc(window._etLastProjectDocId).update(payload);
            return;
          } catch (e) { /* fall through to heuristic */ }
        }
        // Fallback — attach to the most recent project for this user.
        var snap = null;
        try {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .orderBy('created_at', 'desc')
            .limit(1).get();
        } catch (ie) {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .limit(1).get();
        }
        if (snap && !snap.empty) {
          var docRef = snap.docs[0].ref;
          try { await docRef.update(payload); } catch (_) { /* ignore */ }
        }
      } catch (e) {
        console.warn('attach snippet failed:', e && e.message);
      }
    }

    function _mgdShowSuccess(data) {
      var box = document.getElementById('mgdResult');
      if (!box) return;
      box.style.display = 'block';
      // fire-and-forget — keep My Projects in sync with the real GTM snippet
      try { _etAttachSnippetToProject(data); } catch (_) { /* ignore */ }

      var gtmId  = data.gtmPublicId;
      var head   = (data.snippetHead || '').replace(/</g, '&lt;');
      var body   = (data.snippetBody || '').replace(/</g, '&lt;');
      var containerName = (data.containerName || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      var inviteEmail   = (data.inviteEmail   || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      var status = data.published
        ? '<span style="background:rgba(70,241,197,.12);color:var(--acc);padding:3px 10px;border-radius:4px;font-size:11px;font-weight:700;letter-spacing:.5px;">LIVE</span>'
        : '<span style="background:rgba(245,158,11,.12);color:var(--amber);padding:3px 10px;border-radius:4px;font-size:11px;font-weight:700;letter-spacing:.5px;">DRAFT</span>';

      // Invite banner — shown only if an email was sent (success) or failed
      var inviteBanner = '';
      if (data.invited && inviteEmail) {
        inviteBanner =
          '<div style="background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.2);border-radius:10px;padding:10px 12px;margin-bottom:14px;display:flex;align-items:center;gap:10px;">' +
            '<span class="material-symbols-outlined" style="color:var(--acc);font-size:18px;">mark_email_read</span>' +
            '<div style="font-size:12px;color:var(--wht2);line-height:1.5;">' +
              'تم إرسال دعوة GTM (صلاحية قراءة) على <b style="color:var(--wht);">' + inviteEmail + '</b>. افتح بريدك واقبل الدعوة لتشوف الـ container في حساب GTM بتاعك.' +
            '</div>' +
          '</div>';
      } else if (data.inviteError && inviteEmail) {
        inviteBanner =
          '<div style="background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:10px;padding:10px 12px;margin-bottom:14px;display:flex;align-items:center;gap:10px;">' +
            '<span class="material-symbols-outlined" style="color:var(--amber);font-size:18px;">warning</span>' +
            '<div style="font-size:12px;color:var(--wht2);line-height:1.5;">' +
              'فشل إرسال دعوة GTM لـ <b style="color:var(--wht);">' + inviteEmail + '</b> — الـ container اتعمل بشكل طبيعي. ممكن تتواصل معانا عشان ندعيك يدوياً.' +
            '</div>' +
          '</div>';
      }

      box.innerHTML =
        '<div style="background:rgba(70,241,197,.06);border:1px solid rgba(70,241,197,.25);border-radius:14px;padding:16px 18px;">' +
          '<div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">' +
            '<span class="material-symbols-outlined" style="color:var(--acc);font-size:22px;">check_circle</span>' +
            '<div style="font-family:var(--font-display);font-weight:800;font-size:16px;color:var(--wht);">' +
              (containerName
                ? 'تم إنشاء "<span style="color:var(--acc);">' + containerName + '</span>" بنجاح'
                : 'الـ Container اتعمل بنجاح') +
            '</div>' +
            '<div style="margin-right:auto;">' + status + '</div>' +
          '</div>' +
          inviteBanner +

          '<div style="background:var(--sur);border-radius:10px;padding:12px 14px;margin-bottom:14px;display:flex;align-items:center;gap:12px;">' +
            '<div style="font-size:11px;color:var(--mut);letter-spacing:1px;font-family:var(--font-mono);text-transform:uppercase;">GTM ID</div>' +
            '<div id="mgdGtmId" style="font-family:var(--font-mono);font-size:16px;font-weight:700;color:var(--acc);letter-spacing:.5px;">' + gtmId + '</div>' +
            '<button onclick="_mgdCopy(\'' + gtmId + '\', this)" ' +
              'style="margin-right:auto;background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:6px 12px;color:var(--wht2);font-family:var(--font-ui);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;">' +
              '<span class="material-symbols-outlined" style="font-size:13px;">content_copy</span>Copy' +
            '</button>' +
          '</div>' +

          '<div style="font-size:12px;color:var(--wht2);font-weight:700;margin-bottom:6px;">حط الـ code ده في &lt;head&gt; بتاع الموقع:</div>' +
          '<pre id="mgdSnippetHead" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--wht2);max-height:140px;overflow:auto;direction:ltr;text-align:left;margin-bottom:8px;line-height:1.5;">' + head + '</pre>' +
          '<button onclick="_mgdCopy(document.getElementById(\'mgdSnippetHead\').textContent, this)" style="margin-bottom:14px;background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:6px 12px;color:var(--wht2);font-family:var(--font-ui);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;"><span class="material-symbols-outlined" style="font-size:13px;">content_copy</span>نسخ</button>' +

          '<div style="font-size:12px;color:var(--wht2);font-weight:700;margin-bottom:6px;">وحط ده بعد &lt;body&gt; مباشرة:</div>' +
          '<pre id="mgdSnippetBody" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--wht2);max-height:100px;overflow:auto;direction:ltr;text-align:left;margin-bottom:8px;line-height:1.5;">' + body + '</pre>' +
          '<button onclick="_mgdCopy(document.getElementById(\'mgdSnippetBody\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:6px 12px;color:var(--wht2);font-family:var(--font-ui);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;"><span class="material-symbols-outlined" style="font-size:13px;">content_copy</span>نسخ</button>' +

          '<div style="margin-top:14px;padding-top:14px;border-top:1px solid var(--bdr2);display:flex;gap:16px;flex-wrap:wrap;font-size:11px;color:var(--mut);">' +
            '<span>🏷️ ' + (data.importedTagCount       || 0) + ' tags</span>' +
            '<span>⚡ '  + (data.importedTriggerCount  || 0) + ' triggers</span>' +
            '<span>🔧 '  + (data.importedVariableCount || 0) + ' variables</span>' +
          '</div>' +
        '</div>';

      // ─── Server-Side block — only when mode=client_server returned a server ───
      // Two paths:
      //   AUTO   — backend deployed to Stape via STAPE_API_KEY. Show a green
      //            "everything's wired" banner with the deployed URL. No
      //            interaction required from the user.
      //   FALLBACK — backend couldn't deploy (key missing or Stape API failed).
      //              Show the legacy manual flow: containerConfig blob + URL
      //              input + "ربط ونشر" button (calls /api/ss/wire-transport).
      if (data.server && data.server.publicId) {
        var serverBlock  = document.createElement('div');
        var serverGtmId  = data.server.publicId;
        var deployedUrl  = data.server.deployedUrl || null;
        var deployError  = data.server.deployError || null;
        var transportOK  = !!data.server.transportUrlWired;

        if (deployedUrl && transportOK) {
          // ── AUTO PATH ── single banner, no controls.
          serverBlock.style.cssText = 'margin-top:18px;background:rgba(70,241,197,.06);border:1px solid rgba(70,241,197,.3);border-radius:14px;padding:16px 18px;';
          var safeUrl = deployedUrl.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          serverBlock.innerHTML =
            '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">' +
              '<span class="material-symbols-outlined" style="color:var(--acc);font-size:22px;">rocket_launch</span>' +
              '<div style="font-family:var(--font-display);font-weight:800;font-size:15px;color:var(--wht);">Server-Side Tracking مفعّل تلقائياً</div>' +
              '<span style="margin-right:auto;background:rgba(70,241,197,.12);color:var(--acc);padding:3px 10px;border-radius:4px;font-size:11px;font-weight:700;letter-spacing:.5px;">LIVE</span>' +
            '</div>' +
            '<div style="font-size:12.5px;color:var(--wht2);line-height:1.6;margin-bottom:12px;">' +
              'تم نشر sGTM container على Stape وربطه بـ web container تلقائياً. الـ tracking دلوقت سيرفر-سايد بالكامل — مفيش حاجة تعملها انت.' +
            '</div>' +
            '<div style="background:var(--sur);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:12px;">' +
              '<div style="font-size:11px;color:var(--mut);letter-spacing:1px;font-family:var(--font-mono);text-transform:uppercase;flex-shrink:0;">sGTM URL</div>' +
              '<div style="font-family:var(--font-mono);font-size:12px;color:var(--acc);direction:ltr;text-align:left;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">' + safeUrl + '</div>' +
              '<button onclick="_mgdCopy(\'' + deployedUrl.replace(/'/g, "\\'") + '\', this)" ' +
                'style="background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:6px 12px;color:var(--wht2);font-family:var(--font-ui);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;flex-shrink:0;">' +
                '<span class="material-symbols-outlined" style="font-size:13px;">content_copy</span>Copy' +
              '</button>' +
            '</div>' +
            '<div style="margin-top:10px;font-size:11px;color:var(--mut);">' +
              'Server GTM ID: <span style="font-family:var(--font-mono);color:#a99cff;">' + serverGtmId + '</span>' +
            '</div>';
        } else {
          // ── FALLBACK PATH ── auto-deploy didn't run/succeed — show manual UI.
          serverBlock.style.cssText = 'margin-top:18px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.3);border-radius:14px;padding:16px 18px;';
          var rawConfig  = data.server.containerConfig || '(الـ container config لسه بيتولّد — حاول reload الصفحة)';
          var safeConfig = rawConfig.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          var errLine    = deployError
            ? '<div style="background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.25);border-radius:8px;padding:8px 12px;margin-bottom:12px;font-size:12px;color:var(--amber);">' +
              '⚠️ الـ auto-deploy فشل: ' + deployError.replace(/</g, '&lt;') +
              '</div>'
            : '';
          serverBlock.innerHTML =
            '<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">' +
              '<span class="material-symbols-outlined" style="color:var(--amber);font-size:22px;">build</span>' +
              '<div style="font-family:var(--font-display);font-weight:800;font-size:15px;color:var(--wht);">Server Container — نشر يدوي مطلوب</div>' +
            '</div>' +
            errLine +
            '<div style="font-size:12px;color:var(--wht2);font-weight:700;margin-bottom:6px;">1️⃣ انسخ Container Config code:</div>' +
            '<pre id="mgdServerConfig" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--wht2);max-height:140px;overflow:auto;direction:ltr;text-align:left;margin-bottom:8px;line-height:1.5;word-break:break-all;">' + safeConfig + '</pre>' +
            '<button onclick="_mgdCopy(document.getElementById(\'mgdServerConfig\').textContent, this)" style="margin-bottom:14px;background:var(--sur3);border:1px solid var(--bdr2);border-radius:8px;padding:6px 12px;color:var(--wht2);font-family:var(--font-ui);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:5px;"><span class="material-symbols-outlined" style="font-size:13px;">content_copy</span>نسخ Config</button>' +
            '<div style="font-size:12px;color:var(--wht2);font-weight:700;margin-bottom:6px;">2️⃣ بعد ما تنشره يدوياً، الصق الـ sGTM URL هنا:</div>' +
            '<div style="display:flex;gap:8px;align-items:stretch;margin-bottom:8px;">' +
              '<input id="mgdSgtmUrl" type="url" placeholder="https://gtm.your-domain.com" ' +
                'style="flex:1;padding:10px 12px;border-radius:8px;border:1px solid var(--bdr2);background:var(--bg);color:var(--wht);font-family:var(--font-mono);font-size:12px;direction:ltr;text-align:left;">' +
              '<button id="mgdWireBtn" onclick="_mgdWireTransport()" ' +
                'style="background:var(--acc);border:none;border-radius:8px;padding:10px 16px;color:var(--bg);font-weight:700;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;">' +
                '<span class="material-symbols-outlined" style="font-size:15px;">link</span>ربط ونشر' +
              '</button>' +
            '</div>' +
            '<div id="mgdWireStatus" style="font-size:11.5px;color:var(--mut);min-height:18px;line-height:1.5;"></div>';
        }
        box.appendChild(serverBlock);
      }
    }

    // ── Wire the web container's GA4 transport_url to the deployed sGTM URL ──
    // Calls /api/ss/wire-transport via the authenticated _ssApi helper. After
    // success, the web container is auto-published with the new transport_url.
    window._mgdWireTransport = function () {
      var input  = document.getElementById('mgdSgtmUrl');
      var btn    = document.getElementById('mgdWireBtn');
      var status = document.getElementById('mgdWireStatus');
      if (!input || !btn || !status) return;
      var url = (input.value || '').trim();
      if (!url) { status.innerHTML = '<span style="color:#f87171;">اكتب URL الأول</span>'; return; }
      if (!/^https:\/\//i.test(url)) {
        status.innerHTML = '<span style="color:#f87171;">لازم URL يبدأ بـ https://</span>';
        return;
      }

      btn.disabled = true; btn.style.opacity = '.6'; btn.style.cursor = 'wait';
      status.innerHTML = '⏳ جاري ربط الـ web container ونشره...';

      _ssApi('POST', '/api/ss/wire-transport', { sgtmUrl: url }, function (err, res) {
        btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer';
        if (err)              { status.innerHTML = '<span style="color:#f87171;">❌ ' + (err.message || 'فشل') + '</span>'; return; }
        if (!res)             { status.innerHTML = '<span style="color:#f87171;">❌ مفيش رد من السيرفر</span>'; return; }
        if (!res.ok || !res.data || !res.data.ok) {
          var msg = (res.data && (res.data.error || res.data.detail)) || ('HTTP ' + res.status);
          status.innerHTML = '<span style="color:#f87171;">❌ ' + msg + '</span>';
          return;
        }
        status.innerHTML = '<span style="color:var(--acc);">✅ تم ربط الـ web container ونشره — الـ tracking دلوقت سيرفر-سايد!</span>';
        if (btn) { btn.textContent = '✓ تم الربط'; btn.disabled = true; btn.style.opacity = '.5'; }
        if (input) input.disabled = true;
      });
    };

    function _mgdCopy(text, btn) {
      try {
        navigator.clipboard.writeText(text).then(function () {
          if (!btn) return;
          var orig = btn.innerHTML;
          btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:13px;">check</span>تم';
          setTimeout(function () { btn.innerHTML = orig; }, 1500);
        });
      } catch (_) { /* ignore */ }
    }

    async function gtmManagedCreate() {
      // 1. Preconditions
      if (typeof currentUser === 'undefined' || !currentUser || !currentUser.id) {
        _mgdShowError('محتاج تسجل دخول الأول', 'افتح الحساب من أعلى يمين.');
        return;
      }
      if (!_cachedGtmStr || !_cachedGtmStr.trim()) {
        _mgdShowError('لسه مفيش GTM config متولّد', 'ارجع لـ Pixel Config وكمل الـ 5 خطوات.');
        return;
      }

      var configJson;
      try { configJson = JSON.parse(_cachedGtmStr); }
      catch (e) { _mgdShowError('الـ GTM JSON مش صحيح: ' + e.message); return; }

      // 2. Collect metadata from current session state (S) + currentUser
      var _ssToggle = document.getElementById('mgdServerSideChk');
      var _wantServer = !!(_ssToggle && _ssToggle.checked);
      var payload = {
        clientId:    currentUser.id,
        clientEmail: currentUser.email || null,
        projectName: (window.S && S.lead && S.lead.name)
                     ? (S.lead.name + ' — ' + (CMS[S.cms] ? CMS[S.cms].name : S.cms))
                     : ((currentUser.name || currentUser.email || 'Client') + ' — ' + (S.cms || 'site')),
        domain:      (S.lead && S.lead.domain) || null,
        cmsType:     S.cms || null,
        platforms:   S.platforms || [],
        events:      S.events    || [],
        pixelIds:    _serializePixelIds(S.pixelIds),
        configJson:  configJson,
        // When mode=client_server, the server defers publishing the web
        // container until /api/ss/wire-transport runs — we override the user's
        // publishLive choice in that case.
        mode:        _wantServer ? 'client_server' : 'client',
        publishLive: _wantServer ? false : !!document.getElementById('mgdPublishChk').checked,
      };

      // 3. UI → busy
      var btn = document.getElementById('mgdCreateBtn');
      var resultBox = document.getElementById('mgdResult');
      if (btn) { btn.disabled = true; btn.style.opacity = '.6'; btn.style.cursor = 'wait'; }
      if (resultBox) resultBox.style.display = 'none';
      _mgdProgress('جاري إنشاء Container جديد على Easy Track GTM...', true);

      // 4. Call server — kick off an async job, then poll for status.
      // Container provisioning takes 60-120s because of GTM write-quota pacing,
      // so the server returns a jobId immediately and we poll until done.
      try {
        var resp = await fetch('/api/managed/create-container', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(payload),
        });

        // Read response as text first, then try to parse — so HTML error pages
        // (Cloudflare / Railway timeout pages) give a clear message.
        var rawText = await resp.text();
        var data;
        try { data = JSON.parse(rawText); }
        catch (_) {
          throw new Error('السيرفر رجّع صفحة HTML بدل JSON (HTTP ' + resp.status + '). حاول تاني بعد دقيقة.');
        }

        if (!resp.ok || !data.ok) {
          _mgdProgress('', false);
          if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
          _mgdShowError(data.error || ('HTTP ' + resp.status), data.hint || null);
          return;
        }

        if (!data.jobId) {
          // Old server behavior — accept synchronous result if present
          _mgdProgress('', false);
          if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
          _mgdShowSuccess(data);
          return;
        }

        // Poll the job endpoint
        var jobId = data.jobId;
        var _projectDisplayName = payload.projectName || 'Container';
        var stageMsgs = {
          queued:            'في الطابور...',
          capacity_check:    'جاري التحقق من السعة...',
          gtm_provisioning:  'جاري إنشاء "' + _projectDisplayName + '"',
          inviting_user:     'جاري إرسال دعوة "' + _projectDisplayName + '" لبريدك',
          saving:            'جاري حفظ "' + _projectDisplayName + '"',
          done:              'تم إنشاء "' + _projectDisplayName + '" بنجاح',
          error:             'حصل خطأ في "' + _projectDisplayName + '"',
          capacity_exceeded: 'السعة وصلت للحد الأقصى',
        };

        var maxWaitMs   = 15 * 60 * 1000;  // 15 min hard cap
        var pollEveryMs = 4000;            // poll every 4s
        var startedAt   = Date.now();
        var final       = null;
        var lastSeenAt  = Date.now();      // last time we got a valid status update

        while (Date.now() - startedAt < maxWaitMs) {
          await new Promise(function (r) { setTimeout(r, pollEveryMs); });
          try {
            var r2 = await fetch('/api/managed/job/' + encodeURIComponent(jobId));
            var t2 = await r2.text();
            var j2;
            try { j2 = JSON.parse(t2); }
            catch (_) {
              // transient HTML error — keep polling
              continue;
            }
            if (!r2.ok || !j2.ok) continue;

            lastSeenAt = Date.now();

            // Build a rich progress message with counter if available
            var base = stageMsgs[j2.stage] || ('جاري العمل... (' + j2.stage + ')');
            if (j2.progress && j2.progress.total) {
              base += ' (' + j2.progress.done + '/' + j2.progress.total + ')';
            }
            var elapsed = Math.floor((Date.now() - startedAt) / 1000);
            base += ' — ' + elapsed + 's';
            _mgdProgress(base, true);

            if (j2.status === 'completed') { final = j2; break; }
            if (j2.status === 'failed')    { final = j2; break; }
            // otherwise still pending/running — keep polling
          } catch (_) { /* transient network error — keep polling */ }
        }

        _mgdProgress('', false);
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }

        if (!final) {
          // Polling timed out — but the container might have been created successfully.
          // Fetch the latest container for this client from Firestore and show it.
          _mgdProgress('جاري البحث عن الـ Container المنشأ...', true);
          try {
            var listResp = await fetch('/api/managed/client/' + encodeURIComponent(currentUser.id));
            var listTxt  = await listResp.text();
            var listJson = null;
            try { listJson = JSON.parse(listTxt); } catch (_) {}
            _mgdProgress('', false);
            if (listJson && listJson.containers && listJson.containers.length) {
              // Sort by createdAt desc and pick the newest
              var sorted = listJson.containers.slice().sort(function (a, b) {
                var ta = (a.createdAt && a.createdAt._seconds) || 0;
                var tb = (b.createdAt && b.createdAt._seconds) || 0;
                return tb - ta;
              });
              var latest = sorted[0];
              _mgdShowSuccess({
                gtmPublicId:           latest.gtmPublicId,
                gtmAccountId:          latest.gtmAccountId,
                gtmContainerId:        latest.gtmContainerId,
                gtmWorkspaceId:        latest.gtmWorkspaceId,
                gtmVersionId:          latest.gtmVersionId,
                published:             latest.published,
                publishedAt:           latest.publishedAt,
                snippetHead:           latest.snippetHead,
                snippetBody:           latest.snippetBody,
                containerName:         latest.containerName  || latest.projectName || null,
                invited:               !!latest.invited,
                inviteEmail:           latest.inviteEmail    || latest.clientEmail || null,
                inviteError:           latest.inviteError    || null,
                importedTagCount:      (latest.importedCounts && latest.importedCounts.tags)      || 0,
                importedTriggerCount:  (latest.importedCounts && latest.importedCounts.triggers)  || 0,
                importedVariableCount: (latest.importedCounts && latest.importedCounts.variables) || 0,
              });
              return;
            }
          } catch (_) { _mgdProgress('', false); }

          _mgdShowError('انتهت مهلة الانتظار (15 دقيقة) ومقدرناش نلاقي Container جديد. افتح GTM مباشرة للتأكد.');
          return;
        }

        if (final.status === 'failed') {
          _mgdShowError(final.error || 'فشل إنشاء Container', final.hint || null);
          return;
        }

        // status === 'completed'
        _mgdShowSuccess(final.result || final);
      } catch (e) {
        _mgdProgress('', false);
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
        _mgdShowError('فشل الاتصال بالسيرفر: ' + (e.message || e));
      }
    }

    // pixelIds stored as objects sometimes — flatten to plain string map for the server
    function _serializePixelIds(ids) {
      if (!ids) return {};
      var out = {};
      Object.keys(ids).forEach(function (k) {
        var v = ids[k];
        if (v && typeof v === 'object') out[k] = v.id || v.value || '';
        else out[k] = v || '';
      });
      return out;
    }

    // ===== GTM DIRECT PUBLISH =====
    var _gtmSecondaryApp = null;

    // ── Inline GTM state (used by the panel dropdowns — no popup) ──
    var _gtmInlineState = { token: null, accountId: null, containerId: null, workspaceId: null };

    async function _inlineGtmGet(path) {
      var token = _gtmInlineState.token;
      var ctrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
      var timer = ctrl ? setTimeout(function () { ctrl.abort(); }, 15000) : null;
      try {
        var r = await fetch('https://tagmanager.googleapis.com/tagmanager/v2/' + path,
          { headers: { 'Authorization': 'Bearer ' + token }, signal: ctrl ? ctrl.signal : undefined });
        clearTimeout(timer);
        var txt = await r.text();
        try { return { ok: r.ok, status: r.status, data: JSON.parse(txt) }; }
        catch (e) { return { ok: false, status: r.status, data: null, raw: txt.substring(0, 400) }; }
      } catch (fe) {
        clearTimeout(timer);
        return { ok: false, status: fe.name === 'AbortError' ? 408 : 0, data: null, raw: fe.message || String(fe) };
      }
    }

    async function _inlineGtmPost(path, body, _attempt) {
      _attempt = _attempt || 1;
      var token = _gtmInlineState.token;
      var ctrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
      var timer = ctrl ? setTimeout(function () { ctrl.abort(); }, 20000) : null;
      try {
        var r = await fetch('https://tagmanager.googleapis.com/tagmanager/v2/' + path,
          {
            method: 'POST', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify(body), signal: ctrl ? ctrl.signal : undefined
          });
        clearTimeout(timer);
        var txt = await r.text();
        // ── Retry on transient 5xx or 429 (up to 3 attempts, exponential backoff) ──
        if ((r.status === 503 || r.status === 502 || r.status === 429) && _attempt < 3) {
          console.warn('[GTM] ' + r.status + ' on ' + path + ' — retry ' + _attempt + '/3');
          await new Promise(function (res) { setTimeout(res, 800 * _attempt); });
          return _inlineGtmPost(path, body, _attempt + 1);
        }
        try { return { ok: r.ok, status: r.status, data: JSON.parse(txt) }; }
        catch (e) { return { ok: false, status: r.status, data: null, raw: txt.substring(0, 400) }; }
      } catch (fe) {
        clearTimeout(timer);
        return { ok: false, status: fe.name === 'AbortError' ? 408 : 0, data: null, raw: fe.message || String(fe) };
      }
    }

    async function _inlineGtmPut(path, body) {
      var token = _gtmInlineState.token;
      var ctrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
      var timer = ctrl ? setTimeout(function () { ctrl.abort(); }, 20000) : null;
      try {
        var r = await fetch('https://tagmanager.googleapis.com/tagmanager/v2/' + path,
          {
            method: 'PUT', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify(body), signal: ctrl ? ctrl.signal : undefined
          });
        clearTimeout(timer);
        var txt = await r.text();
        try { return { ok: r.ok, status: r.status, data: JSON.parse(txt) }; }
        catch (e) { return { ok: false, status: r.status, data: null, raw: txt.substring(0, 400) }; }
      } catch (fe) {
        clearTimeout(timer);
        return { ok: false, status: fe.name === 'AbortError' ? 408 : 0, data: null, raw: fe.message || String(fe) };
      }
    }

    function _gtmErrMsg(res) {
      if (res && res.data && res.data.error) return res.data.error.message || JSON.stringify(res.data.error);
      if (res && res.raw) return res.raw;
      return JSON.stringify(res && res.data);
    }

    // Wraps English words/numbers inside Arabic strings with FSI/PDI unicode chars
    // so they stay LTR without flipping the whole line direction.
    function _bidi(str) {
      if (!str) return str;
      return str.replace(/[A-Za-z0-9][\w\-\.\/\(\):@#]*/g, function (m) { return '\u2068' + m + '\u2069'; });
    }

    function _setGtmProgress(msg, show) {
      var el = document.getElementById('gtmProgress');
      var txt = document.getElementById('gtmProgressText');
      if (!el) return;
      if (show === false) { el.style.display = 'none'; return; }
      el.style.display = 'block';
      if (txt) txt.textContent = _bidi(msg) || '';
    }

    function _setGtmResult(msg, isError) {
      var old = document.getElementById('gtmResultMsg');
      if (old) old.remove();
      var div = document.createElement('div');
      div.id = 'gtmResultMsg';
      div.style.cssText = 'margin-top:10px;padding:12px 14px;border-radius:10px;font-size:13px;font-weight:600;line-height:1.5;white-space:pre-line;direction:rtl;unicode-bidi:isolate;text-align:right;'
        + (isError
          ? 'background:rgba(255,180,171,.08);border:1px solid rgba(255,180,171,.3);color:#ffb4ab;'
          : 'background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.25);color:var(--acc);');
      div.setAttribute('dir', 'auto');
      div.textContent = _bidi(msg);
      var deployBtn = document.getElementById('pubGtm');
      if (deployBtn && deployBtn.parentNode) deployBtn.parentNode.insertBefore(div, deployBtn.nextSibling);
    }

    // ── Called by "Connect Google Account" button ──────────────────
    async function gtmConnect() {
      var btnConnect = document.getElementById('gtmConnectBtn');
      var statusEl = document.getElementById('gtmConnStatus');
      var avatarEl = document.getElementById('gtmConnAvatar');

      if (btnConnect) {
        btnConnect.disabled = true;
        btnConnect.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">sync</span> جاري الاتصال...';
      }

      try {
        if (!_gtmSecondaryApp) {
          var existingApp = firebase.apps.find(function (a) { return a.name === 'gtm-oauth'; });
          _gtmSecondaryApp = existingApp || firebase.initializeApp(FB_CONFIG, 'gtm-oauth');
        }
        var gtmAuth = _gtmSecondaryApp.auth();
        var provider = new firebase.auth.GoogleAuthProvider();
        provider.addScope('https://www.googleapis.com/auth/tagmanager.readonly');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.edit.containers');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.edit.containerversions');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.publish');
        provider.setCustomParameters({ prompt: 'consent select_account' });

        var result = await gtmAuth.signInWithPopup(provider);
        var token = result.credential && result.credential.accessToken;

        if (!token) {
          if (statusEl) statusEl.textContent = '❌ لا يوجد Access Token';
          if (btnConnect) { btnConnect.disabled = false; btnConnect.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">device_hub</span> Connect Google Account'; }
          return;
        }

        _gtmInlineState.token = token;
        var email = (result.user && result.user.email) ? result.user.email : '';
        if (statusEl) statusEl.textContent = (email ? '✅ متصل: ' + email : '✅ متصل');
        if (avatarEl) avatarEl.textContent = '🔓';
        if (btnConnect) { btnConnect.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">check_circle</span> ' + (email || 'متصل'); btnConnect.disabled = true; }

        // Load accounts into inline dropdown
        await _gtmLoadAccounts();

      } catch (e) {
        if (btnConnect) { btnConnect.disabled = false; btnConnect.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">device_hub</span> Connect Google Account'; }
        if (e.code === 'auth/popup-closed-by-user' || e.code === 'auth/cancelled-popup-request') return;
        var msg = e.message || e.code || String(e);
        if (e.code === 'auth/unauthorized-domain') msg = 'الدومين مش مضاف في Firebase → Authorized domains → أضف: ' + location.hostname;
        else if (e.code === 'auth/popup-blocked') msg = 'البراوزر بلوك الـ Popup — اسمح بالـ Popups لهذا الموقع ثم حاول تاني';
        else if (e.code === 'auth/operation-not-allowed') msg = 'Google Sign-In مش مفعّل في Firebase → Authentication → Sign-in method';
        if (statusEl) statusEl.textContent = '❌ فشل الاتصال';
        _setGtmResult('❌ فشل الاتصال بـ Google:\n' + msg, true);
      }
    }

    async function _gtmLoadAccounts() {
      _setGtmProgress('⏳ جاري تحميل الـ GTM Accounts...', true);
      var res = await _inlineGtmGet('accounts');
      _setGtmProgress('', false);
      if (!res.ok) { _setGtmResult('❌ فشل جلب الـ Accounts: ' + _gtmErrMsg(res), true); return; }
      var accounts = (res.data && res.data.account) || [];
      if (!accounts.length) { _setGtmResult('⚠️ مش لاقي أي GTM Account مربوط بالـ Google Account ده', true); return; }

      var sel = document.getElementById('gtmAccSelect');
      if (sel) {
        sel.innerHTML = '<option value="">اختار Account...</option>';
        accounts.forEach(function (a) {
          var opt = document.createElement('option');
          opt.value = a.accountId;
          opt.textContent = a.name + '  (ID: ' + a.accountId + ')';
          sel.appendChild(opt);
        });
      }
      var selectsEl = document.getElementById('gtmSelects');
      if (selectsEl) selectsEl.style.display = 'block';
    }

    // ── Called when account dropdown changes ───────────────────────
    async function gtmOnAccountChange(accountId) {
      _gtmInlineState.accountId = accountId || null;
      _gtmInlineState.containerId = null;
      _gtmInlineState.workspaceId = null;

      var conSel = document.getElementById('gtmConSelect');
      var wsSel = document.getElementById('gtmWsSelect');
      var pubBtn = document.getElementById('pubGtm');
      if (conSel) { conSel.innerHTML = '<option value="">اختار Container...</option>'; conSel.disabled = true; }
      if (wsSel) { wsSel.innerHTML = '<option value="">اختار Container أولاً</option>'; wsSel.disabled = true; }
      if (pubBtn) { pubBtn.disabled = true; pubBtn.classList.remove('ready'); }
      if (!accountId) return;

      _setGtmProgress('⏳ جاري تحميل الـ Containers...', true);
      var res = await _inlineGtmGet('accounts/' + accountId + '/containers');
      _setGtmProgress('', false);
      if (!res.ok) { _setGtmResult('❌ فشل جلب الـ Containers: ' + _gtmErrMsg(res), true); return; }
      var containers = (res.data && res.data.container) || [];
      if (!containers.length) { _setGtmResult('⚠️ مش لاقي أي Container في الـ Account ده', true); return; }

      if (conSel) {
        conSel.innerHTML = '<option value="">اختار Container...</option>';
        containers.forEach(function (c) {
          var opt = document.createElement('option');
          opt.value = c.containerId;
          opt.textContent = c.name + '  (' + (c.publicId || c.containerId) + ')';
          conSel.appendChild(opt);
        });
        conSel.disabled = false;
      }
    }

    // ── Called when container dropdown changes ──────────────────────
    async function gtmOnContainerChange(containerId) {
      _gtmInlineState.containerId = containerId || null;
      _gtmInlineState.workspaceId = null;

      var wsSel = document.getElementById('gtmWsSelect');
      var pubBtn = document.getElementById('pubGtm');
      if (wsSel) { wsSel.innerHTML = '<option value="">اختار Workspace...</option>'; wsSel.disabled = true; }
      if (pubBtn) { pubBtn.disabled = true; pubBtn.classList.remove('ready'); }
      if (!containerId || !_gtmInlineState.accountId) return;

      _setGtmProgress('⏳ جاري تحميل الـ Workspaces...', true);
      var res = await _inlineGtmGet('accounts/' + _gtmInlineState.accountId + '/containers/' + containerId + '/workspaces');
      _setGtmProgress('', false);
      if (!res.ok) { _setGtmResult('❌ فشل جلب الـ Workspaces: ' + _gtmErrMsg(res), true); return; }
      var workspaces = (res.data && res.data.workspace) || [];
      if (!workspaces.length) { _setGtmResult('⚠️ مش لاقي أي Workspace في الـ Container ده', true); return; }

      if (wsSel) {
        wsSel.innerHTML = '<option value="">اختار Workspace...</option>';
        workspaces.forEach(function (w) {
          var opt = document.createElement('option');
          opt.value = w.workspaceId;
          opt.textContent = w.name + (w.description ? '  — ' + w.description : '');
          wsSel.appendChild(opt);
        });
        wsSel.disabled = false;
      }
    }

    // ── Called when workspace dropdown changes ──────────────────────
    function gtmOnWorkspaceChange(workspaceId) {
      _gtmInlineState.workspaceId = workspaceId || null;
      var pubBtn = document.getElementById('pubGtm');
      if (pubBtn) {
        pubBtn.disabled = !workspaceId;
        if (workspaceId) pubBtn.classList.add('ready');
        else pubBtn.classList.remove('ready');
      }
    }

    // ── Called by "Sync & Deploy Changes" button ────────────────────
    async function gtmDeploy() {
      var s = _gtmInlineState;
      if (!s.token) { _setGtmResult('⚠️ اتصل بـ Google Account أولاً', true); return; }
      if (!s.accountId) { _setGtmResult('⚠️ اختار الـ GTM Account', true); return; }
      if (!s.containerId) { _setGtmResult('⚠️ اختار الـ Container', true); return; }
      if (!s.workspaceId) { _setGtmResult('⚠️ اختار الـ Workspace', true); return; }

      if (!_cachedGtmStr || !_cachedGtmStr.trim()) {
        var fb = (document.getElementById('gtmBody') || {}).textContent || '';
        if (!fb.trim() || fb.trim().charAt(0) !== '{') {
          _setGtmResult('⚠️ اعمل Generate للـ Config الأول من Pixel Config ثم ارجع هنا', true); return;
        }
        _cachedGtmStr = fb;
      }
      var gtmJson;
      try { gtmJson = JSON.parse(_cachedGtmStr); }
      catch (e) { _setGtmResult('❌ GTM JSON غير صحيح — اعمل Generate من جديد', true); return; }

      var modeVal = (document.getElementById('gtmModeSelect') || {}).value || 'publish_overwrite';
      var isPublish = modeVal.startsWith('publish');
      var doRename = modeVal.endsWith('rename'); // false = overwrite conflicts, true = rename new

      var pubBtn = document.getElementById('pubGtm');
      var conBtn = document.getElementById('gtmConnectBtn');
      if (pubBtn) pubBtn.disabled = true;
      if (conBtn) conBtn.disabled = true;
      var old = document.getElementById('gtmResultMsg');
      if (old) old.remove();

      var containerPath = 'accounts/' + s.accountId + '/containers/' + s.containerId;
      var wsPath = containerPath + '/workspaces/' + s.workspaceId;

      // Strip server-assigned fields before sending to API
      function clean(obj) {
        var o = JSON.parse(JSON.stringify(obj));
        ['accountId', 'containerId', 'tagId', 'triggerId', 'variableId', 'fingerprint', 'path', 'parentFolderId'].forEach(function (k) { delete o[k]; });
        return o;
      }

      // ─────────────────────────────────────────────────────────────────────
      // PRE-FLIGHT SANITIZER
      // Strips parameters known to cause "Service unavailable" from GTM backend
      // regardless of whether the JSON was generated by a newer or older tool build.
      // Each entry: tagType → set of parameter keys not supported on that type.
      // ─────────────────────────────────────────────────────────────────────
      var FORBIDDEN_PARAMS = {
        // gclidw: Conversion Linker — accepts no parameters by default
        gclidw: ['enableCookieOverrides', 'enableCrossDomain'],
        // awct: Google Ads Conversion — reject params that belong to other tag types
        awct:   ['enableConversionLinker', 'userProperties', 'sendEcommerceData'],
        // gaawe: GA4 Event — sendEcommerceData causes 503 when explicitly 'false'
        gaawe:  ['sendEcommerceData'],
        // sp: Google Ads Remarketing — keep minimal
        sp:     ['userProperties', 'sendEcommerceData']
      };
      function sanitizeTag(t) {
        var bad = FORBIDDEN_PARAMS[t.type];
        if (!bad || !t.parameter) return t;
        var before = t.parameter.length;
        t.parameter = t.parameter.filter(function (p) { return bad.indexOf(p.key) === -1; });
        if (before !== t.parameter.length) {
          console.info('[sanitize] stripped ' + (before - t.parameter.length) + ' param(s) from', t.name, '(' + t.type + ')');
        }
        return t;
      }

      var BUILTIN = { 2147479553: true, 2147479572: true };

      try {
        var cv = gtmJson.containerVersion ? gtmJson.containerVersion : gtmJson;
        var tags = cv.tag || [];
        var triggers = cv.trigger || [];
        var vars = cv.variable || [];
        var builtIns = cv.builtInVariable || [];

        // ── Failure tracking ──────────────────────────────────────
        var failedVars = [], failedTrigs = [], failedTags = [];

        // ── Step 0a: Sync workspace FIRST (before any changes) ──────
        // CRITICAL: must sync BEFORE adding entities.
        // Syncing AFTER would revert our newly-added workspace changes.
        _setGtmProgress('⏳ مزامنة الـ Workspace مع الـ Container...', true);
        await _inlineGtmPost(wsPath + ':sync', {});
        // (ignore sync conflicts — they'll be overwritten by our entities below)

        // ── Step 0b: Load existing entities (for overwrite/rename resolution) ──
        _setGtmProgress('⏳ تحميل الـ Entities الحالية من الـ Workspace...', true);
        var existingVarMap = {}; // name → variableId
        var existingTrigMap = {}; // name → triggerId
        var existingTagMap = {}; // name → tagId

        var evRes = await _inlineGtmGet(wsPath + '/variables');
        var etRes = await _inlineGtmGet(wsPath + '/triggers');
        var egRes = await _inlineGtmGet(wsPath + '/tags');
        (evRes.data && evRes.data.variable || []).forEach(function (v) { existingVarMap[v.name] = v.variableId; });
        (etRes.data && etRes.data.trigger || []).forEach(function (t) { existingTrigMap[t.name] = t.triggerId; });
        (egRes.data && egRes.data.tag || []).forEach(function (g) { existingTagMap[g.name] = g.tagId; });

        // Name resolver: if rename mode, append suffix to avoid collision
        function resolvedName(name, existsMap) {
          if (!doRename) return name; // overwrite mode — use original name
          var safeName = name;
          var suffix = 1;
          while (existsMap[safeName]) { safeName = name + ' (' + suffix + ')'; suffix++; }
          return safeName;
        }

        // ── Step 1: Enable built-in variables ──────────────────────
        if (builtIns.length) {
          _setGtmProgress('⏳ تفعيل Built-in Variables... (1/5)', true);
          var btypes = builtIns.map(function (b) { return 'type=' + encodeURIComponent(b.type); }).join('&');
          await _inlineGtmPost(wsPath + '/built_in_variables?' + btypes, {});
        }

        // ── Step 2: Variables (create or update) ───────────────────
        // Early-abort helper: if first entity returns 401/403 → token issue
        function _isAuthErr(res) { return res.status === 401 || res.status === 403; }
        // Rate-limit helper: 250ms between calls to avoid GTM quota (429)
        function _gtmDelay() { return new Promise(function (r) { setTimeout(r, 250); }); }

        for (var vi = 0; vi < vars.length; vi++) {
          if (vi > 0) await _gtmDelay();
          _setGtmProgress('⏳ Variables... (' + (vi + 1) + '/' + vars.length + ')  —  Step 2/5', true);
          var vObj = clean(vars[vi]);
          var vName = resolvedName(vObj.name, existingVarMap);
          vObj.name = vName;
          var existingVid = !doRename && existingVarMap[vObj.name];
          var vRes;
          if (existingVid) {
            vRes = await _inlineGtmPut(wsPath + '/variables/' + existingVid, vObj);
          } else {
            vRes = await _inlineGtmPost(wsPath + '/variables', vObj);
          }
          if (!vRes.ok) {
            console.warn('[GTM var]', vObj.name, vRes.status, _gtmErrMsg(vRes));
            failedVars.push(vObj.name + ' [' + vRes.status + ': ' + _gtmErrMsg(vRes) + ']');
            if (vi === 0 && _isAuthErr(vRes)) {
              _setGtmProgress('', false);
              _setGtmResult('❌ خطأ في الصلاحيات (' + vRes.status + '):\n' + _gtmErrMsg(vRes) + '\n\nيبدو إن الـ Token منتهي أو ناقص الـ Scope.\nاعمل Disconnect ثم اتصل بحسابك Google من جديد.', true);
              if (pubBtn) pubBtn.disabled = false;
              if (conBtn) conBtn.disabled = false;
              return;
            }
          }
          // Update map so subsequent renames see the new name
          if (vRes.ok && vRes.data && vRes.data.variableId) existingVarMap[vName] = vRes.data.variableId;
        }

        // ── Step 3: Triggers (create or update, capture new IDs) ───
        var trigIdMap = {};
        for (var ti = 0; ti < triggers.length; ti++) {
          await _gtmDelay();
          _setGtmProgress('⏳ Triggers... (' + (ti + 1) + '/' + triggers.length + ')  —  Step 3/5', true);
          var tObj = clean(triggers[ti]);
          var oldTid = triggers[ti].triggerId;
          var tName = resolvedName(tObj.name, existingTrigMap);
          tObj.name = tName;
          var existingTid = !doRename && existingTrigMap[tObj.name];
          var tRes;
          if (existingTid) {
            tRes = await _inlineGtmPut(wsPath + '/triggers/' + existingTid, tObj);
            // Overwrite: map old JSON id → existing workspace id
            trigIdMap[oldTid] = existingTid;
          } else {
            tRes = await _inlineGtmPost(wsPath + '/triggers', tObj);
            if (tRes.ok && tRes.data && tRes.data.triggerId) trigIdMap[oldTid] = tRes.data.triggerId;
          }
          if (!tRes.ok) { console.warn('[GTM trig]', tObj.name, tRes.status, _gtmErrMsg(tRes)); failedTrigs.push(tObj.name + ' [' + tRes.status + ': ' + _gtmErrMsg(tRes) + ']'); }
          if (tRes.ok && tRes.data && tRes.data.triggerId) existingTrigMap[tName] = tRes.data.triggerId;
        }

        // ── Step 4: Tags (create or update, remap trigger IDs) ─────
        function remapIds(arr) {
          return (arr || []).map(function (id) { return BUILTIN[id] ? id : (trigIdMap[id] || id); });
        }
        for (var gi = 0; gi < tags.length; gi++) {
          await _gtmDelay();
          _setGtmProgress('⏳ Tags... (' + (gi + 1) + '/' + tags.length + ')  —  Step 4/5', true);
          var gObj = sanitizeTag(clean(tags[gi]));   // ← strips forbidden params
          gObj.name = resolvedName(gObj.name, existingTagMap);
          gObj.firingTriggerId = remapIds(gObj.firingTriggerId);
          gObj.blockingTriggerId = remapIds(gObj.blockingTriggerId);
          var existingGid = !doRename && existingTagMap[gObj.name];
          var gRes;
          if (existingGid) {
            gRes = await _inlineGtmPut(wsPath + '/tags/' + existingGid, gObj);
          } else {
            gRes = await _inlineGtmPost(wsPath + '/tags', gObj);
          }
          if (!gRes.ok) { console.warn('[GTM tag]', gObj.name, gRes.status, _gtmErrMsg(gRes)); failedTags.push(gObj.name + ' [' + gRes.status + ': ' + _gtmErrMsg(gRes) + ']'); }
        }

        // ── Import Draft: entities are now in workspace — DONE ──────
        // No create_version needed: the workspace IS the draft.
        if (!isPublish) {
          _setGtmProgress('', false);
          var okT = tags.length - failedTags.length;
          var okTr = triggers.length - failedTrigs.length;
          var okV = vars.length - failedVars.length;
          var anyErr = failedVars.length || failedTrigs.length || failedTags.length;
          var msg = (anyErr ? '⚠️  الاستيراد اكتمل مع أخطاء\n' : '✅ تم الاستيراد في الـ Workspace بنجاح!\n')
            + okT + '/' + tags.length + ' Tag  ·  '
            + okTr + '/' + triggers.length + ' Trigger  ·  '
            + okV + '/' + vars.length + ' Variable';
          if (anyErr) {
            msg += '\n\n❌ فشلت الـ Entities التالية (ابعتها لي لتشخيص سبب الـ Service unavailable):';
            if (failedVars.length)  msg += '\n— Variables:\n   • ' + failedVars.join('\n   • ');
            if (failedTrigs.length) msg += '\n— Triggers:\n   • ' + failedTrigs.join('\n   • ');
            if (failedTags.length)  msg += '\n— Tags:\n   • ' + failedTags.join('\n   • ');
            msg += '\n\n💡 افتح DevTools → Console عشان تشوف الـ response الكامل لكل فشل.';
          } else {
            msg += '\nافتح GTM وهتلاقي التغييرات في الـ Workspace جاهزة للمراجعة.';
          }
          _setGtmResult(msg, anyErr ? true : false);
          if (pubBtn) pubBtn.disabled = false;
          if (conBtn) conBtn.disabled = false;
          return;
        }

        // ── Step 5: Create Version ───────────────────────────────────
        // Extra pause before create_version to let quota recover
        await new Promise(function (r) { setTimeout(r, 500); });
        var verBody = {
          name: 'Easy Track — ' + new Date().toLocaleDateString('ar-EG'),
          notes: 'Generated by Easy Track · ' + tags.length + ' Tags · ' + triggers.length + ' Triggers · ' + vars.length + ' Variables'
        };
        _setGtmProgress('⏳ إنشاء Version... (5/5)', true);
        var verRes = await _inlineGtmPost(wsPath + ':create_version', verBody);

        // NOTE: We do NOT sync here — syncing after adding entities would revert them.
        // The workspace was already synced at Step 0a before any changes were made.
        _setGtmProgress('', false);

        if (!verRes.ok) {
          // Extract detailed error info (Google often includes a `details` array with the offending entity)
          var detailMsg = _gtmErrMsg(verRes);
          var details = (verRes.data && verRes.data.error && verRes.data.error.details) || [];
          if (details.length) {
            detailMsg += '\n\n🔎 تفاصيل الأخطاء من GTM API:';
            details.forEach(function (d) {
              detailMsg += '\n   • ' + (d.reason || d['@type'] || '') + ': ' + (d.message || JSON.stringify(d).substring(0, 200));
            });
          }
          var stepErrs = '';
          if (failedVars.length)  stepErrs += '\n— Variables فشلت: ' + failedVars.length;
          if (failedTrigs.length) stepErrs += '\n— Triggers فشلت: ' + failedTrigs.length;
          if (failedTags.length)  stepErrs += '\n— Tags فشلت: ' + failedTags.length;
          _setGtmResult(
            '❌ فشل إنشاء الـ Version (' + verRes.status + '):\n' + detailMsg
            + (stepErrs ? '\n\nقبل الإصدار:' + stepErrs : '')
            + '\n\n💡 افتح DevTools Console عشان تشوف أي Entity سبب المشكلة.',
            true
          );
          if (pubBtn) pubBtn.disabled = false;
          if (conBtn) conBtn.disabled = false;
          return;
        }
        // syncError after pre-sync means unresolvable conflict — report clearly
        if (verRes.data && verRes.data.syncStatus && verRes.data.syncStatus.syncError) {
          _setGtmResult(
            '❌ يوجد Sync Conflict لم يتم حله.\n'
            + 'الـ Entities أُضيفت للـ Workspace بنجاح، لكن لم يمكن إنشاء الـ Version.\n'
            + 'افتح GTM → Workspace → حل الـ Conflicts يدوياً ثم انشر.',
            true
          );
          if (pubBtn) pubBtn.disabled = false;
          if (conBtn) conBtn.disabled = false;
          return;
        }

        var verId = verRes.data && verRes.data.containerVersion && verRes.data.containerVersion.containerVersionId;
        if (!verId) {
          _setGtmResult('❌ مش لاقي الـ Version ID في الرد:\n' + JSON.stringify(verRes.data).substring(0, 300), true);
          if (pubBtn) pubBtn.disabled = false;
          if (conBtn) conBtn.disabled = false;
          return;
        }

        // ── Step 6: Publish Live ─────────────────────────────────────
        _setGtmProgress('⏳ جاري النشر Live...', true);
        var pubRes = await _inlineGtmPost(containerPath + '/versions/' + verId + ':publish', {});
        _setGtmProgress('', false);

        if (pubRes.ok) {
          var okTags = tags.length - failedTags.length;
          var okTrigs = triggers.length - failedTrigs.length;
          var okVars = vars.length - failedVars.length;
          var hasErrs = failedVars.length || failedTrigs.length || failedTags.length;
          var successMsg = '✅ تم النشر بنجاح! 🎉\n'
            + okTags + ' Tag  ·  ' + okTrigs + ' Trigger  ·  ' + okVars + ' Variable\n'
            + 'اتنشروا Live على GTM — Version ID: ' + verId;
          if (hasErrs) {
            successMsg += '\n\n⚠️ فشل إضافة بعض الـ Entities:';
            if (failedVars.length) successMsg += '\n— Variables: ' + failedVars.join(' | ');
            if (failedTrigs.length) successMsg += '\n— Triggers:  ' + failedTrigs.join(' | ');
            if (failedTags.length) successMsg += '\n— Tags:      ' + failedTags.join(' | ');
          }
          _setGtmResult(successMsg, hasErrs ? true : false);
          // Log to Health Monitor
          hmLogDeploy({
            ts: Date.now(), tags: okTags, triggers: okTrigs, vars: okVars, versionId: verId, ok: true,
            errors: failedVars.concat(failedTrigs).concat(failedTags)
          });
        } else {
          _setGtmResult('❌ فشل النشر (' + pubRes.status + '):\n' + _gtmErrMsg(pubRes), true);
          hmLogDeploy({
            ts: Date.now(), tags: 0, triggers: 0, vars: 0, versionId: null, ok: false,
            errors: ['Publish failed: ' + _gtmErrMsg(pubRes)]
          });
        }

      } catch (execErr) {
        _setGtmProgress('', false);
        console.error('[gtmDeploy]', execErr);
        _setGtmResult('❌ خطأ غير متوقع:\n' + (execErr.message || String(execErr)), true);
      }

      if (pubBtn) pubBtn.disabled = false;
      if (conBtn) conBtn.disabled = false;
    }

    // ── Legacy function (kept for reference, no longer called by UI) ──
    async function doGTMPublish() {
      // Use the cached GTM string — avoids race conditions with the lazy-build loader
      if (!_cachedGtmStr || !_cachedGtmStr.trim()) {
        // Fallback: try reading from the DOM in case the cache is somehow missing
        var _fallbackText = (document.getElementById('gtmBody') || {}).textContent || '';
        if (!_fallbackText.trim() || _fallbackText.trim().charAt(0) !== '{') {
          alert('\u26a0\ufe0f اعمل Generate للـ Config الأول من Pixel Config ثم ارجع هنا\n(لو عملت Generate بالفعل، انتظر ثانية وحاول تاني)');
          return;
        }
        _cachedGtmStr = _fallbackText;
      }
      var gtmJson;
      try { gtmJson = JSON.parse(_cachedGtmStr); }
      catch (e) { alert('\u274c GTM JSON غير صحيح \u2014 اعمل Generate من جديد'); return; }

      var btnConnect = document.getElementById('gtmConnectBtn');
      var btnDeploy = document.getElementById('pubGtm');
      var statusEl = document.getElementById('gtmConnStatus');
      var avatarEl = document.querySelector('.gtm-conn-avatar');

      // Loading state helper
      function setLoading(on) {
        [btnConnect, btnDeploy].forEach(function (b) {
          if (b) b.disabled = on;
        });
        if (btnConnect) btnConnect.innerHTML = on
          ? '<span class="material-symbols-outlined" style="font-size:16px;">sync</span> \u062c\u0627\u0631\u064a \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0628\u0640 Google...'
          : '<span class="material-symbols-outlined" style="font-size:16px;">device_hub</span> Connect Google Account';
      }

      setLoading(true);

      try {
        // Use a SECONDARY Firebase app to avoid conflicting with email/password session
        if (!_gtmSecondaryApp) {
          var existingApp = firebase.apps.find(function (a) { return a.name === 'gtm-oauth'; });
          _gtmSecondaryApp = existingApp || firebase.initializeApp(FB_CONFIG, 'gtm-oauth');
        }
        var gtmAuth = _gtmSecondaryApp.auth();

        var provider = new firebase.auth.GoogleAuthProvider();
        provider.addScope('https://www.googleapis.com/auth/tagmanager.readonly');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.edit.containers');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.edit.containerversions');
        provider.addScope('https://www.googleapis.com/auth/tagmanager.publish');
        provider.setCustomParameters({ prompt: 'consent select_account' });

        var result = await gtmAuth.signInWithPopup(provider);
        var token = result.credential && result.credential.accessToken;

        setLoading(false);

        if (!token) {
          if (statusEl) statusEl.textContent = '\u274c \u0641\u0634\u0644 \u2014 \u0644\u0627 \u064a\u0648\u062c\u062f Access Token';
          alert('\u274c \u0645\u0634 \u0642\u0627\u062f\u0631 \u064a\u062c\u064a\u0628 \u0627\u0644\u0640 Access Token \u0645\u0646 Google\n\u062a\u0623\u0643\u062f \u0625\u0646 GTM API \u0645\u0641\u0639\u0651\u0644 \u0641\u064a Google Cloud Console');
          return;
        }

        // Update connection status UI
        var email = result.user && result.user.email ? result.user.email : '';
        if (statusEl) statusEl.textContent = '\u2705 \u0645\u062a\u0635\u0644: ' + email;
        if (avatarEl) avatarEl.textContent = '\ud83d\udd13';
        if (btnDeploy) btnDeploy.classList.add('ready');

        // Launch account → container → workspace picker
        await showGTMContainerPicker(token, gtmJson);

      } catch (e) {
        setLoading(false);
        if (e.code === 'auth/popup-closed-by-user' ||
          e.code === 'auth/cancelled-popup-request') return;

        console.error('[GTM OAuth]', e);
        var msg = e.message || e.code || String(e);
        if (e.code === 'auth/unauthorized-domain') {
          msg = 'الدومين مش مضاف في Firebase Console\n\u21d2 Authentication \u21d2 Authorized domains\n\u0623\u0636\u0641: ' + location.hostname;
        } else if (e.code === 'auth/popup-blocked') {
          msg = 'الـ Browser بلوك الـ Popup \u2014 \u0627\u0633\u0645\u062d \u0628\u0627\u0644\u0640 Popups \u0644\u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u062b\u0645 \u062d\u0627\u0648\u0644 \u062a\u0627\u0646\u064a';
        } else if (e.code === 'auth/operation-not-allowed') {
          msg = 'Google Sign-In \u0645\u0634 \u0645\u0641\u0639\u0651\u0644 \u0641\u064a Firebase Console \u21d2 Authentication \u21d2 Sign-in method';
        }
        if (statusEl) statusEl.textContent = '\u274c \u0641\u0634\u0644 \u0627\u0644\u0627\u062a\u0635\u0627\u0644';
        alert('\u274c \u0641\u0634\u0644 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0628\u0640 Google:\n' + msg);
      }
    }

    // No longer needed (popup replaces redirect)
    async function checkGTMRedirectResult() { /* popup-based — no redirect needed */ }

    // ⚠️ Legacy popup picker — superseded by inline panel (gtmConnect / gtmDeploy).
    // Kept for reference only; no longer called by any UI element.
    async function showGTMContainerPicker(token, gtmJson) {

      // ── helpers ───────────────────────────────────────────────
      async function gtmGet(path) {
        var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
        var timer = controller ? setTimeout(function () { controller.abort(); }, 15000) : null;
        try {
          var r = await fetch('https://tagmanager.googleapis.com/tagmanager/v2/' + path, {
            headers: { 'Authorization': 'Bearer ' + token },
            signal: controller ? controller.signal : undefined
          });
          clearTimeout(timer);
          var text = await r.text();
          try { return { ok: r.ok, status: r.status, data: JSON.parse(text) }; }
          catch (e) { return { ok: false, status: r.status, data: null, raw: text.substring(0, 400) }; }
        } catch (fetchErr) {
          clearTimeout(timer);
          var isTimeout = fetchErr.name === 'AbortError';
          return { ok: false, status: isTimeout ? 408 : 0, data: null, raw: isTimeout ? 'انتهى الوقت — تأكد من اتصالك وحاول تاني' : (fetchErr.message || String(fetchErr)) };
        }
      }

      async function gtmPost(path, body) {
        var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
        var timer = controller ? setTimeout(function () { controller.abort(); }, 20000) : null;
        try {
          var r = await fetch('https://tagmanager.googleapis.com/tagmanager/v2/' + path, {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            signal: controller ? controller.signal : undefined
          });
          clearTimeout(timer);
          var text = await r.text();
          try { return { ok: r.ok, status: r.status, data: JSON.parse(text) }; }
          catch (e) { return { ok: false, status: r.status, data: null, raw: text.substring(0, 400) }; }
        } catch (fetchErr) {
          clearTimeout(timer);
          var isTimeout = fetchErr.name === 'AbortError';
          return { ok: false, status: isTimeout ? 408 : 0, data: null, raw: isTimeout ? 'انتهى الوقت (20 ثانية) — تأكد من اتصالك بالإنترنت وحاول تاني' : (fetchErr.message || String(fetchErr)) };
        }
      }

      function errMsg(res) {
        if (res.data && res.data.error) return res.data.error.message || JSON.stringify(res.data.error);
        if (res.raw) return res.raw;
        return JSON.stringify(res.data);
      }

      function isApiNotEnabled(res) {
        var msg = errMsg(res).toLowerCase();
        return msg.indexOf('has not been used') !== -1 ||
          msg.indexOf('is disabled') !== -1 ||
          msg.indexOf('api_not_enabled') !== -1 ||
          res.status === 403;
      }

      function showApiNotEnabledUI(onRetry) {
        var secs = 10;
        overlay.innerHTML = '<div id="_gtm_api_err" style="background:#12121f;border:1.5px solid rgba(239,68,68,.4);border-radius:16px;padding:28px 24px;min-width:320px;max-width:440px;width:92vw;color:#e2e8f0;text-align:center">'
          + '<div style="font-size:36px;margin-bottom:12px">⚙️</div>'
          + '<div style="font-size:18px;font-weight:800;color:#fca5a5;margin-bottom:8px">Tag Manager API غير مفعّلة</div>'
          + '<div style="font-size:13px;color:#94a3b8;line-height:1.7;margin-bottom:20px">'
          + 'الـ API اتفعّلت لكن محتاجة بعض الوقت حتى تنتشر.<br>'
          + 'هيحاول تاني تلقائياً بعد <span id="_gtm_cdown" style="color:#c4b5fd;font-weight:700">' + secs + '</span> ثانية.</div>'
          + '<div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">'
          + '<button id="_gtm_retry_now" onclick="window._gtmRetryNow()" style="background:rgba(124,58,237,.18);border:1.5px solid rgba(124,58,237,.5);border-radius:10px;padding:10px 20px;color:#c4b5fd;cursor:pointer;font-family:Cairo,sans-serif;font-size:14px;font-weight:700">🔄 حاول دلوقتي</button>'
          + '<a href="https://console.developers.google.com/apis/api/tagmanager.googleapis.com/overview?project=976141198118" target="_blank" style="background:rgba(59,130,246,.1);border:1.5px solid rgba(59,130,246,.4);border-radius:10px;padding:10px 20px;color:#93c5fd;cursor:pointer;font-family:Cairo,sans-serif;font-size:14px;font-weight:700;text-decoration:none;display:inline-block">🔗 فعّل الـ API</a>'
          + '</div>'
          + '<button onclick="window._gtmPickerClose()" style="margin-top:14px;background:transparent;border:none;color:#475569;cursor:pointer;font-family:Cairo,sans-serif;font-size:12px">إلغاء</button>'
          + '</div>';
        window._gtmPickerClose = function () { overlay.remove(); };
        window._gtmRetryNow = function () { clearInterval(window._gtmCdownInterval); onRetry(); };
        window._gtmCdownInterval = setInterval(function () {
          secs--;
          var el = document.getElementById('_gtm_cdown');
          if (el) el.textContent = secs;
          if (secs <= 0) {
            clearInterval(window._gtmCdownInterval);
            onRetry();
          }
        }, 1000);
      }

      // ── overlay ───────────────────────────────────────────────
      if (!document.getElementById('_gtm_spin_style')) {
        var st = document.createElement('style');
        st.id = '_gtm_spin_style';
        st.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
        document.head.appendChild(st);
      }
      var overlay = document.createElement('div');
      overlay.id = '_gtm_picker';
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:99999;display:flex;align-items:center;justify-content:center;font-family:Cairo,sans-serif;direction:rtl';
      document.body.appendChild(overlay);

      function spin(msg) {
        overlay.innerHTML = '<div style="background:#12121f;border:1px solid #2d2d45;border-radius:16px;padding:36px 32px;min-width:300px;text-align:center;color:#e2e8f0">'
          + '<div style="font-size:16px;font-weight:600;margin-bottom:20px;color:#c4b5fd">' + msg + '</div>'
          + '<div style="width:36px;height:36px;border:3px solid #7c3aed;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto"></div>'
          + '</div>';
      }

      function renderList(icon, title, sub, items, onPick, onBack) {
        var rows = items.map(function (it) {
          var safeId = it.id.replace(/'/g, "\\'");
          return '<button onclick="window._gtmPick(\'' + safeId + '\')" style="width:100%;background:#0d1117;border:1px solid #21263a;border-radius:10px;padding:13px 16px;margin-bottom:8px;cursor:pointer;color:#e2e8f0;font-family:Cairo,sans-serif;font-size:14px;text-align:right;transition:all .15s" onmouseover="this.style.borderColor=\'#7c3aed\';this.style.background=\'#16192a\'" onmouseout="this.style.borderColor=\'#21263a\';this.style.background=\'#0d1117\'">'
            + '<div style="font-weight:700">' + it.name + '</div>'
            + (it.sub ? '<div style="font-size:11px;color:#64748b;font-family:monospace;margin-top:3px">' + it.sub + '</div>' : '')
            + '</button>';
        }).join('');
        var backBtn = onBack ? '<button onclick="window._gtmBack()" style="background:transparent;border:none;color:#64748b;cursor:pointer;font-family:Cairo,sans-serif;font-size:13px;margin-bottom:12px;padding:0">← رجوع</button>' : '';
        overlay.innerHTML = '<div style="background:#12121f;border:1px solid #2d2d45;border-radius:16px;padding:24px 20px;min-width:320px;max-width:460px;width:92vw;max-height:82vh;overflow-y:auto;color:#e2e8f0">'
          + backBtn
          + '<div style="font-size:19px;font-weight:800;margin-bottom:4px">' + icon + ' ' + title + '</div>'
          + '<div style="color:#64748b;font-size:12px;margin-bottom:18px">' + sub + '</div>'
          + rows
          + '<button onclick="window._gtmPickerClose()" style="width:100%;margin-top:6px;background:transparent;border:1px solid #21263a;border-radius:8px;padding:10px;color:#475569;cursor:pointer;font-family:Cairo,sans-serif;font-size:13px">إلغاء</button>'
          + '</div>';
        window._gtmPick = onPick;
        window._gtmBack = onBack || null;
        window._gtmPickerClose = function () { overlay.remove(); };
      }

      function renderAction(accountId, containerId, workspaceId) {
        overlay.innerHTML = '<div style="background:#12121f;border:1px solid #2d2d45;border-radius:16px;padding:28px 24px;min-width:320px;max-width:440px;width:92vw;color:#e2e8f0">'
          + '<button onclick="window._gtmBack()" style="background:transparent;border:none;color:#64748b;cursor:pointer;font-family:Cairo,sans-serif;font-size:13px;margin-bottom:14px;padding:0">← رجوع</button>'
          + '<div style="font-size:19px;font-weight:800;margin-bottom:6px">🚀 إيه اللي هتعمله؟</div>'
          + '<div style="color:#64748b;font-size:12px;margin-bottom:20px">اختار العملية على الـ Workspace المختار</div>'
          + '<button onclick="window._gtmAction(\'publish\')" style="width:100%;background:rgba(124,58,237,.12);border:1.5px solid rgba(124,58,237,.5);border-radius:12px;padding:16px;margin-bottom:10px;cursor:pointer;color:#c4b5fd;font-family:Cairo,sans-serif;font-size:15px;font-weight:700;text-align:right">'
          + '<div>🚀 Publish مباشرة</div>'
          + '<div style="font-size:12px;font-weight:400;color:#8b7dd8;margin-top:4px">استورد الـ Container وانشره Live فوراً</div>'
          + '</button>'
          + '<button onclick="window._gtmAction(\'import\')" style="width:100%;background:rgba(234,179,8,.08);border:1.5px solid rgba(234,179,8,.35);border-radius:12px;padding:16px;margin-bottom:16px;cursor:pointer;color:#fde68a;font-family:Cairo,sans-serif;font-size:15px;font-weight:700;text-align:right">'
          + '<div>✏️ Import فقط (Draft)</div>'
          + '<div style="font-size:12px;font-weight:400;color:#ca8a04;margin-top:4px">استورد التغييرات في الـ Workspace من غير نشر</div>'
          + '</button>'
          + '<button onclick="window._gtmPickerClose()" style="width:100%;background:transparent;border:1px solid #21263a;border-radius:8px;padding:10px;color:#475569;cursor:pointer;font-family:Cairo,sans-serif;font-size:13px">إلغاء</button>'
          + '</div>';
        window._gtmBack = function () { pickWorkspace(accountId, containerId); };
        window._gtmPickerClose = function () { overlay.remove(); };
        window._gtmAction = function (mode) { executeAction(mode, accountId, containerId, workspaceId); };
      }

      // ── steps ─────────────────────────────────────────────────
      async function step_accounts() {
        spin('⏳ جاري تحميل الـ GTM Accounts...');
        var res = await gtmGet('accounts');
        if (!res.ok) {
          if (isApiNotEnabled(res)) {
            showApiNotEnabledUI(step_accounts);
          } else {
            overlay.remove();
            alert('❌ فشل جلب الـ Accounts:\n' + errMsg(res));
          }
          return;
        }
        var accounts = (res.data.account) || [];
        if (!accounts.length) { overlay.remove(); alert('مش لاقي أي GTM Account مربوط بالـ Google Account ده'); return; }
        if (accounts.length === 1) { step_containers(accounts[0].accountId); return; }
        renderList('📋', 'اختار الـ Account', accounts.length + ' Account متاح',
          accounts.map(function (a) { return { id: a.accountId, name: a.name, sub: 'ID: ' + a.accountId }; }),
          step_containers, null);
      }

      async function step_containers(accountId) {
        spin('جاري تحميل الـ Containers...');
        var res = await gtmGet('accounts/' + accountId + '/containers');
        if (!res.ok) { overlay.remove(); alert('❌ فشل جلب الـ Containers:\n' + errMsg(res)); return; }
        var containers = (res.data.container) || [];
        if (!containers.length) { overlay.remove(); alert('مش لاقي أي Container في الـ Account ده'); return; }
        if (containers.length === 1) { pickWorkspace(accountId, containers[0].containerId); return; }
        renderList('📦', 'اختار الـ Container', containers.length + ' Container متاح',
          containers.map(function (c) { return { id: c.containerId, name: c.name, sub: (c.publicId || '') + ' · ID: ' + c.containerId }; }),
          function (cid) { pickWorkspace(accountId, cid); },
          step_accounts);
      }

      async function pickWorkspace(accountId, containerId) {
        spin('جاري تحميل الـ Workspaces...');
        var res = await gtmGet('accounts/' + accountId + '/containers/' + containerId + '/workspaces');
        if (!res.ok) { overlay.remove(); alert('❌ فشل جلب الـ Workspaces:\n' + errMsg(res)); return; }
        var workspaces = (res.data.workspace) || [];
        if (!workspaces.length) { overlay.remove(); alert('مش لاقي أي Workspace في الـ Container ده'); return; }
        if (workspaces.length === 1) { renderAction(accountId, containerId, workspaces[0].workspaceId); return; }
        renderList('🗂️', 'اختار الـ Workspace', workspaces.length + ' Workspace متاح',
          workspaces.map(function (w) { return { id: w.workspaceId, name: w.name, sub: w.description || ('ID: ' + w.workspaceId) }; }),
          function (wsId) { renderAction(accountId, containerId, wsId); },
          function () { step_containers(accountId); });
      }

      // ── execute ───────────────────────────────────────────────
      // Uses GTM API v2 workspace endpoints to push entities one-by-one,
      // then create_version + publish. This is the only reliable way since
      // there is no bulk-import endpoint in GTM API v2.
      async function executeAction(mode, accountId, containerId, workspaceId) {
        var containerPath = 'accounts/' + accountId + '/containers/' + containerId;
        var wsPath = containerPath + '/workspaces/' + workspaceId;

        // Strip server-assigned / placeholder fields before sending to API
        function clean(obj) {
          var o = JSON.parse(JSON.stringify(obj));
          delete o.accountId; delete o.containerId;
          delete o.tagId; delete o.triggerId; delete o.variableId;
          delete o.fingerprint; delete o.path;
          delete o.parentFolderId; // skip folder assignment
          return o;
        }

        // Built-in GTM trigger IDs that must pass through unchanged
        var BUILTIN = { 2147479553: true, 2147479572: true };

        try {
          var cv = (gtmJson && gtmJson.containerVersion) ? gtmJson.containerVersion : gtmJson;
          var tags = cv.tag || [];
          var triggers = cv.trigger || [];
          var vars = cv.variable || [];
          var builtIns = cv.builtInVariable || [];

          // ── Step 1: Enable built-in variables ──────────────────
          if (builtIns.length) {
            spin('⏳ تفعيل Built-in Variables... (1/5)');
            var btypes = builtIns.map(function (b) { return 'type=' + encodeURIComponent(b.type); }).join('&');
            await gtmPost(wsPath + '/built_in_variables?' + btypes, {});
            // continue even if some already exist (4xx)
          }

          // ── Step 2: Create Data Layer variables ─────────────────
          for (var vi = 0; vi < vars.length; vi++) {
            spin('⏳ إنشاء Variables... (' + (vi + 1) + '/' + vars.length + ') — Step 2/5');
            var vRes = await gtmPost(wsPath + '/variables', clean(vars[vi]));
            if (!vRes.ok) console.warn('[GTM var] "' + vars[vi].name + '" →', vRes.status, errMsg(vRes));
          }

          // ── Step 3: Create triggers, capture new IDs ────────────
          var trigIdMap = {}; // oldId (from JSON) → newId (from API)
          for (var ti = 0; ti < triggers.length; ti++) {
            spin('⏳ إنشاء Triggers... (' + (ti + 1) + '/' + triggers.length + ') — Step 3/5');
            var oldTrigId = triggers[ti].triggerId;
            var tRes = await gtmPost(wsPath + '/triggers', clean(triggers[ti]));
            if (tRes.ok && tRes.data && tRes.data.triggerId) {
              trigIdMap[oldTrigId] = tRes.data.triggerId;
            } else {
              console.warn('[GTM trig] "' + triggers[ti].name + '" →', tRes.status, errMsg(tRes));
            }
          }

          // ── Step 4: Create tags (with remapped firingTriggerId) ──
          function remapIds(arr) {
            return (arr || []).map(function (id) {
              return BUILTIN[id] ? id : (trigIdMap[id] || id);
            });
          }
          for (var gi = 0; gi < tags.length; gi++) {
            spin('⏳ إنشاء Tags... (' + (gi + 1) + '/' + tags.length + ') — Step 4/5');
            var tagBody = clean(tags[gi]);
            tagBody.firingTriggerId = remapIds(tagBody.firingTriggerId);
            tagBody.blockingTriggerId = remapIds(tagBody.blockingTriggerId);
            var gRes = await gtmPost(wsPath + '/tags', tagBody);
            if (!gRes.ok) console.warn('[GTM tag] "' + tags[gi].name + '" →', gRes.status, errMsg(gRes));
          }

          // ── Step 5: Create ContainerVersion from workspace ──────
          spin('⏳ إنشاء Version... (5/5)');
          var verRes = await gtmPost(wsPath + ':create_version', {
            name: 'Easy Track — ' + new Date().toLocaleDateString('ar-EG'),
            notes: 'Generated by Easy Track · ' + tags.length + ' Tags · ' + triggers.length + ' Triggers · ' + vars.length + ' Variables'
          });
          if (!verRes.ok) {
            overlay.remove();
            alert('❌ فشل إنشاء الـ Version (' + verRes.status + '):\n' + errMsg(verRes));
            return;
          }

          var verId = verRes.data && verRes.data.containerVersion && verRes.data.containerVersion.containerVersionId;

          if (mode === 'import') {
            overlay.remove();
            alert('✅ تم الاستيراد بنجاح!\n' + tags.length + ' Tag  ·  ' + triggers.length + ' Trigger  ·  ' + vars.length + ' Variable\nاتضافوا للـ Workspace. Version ID: ' + (verId || '—'));
            return;
          }

          // ── Step 6: Publish version live ────────────────────────
          if (!verId) {
            overlay.remove();
            alert('❌ مش لاقي الـ Version ID في الرد:\n' + JSON.stringify(verRes.data).substring(0, 200));
            return;
          }
          spin('⏳ جاري النشر Live...');
          var pubRes = await gtmPost(containerPath + '/versions/' + verId + ':publish', {});
          overlay.remove();
          if (pubRes.ok) {
            alert('✅ تم النشر بنجاح!\n' + tags.length + ' Tag  ·  ' + triggers.length + ' Trigger  ·  ' + vars.length + ' Variable\nاتنشروا Live على GTM.');
          } else {
            alert('❌ فشل النشر (' + pubRes.status + '):\n' + errMsg(pubRes));
          }

        } catch (execErr) {
          overlay.remove();
          console.error('[executeAction]', execErr);
          alert('❌ خطأ غير متوقع:\n' + (execErr.message || String(execErr)));
        }
      }

      step_accounts();
    }

    // ===== COPY & DOWNLOAD =====
    function bindDownloads() {
      var clientName = ((S.lead && S.lead.name) || 'client').replace(/\s+/g, '-');
      var today = new Date().toISOString().split('T')[0];

      function wire(id, fn) {
        var el = document.getElementById(id);
        if (el) el.onclick = fn;
      }

      wire('dlGtm', function () {
        var content = _cachedGtmStr;
        if (!content || !content.trim() || content.trim().charAt(0) !== '{') {
          alert('⏳ الـ GTM Container لسه بيتبني — انتظر ثانية وحاول تاني.');
          return;
        }
        dlFile(content, 'gtm-container-' + clientName + '-' + today + '.json', 'application/json');
      });
      wire('cpyGtm', function () {
        var content = _cachedGtmStr || document.getElementById('gtmBody').textContent;
        if (!content || !content.trim() || content.trim().charAt(0) !== '{') { alert('⏳ الـ GTM Container لسه بيتبني.'); return; }
        navigator.clipboard.writeText(content).then(function () {
          var btn = document.getElementById('cpyGtm');
          if (btn) { var orig = btn.textContent; btn.textContent = '✅ تم'; setTimeout(function () { btn.textContent = orig; }, 2000); }
        });
      });
      // kept for backward compat (elements may not exist after tab removal)
      wire('dlJson', function () {
        dlFile(document.getElementById('jsonBody').textContent, 'pixel-config-' + clientName + '-' + today + '.json', 'application/json');
      });
      wire('cpyJson', function () { copyEl('jsonBody', this); });
      wire('cpyDl', function () { copyEl('dlBody', this); });
    }

    function dlFile(text, name, type) {
      var blob = new Blob([text], { type: type });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url; a.download = name;
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    function copyEl(id, btn) {
      var text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text).then(function () {
        var orig = btn.textContent;
        btn.textContent = '✅ تم';
        setTimeout(function () { btn.textContent = orig; }, 2000);
      });
    }

    // ===== RESET =====
    function resetAll() {
      S.cms = null; S.platforms = []; S.events = []; S.platformEvents = {}; S.pixelIds = {};
      document.getElementById('outWrap').classList.remove('on');
      for (var i = 1; i <= 4; i++) document.getElementById('s' + i).classList.remove('on');
      document.getElementById('s1').classList.add('on');
      var allBtns = document.querySelectorAll('.cbtn');
      for (var i = 0; i < allBtns.length; i++) allBtns[i].classList.remove('on');
      document.getElementById('btn1').disabled = true;
      updateProg(1);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }



    // ═══════════════════════════════════════
    // EASY TRACK · SESSION + SUPABASE
    // ═══════════════════════════════════════
    // ══ FIREBASE CONFIG ════════════════════════════════════
    var FB_CONFIG = {
      apiKey: "AIzaSyDcnFOWldXptsrbAUoPnZqW7w2qYVf_YnQ",
      authDomain: "easytrack-137d4.firebaseapp.com",
      projectId: "easytrack-137d4",
      storageBucket: "easytrack-137d4.firebasestorage.app",
      messagingSenderId: "976141198118",
      appId: "1:976141198118:web:763607661ae0cccb0e57e7"
    };

    // Initialize Firebase — with file:// localhost bypass
    var db = null, auth = null;
    var currentUser = null; // ensure always defined early

    // ── Dev Bypass: if running from file:// or localhost without Firebase ──
    function _isLocalDev() {
      return location.protocol === 'file:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
    }

    function _enterDevMode() {
      // Auto-login as demo user when running locally (no Firebase needed)
      var devUser = {
        id: 'dev-local',
        name: 'Dev User',
        email: 'dev@easytrack.local',
        plan: 'Growth',
        status: 'active',
        projects_used: 0
      };
      console.warn('[Easy Track] Running in LOCAL DEV mode — Firebase disabled');
      setTimeout(function() { enterTool(devUser, 'dev-token'); }, 300);
    }

    // ── Cached session fallback (used when Firebase is unavailable) ──
    function _tryLoadCachedSession() {
      try {
        var cached = localStorage.getItem('et_user');
        if (cached) {
          var u = JSON.parse(cached);
          if (u && u.id && u.plan && u.status === 'active') {
            console.warn('[Easy Track] Firebase unavailable — using cached session for:', u.email);
            enterTool(u, 'cached-token');
            return true;
          }
        }
      } catch(e) {}
      return false;
    }

    function initFirebase() {
      // If running locally from file://, skip Firebase and use dev mode
      if (_isLocalDev()) {
        _enterDevMode();
        return;
      }

      // Firebase load timeout — if SDK never loads after 10s, try cache or show gate
      var _fbLoadTimer = setTimeout(function() {
        console.warn('[Easy Track] Firebase SDK timeout');
        if (!_tryLoadCachedSession()) {
          // Show gate with offline warning
          var gErr = document.getElementById('gGlobalErr');
          if (gErr) { gErr.textContent = '⚠️ مشكلة في الاتصال — تأكد من الإنترنت وحاول تاني'; gErr.style.display = 'block'; }
        }
      }, 10000);

      if (typeof firebase === 'undefined') {
        setTimeout(initFirebase, 50);
        return;
      }

      clearTimeout(_fbLoadTimer);

      if (!firebase.apps.length) firebase.initializeApp(FB_CONFIG);
      db = firebase.firestore();
      auth = firebase.auth();

      // Enable Firestore offline persistence for resilience
      try {
        db.enablePersistence({ synchronizeTabs: true }).catch(function(e) {
          if (e.code !== 'failed-precondition' && e.code !== 'unimplemented') console.warn('Firestore persistence:', e);
        });
      } catch(e) {}

      checkGTMRedirectResult();
      initSession();
    }





    /*
     * ══════════════════════════════════════════════════════════════
     * FIRESTORE SECURITY RULES
     * انسخ الكود ده وحطه في Firebase Console:
     * Firebase Console → Firestore Database → Rules
     * ══════════════════════════════════════════════════════════════
     *
     * rules_version = '2';
     * service cloud.firestore {
     *   match /databases/{database}/documents {
     *     match /{document=**} {
     *       allow read, write: if request.time < timestamp.date(2026, 4, 22);
     *     }
     *   }
     * }
     *
     * ══════════════════════════════════════════════════════════════
     */

    // Plan limits
    var PLAN_LIMITS = { basic: 1, growth: 3, enterprise: 999 };

    // Free events allowed on Basic plan (view_item, add_to_cart, view_item_list)
    var FREE_EVENTS = ['view_item', 'add_to_cart', 'view_item_list'];

    // async function sbGet( — replaced by Firebase

    async function sbInsert(table, data) {
      try {
        var res = await fetch(SB_URL + '/rest/v1/' + table, {
          method: 'POST',
          headers: {
            'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY,
            'Content-Type': 'application/json', 'Prefer': 'return=representation'
          },
          body: JSON.stringify(data)
        });
        var txt = await res.text();
        return txt ? JSON.parse(txt) : null;
      } catch (e) { return null; }
    }

    async function sbUpdate(table, filter, data) {
      try {
        var res = await fetch(SB_URL + '/rest/v1/' + table + '?' + filter, {
          method: 'PATCH',
          headers: {
            'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });
        return res.ok;
      } catch (e) { return false; }
    }

    // ── INIT SESSION ──
    function initSession() {
      auth.onAuthStateChanged(async function (fbUser) {
        if (!fbUser) {
          // Not logged in — try cached session as fallback
          _tryLoadCachedSession();
          return;
        }

        try {
          var doc = await db.collection('clients').doc(fbUser.uid).get();
          if (!doc.exists) return;

          var client = doc.data();
          client.id = fbUser.uid;
          client.email = fbUser.email;

          localStorage.setItem('et_user', JSON.stringify(client));
          localStorage.setItem('et_user_email', fbUser.email);

          if (!client.status || client.status === 'pending') {
            // Account created but not yet approved by admin → show in-page panel
            // instead of auto-opening WhatsApp (which felt like a redirect bug to users).
            showApprovalPending(fbUser.email || client.email);
            return;
          }

          enterTool(client, null);
        } catch (e) {
          console.error('initSession error:', e);
          // Firestore unavailable — fallback to cached session
          if (e.code === 'unavailable' || (e.message && e.message.toLowerCase().indexOf('unavailable') !== -1)) {
            if (!_tryLoadCachedSession()) {
              var gErr = document.getElementById('gGlobalErr');
              if (gErr) { gErr.textContent = '⚠️ الخدمة غير متاحة مؤقتاً — حاول مرة أخرى'; gErr.style.display = 'block'; }
            }
          }
        }
      });
    }

    // async function refreshUser( — replaced by Firebase

    function checkProjectLimit() {
      // Must be logged in
      if (!currentUser) {
        var gate = document.getElementById('gate');
        if (gate) { gate.style.display = 'flex'; gate.style.opacity = '1'; }
        return false;
      }
      var plan = (currentUser.plan || 'Basic').toLowerCase();
      var limit = PLAN_LIMITS[plan] || 1;
      var used = currentUser.projects_used || 0;
      if (used >= limit) {
        var msg = document.getElementById('limitMsg');
        if (msg) msg.textContent = 'خطتك ' + (currentUser.plan || 'Basic') + ' بتسمح بـ ' + (limit === 999 ? 'مشاريع غير محدودة' : limit + ' مشروع') + ' — Upgrade عشان تكمل.';
        var banner = document.getElementById('limitBanner');
        if (banner) banner.style.display = 'block';
        return false;
      }
      return true;
    }

    // Save project to Supabase after generate
    async function saveProject(config) {
      if (!currentUser || !currentUser.id) {
        console.warn('saveProject: no currentUser.id');
        return;
      }
      if (!db) {
        console.warn('saveProject: db not ready');
        return;
      }

      try {
        var projectName = (S.lead && S.lead.name ? S.lead.name + ' — ' : '') + (S.cms || 'Custom') + ' Config';

        // 1. Add project to Firestore — keep the ref so we can later attach
        //    the GTM snippet when the container is created.
        var _projectRef = await db.collection('projects').add({
          client_id: currentUser.id,
          client_name: (S.lead && S.lead.name) || currentUser.name || currentUser.email,
          email: currentUser.email,
          name: projectName,
          cms: S.cms || 'custom',
          platforms: S.platforms || [],
          events_count: (S.events || []).length,
          pixel_ids: S.pixelIds || {},
          config: {
            cms: S.cms,
            platforms: S.platforms,
            events: S.events,
            platformEvents: S.platformEvents || {},
            pixelIds: S.pixelIds,
            lead: S.lead
          },
          created_at: firebase.firestore.FieldValue.serverTimestamp()
        });
        // Remember the doc id so gtmManagedCreate() can write snippetHead /
        // snippetBody / gtmPublicId onto the same project after provisioning.
        try {
          window._etLastProjectDocId = _projectRef.id;
          window._etLastProjectCreatedAt = Date.now();
        } catch (_) { /* ignore */ }

        // 2. Increment projects_used
        var newUsed = (currentUser.projects_used || 0) + 1;
        await db.collection('clients').doc(currentUser.id).update({
          projects_used: newUsed
        });

        // 3. Update local state
        currentUser.projects_used = newUsed;
        localStorage.setItem('et_user', JSON.stringify(currentUser));

        // 4. Update UI
        var usedEl = document.getElementById('projUsed');
        if (usedEl) usedEl.textContent = newUsed;

        _dashLoaded = false;
        console.log('✅ Project saved to Firestore');

      } catch (e) {
        console.error('saveProject error:', e);
      }
    }

    function logout() {
      auth.signOut();
      localStorage.removeItem('et_user');
      localStorage.removeItem('et_user_email');
      localStorage.removeItem('et_auth_uid');
      // ── Logout redirect ──
      // Tool runs on `tool.easytrac.io`, but the landing page (`index.html`) only
      // exists on the apex domain `easytrac.io`. A relative redirect to
      // `index.html` therefore produced "Not found" on the tool subdomain.
      // We now redirect to the apex domain in production, and fall back to `/`
      // (which the server maps to tool.html → the login gate) on localhost.
      try {
        var host = window.location.hostname || '';
        if (host && host !== 'localhost' && host !== '127.0.0.1' && host.indexOf('localhost:') === -1) {
          // strip leading "tool." (or any subdomain) → land on the apex marketing site
          var apex = host.replace(/^[^.]+\./, '');
          // safety: if hostname has only one label (no dot), keep it as-is
          if (apex.indexOf('.') === -1) apex = host;
          window.location.href = window.location.protocol + '//' + apex + '/';
        } else {
          window.location.href = '/';
        }
      } catch (_) {
        window.location.href = '/';
      }
    }

    // Hook into generate() to check limits + save
    var _origGenerate = generate;
    generate = function () {
      if (!checkProjectLimit()) return;

      // Free (Basic) plan: restrict events to FREE_EVENTS only
      var _savedEvents = null;
      var _savedPlatEvents = null;
      if (currentUser) {
        var _plan = (currentUser.plan || 'basic').toLowerCase();
        if (_plan === 'basic') {
          _savedEvents = S.events.slice();
          _savedPlatEvents = JSON.parse(JSON.stringify(S.platformEvents || {}));
          // Filter events to FREE_EVENTS only
          S.events = S.events.filter(function(ev) { return FREE_EVENTS.indexOf(ev) !== -1; });
          // Filter platformEvents too
          Object.keys(S.platformEvents || {}).forEach(function(p) {
            S.platformEvents[p] = (S.platformEvents[p] || []).filter(function(ev) { return FREE_EVENTS.indexOf(ev) !== -1; });
          });
          // Show notice if events were removed
          var removedCount = _savedEvents.length - S.events.length;
          if (removedCount > 0) {
            setTimeout(function() {
              var banner = document.createElement('div');
              banner.style.cssText = 'position:fixed;top:70px;left:50%;transform:translateX(-50%);z-index:9999;background:#191c22;border:1px solid rgba(245,158,11,.4);border-radius:14px;padding:14px 22px;font-size:13px;color:#ffd680;font-family:var(--font-display);font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;align-items:center;gap:10px;max-width:500px;text-align:center;';
              banner.innerHTML = '<span style="font-size:18px;">⚡</span><span>الخطة Basic تدعم 3 Events فقط (View Item, Add to Cart, View Item List)<br><span style="font-size:11px;color:var(--mut);font-weight:400;"><a href=\"https://wa.me/201552388174?text=مرحباً،%20أريد%20الترقية%20إلى%20خطة%20أعلى%20في%20Easy%20Track\" target=\"_blank\" style=\"color:#ffd680;\">تواصل معنا للترقية ↗</a> عشان تضيف باقي الـ Events</span></span>';
              document.body.appendChild(banner);
              setTimeout(function() { banner.remove(); }, 5000);
            }, 500);
          }
        }
      }

      _origGenerate();
      // Mark project as started — will save on output open
      // Save after a short delay to let outputs build
      setTimeout(async function () {
        var config = {};
        try { config = JSON.parse(document.getElementById('jsonBody') ? document.getElementById('jsonBody').textContent || '{}' : '{}'); } catch (e) { }
        await saveProject(config);
      }, 800);
    };

    // Firebase init triggered on DOMContentLoaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFirebase);
    } else {
      initFirebase();
    }


    // ══ PROJECT HISTORY ═══════════════════════════════════════
    async function loadProjects() {
      var el = document.getElementById('projectsList');
      if (!el) return;
      el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-family:monospace;font-size:12px;">⏳ جاري التحميل...</div>';

      try {
        // Wait for db to be ready
        var attempts = 0;
        while (!db && attempts < 20) {
          await new Promise(function (r) { setTimeout(r, 300); });
          attempts++;
        }
        if (!db) {
          el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-size:13px;">⚠️ مش متصل بالسيرفر دلوقتي<br><span style="font-size:11px;color:var(--mut2);">تأكد من الإنترنت وحدّث الصفحة</span></div>';
          return;
        }

        if (!currentUser || !currentUser.id) {
          el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-size:13px;">سجّل دخولك عشان تشوف مشاريعك</div>';
          return;
        }

        // Load from Firestore — same as dashboard
        var snap;
        try {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .orderBy('created_at', 'desc')
            .limit(20)
            .get();
        } catch (indexErr) {
          // Fallback: no orderBy if index not created yet
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .limit(20)
            .get();
        }

        if (snap.empty) {
          el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--mut);font-size:13px;">مفيش مشاريع لحد دلوقتي — اعمل Generate أول مشروع!</div>';
          return;
        }

        var projects = [];
        snap.forEach(function (doc) {
          var d = doc.data(); d.id = doc.id;
          projects.push(d);
        });

        var html = '<div style="display:flex;flex-direction:column;gap:12px;">';
        projects.forEach(function (p, i) {
          var date = '—';
          try {
            if (p.created_at && typeof p.created_at.toDate === 'function') {
              date = new Date(p.created_at.toDate()).toLocaleDateString('ar-EG');
            } else if (p.created_at && p.created_at.seconds) {
              date = new Date(p.created_at.seconds * 1000).toLocaleDateString('ar-EG');
            } else if (p.created_at) {
              date = new Date(p.created_at).toLocaleDateString('ar-EG');
            }
          } catch (de) { date = '—'; }
          var platforms = (p.config && p.config.platforms) ? p.config.platforms.join(' · ') : (p.platforms || []).join(' · ') || '—';
          var events = (p.config && p.config.events) ? p.config.events.length + ' events' : (p.events_count || 0) + ' events';
          var cms = (p.config && p.config.cms) ? p.config.cms : (p.cms || '—');
          var hasGtm = !!(p.gtmPublicId && p.snippetHead);
          html += '<div style="background:var(--sur2);border:1px solid var(--bdr2);border-radius:14px;padding:18px 20px;transition:border-color .15s;" '
            + 'onmouseover="this.style.borderColor=\'rgba(14,165,233,.3)\'" '
            + 'onmouseout="this.style.borderColor=\'rgba(255,255,255,.07)\'">';
          html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;cursor:pointer;" onclick="loadProject(' + i + ')">';
          html += '<div style="font-weight:700;font-size:15px;color:var(--wht2);">' + (p.client_name || p.name || 'مشروع #' + (i + 1)) + '</div>';
          html += '<div style="font-family:monospace;font-size:10px;color:var(--mut2);">' + date + '</div>';
          html += '</div>';
          html += '<div style="display:flex;gap:6px;flex-wrap:wrap;cursor:pointer;" onclick="loadProject(' + i + ')">';
          html += '<span style="background:rgba(16,185,129,.08);color:var(--grn);font-size:11px;padding:2px 10px;border-radius:6px;font-family:monospace;border:1px solid rgba(16,185,129,.15);">' + cms + '</span>';
          html += '<span style="background:var(--acc-dim);color:var(--acc);font-size:11px;padding:2px 10px;border-radius:6px;font-family:monospace;border:1px solid rgba(14,165,233,.15);">' + platforms + '</span>';
          html += '<span style="background:var(--sur3);color:var(--mut);font-size:11px;padding:2px 10px;border-radius:6px;font-family:monospace;border:1px solid var(--bdr2);">' + events + '</span>';
          if (hasGtm) {
            html += '<span style="background:rgba(70,241,197,.12);color:var(--acc);font-size:11px;padding:2px 10px;border-radius:6px;font-family:monospace;border:1px solid rgba(70,241,197,.2);" title="GTM Container ID">' + p.gtmPublicId + '</span>';
          } else {
            html += '<span style="background:rgba(245,158,11,.08);color:var(--amber);font-size:11px;padding:2px 10px;border-radius:6px;font-family:monospace;border:1px solid rgba(245,158,11,.2);">لم يتم رفعه على GTM</span>';
          }
          html += '</div>';
          // ── GTM Snippet toggle + panel ──
          if (hasGtm) {
            html += '<div style="display:flex;gap:8px;margin-top:12px;">';
            html += '<button id="mp-snip-btn-' + i + '" onclick="_toggleMpSnippet(' + i + ')" style="flex:1;background:rgba(70,241,197,.08);border:1px solid rgba(70,241,197,.25);color:var(--acc);font-family:var(--font-mono);font-size:12px;padding:8px 12px;border-radius:8px;cursor:pointer;">📋 عرض كود GTM</button>';
            html += '<button onclick="loadProject(' + i + ')" style="flex:1;background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-family:var(--font-ui);font-size:12px;padding:8px 12px;border-radius:8px;cursor:pointer;">⚡ تحميل المشروع</button>';
            html += '</div>';
            html += '<div id="mp-snip-' + i + '" style="display:none;margin-top:12px;">';
            html += '  <div style="background:var(--sur);border:1px solid var(--bdr2);border-radius:10px;padding:10px 12px;margin-bottom:10px;display:flex;align-items:center;gap:10px;">';
            html += '    <span style="font-size:10px;color:var(--mut);letter-spacing:1px;font-family:var(--font-mono);">GTM ID</span>';
            html += '    <span id="mp-gtm-' + i + '" style="font-family:var(--font-mono);font-size:14px;font-weight:700;color:var(--acc);">' + p.gtmPublicId + '</span>';
            html += '    <button onclick="_mgdCopy(\'' + p.gtmPublicId + '\', this)" style="margin-right:auto;background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:11px;padding:5px 10px;border-radius:6px;cursor:pointer;">📋 نسخ</button>';
            html += '  </div>';
            html += '  <div style="font-size:11px;color:var(--wht2);font-weight:700;margin-bottom:6px;">حط الكود ده داخل &lt;head&gt; بتاع الموقع:</div>';
            html += '  <pre id="mp-snip-head-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--wht2);max-height:140px;overflow:auto;direction:ltr;text-align:left;margin-bottom:6px;line-height:1.5;white-space:pre;">' + _esc(p.snippetHead || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'mp-snip-head-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;margin-bottom:12px;">📋 نسخ HEAD</button>';
            html += '  <div style="font-size:11px;color:var(--wht2);font-weight:700;margin-bottom:6px;">وحط الكود ده بعد فتح &lt;body&gt; مباشرة:</div>';
            html += '  <pre id="mp-snip-body-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:10px;font-family:var(--font-mono);font-size:10.5px;color:var(--wht2);max-height:100px;overflow:auto;direction:ltr;text-align:left;margin-bottom:6px;line-height:1.5;white-space:pre;">' + _esc(p.snippetBody || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'mp-snip-body-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:11px;padding:6px 10px;border-radius:6px;cursor:pointer;">📋 نسخ BODY</button>';
            html += '</div>';
          } else {
            html += '<div style="margin-top:10px;font-size:11px;color:var(--acc);opacity:.7;cursor:pointer;" onclick="loadProject(' + i + ')">← اضغط لتحميل الكونفيج — ولسه محتاج تعمل Create Container</div>';
          }
          html += '</div>';
        });
        html += '</div>';

        window._etProjects = projects;
        el.innerHTML = html;

      } catch (e) {
        console.error('loadProjects error:', e);
        el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--red);font-size:13px;">خطأ في تحميل المشاريع<br><span style="font-size:11px;color:var(--mut);">' + (e.message || '') + '</span></div>';
      }
    }

    function loadProject(idx) {
      var p = window._etProjects && window._etProjects[idx];
      if (!p || !p.config) return;
      var cfg = p.config;

      // Restore state
      if (cfg.cms) S.cms = cfg.cms;
      if (cfg.platforms) S.platforms = cfg.platforms;
      if (cfg.events) S.events = cfg.events;
      if (cfg.platformEvents) S.platformEvents = cfg.platformEvents;
      if (cfg.pixelIds) S.pixelIds = cfg.pixelIds;
      if (cfg.lead) S.lead = cfg.lead;

      // Re-generate output
      generate();

      // Show toast
      var toast = document.createElement('div');
      toast.textContent = '✅ تم تحميل المشروع: ' + (p.client_name || '');
      toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0ecfb0;color:#05090f;padding:12px 20px;border-radius:12px;font-family:Cairo,sans-serif;font-weight:700;font-size:14px;z-index:9999;animation:pin .3s ease;';
      document.body.appendChild(toast);
      setTimeout(function () { toast.remove(); }, 3000);
    }


    // ══ DASHBOARD PANEL ═══════════════════════════════════════
    var _dashLoaded = false;
    var _dashProjects = [];

    /* ── History Panel ──────────────────────────────────────── */
    var _historyLog = JSON.parse(localStorage.getItem('et_history') || '[]');

    function addHistoryEntry(icon, name, meta, badge) {
      var entry = { icon: icon, name: name, meta: meta, badge: badge, ts: Date.now() };
      _historyLog.unshift(entry);
      if (_historyLog.length > 50) _historyLog.length = 50;
      try { localStorage.setItem('et_history', JSON.stringify(_historyLog)); } catch (e) { }
      renderHistory();
    }

    function renderHistory() {
      var list = document.getElementById('historyList');
      var empty = document.getElementById('historyEmpty');
      if (!list) return;
      if (!_historyLog.length) { empty.style.display = ''; list.innerHTML = ''; return; }
      empty.style.display = 'none';
      list.innerHTML = _historyLog.map(function (e) {
        var d = new Date(e.ts);
        var timeStr = d.toLocaleDateString('ar-EG', { month: 'short', day: 'numeric' }) + ' · ' + d.toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit' });
        return '<div class="hp-item">'
          + '<div class="hp-item-icon"><span class="material-symbols-outlined" style="font-size:18px;font-variation-settings:\'FILL\' 1;">' + (e.icon || 'dataset') + '</span></div>'
          + '<div class="hp-item-info"><div class="hp-item-name">' + (e.name || '—') + '</div><div class="hp-item-meta">' + timeStr + (e.meta ? ' · ' + e.meta : '') + '</div></div>'
          + (e.badge ? '<span class="hp-item-badge">' + e.badge + '</span>' : '')
          + '</div>';
      }).join('');
    }

    function toggleHistory() {
      var panel = document.getElementById('historyPanel');
      var overlay = document.getElementById('historyOverlay');
      if (!panel || !overlay) return;
      var isOpen = panel.classList.contains('open');
      if (isOpen) {
        panel.classList.remove('open');
        overlay.classList.remove('open');
      } else {
        renderHistory();
        panel.classList.add('open');
        overlay.classList.add('open');
      }
    }

    function toggleDashboard() {
      var panel = document.getElementById('dashPanel');
      var overlay = document.getElementById('dashOverlay');
      var isOpen = panel.classList.contains('open');
      if (isOpen) {
        panel.classList.remove('open');
        overlay.classList.remove('show');
      } else {
        panel.classList.add('open');
        overlay.classList.add('show');
        if (!_dashLoaded) { _dashLoaded = true; loadDashProjects(); }
      }
    }

    function toggleSettings() {
      var panel = document.getElementById('settingsPanel');
      var overlay = document.getElementById('settingsOverlay');
      if (!panel || !overlay) return;
      var isOpen = panel.style.transform === 'translateX(0px)' || panel.style.transform === 'translateX(0)';
      if (isOpen) {
        panel.style.transform = 'translateX(-100%)';
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
      } else {
        // Populate from Firebase user
        try {
          var user = firebase.auth().currentUser;
          if (user) {
            var nameEl = document.getElementById('settingsName');
            var emailEl = document.getElementById('settingsEmail');
            if (nameEl) nameEl.value = user.displayName || '';
            if (emailEl) emailEl.value = user.email || '';
          }
        } catch (e) { }
        // Load saved settings
        try {
          var saved = JSON.parse(localStorage.getItem('et_user_settings') || '{}');
          if (saved.phone) document.getElementById('settingsPhone').value = saved.phone;
          if (saved.cms) document.getElementById('settingsCms').value = saved.cms;
          var planBadge = document.getElementById('settingsPlanBadge');
          var planBadgeSrc = document.getElementById('userPlanBadge');
          if (planBadge && planBadgeSrc) planBadge.textContent = planBadgeSrc.textContent || 'BASIC';
        } catch (e) { }
        panel.style.transform = 'translateX(0)';
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'all';
      }
    }

    function saveSettings() {
      var phone = (document.getElementById('settingsPhone') || {}).value || '';
      var cms = (document.getElementById('settingsCms') || {}).value || '';
      var name = (document.getElementById('settingsName') || {}).value || '';
      try {
        localStorage.setItem('et_user_settings', JSON.stringify({ phone: phone, cms: cms, name: name }));
      } catch (e) { }
      // Save name to Firebase if changed
      try {
        var user = firebase.auth().currentUser;
        if (user && name && name !== user.displayName) {
          user.updateProfile({ displayName: name });
        }
      } catch (e) { }
      // Show success toast
      var toast = document.createElement('div');
      toast.style.cssText = 'position:fixed;bottom:24px;right:50%;transform:translateX(50%);background:#191c22;border:1px solid rgba(70,241,197,0.3);color:var(--acc);padding:12px 20px;border-radius:12px;font-size:13px;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.5);';
      toast.textContent = '✅ تم حفظ الإعدادات';
      document.body.appendChild(toast);
      setTimeout(function () { toast.remove(); }, 2500);
      toggleSettings();
    }

    function showCmsGuide(cmsKey) {
      // Switch to pixels view
      switchAppView('pixels', document.getElementById('sbPixels'));
      // If output is visible, switch to guide tab
      var outWrap = document.getElementById('outWrap');
      if (outWrap && outWrap.classList.contains('on')) {
        var guidePaneBtn = document.querySelector('.otab[onclick*="guide"]');
        if (guidePaneBtn) oTab('guide', guidePaneBtn);
      } else {
        // Show a modal/toast indicating user should generate first
        var msg = cmsKey === 'salla'
          ? '🛍️ اختار سلة من CMS وولّد الـ Config عشان تشوف الـ Setup Guide'
          : '⚡ اختار زد من CMS وولّد الـ Config عشان تشوف الـ Setup Guide';
        // Use a simple notification
        var toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:24px;right:50%;transform:translateX(50%);background:#191c22;border:1px solid rgba(70,241,197,0.3);color:var(--wht2);padding:12px 20px;border-radius:12px;font-size:13px;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.5);';
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(function () { toast.remove(); }, 3000);
      }
    }

    async function loadDashProjects() {
      var listEl = document.getElementById('dp-list');
      try {
        // Wait for db
        var attempts = 0;
        while (!db && attempts < 20) {
          await new Promise(function (r) { setTimeout(r, 300); });
          attempts++;
        }
        if (!db) {
          listEl.innerHTML = '<div class="dp-empty"><div class="dp-empty-icon">⚠️</div><div class="dp-empty-text">مش متصل — تأكد من الإنترنت</div></div>';
          return;
        }

        if (!currentUser || !currentUser.id) {
          listEl.innerHTML = '<div class="dp-empty"><div class="dp-empty-icon">🔒</div><div class="dp-empty-text">سجّل دخولك عشان تشوف مشاريعك</div></div>';
          return;
        }

        var snap;
        try {
          snap = await db.collection('projects')
            .where('client_id', '==', currentUser.id)
            .orderBy('created_at', 'desc')
            .limit(20)
            .get();
        } catch (indexErr) {
          console.warn('orderBy failed, trying without:', indexErr.message);
          try {
            snap = await db.collection('projects')
              .where('client_id', '==', currentUser.id)
              .limit(20)
              .get();
          } catch (fallbackErr) {
            throw fallbackErr;
          }
        }

        _dashProjects = [];
        snap.forEach(function (doc) {
          _dashProjects.push(doc.data());
        });

        // Stats
        var totalP = 0, totalE = 0;
        _dashProjects.forEach(function (p) {
          if (p.platforms) totalP += p.platforms.length;
          if (p.events_count) totalE += p.events_count;
        });

        var plan = (currentUser.plan || 'Basic').toLowerCase();
        var limit = PLAN_LIMITS[plan] || 1;
        var used = currentUser.projects_used || 0;

        document.getElementById('dp-total').textContent = _dashProjects.length;
        document.getElementById('dp-platforms').textContent = totalP;
        document.getElementById('dp-events').textContent = totalE;
        document.getElementById('dp-remain').textContent = limit === 999 ? '∞' : Math.max(0, limit - used);

        if (!_dashProjects.length) {
          listEl.innerHTML = '<div class="dp-empty"><div class="dp-empty-icon">📭</div><div class="dp-empty-text">مفيش مشاريع لحد دلوقتي</div></div>';
          return;
        }

        var html = '';
        _dashProjects.forEach(function (p, i) {
          var date = '—';
          try {
            if (p.created_at && typeof p.created_at.toDate === 'function') date = new Date(p.created_at.toDate()).toLocaleDateString('ar-EG');
            else if (p.created_at && p.created_at.seconds) date = new Date(p.created_at.seconds * 1000).toLocaleDateString('ar-EG');
            else if (p.created_at) date = new Date(p.created_at).toLocaleDateString('ar-EG');
          } catch (de) { date = '—'; }
          var cms = p.cms || '—';
          var plat = p.platforms ? p.platforms.join(' · ') : '—';
          var evs = (p.events_count || 0) + ' events';
          var hasGtm = !!(p.gtmPublicId && p.snippetHead);
          html += '<div class="dp-card">';
          html += '<div class="dp-card-name">' + (p.client_name || 'مشروع #' + (i + 1)) + '</div>';
          html += '<div class="dp-card-tags">';
          html += '<span class="dp-tag cms">' + cms + '</span>';
          html += '<span class="dp-tag plat">' + plat + '</span>';
          html += '<span class="dp-tag evs">' + evs + '</span>';
          // GTM ID badge — so the client can instantly identify which project this is
          if (hasGtm) {
            html += '<span class="dp-tag" style="background:rgba(70,241,197,.14);color:var(--acc);border:1px solid rgba(70,241,197,.28);font-weight:700;" title="GTM Container ID">' + p.gtmPublicId + '</span>';
          } else if (p.gtmPublicId) {
            html += '<span class="dp-tag" style="background:rgba(70,241,197,.08);color:var(--acc);border:1px solid rgba(70,241,197,.2);" title="GTM Container ID">' + p.gtmPublicId + '</span>';
          } else {
            html += '<span class="dp-tag" style="background:rgba(245,158,11,.08);color:var(--amber);border:1px solid rgba(245,158,11,.2);">لم يُرفع</span>';
          }
          html += '</div>';
          html += '<div class="dp-card-footer">';
          html += '<span class="dp-card-date">' + date + '</span>';
          html += '<div style="display:flex;gap:6px;">';
          if (hasGtm) {
            html += '<button onclick="_toggleDpSnippet(' + i + ')" id="dp-snip-btn-' + i + '" class="dp-load-btn" style="background:rgba(70,241,197,.1);color:var(--acc);border:1px solid rgba(70,241,197,.28);">📋 كود GTM</button>';
          }
          html += '<button class="dp-load-btn" onclick="loadDashProject(' + i + ')">⚡ تحميل</button>';
          html += '</div></div>';
          // ── Expandable GTM snippet panel (hidden by default) ──
          if (hasGtm) {
            html += '<div id="dp-snip-' + i + '" style="display:none;margin-top:10px;padding-top:10px;border-top:1px dashed var(--bdr2);">';
            html += '  <div style="display:flex;align-items:center;gap:8px;background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:7px 10px;margin-bottom:8px;">';
            html += '    <span style="font-size:9px;color:var(--mut);letter-spacing:1px;font-family:var(--font-mono);">GTM ID</span>';
            html += '    <span style="font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--acc);">' + p.gtmPublicId + '</span>';
            html += '    <button onclick="_mgdCopy(\'' + p.gtmPublicId + '\', this)" style="margin-right:auto;background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:10px;padding:3px 8px;border-radius:5px;cursor:pointer;">نسخ</button>';
            html += '  </div>';
            html += '  <div style="font-size:10px;color:var(--mut);font-family:var(--font-mono);letter-spacing:.5px;margin-bottom:3px;">HEAD — داخل &lt;head&gt;</div>';
            html += '  <pre id="dp-snip-head-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:8px;font-family:var(--font-mono);font-size:9.5px;color:var(--wht2);max-height:100px;overflow:auto;direction:ltr;text-align:left;margin:0 0 4px;line-height:1.4;white-space:pre;">' + _esc(p.snippetHead || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'dp-snip-head-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:10px;padding:4px 8px;border-radius:5px;cursor:pointer;margin-bottom:8px;">📋 نسخ HEAD</button>';
            html += '  <div style="font-size:10px;color:var(--mut);font-family:var(--font-mono);letter-spacing:.5px;margin-bottom:3px;">BODY — بعد &lt;body&gt;</div>';
            html += '  <pre id="dp-snip-body-' + i + '" style="background:var(--bg);border:1px solid var(--bdr2);border-radius:8px;padding:8px;font-family:var(--font-mono);font-size:9.5px;color:var(--wht2);max-height:90px;overflow:auto;direction:ltr;text-align:left;margin:0 0 4px;line-height:1.4;white-space:pre;">' + _esc(p.snippetBody || '') + '</pre>';
            html += '  <button onclick="_mgdCopy(document.getElementById(\'dp-snip-body-' + i + '\').textContent, this)" style="background:var(--sur3);border:1px solid var(--bdr2);color:var(--wht2);font-size:10px;padding:4px 8px;border-radius:5px;cursor:pointer;">📋 نسخ BODY</button>';
            html += '</div>';
          }
          html += '</div>';
        });
        listEl.innerHTML = html;

      } catch (e) {
        console.error('loadDashProjects error:', e);
        var errMsg = e.message || 'unknown error';
        var hint = '';
        if (errMsg.indexOf('permission') !== -1 || errMsg.indexOf('PERMISSION') !== -1) {
          hint = 'تأكد إن Firestore Rules صح وإن الـ domain مضاف في Firebase Console';
        } else if (errMsg.indexOf('offline') !== -1 || errMsg.indexOf('unavailable') !== -1) {
          hint = 'مش متصل بالإنترنت — حاول تاني';
        } else if (errMsg.indexOf('index') !== -1) {
          hint = 'Firestore index ناقص — افتح Firebase Console وأضف الـ index';
        }
        listEl.innerHTML = '<div class="dp-empty">'
          + '<div class="dp-empty-icon">⚠️</div>'
          + '<div class="dp-empty-text" style="color:var(--red);">' + errMsg + '</div>'
          + (hint ? '<div style="font-size:11px;color:var(--mut);margin-top:8px;line-height:1.6;">' + hint + '</div>' : '')
          + '<button onclick="loadDashProjects()" style="margin-top:14px;padding:8px 20px;background:var(--acc);color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:var(--font-ui);font-size:12px;font-weight:700;">🔄 حاول تاني</button>'
          + '</div>';
      }
    }

    function loadDashProject(idx) {
      var p = _dashProjects[idx];
      if (!p || !p.config) return;
      var cfg = p.config;
      if (cfg.cms) S.cms = cfg.cms;
      if (cfg.platforms) S.platforms = cfg.platforms;
      if (cfg.events) S.events = cfg.events;
      if (cfg.platformEvents) S.platformEvents = cfg.platformEvents;
      if (cfg.pixelIds) S.pixelIds = cfg.pixelIds;
      if (cfg.lead) S.lead = cfg.lead;
      toggleDashboard();
      generate();
      var t = document.createElement('div');
      t.textContent = '✅ ' + (p.client_name || 'المشروع') + ' اتحمل';
      t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0ecfb0;color:#05090f;padding:12px 20px;border-radius:12px;font-family:Cairo,sans-serif;font-weight:700;font-size:14px;z-index:9999;';
      document.body.appendChild(t);
      setTimeout(function () { t.remove(); }, 3000);
    }

    function startNewProject() {
      toggleDashboard();
      // Reset and go to step 1
      resetAll();
    }


    // ══ GATE AUTH ═════════════════════════════════════════════
    function switchGateTab(tab) {
      var isLogin = tab === 'login';
      document.getElementById('gform-login').style.display = isLogin ? 'block' : 'none';
      document.getElementById('gform-signup').style.display = isLogin ? 'none' : 'block';
      var pending = document.getElementById('gform-pending');
      if (pending) pending.style.display = 'none';
      var tabsRow = document.querySelector('.gate-tabs');
      if (tabsRow) tabsRow.style.display = '';
      document.getElementById('gtab-login').classList.toggle('on', isLogin);
      document.getElementById('gtab-signup').classList.toggle('on', !isLogin);
    }

    // Show the "Approval Pending" panel inside the gate.
    // Replaces the old behaviour of auto-opening WhatsApp on signup / pending-status login.
    // The user is asked to message Yousef Elsouly manually; we pre-fill the email so the
    // admin can match the request to the Firestore client doc.
    function showApprovalPending(userEmail) {
      var loginForm   = document.getElementById('gform-login');
      var signupForm  = document.getElementById('gform-signup');
      var pendingForm = document.getElementById('gform-pending');
      var tabsRow     = document.querySelector('.gate-tabs');
      if (loginForm)   loginForm.style.display   = 'none';
      if (signupForm)  signupForm.style.display  = 'none';
      if (tabsRow)     tabsRow.style.display     = 'none';
      if (pendingForm) pendingForm.style.display = 'block';

      // Show email + build pre-filled WhatsApp link
      var emailEl = document.getElementById('gate-pending-email');
      var waEl    = document.getElementById('gate-pending-wa');
      var em = (userEmail || '').trim();
      if (emailEl) emailEl.textContent = em || '—';
      if (waEl) {
        var msg = 'مرحباً يوسف، أنا سجّلت حساب جديد في Easy Track'
                + (em ? ' بإيميل: ' + em : '')
                + ' وأريد تفعيل دخولي. شكراً.';
        waEl.href = 'https://wa.me/201552388174?text=' + encodeURIComponent(msg);
      }

      // Make sure the gate itself is visible (in case enterTool was about to hide it)
      var gate = document.getElementById('gate');
      if (gate) {
        gate.style.display    = 'flex';
        gate.style.opacity    = '1';
        gate.style.transition = '';
      }
    }

    // Reset the gate back to the login form (used by the "ارجع لتسجيل الدخول" link
    // on the approval-pending panel).
    function showGateLogin() {
      try { if (typeof auth !== 'undefined' && auth) auth.signOut(); } catch (_) {}
      try { localStorage.removeItem('et_user'); } catch (_) {}
      try { localStorage.removeItem('et_user_email'); } catch (_) {}
      try { localStorage.removeItem('et_auth_uid'); } catch (_) {}
      switchGateTab('login');
    }

    function showGateError(formId, msg) {
      var el = document.getElementById('gErr-' + formId);
      if (el) { el.textContent = '⚠️ ' + msg; el.style.display = 'block'; }
    }
    function hideGateError(formId) {
      var el = document.getElementById('gErr-' + formId);
      if (el) el.style.display = 'none';
    }

    function enterTool(user, token, isNewSignup) {
      currentUser = user;
      localStorage.setItem('et_auth_token', token || '');
      localStorage.setItem('et_user_email', user.email || '');
      localStorage.setItem('et_user', JSON.stringify(user));
      // Make sure id is set
      if (!currentUser.id && user.id) currentUser.id = user.id;

      // If new signup → show approval-pending panel (admin must approve manually
      // via WhatsApp). NEVER auto-open WhatsApp — the user clicks the button if
      // they want to message Yousef Elsouly.
      if (isNewSignup) {
        localStorage.setItem('et_pending_plan', 'basic');
        localStorage.setItem('et_pending_token', token);
        localStorage.setItem('et_pending_user', JSON.stringify(user));
        showApprovalPending(user.email);
        return;
      }

      // If existing user but not yet approved → show the same approval-pending panel
      if (!user.status || user.status === 'pending') {
        showApprovalPending(user.email);
        return;
      }

      // Update user bar
      var plan = (user.plan || 'Basic');
      var limit = PLAN_LIMITS[plan.toLowerCase()] || 1;
      var used = user.projects_used || 0;
      document.getElementById('userName').textContent = user.name || user.email.split('@')[0];
      document.getElementById('projUsed').textContent = used;
      document.getElementById('projMax').textContent = limit === 999 ? '∞' : limit;
      var badge = document.getElementById('userPlanBadge');
      badge.textContent = plan.toUpperCase();
      badge.className = 'plan-badge plan-' + plan.toLowerCase();

      // Update sidebar project info
      var sbName = document.getElementById('sbUserName');
      var sbPlan = document.getElementById('sbUserPlan');
      if (sbName) sbName.textContent = user.name || user.email.split('@')[0];
      if (sbPlan) sbPlan.textContent = plan + ' Plan';

      // Update overview user header
      var ovName = document.getElementById('ovWelcomeName');
      var ovPlan = document.getElementById('ovPlanText');
      var ovAvatar = document.getElementById('ovUserAvatar');
      var displayName = user.name || user.email.split('@')[0];
      if (ovName) ovName.textContent = 'مرحباً، ' + displayName;
      if (ovPlan) ovPlan.textContent = plan.toUpperCase();
      // Show initials in avatar if no photo
      if (ovAvatar) {
        var initials = displayName ? displayName.charAt(0).toUpperCase() : '?';
        ovAvatar.innerHTML = '<span style="font-family:var(--font-display);font-weight:800;font-size:18px;color:var(--acc);">' + initials + '</span>';
      }

      // Hide gate, show tool
      var g = document.getElementById('gate');
      g.style.transition = 'opacity .4s';
      g.style.opacity = '0';
      setTimeout(function () {
        g.style.display = 'none';
        S.lead = { name: user.name || '', phone: '', location: '', ts: new Date().toISOString() };
        document.getElementById('s1').classList.add('on');
        updateProg(1);
      }, 400);
    }

    async function doGateLogin() {
      // Dev mode bypass for local testing
      if (_isLocalDev()) {
        var devUser = { id: 'dev-local', name: 'Dev User', email: 'dev@local', plan: 'Growth', status: 'active', projects_used: 0 };
        enterTool(devUser, 'dev-token');
        return;
      }
      var email = document.getElementById('gEmail-l').value.trim();
      var pass = document.getElementById('gPass-l').value;
      var btn = document.getElementById('gBtn-l');
      hideGateError('l');

      if (!email || !pass) { showGateError('l', 'برجاء ملء جميع الحقول'); return; }
      btn.textContent = '⏳ جاري الدخول...'; btn.disabled = true;

      try {
        // 1. Firebase Auth login
        var cred = await auth.signInWithEmailAndPassword(email, pass);
        var uid = cred.user.uid;

        // 2. Get client from Firestore
        var doc = await db.collection('clients').doc(uid).get();
        if (!doc.exists) throw new Error('الحساب مش موجود في Easy Track');

        var client = doc.data();
        client.id = uid;

        // 3. Save session
        localStorage.setItem('et_user', JSON.stringify(client));
        localStorage.setItem('et_user_email', email);

        // 4. Check approval status — show pending panel (NOT auto-open WhatsApp)
        if (!client.status || client.status === 'pending') {
          localStorage.setItem('et_auth_uid', uid);
          showApprovalPending(client.email || email);
          return;
        }

        enterTool(client, '');

      } catch (e) {
        var msg;
        if (e.code === 'auth/wrong-password' || e.code === 'auth/user-not-found' || e.code === 'auth/invalid-credential' || e.code === 'auth/invalid-email') {
          msg = 'البريد أو كلمة المرور غلط';
        } else if (e.code === 'unavailable' || (e.message && e.message.toLowerCase().indexOf('unavailable') !== -1)) {
          // Firebase unavailable — try cached session
          if (_tryLoadCachedSession()) return;
          msg = '⚠️ الخدمة غير متاحة مؤقتاً — انتظر ثواني وحاول تاني';
        } else if (e.code === 'auth/network-request-failed') {
          msg = '⚠️ تأكد من اتصال الإنترنت وحاول تاني';
        } else {
          msg = e.message || 'خطأ في الدخول';
        }
        showGateError('l', msg);
        btn.textContent = 'دخول ←'; btn.disabled = false;
      }
    }

    async function doGateSignup() {
      // Dev mode bypass for local testing
      if (_isLocalDev()) {
        var devUser = { id: 'dev-local', name: 'Dev User', email: 'dev@local', plan: 'Growth', status: 'active', projects_used: 0 };
        enterTool(devUser, 'dev-token');
        return;
      }
      var name     = document.getElementById('gName-s').value.trim();
      var email    = document.getElementById('gEmail-s').value.trim();
      var pass     = document.getElementById('gPass-s').value;
      var country  = document.getElementById('gCountry-s').value;
      var whatsapp = document.getElementById('gWhatsapp-s').value.trim();
      var job      = document.getElementById('gJob-s').value.trim();
      var btn      = document.getElementById('gBtn-s');
      hideGateError('s');

      if (!name || !email || !pass || !country || !whatsapp || !job) {
        showGateError('s', 'برجاء ملء جميع الحقول');
        return;
      }
      if (pass.length < 6) { showGateError('s', 'كلمة المرور 6 أحرف على الأقل'); return; }

      // Basic WhatsApp validation — must contain at least 8 digits
      var digitCount = (whatsapp.match(/\d/g) || []).length;
      if (digitCount < 8) {
        showGateError('s', 'رقم الواتساب غير صحيح — اكتب الرقم كامل مع كود الدولة');
        return;
      }
      // Normalize whatsapp to digits only + leading +
      var whatsappNormalized = whatsapp.startsWith('+')
        ? '+' + whatsapp.slice(1).replace(/\D/g, '')
        : whatsapp.replace(/\D/g, '');

      btn.textContent = '⏳ جاري التسجيل...'; btn.disabled = true;

      try {
        // 1. Firebase Auth signup
        var cred = await auth.createUserWithEmailAndPassword(email, pass);
        var uid = cred.user.uid;

        // 2. Save to Firestore clients collection
        await db.collection('clients').doc(uid).set({
          id: uid,
          name: name,
          email: email,
          country: country,
          whatsapp: whatsappNormalized,
          job: job,
          plan: 'Basic',
          status: 'pending',
          projects_used: 0,
          created_at: firebase.firestore.FieldValue.serverTimestamp()
        });

        var user = {
          id: uid, name: name, email: email,
          country: country, whatsapp: whatsappNormalized, job: job,
          plan: 'Basic', projects_used: 0, status: 'pending'
        };
        enterTool(user, null, true);  // isNewSignup = true → go to payment

      } catch (e) {
        var msg = e.code === 'auth/email-already-in-use' ? 'البريد ده مسجّل بالفعل — سجّل دخول' : (e.message || 'خطأ في إنشاء الحساب');
        showGateError('s', msg);
        btn.textContent = 'إنشاء حساب ←'; btn.disabled = false;
      }
    }


    // ══ EXTENSION INTEGRATION ═════════════════════════════════
    function checkExtensionData() {
      try {
        var raw = localStorage.getItem('et_ext_datalayer');
        if (!raw) return;
        var dl = JSON.parse(raw);
        if (!dl || !dl.events) return;

        // Clear after reading
        localStorage.removeItem('et_ext_datalayer');

        // Auto-select CMS
        if (dl.cms && S.cms === null) {
          S.cms = dl.cms;
          var cmsBtn = document.querySelector('.cbtn[data-val="' + dl.cms + '"]');
          if (cmsBtn) {
            document.querySelectorAll('#cmsGrid .cbtn').forEach(function (b) { b.classList.remove('on'); });
            cmsBtn.classList.add('on');
            document.getElementById('btn1').disabled = false;
          }
        }

        // Map events to GA4 schema
        var knownEvents = Object.keys(GA4);
        var matched = [];
        Object.keys(dl.events).forEach(function (evName) {
          if (knownEvents.indexOf(evName) !== -1) {
            matched.push(evName);
          }
        });

        if (matched.length) {
          S.events = matched;
        }

        // Show toast
        var toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0ecfb0;color:#05090f;padding:14px 20px;border-radius:12px;font-family:Cairo,sans-serif;font-weight:700;font-size:14px;z-index:9999;box-shadow:0 8px 24px rgba(14,207,176,.3);';
        toast.innerHTML = '⚡ Extension: تم اكتشاف ' + matched.length + ' events من ' + (dl.cms || 'الموقع');
        document.body.appendChild(toast);
        setTimeout(function () { toast.remove(); }, 4000);

        console.log('Extension data loaded:', dl);
      } catch (e) {
        console.error('Extension data error:', e);
      }
    }

    // Check on load and if URL has from_extension param
    (function () {
      if (window.location.search.indexOf('from_extension=1') !== -1) {
        // Wait for page to init then load extension data
        setTimeout(checkExtensionData, 1000);
      }
    })();

    // ══════ PIXEL SCANNER ══════
    var HM_PLATFORMS_DEF = [
      {
        key: 'meta', name: 'Meta Pixel', icon: '👥', color: '#1877F2',
        patterns: [/fbq\s*\(\s*['"]init['"]\s*,\s*['"](\d{10,})['"]/g,
          /facebook\.com\/tr\?id=(\d{10,})/g],
        detect: function (h) { return h.indexOf('connect.facebook.net') > -1 || h.indexOf('facebook.com/tr') > -1; }
      },
      {
        key: 'ga4', name: 'Google Analytics (GA4)', icon: '📊', color: '#E37400',
        patterns: [/gtag\s*\(\s*['"]config['"]\s*,\s*['"]( G-[A-Z0-9]+)['"]/g,
          /gtag\s*\(\s*['"]config['"]\s*,\s*['"](G-[A-Z0-9]+)['"]/g,
          /[?&]id=(G-[A-Z0-9]+)/g],
        detect: function (h) { return h.indexOf('G-') > -1 && h.indexOf('gtag') > -1; }
      },
      {
        key: 'google', name: 'Google Ads', icon: '🎯', color: '#4285F4',
        patterns: [/gtag\s*\(\s*['"]config['"]\s*,\s*['"]( AW-[0-9]+)['"]/g,
          /gtag\s*\(\s*['"]config['"]\s*,\s*['"](AW-[0-9]+)['"]/g,
          /[?&]id=(AW-[0-9]+)/g],
        detect: function (h) { return h.indexOf('AW-') > -1; }
      },
      {
        key: 'gtm', name: 'Google Tag Manager', icon: '📦', color: '#246FDB',
        patterns: [/GTM-([A-Z0-9]+)/g],
        detect: function (h) { return h.indexOf('googletagmanager.com/gtm') > -1; }
      },
      {
        key: 'tiktok', name: 'TikTok Pixel', icon: '🎵', color: '#010101',
        patterns: [/ttq\.load\s*\(\s*['"]([A-Z0-9]{16,})['"]/g,
          /tiktok['"]\s*,\s*['"]([A-Z0-9]{16,})['"]/g],
        detect: function (h) { return h.indexOf('analytics.tiktok.com') > -1 || h.indexOf('ttq') > -1; }
      },
      {
        key: 'snapchat', name: 'Snapchat Pixel', icon: '👻', color: '#FFFC00',
        patterns: [/snaptr\s*\(\s*['"]init['"]\s*,\s*['"]([a-f0-9-]{30,})['"]/g],
        detect: function (h) { return h.indexOf('sc-static.net') > -1 || h.indexOf('snaptr') > -1; }
      },
      {
        key: 'twitter', name: 'X (Twitter) Pixel', icon: '𝕏', color: '#000000',
        patterns: [/twq\s*\(\s*['"]init['"]\s*,\s*['"]([a-z0-9]+)['"]/g,
          /twq\s*\(\s*['"]event['"]\s*,\s*['"]([a-z0-9]+)['"]/g],
        detect: function (h) { return h.indexOf('ads-twitter.com') > -1 || h.indexOf('static.ads-twitter') > -1; }
      },
      {
        key: 'linkedin', name: 'LinkedIn Insight', icon: '💼', color: '#0A66C2',
        patterns: [/_linkedin_partner_id\s*=\s*['"]?(\d+)['"]?/g,
          /linkedin_partner_id['"]\s*:\s*['"]?(\d+)['"]?/g],
        detect: function (h) { return h.indexOf('snap.licdn.com') > -1 || h.indexOf('linkedin') > -1; }
      },
      {
        key: 'mixpanel', name: 'Mixpanel', icon: '📈', color: '#7856FF',
        patterns: [/mixpanel\.init\s*\(\s*['"]([a-f0-9]{32})['"]/g],
        detect: function (h) { return h.indexOf('mixpanel') > -1; }
      },
    ];

    function hmExtractIds(html, patterns) {
      var ids = [];
      patterns.forEach(function (rx) {
        var re = new RegExp(rx.source, rx.flags);
        var m;
        while ((m = re.exec(html)) !== null) {
          var id = m[1].trim();
          if (id && ids.indexOf(id) === -1) ids.push(id);
        }
      });
      return ids;
    }

    // ── Event Schemas: required + recommended params per platform ──
    var HM_EVENT_SCHEMAS = {
      meta: {
        'PageView': { required: [], recommended: ['external_id'] },
        'ViewContent': { required: ['content_ids', 'content_type'], recommended: ['value', 'currency', 'content_name', 'content_category', 'contents'] },
        'AddToCart': { required: ['content_ids', 'content_type'], recommended: ['value', 'currency', 'content_name', 'contents', 'num_items'] },
        'AddToWishlist': { required: ['content_ids', 'content_type'], recommended: ['value', 'currency', 'content_name'] },
        'InitiateCheckout': { required: ['value', 'currency'], recommended: ['content_ids', 'contents', 'num_items'] },
        'AddPaymentInfo': { required: ['value', 'currency'], recommended: ['content_ids', 'contents', 'num_items'] },
        'Purchase': { required: ['value', 'currency'], recommended: ['content_ids', 'content_type', 'contents', 'num_items', 'order_id'] },
        'Lead': { required: [], recommended: ['value', 'currency', 'content_name', 'content_category'] },
        'CompleteRegistration': { required: [], recommended: ['value', 'currency', 'content_name', 'status'] },
        'Search': { required: ['search_string'], recommended: ['value', 'currency', 'content_ids', 'content_category'] },
        'Subscribe': { required: [], recommended: ['value', 'currency', 'predicted_ltv'] },
        'StartTrial': { required: [], recommended: ['value', 'currency', 'predicted_ltv'] },
        'Contact': { required: [], recommended: [] },
        'CustomizeProduct': { required: [], recommended: [] },
        'Donate': { required: ['value', 'currency'], recommended: [] },
        'FindLocation': { required: [], recommended: [] },
        'Schedule': { required: [], recommended: [] },
        'SubmitApplication': { required: [], recommended: [] },
      },
      tiktok: {
        'PageView': { required: [], recommended: [] },
        'ViewContent': { required: ['content_id', 'content_type'], recommended: ['value', 'currency', 'content_name', 'description'] },
        'ClickButton': { required: [], recommended: ['content_id', 'content_name'] },
        'Search': { required: ['query'], recommended: ['value', 'currency'] },
        'AddToWishlist': { required: ['content_id', 'content_type'], recommended: ['value', 'currency'] },
        'AddToCart': { required: ['content_id', 'content_type'], recommended: ['value', 'currency', 'quantity', 'content_name'] },
        'InitiateCheckout': { required: ['value', 'currency'], recommended: ['content_id', 'quantity'] },
        'AddPaymentInfo': { required: ['value', 'currency'], recommended: ['content_id'] },
        'PlaceAnOrder': { required: ['value', 'currency', 'content_id'], recommended: ['content_type', 'quantity', 'order_id'] },
        'CompletePayment': { required: ['value', 'currency', 'content_id'], recommended: ['content_type', 'quantity', 'order_id'] },
        'Purchase': { required: ['value', 'currency', 'content_id'], recommended: ['content_type', 'quantity', 'order_id'] },
        'CompleteRegistration': { required: [], recommended: ['value', 'currency'] },
        'SubmitForm': { required: [], recommended: [] },
        'Contact': { required: [], recommended: [] },
        'Download': { required: [], recommended: [] },
        'Subscribe': { required: [], recommended: ['value', 'currency'] },
      },
      ga4: {
        // page_view: gtag.js auto-populates page_title/page_location/page_referrer/page_path
        // so we don't flag them as missing. Only flag params the user must add manually.
        'page_view': { required: [], recommended: [] },
        'view_item_list': { required: ['items'], recommended: ['item_list_id', 'item_list_name'] },
        'view_item': { required: ['items'], recommended: ['currency', 'value'] },
        'select_item': { required: ['items'], recommended: ['item_list_id', 'item_list_name'] },
        'add_to_wishlist': { required: ['items'], recommended: ['currency', 'value'] },
        'add_to_cart': { required: ['items'], recommended: ['currency', 'value'] },
        'remove_from_cart': { required: ['items'], recommended: ['currency', 'value'] },
        'view_cart': { required: ['items'], recommended: ['currency', 'value'] },
        'begin_checkout': { required: ['items'], recommended: ['currency', 'value', 'coupon'] },
        'add_shipping_info': { required: ['items'], recommended: ['currency', 'value', 'shipping_tier'] },
        'add_payment_info': { required: ['items'], recommended: ['currency', 'value', 'payment_type'] },
        'purchase': { required: ['transaction_id', 'value', 'currency'], recommended: ['items', 'coupon', 'shipping', 'tax'] },
        'refund': { required: ['transaction_id'], recommended: ['value', 'currency', 'items'] },
        'generate_lead': { required: [], recommended: ['value', 'currency'] },
        'login': { required: [], recommended: ['method'] },
        'sign_up': { required: [], recommended: ['method'] },
        'search': { required: ['search_term'], recommended: [] },
        'select_promotion': { required: [], recommended: ['items', 'promotion_id', 'promotion_name'] },
        'view_promotion': { required: [], recommended: ['items', 'promotion_id', 'promotion_name'] },
        'share': { required: [], recommended: ['method', 'content_type', 'item_id'] },
      },
      google_ads: {
        'conversion': { required: ['value', 'currency_code'], recommended: ['transaction_id'] },
        'purchase': { required: ['value', 'currency_code', 'transaction_id'], recommended: [] },
        'page_view': { required: [], recommended: [] },
      },
      snapchat: {
        'PAGE_VIEW': { required: [], recommended: [] },
        'VIEW_CONTENT': { required: ['item_ids'], recommended: ['price', 'currency', 'item_category'] },
        'ADD_CART': { required: ['item_ids'], recommended: ['price', 'currency', 'item_category', 'number_items'] },
        'START_CHECKOUT': { required: ['price', 'currency'], recommended: ['item_ids', 'number_items'] },
        'PURCHASE': { required: ['price', 'currency'], recommended: ['item_ids', 'transaction_id', 'number_items'] },
        'SIGN_UP': { required: [], recommended: ['sign_up_method'] },
        'SEARCH': { required: ['search_string'], recommended: [] },
        'SUBSCRIBE': { required: [], recommended: ['price', 'currency'] },
        'ADD_BILLING': { required: [], recommended: ['price', 'currency'] },
        'COMPLETE_TUTORIAL': { required: [], recommended: [] },
      },
      twitter: {
        'PageView': { required: [], recommended: [] },
        'Purchase': { required: ['value', 'currency'], recommended: ['conversion_id', 'num_items'] },
        'AddToCart': { required: [], recommended: ['value', 'currency', 'content_ids'] },
        'Signup': { required: [], recommended: [] },
        'Lead': { required: [], recommended: ['value', 'currency'] },
      },
      linkedin: {
        'conversion': { required: ['conversion_id'], recommended: ['value', 'currency'] },
        'page_view': { required: [], recommended: [] },
      },
    };

    // ══════ Core events each platform recommends for e-commerce ═══════════
    // priority: 'critical' = campaigns won't optimize without it
    //           'important' = platform's funnel insights suffer
    //           'optional'  = nice-to-have
    // pageHint: where this event typically fires — helps user know if it's
    //           "missing" because we scanned the wrong page type
    var HM_CORE_EVENTS = {
      meta: [
        { name: 'PageView',          priority: 'critical',  pageHint: 'all pages',     reason: 'Required for retargeting audiences & reach optimization' },
        { name: 'ViewContent',       priority: 'critical',  pageHint: 'product page',  reason: 'Needed for Dynamic Product Ads + view-content audiences' },
        { name: 'AddToCart',         priority: 'critical',  pageHint: 'product page',  reason: 'Mid-funnel signal for conversion optimization' },
        { name: 'InitiateCheckout',  priority: 'important', pageHint: 'checkout page', reason: 'Cart abandonment retargeting' },
        { name: 'AddPaymentInfo',    priority: 'optional',  pageHint: 'checkout',      reason: 'Deeper funnel signal' },
        { name: 'Purchase',          priority: 'critical',  pageHint: 'thank-you page',reason: 'Conversion event — Meta optimizes toward this' },
        { name: 'Lead',              priority: 'optional',  pageHint: 'form submit',   reason: 'Only for lead-gen businesses' },
        { name: 'CompleteRegistration', priority: 'optional', pageHint: 'signup done',  reason: 'Track sign-up conversions' },
        { name: 'Search',            priority: 'optional',  pageHint: 'search result', reason: 'Better audience segmentation' },
      ],
      tiktok: [
        { name: 'PageView',          priority: 'critical',  pageHint: 'all pages',     reason: 'Base pixel signal for TikTok audiences' },
        { name: 'ViewContent',       priority: 'critical',  pageHint: 'product page',  reason: 'Product-level retargeting' },
        { name: 'AddToCart',         priority: 'critical',  pageHint: 'product page',  reason: 'Mid-funnel signal' },
        { name: 'InitiateCheckout',  priority: 'important', pageHint: 'checkout page', reason: 'Abandon-cart retargeting' },
        { name: 'PlaceAnOrder',      priority: 'important', pageHint: 'order-placed',  reason: 'Order placement signal' },
        { name: 'CompletePayment',   priority: 'critical',  pageHint: 'thank-you page',reason: 'Conversion event — TikTok optimizes toward this' },
        { name: 'CompleteRegistration', priority: 'optional', pageHint: 'signup done', reason: 'Sign-up tracking' },
        { name: 'ClickButton',       priority: 'optional',  pageHint: 'CTA clicks',    reason: 'Engagement signal' },
      ],
      ga4: [
        { name: 'page_view',         priority: 'critical',  pageHint: 'all pages',     reason: 'Base GA4 signal (auto-sent by gtag)' },
        { name: 'view_item_list',    priority: 'optional',  pageHint: 'category page', reason: 'Track which product lists users view' },
        { name: 'view_item',         priority: 'critical',  pageHint: 'product page',  reason: 'Required for e-commerce reports + DPA' },
        { name: 'add_to_cart',       priority: 'critical',  pageHint: 'product page',  reason: 'Cart funnel analysis' },
        { name: 'view_cart',         priority: 'optional',  pageHint: 'cart page',     reason: 'Mid-funnel drop-off analysis' },
        { name: 'begin_checkout',    priority: 'critical',  pageHint: 'checkout page', reason: 'Checkout funnel step' },
        { name: 'add_payment_info',  priority: 'important', pageHint: 'payment step',  reason: 'Deeper funnel step' },
        { name: 'purchase',          priority: 'critical',  pageHint: 'thank-you page',reason: 'Required for revenue attribution + ROAS' },
        { name: 'refund',            priority: 'optional',  pageHint: 'backend trigger', reason: 'Net revenue reporting' },
        { name: 'login',             priority: 'optional',  pageHint: 'auth flow',     reason: 'User engagement tracking' },
        { name: 'sign_up',           priority: 'optional',  pageHint: 'signup done',   reason: 'Registration tracking' },
      ],
      google_ads: [
        { name: 'conversion',        priority: 'critical',  pageHint: 'conversion page',reason: 'Required for Google Ads bid optimization' },
        { name: 'purchase',          priority: 'critical',  pageHint: 'thank-you page',reason: 'Enhanced conversions for Google Ads' },
        { name: 'page_view',         priority: 'important', pageHint: 'all pages',     reason: 'Remarketing audience building' },
      ],
      snapchat: [
        { name: 'PAGE_VIEW',         priority: 'critical',  pageHint: 'all pages',     reason: 'Base Snap Pixel signal' },
        { name: 'VIEW_CONTENT',      priority: 'critical',  pageHint: 'product page',  reason: 'Product retargeting' },
        { name: 'ADD_CART',          priority: 'critical',  pageHint: 'product page',  reason: 'Mid-funnel signal' },
        { name: 'START_CHECKOUT',    priority: 'important', pageHint: 'checkout page', reason: 'Cart abandonment' },
        { name: 'PURCHASE',          priority: 'critical',  pageHint: 'thank-you page',reason: 'Conversion event — Snap optimizes toward this' },
        { name: 'SIGN_UP',           priority: 'optional',  pageHint: 'signup done',   reason: 'Registration tracking' },
      ],
      twitter: [
        { name: 'PageView',          priority: 'critical',  pageHint: 'all pages',     reason: 'Base X Pixel signal' },
        { name: 'Purchase',          priority: 'critical',  pageHint: 'thank-you page',reason: 'X Ads conversion' },
        { name: 'AddToCart',         priority: 'important', pageHint: 'product page',  reason: 'Mid-funnel signal' },
        { name: 'Lead',              priority: 'optional',  pageHint: 'form submit',   reason: 'Lead-gen only' },
        { name: 'Signup',            priority: 'optional',  pageHint: 'signup done',   reason: 'Registration tracking' },
      ],
      linkedin: [
        { name: 'page_view',         priority: 'critical',  pageHint: 'all pages',     reason: 'Base LinkedIn Insight Tag signal' },
        { name: 'conversion',        priority: 'critical',  pageHint: 'conversion page',reason: 'Required for LinkedIn Ads optimization' },
      ],
      // GTM doesn't have its own events — it's a loader
    };

    // Actionable hint for each missing param — what to do in GTM or site code
    var HM_PARAM_HINTS = {
      // Meta params
      content_ids:   'أضف content_ids (array of SKUs) من الـ dataLayer أو من page variables',
      content_type:  'اضبط content_type = "product" (أو "product_group") في الـ event tag',
      contents:      'أفضل format: contents=[{id, quantity, item_price}] — استخدمه بدل content_ids',
      content_name:  'مرّر اسم المنتج من الـ dataLayer (product.name)',
      content_category: 'مرّر الفئة/القسم من الـ dataLayer (product.category)',
      value:         'ضروري في Purchase/InitiateCheckout — مرّر إجمالي السعر رقم من الـ dataLayer',
      currency:      'ضروري مع value — مثل "USD" أو "EGP" (ISO-4217)',
      num_items:     'عدد القطع الكلي في السلة',
      order_id:      'مرّر transaction_id من صفحة التأكيد — يمنع duplicate deduplication مع CAPI',
      search_string: 'مرّر query الـ search box من الـ URL أو الـ dataLayer',
      external_id:   'hashed user ID — يحسّن attribution مع iOS 14+',
      predicted_ltv: 'قيمة الـ customer lifetime value المتوقعة',
      status:        'true/false — نجاح التسجيل',
      // TikTok params
      content_id:    'مرّر SKU المنتج من الـ dataLayer',
      quantity:      'عدد القطع',
      query:         'نص الـ search query',
      description:   'وصف المنتج المختصر',
      // GA4 params
      items:         'array من الـ item objects — {item_id, item_name, price, quantity, ...}',
      transaction_id:'ID الطلب من الـ order — ضروري عشان يمنع التكرار',
      coupon:        'كود الخصم المستخدم (لو موجود)',
      shipping:      'تكلفة الشحن',
      tax:           'الضرائب',
      shipping_tier: 'نوع الشحن (Standard/Express)',
      payment_type:  'طريقة الدفع (Credit Card/PayPal/COD)',
      page_title:    'auto-populated في gtag.js — تأكد إنه مش overridden',
      page_location: 'auto-populated — window.location.href',
      page_referrer: 'auto-populated — document.referrer',
      item_list_id:  'ID الـ list اللي ظهر فيها المنتج (collection/search)',
      item_list_name:'اسم الـ list',
      promotion_id:  'ID الـ promotion banner',
      promotion_name:'اسم الـ promotion',
      search_term:   'نص الـ search query',
      method:        'طريقة الدخول/التسجيل (email/google/facebook)',
      content_type_ga:'نوع المحتوى اللي اتشارك',
      item_id:       'ID العنصر اللي اتشارك',
      // Google Ads params
      currency_code: 'كود العملة (ISO-4217) — مختلف عن GA4 اللي اسمه currency',
      // Snapchat params
      item_ids:      'array من item IDs',
      price:         'السعر الإجمالي — ملحوظة: snapchat بيستخدم price مش value',
      item_category: 'category المنتج',
      number_items:  'عدد القطع',
      sign_up_method:'طريقة التسجيل',
      // Twitter params
      conversion_id: 'Twitter conversion event ID من الـ ads manager',
    };

    // Extract fbq / ttq / gtag events fired on the page
    function hmExtractEvents(html, platformKey) {
      var results = [];
      var re;
      if (platformKey === 'meta') {
        re = /fbq\s*\(\s*['"]track(?:Custom)?['"]\s*,\s*['"](\w+)['"](?:\s*,\s*(\{[^}]{0,800}\}))?\s*\)/g;
      } else if (platformKey === 'tiktok') {
        re = /ttq\.track\s*\(\s*['"](\w+)['"](?:\s*,\s*(\{[^}]{0,800}\}))?\s*\)/g;
      } else if (platformKey === 'ga4') {
        re = /gtag\s*\(\s*['"]event['"]\s*,\s*['"](\w+)['"](?:\s*,\s*(\{[^}]{0,800}\}))?\s*\)/g;
      } else { return results; }

      var m;
      while ((m = re.exec(html)) !== null) {
        var evName = m[1];
        var paramKeys = [];
        if (m[2]) {
          var pkRe = /['"](\w+)['"]\s*:/g, pk;
          while ((pk = pkRe.exec(m[2])) !== null) paramKeys.push(pk[1]);
        }
        // avoid duplicates
        var exists = results.filter(function (r) { return r.name === evName; })[0];
        if (exists) {
          paramKeys.forEach(function (k) { if (exists.params.indexOf(k) === -1) exists.params.push(k); });
        } else {
          results.push({ name: evName, params: paramKeys });
        }
      }
      return results;
    }

    // ══════ INTELLIGENT PIXEL ANALYSIS ═══════════════════════════════════
    // Reads the ACTUAL events captured and deduces concrete issues based on
    // funnel patterns, event dependencies, and missing params. Never
    // "recommends events at random" — every insight is triggered by a real
    // signal in the scanned data.
    function hmAnalyzePixel(px) {
      var issues = [];
      var key = px.key;
      var events = (px.events || []).filter(function (e) { return !e.generic; });
      var hasGeneric = (px.events || []).some(function (e) { return e.generic; });
      var eventHitCount = typeof px.eventHitCount === 'number' ? px.eventHitCount : 0;
      var evNames = events.map(function (e) { return (e.name || '').toLowerCase(); });
      var hasEv = function (n) { return evNames.indexOf(n.toLowerCase()) > -1; };
      var getEv = function (n) { return events.filter(function (e) { return (e.name || '').toLowerCase() === n.toLowerCase(); })[0]; };
      var lacksParam = function (ev, p) { return ev && ev.params.indexOf(p) === -1; };

      // ── A. Pixel loaded but NO event hits at all ──
      if (!events.length && !eventHitCount && !hasGeneric) {
        if (HM_CORE_EVENTS[key]) {
          issues.push({
            severity: 'critical',
            title: 'الـ Pixel متركب بس مش بيبعت أي events',
            detail: 'الكود الأساسي للـ ' + px.name + ' موجود لكن مفيش أي event بيتبعت — يعني الـ tracking معطّل فعلياً.',
            fix: 'فعّل على الأقل ' + (key === 'ga4' ? 'page_view' : 'PageView') + ' + e-commerce events من الـ dataLayer عبر GTM.'
          });
        }
        return issues;
      }

      // ── B. Removed: all platforms now have extractEvent, so empty events means
      //     the pixel genuinely didn't fire — no need to warn about "unparseable names".

      // ══ META / FACEBOOK PIXEL ══════════════════════════════════════════
      if (key === 'meta') {
        var pv = getEv('PageView'), vc = getEv('ViewContent'), atc = getEv('AddToCart'),
            ic = getEv('InitiateCheckout'), pur = getEv('Purchase'), lead = getEv('Lead');

        // Funnel integrity: AddToCart without ViewContent
        if (atc && !vc) {
          issues.push({
            severity: 'warning',
            title: 'Funnel مكسور: AddToCart من غير ViewContent',
            detail: 'بتبعت AddToCart لكن مفيش ViewContent قبله — ده هيضعف Dynamic Product Ads ويمنع Meta من بناء retargeting audience للناس اللي شافت المنتج.',
            fix: 'في GTM، أضف Meta ViewContent event يفاير على صفحة المنتج بنفس content_ids اللي في AddToCart.'
          });
        }
        // Purchase without prior funnel steps
        if (pur && !atc) {
          issues.push({
            severity: 'warning',
            title: 'Purchase من غير AddToCart في الـ pipeline',
            detail: 'Meta بيستخدم AddToCart كـ mid-funnel signal للـ optimization — بدونه الـ bidding هيكون أقل دقة.',
            fix: 'تأكد إن AddToCart event يفاير على صفحة المنتج قبل الـ checkout.'
          });
        }
        if (pur && !ic) {
          issues.push({
            severity: 'info',
            title: 'Purchase بدون InitiateCheckout',
            detail: 'مفيش إشارة لبداية الـ checkout — الـ abandoned-cart audiences مش هتقدر تتكوّن.',
            fix: 'أضف InitiateCheckout event يفاير أول ما العميل يدخل الـ checkout page.'
          });
        }
        // Missing required params per event
        if (pur) {
          if (lacksParam(pur, 'value') || lacksParam(pur, 'currency')) {
            issues.push({
              severity: 'critical',
              title: 'Purchase بدون value/currency — ROAS معطّل',
              detail: 'Meta مش هيقدر يحسب ROAS ولا يعمل value-based bidding بدون value + currency.',
              fix: 'في الـ Purchase tag، مرّر {{DLV - ecommerce.purchase.value}} و {{DLV - ecommerce.currencyCode}} من الـ dataLayer.'
            });
          }
          if (lacksParam(pur, 'content_ids') && lacksParam(pur, 'contents')) {
            issues.push({
              severity: 'critical',
              title: 'Purchase بدون content_ids — DPA مش هيشتغل',
              detail: 'Dynamic Product Ads محتاجة SKUs المنتجات اللي اتباعت عشان تعرض نفسها في الـ retargeting.',
              fix: 'أضف content_ids (array من الـ SKUs) أو contents (array of {id, quantity, item_price}).'
            });
          }
          if (lacksParam(pur, 'order_id')) {
            issues.push({
              severity: 'warning',
              title: 'Purchase بدون order_id — خطر duplicate events',
              detail: 'لو عندك Conversions API (server-side) بجانب Pixel، Meta هيعدّ كل Purchase مرتين بدون order_id للـ deduplication.',
              fix: 'مرّر order_id = transaction_id من الـ thank-you page.'
            });
          }
        }
        if (vc && lacksParam(vc, 'content_ids') && lacksParam(vc, 'contents')) {
          issues.push({
            severity: 'critical',
            title: 'ViewContent بدون content_ids',
            detail: 'Meta مش هيقدر يحدد أي منتج العميل شافه — Dynamic Product Ads هتبقى عمياء.',
            fix: 'مرّر SKU المنتج في content_ids من الـ dataLayer (عادةً في product detail page).'
          });
        }
        if (atc && lacksParam(atc, 'content_ids') && lacksParam(atc, 'contents')) {
          issues.push({
            severity: 'critical',
            title: 'AddToCart بدون content_ids',
            detail: 'ما تقدرش تعمل abandoned-cart retargeting بمنتجات محددة.',
            fix: 'مرّر content_ids + content_type = "product" في الـ tag.'
          });
        }
        if (lead && lacksParam(lead, 'value')) {
          issues.push({
            severity: 'info',
            title: 'Lead بدون value',
            detail: 'لو كل lead ليه قيمة متوقعة، Meta يقدر يعمل value-based optimization.',
            fix: 'أضف value approximate (مثلاً 50) + currency.'
          });
        }
        // Missing PageView base signal
        if (!pv && events.length) {
          issues.push({
            severity: 'warning',
            title: 'مفيش PageView',
            detail: 'الـ Pixel بيبعت events متقدمة بدون PageView — بعض الـ audiences والـ reach optimization محتاجين PageView كـ base signal.',
            fix: 'تأكد إن fbq("track", "PageView") بيحصل تلقائياً في الـ base script.'
          });
        }
      }

      // ══ TIKTOK PIXEL ═══════════════════════════════════════════════════
      if (key === 'tiktok') {
        var tVc = getEv('ViewContent'), tAtc = getEv('AddToCart'),
            tIc = getEv('InitiateCheckout'), tCp = getEv('CompletePayment') || getEv('PlaceAnOrder') || getEv('Purchase');

        if (tAtc && !tVc) {
          issues.push({
            severity: 'warning',
            title: 'Funnel مكسور: AddToCart بدون ViewContent',
            detail: 'TikTok Dynamic Showcase Ads (DSA) محتاجة ViewContent عشان retargeting المنتجات.',
            fix: 'أضف TikTok ViewContent event على صفحة المنتج.'
          });
        }
        if (tCp && !tIc) {
          issues.push({
            severity: 'info',
            title: 'Purchase بدون InitiateCheckout',
            detail: 'مفيش checkout funnel signal للـ TikTok — abandon-cart audiences مش هتتكوّن.',
            fix: 'أضف InitiateCheckout على صفحة الـ checkout.'
          });
        }
        if (tCp) {
          if (lacksParam(tCp, 'value') || lacksParam(tCp, 'currency')) {
            issues.push({
              severity: 'critical',
              title: (tCp.name) + ' بدون value/currency',
              detail: 'TikTok Ads Value Optimization مش هتشتغل — الـ ROAS هيكون null.',
              fix: 'مرّر value + currency من الـ dataLayer.'
            });
          }
          if (lacksParam(tCp, 'content_id')) {
            issues.push({
              severity: 'critical',
              title: (tCp.name) + ' بدون content_id',
              detail: 'مفيش SKU المنتج المباع — DSA و product-level reports معطّلة.',
              fix: 'مرّر content_id = SKU من الـ ecommerce dataLayer.'
            });
          }
        }
      }

      // ══ GA4 ════════════════════════════════════════════════════════════
      if (key === 'ga4') {
        var gPv = getEv('page_view'), gVi = getEv('view_item'), gAtc = getEv('add_to_cart'),
            gBc = getEv('begin_checkout'), gPur = getEv('purchase');

        if (gAtc && !gVi) {
          issues.push({
            severity: 'warning',
            title: 'Funnel مكسور: add_to_cart بدون view_item',
            detail: 'Enhanced E-commerce reports في GA4 مش هتعرض product-view-to-cart rate.',
            fix: 'أضف view_item event يفاير على صفحة المنتج بنفس items array.'
          });
        }
        if (gPur && !gBc) {
          issues.push({
            severity: 'info',
            title: 'purchase بدون begin_checkout',
            detail: 'GA4 Checkout Funnel Report ما هيشتغلش — مش هتعرف نسبة الـ drop-off في الـ checkout.',
            fix: 'أضف begin_checkout على أول صفحة checkout.'
          });
        }
        if (gPur) {
          if (lacksParam(gPur, 'transaction_id')) {
            issues.push({
              severity: 'critical',
              title: 'purchase بدون transaction_id — Duplicate revenue',
              detail: 'لو العميل عمل refresh للـ thank-you page، GA4 هيعد purchase كل مرة — الـ revenue هيتضاعف.',
              fix: 'مرّر {{DLV - ecommerce.purchase.transaction_id}} من الـ dataLayer.'
            });
          }
          if (lacksParam(gPur, 'value') || lacksParam(gPur, 'currency')) {
            issues.push({
              severity: 'critical',
              title: 'purchase بدون value/currency — Revenue مش هيتحسب',
              detail: 'GA4 Revenue reports هتكون فاضية، و Google Ads Enhanced Conversions مش هيشتغل.',
              fix: 'مرّر value + currency من الـ dataLayer.'
            });
          }
          if (lacksParam(gPur, 'items')) {
            issues.push({
              severity: 'warning',
              title: 'purchase بدون items[] — Product reports فاضية',
              detail: 'Revenue per product / best-sellers reports مش هتظهر.',
              fix: 'مرّر items array بـ {item_id, item_name, price, quantity, item_category}.'
            });
          }
        }
        if (gAtc && lacksParam(gAtc, 'items')) {
          issues.push({
            severity: 'critical',
            title: 'add_to_cart بدون items',
            detail: 'GA4 E-commerce shopping behaviour report هيكون ناقص.',
            fix: 'أضف items array في الـ event tag.'
          });
        }
        if (gVi && lacksParam(gVi, 'items')) {
          issues.push({
            severity: 'warning',
            title: 'view_item بدون items',
            detail: 'مفيش ID/اسم المنتج في الـ event — product affinity reports مش هتشتغل.',
            fix: 'أضف items[{item_id, item_name, price}].'
          });
        }
      }

      // ══ GOOGLE ADS ═════════════════════════════════════════════════════
      if (key === 'google_ads') {
        var hasConv = evNames.some(function (n) { return /purchase|conversion/i.test(n); });
        if (events.length && !hasConv) {
          issues.push({
            severity: 'critical',
            title: 'Google Ads بدون conversion events',
            detail: 'الـ remarketing tag شغال بس مفيش أي conversion tracking — Smart Bidding و Target ROAS strategies مش هتشتغل.',
            fix: 'أضف Google Ads Conversion Tag (awct) بـ conversionId + conversionLabel على الـ thank-you page.'
          });
        }
        var gaConv = getEv('conversion') || getEv('purchase');
        if (gaConv) {
          if (lacksParam(gaConv, 'value') && lacksParam(gaConv, 'currency_code')) {
            issues.push({
              severity: 'critical',
              title: 'Google Ads conversion بدون value/currency',
              detail: 'Target ROAS و Maximize Conversion Value bidding strategies محتاجين value + currency.',
              fix: 'في الـ awct tag، فعّل "Use different values for each conversion" ومرّر value + currency_code.'
            });
          }
          if (lacksParam(gaConv, 'transaction_id')) {
            issues.push({
              severity: 'warning',
              title: 'Google Ads conversion بدون transaction_id',
              detail: 'Enhanced Conversions مش هتقدر تعمل matching + خطر duplicate conversions.',
              fix: 'مرّر transaction_id من الـ order.'
            });
          }
        }
      }

      // ══ SNAPCHAT ═══════════════════════════════════════════════════════
      if (key === 'snapchat') {
        var sPv = getEv('PAGE_VIEW'), sVc = getEv('VIEW_CONTENT'), sAc = getEv('ADD_CART'), sPur = getEv('PURCHASE');
        if (sAc && !sVc) {
          issues.push({
            severity: 'warning',
            title: 'ADD_CART بدون VIEW_CONTENT',
            detail: 'Snapchat DPA محتاجة VIEW_CONTENT عشان retargeting المنتجات.',
            fix: 'أضف VIEW_CONTENT event مع item_ids على صفحة المنتج.'
          });
        }
        if (sPur) {
          if (lacksParam(sPur, 'price') || lacksParam(sPur, 'currency')) {
            issues.push({
              severity: 'critical',
              title: 'PURCHASE بدون price/currency',
              detail: 'Snapchat Ads value optimization مش هيشتغل. ملحوظة: Snapchat بيستخدم "price" مش "value".',
              fix: 'مرّر price + currency (Snapchat-specific naming).'
            });
          }
          if (lacksParam(sPur, 'item_ids')) {
            issues.push({
              severity: 'warning',
              title: 'PURCHASE بدون item_ids',
              detail: 'مفيش المنتجات المباعة — DPA و product-level reports فاضية.',
              fix: 'مرّر item_ids array من الـ order.'
            });
          }
        }
      }

      return issues;
    }

    // ══ CROSS-PIXEL ANALYSIS ═════════════════════════════════════════════
    // Detects inconsistencies across multiple pixels installed on the same
    // page — e.g. Meta fires Purchase but GA4 doesn't, or one pixel has
    // value while another has a different value.
    function hmCrossAnalyze(pixels) {
      var issues = [];
      if (!pixels || pixels.length < 2) return issues;

      // Map: platform → { hasPurchase, purchaseEv }
      var state = {};
      pixels.forEach(function (px) {
        var evs = px.events || [];
        var purchaseEv = evs.filter(function (e) {
          return /^(purchase|completepayment|placeanorder)$/i.test(e.name);
        })[0] || (px.key === 'google_ads' ? evs.filter(function (e) { return /^(conversion)$/i.test(e.name); })[0] : null);
        state[px.key] = {
          px: px,
          hasPixel: true,
          purchase: purchaseEv || null,
          eventCount: evs.length
        };
      });

      // 1. Conversion-tracking parity — Meta Purchase vs GA4 purchase vs Google Ads conversion
      var metaHasPur = state.meta && state.meta.purchase;
      var ga4HasPur = state.ga4 && state.ga4.purchase;
      var adsHasConv = state.google_ads && state.google_ads.purchase;
      var tiktokHasPur = state.tiktok && state.tiktok.purchase;

      if (metaHasPur && state.ga4 && !ga4HasPur) {
        issues.push({
          severity: 'critical',
          title: 'Meta بيسجّل Purchase — GA4 لا',
          detail: 'Meta Pixel بيبعت Purchase event بس GA4 (موجود في الصفحة) مش بيبعت purchase. Revenue في GA4 reports هتكون غلط + Google Ads Enhanced Conversions مش هيشتغل.',
          fix: 'تأكد إن GA4 purchase tag يفاير على نفس الـ thank-you page trigger زي Meta.'
        });
      }
      if (ga4HasPur && state.google_ads && !adsHasConv) {
        issues.push({
          severity: 'critical',
          title: 'GA4 بيسجّل purchase — Google Ads لا',
          detail: 'Google Ads (موجود في الصفحة) مش بيسجّل conversion — Target ROAS و Smart Bidding مش هيتدرّبوا صح.',
          fix: 'أضف Google Ads Conversion Tag على نفس الـ thank-you trigger.'
        });
      }
      if (metaHasPur && state.tiktok && !tiktokHasPur) {
        issues.push({
          severity: 'warning',
          title: 'Meta بيسجّل Purchase — TikTok لا',
          detail: 'TikTok Pixel موجود بس مش بيبعت CompletePayment/Purchase — Value Optimization للـ TikTok Ads مش هيشتغل.',
          fix: 'أضف TikTok CompletePayment event على الـ thank-you page.'
        });
      }

      // 2. Value mismatch between pixels
      function getVal(pEv, valKey, currKey) {
        if (!pEv) return null;
        var v = null;
        // Try to find value in params (simplified — we only have param NAMES here, not values)
        return pEv.params.indexOf(valKey) > -1 ? true : null;
      }
      // Both Meta and GA4 have purchase but one has value and the other doesn't
      if (metaHasPur && ga4HasPur) {
        var metaHasVal = state.meta.purchase.params.indexOf('value') > -1;
        var ga4HasVal = state.ga4.purchase.params.indexOf('value') > -1;
        if (metaHasVal !== ga4HasVal) {
          issues.push({
            severity: 'warning',
            title: 'Meta و GA4 مش متناسقين في value',
            detail: (metaHasVal ? 'Meta بيبعت value — GA4 لا.' : 'GA4 بيبعت value — Meta لا.') + ' هتحصل على revenue أرقام مختلفة في كل platform.',
            fix: 'وحّد مصدر الـ value من نفس dataLayer variable في الـ tags الاتنين.'
          });
        }
      }

      // 3. No pixel fires any event
      var anyEvents = Object.keys(state).some(function (k) { return state[k].eventCount > 0; });
      if (!anyEvents && pixels.length > 1) {
        issues.push({
          severity: 'critical',
          title: 'كل الـ Pixels شغالة بدون events',
          detail: 'عندك ' + pixels.length + ' pixels متركبين بس مافيش ولا pixel واحد بيبعت أي event. الـ tracking كله معطّل.',
          fix: 'راجع الـ GTM container — يمكن الـ triggers مش شغالة أو الـ dataLayer فارغ.'
        });
      }

      return issues;
    }

    // Helper: render a list of issues as HTML cards
    function hmRenderIssues(issues) {
      if (!issues.length) return '';
      // Sort: critical → warning → info
      var order = { critical: 0, warning: 1, info: 2 };
      issues.sort(function (a, b) { return (order[a.severity] || 9) - (order[b.severity] || 9); });

      var out = '';
      issues.forEach(function (iss) {
        var color = iss.severity === 'critical' ? '#ffb4ab' : iss.severity === 'warning' ? '#ffd680' : '#adc6ff';
        var icon = iss.severity === 'critical' ? '🔴' : iss.severity === 'warning' ? '🟡' : 'ℹ️';
        var label = iss.severity === 'critical' ? 'CRITICAL' : iss.severity === 'warning' ? 'WARNING' : 'INFO';
        out += '<div style="padding:10px 12px;margin-bottom:6px;background:linear-gradient(135deg,' + color + '0f,' + color + '04);border:1px solid ' + color + '30;border-radius:10px;">'
          + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;flex-wrap:wrap;">'
          + '<span style="font-size:10px;font-weight:800;padding:2px 8px;border-radius:12px;background:' + color + '22;color:' + color + ';border:1px solid ' + color + '55;letter-spacing:.5px;">' + icon + ' ' + label + '</span>'
          + '<span style="font-size:12px;font-weight:700;color:var(--wht);">' + _esc(iss.title) + '</span>'
          + '</div>'
          + '<div style="font-size:11px;color:var(--mut2);line-height:1.5;margin-bottom:6px;">' + _esc(iss.detail) + '</div>'
          + '<div style="font-size:11px;color:#46f1c5;line-height:1.5;padding:5px 8px;background:rgba(70,241,197,.05);border-right:2px solid #46f1c5;border-radius:4px;">💡 ' + _esc(iss.fix) + '</div>'
          + '</div>';
      });
      return out;
    }

    // Build a checklist of expected core events vs what was actually seen
    function hmBuildMissingEventsChecklist(platformKey, detectedEvents) {
      var coreEvents = HM_CORE_EVENTS[platformKey];
      if (!coreEvents || !coreEvents.length) return '';

      var detectedNames = (detectedEvents || []).map(function (e) { return (e.name || '').toLowerCase(); });
      var missing = [];
      var present = [];
      coreEvents.forEach(function (ce) {
        if (detectedNames.indexOf(ce.name.toLowerCase()) > -1) {
          present.push(ce);
        } else {
          missing.push(ce);
        }
      });

      if (!missing.length && !present.length) return '';

      // Group missing by priority
      var criticalMissing = missing.filter(function (m) { return m.priority === 'critical'; });
      var importantMissing = missing.filter(function (m) { return m.priority === 'important'; });
      var optionalMissing = missing.filter(function (m) { return m.priority === 'optional'; });

      var out = '';

      // Section header
      var critCount = criticalMissing.length;
      var headerColor = critCount > 0 ? '#ffb4ab' : (importantMissing.length > 0 ? '#ffd680' : '#46f1c5');
      var headerLabel = critCount > 0
        ? critCount + ' critical event' + (critCount > 1 ? 's' : '') + ' missing'
        : (importantMissing.length > 0
            ? importantMissing.length + ' important missing'
            : (optionalMissing.length > 0 ? 'Only optional events missing' : 'All core events present'));

      out += '<div style="margin-top:12px;padding:12px 14px;background:linear-gradient(135deg,' + headerColor + '10,' + headerColor + '04);border:1px solid ' + headerColor + '33;border-radius:10px;">';
      out += '<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;margin-bottom:10px;">'
        + '<div style="font-size:12px;font-weight:800;color:var(--wht);letter-spacing:.5px;">📋 RECOMMENDED EVENTS CHECKLIST</div>'
        + '<span style="font-size:11px;font-weight:800;padding:3px 10px;border-radius:20px;background:' + headerColor + '22;color:' + headerColor + ';border:1px solid ' + headerColor + '55;">' + _esc(headerLabel) + '</span>'
        + '</div>';

      // Present events row
      if (present.length) {
        out += '<div style="margin-bottom:10px;">';
        out += '<div style="font-size:10px;color:#46f1c5;font-weight:800;margin-bottom:4px;letter-spacing:.5px;">✓ DETECTED (' + present.length + ')</div>';
        out += '<div style="display:flex;flex-wrap:wrap;gap:5px;">';
        present.forEach(function (p) {
          out += '<span style="font-size:10px;padding:3px 8px;border-radius:12px;background:rgba(70,241,197,.12);color:#46f1c5;border:1px solid rgba(70,241,197,.3);font-family:var(--font-mono);">✓ ' + _esc(p.name) + '</span>';
        });
        out += '</div></div>';
      }

      // Critical missing — highlighted
      if (criticalMissing.length) {
        out += '<div style="margin-bottom:10px;">';
        out += '<div style="font-size:10px;color:#ffb4ab;font-weight:800;margin-bottom:6px;letter-spacing:.5px;">🔴 CRITICAL MISSING (' + criticalMissing.length + ') — Campaigns won\'t optimize without these</div>';
        criticalMissing.forEach(function (m) {
          out += '<div style="display:flex;align-items:flex-start;gap:8px;padding:7px 10px;margin-bottom:4px;background:rgba(255,180,171,.08);border:1px solid rgba(255,180,171,.25);border-radius:8px;">'
            + '<span style="font-size:10px;padding:3px 8px;border-radius:12px;background:rgba(255,180,171,.15);color:#ffb4ab;border:1px solid rgba(255,180,171,.4);font-family:var(--font-mono);white-space:nowrap;flex-shrink:0;font-weight:700;">✗ ' + _esc(m.name) + '</span>'
            + '<div style="flex:1;min-width:0;">'
            + '<div style="font-size:11px;color:var(--wht);font-weight:600;line-height:1.4;">' + _esc(m.reason) + '</div>'
            + '<div style="font-size:10px;color:var(--mut);margin-top:2px;">📍 Fires on: ' + _esc(m.pageHint) + '</div>'
            + '</div>'
            + '</div>';
        });
        out += '</div>';
      }

      // Important missing
      if (importantMissing.length) {
        out += '<div style="margin-bottom:10px;">';
        out += '<div style="font-size:10px;color:#ffd680;font-weight:800;margin-bottom:6px;letter-spacing:.5px;">🟡 IMPORTANT MISSING (' + importantMissing.length + ')</div>';
        importantMissing.forEach(function (m) {
          out += '<div style="display:flex;align-items:flex-start;gap:8px;padding:6px 10px;margin-bottom:4px;background:rgba(255,214,128,.05);border:1px solid rgba(255,214,128,.2);border-radius:8px;">'
            + '<span style="font-size:10px;padding:3px 8px;border-radius:12px;background:rgba(255,214,128,.12);color:#ffd680;border:1px solid rgba(255,214,128,.35);font-family:var(--font-mono);white-space:nowrap;flex-shrink:0;">? ' + _esc(m.name) + '</span>'
            + '<div style="flex:1;min-width:0;">'
            + '<div style="font-size:11px;color:var(--mut2);line-height:1.4;">' + _esc(m.reason) + '</div>'
            + '<div style="font-size:10px;color:var(--mut);margin-top:2px;">📍 ' + _esc(m.pageHint) + '</div>'
            + '</div>'
            + '</div>';
        });
        out += '</div>';
      }

      // Optional missing — collapsed summary
      if (optionalMissing.length) {
        out += '<div style="font-size:10px;color:var(--mut);margin-top:4px;">'
          + '<span style="color:#adc6ff;font-weight:700;">· Optional:</span> '
          + optionalMissing.map(function (m) { return _esc(m.name); }).join(', ')
          + '</div>';
      }

      out += '<div style="font-size:10px;color:var(--mut);margin-top:8px;padding-top:8px;border-top:1px dashed var(--bdr2);">'
        + '💡 Scanned only this page — events like Purchase/Checkout fire on other pages (thank-you, cart). Scan those pages separately to verify the full funnel.'
        + '</div>';

      out += '</div>';
      return out;
    }

    function hmBuildEventReport(platformKey, detectedEvents) {
      var schema = HM_EVENT_SCHEMAS[platformKey] || {};
      if (!detectedEvents.length) return '';

      // ── Summary metrics across all events for this platform ────────────
      var totalEvents = detectedEvents.length;
      var totalMissingReq = 0;
      var totalMissingRec = 0;
      var totalScore = 0;
      detectedEvents.forEach(function (ev) {
        var def = schema[ev.name] || { required: [], recommended: [] };
        var missingReq = def.required.filter(function (p) { return ev.params.indexOf(p) === -1; });
        var missingRec = def.recommended.filter(function (p) { return ev.params.indexOf(p) === -1; });
        totalMissingReq += missingReq.length;
        totalMissingRec += missingRec.length;
        var s = 100;
        if (def.required.length) s -= missingReq.length * Math.floor(50 / Math.max(def.required.length, 1));
        if (def.recommended.length) s -= missingRec.length * Math.floor(30 / Math.max(def.recommended.length, 1));
        totalScore += Math.max(s, 0);
      });
      var avgScore = Math.round(totalScore / totalEvents);
      var summaryColor = avgScore >= 80 ? '#46f1c5' : avgScore >= 50 ? '#ffd680' : '#ffb4ab';

      var out = '';

      // Platform-level summary banner
      out += '<div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:10px 12px;margin-bottom:10px;background:linear-gradient(135deg,' + summaryColor + '12,' + summaryColor + '06);border:1px solid ' + summaryColor + '33;border-radius:10px;">'
        + '<span style="font-size:11px;font-weight:800;color:' + summaryColor + ';padding:3px 10px;border-radius:20px;background:' + summaryColor + '22;border:1px solid ' + summaryColor + '55;">' + avgScore + '% avg health</span>'
        + '<span style="font-size:11px;color:var(--mut);">• ' + totalEvents + ' event' + (totalEvents > 1 ? 's' : '') + ' captured</span>'
        + (totalMissingReq ? '<span style="font-size:11px;color:#ffb4ab;font-weight:700;">• ' + totalMissingReq + ' missing required param' + (totalMissingReq > 1 ? 's' : '') + '</span>' : '')
        + (totalMissingRec ? '<span style="font-size:11px;color:#ffd680;">• ' + totalMissingRec + ' missing recommended</span>' : '')
        + (!totalMissingReq && !totalMissingRec ? '<span style="font-size:11px;color:#46f1c5;font-weight:700;">✓ All params present</span>' : '')
        + '</div>';

      detectedEvents.forEach(function (ev) {
        var def = schema[ev.name] || null;
        var hasSchema = !!def;
        def = def || { required: [], recommended: [] };
        var missingReq = def.required.filter(function (p) { return ev.params.indexOf(p) === -1; });
        var missingRec = def.recommended.filter(function (p) { return ev.params.indexOf(p) === -1 && missingReq.indexOf(p) === -1; });
        var score = 100;
        if (def.required.length) score -= missingReq.length * Math.floor(50 / Math.max(def.required.length, 1));
        if (def.recommended.length) score -= missingRec.length * Math.floor(30 / Math.max(def.recommended.length, 1));
        score = Math.max(score, 0);
        var scoreColor = score >= 80 ? '#46f1c5' : score >= 50 ? '#ffd680' : '#ffb4ab';

        out += '<div style="border:1px solid var(--bdr2);border-radius:10px;margin-bottom:8px;overflow:hidden;background:var(--sur2);">';
        // Header row
        out += '<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:var(--sur4);flex-wrap:wrap;gap:6px;">'
          + '<span style="font-size:13px;font-weight:700;color:var(--wht);font-family:var(--font-mono);">' + _esc(ev.name) + '</span>'
          + (hasSchema
              ? '<span style="font-size:11px;font-weight:800;padding:2px 9px;border-radius:20px;background:' + scoreColor + '22;color:' + scoreColor + ';border:1px solid ' + scoreColor + '44;">' + score + '% health</span>'
              : '<span style="font-size:10px;padding:2px 9px;border-radius:20px;background:rgba(173,198,255,.1);color:#adc6ff;border:1px solid rgba(173,198,255,.3);">Custom event — no schema</span>')
          + '</div>';

        // Params found
        if (ev.params.length) {
          out += '<div style="padding:8px 13px 0;display:flex;flex-wrap:wrap;gap:5px;align-items:center;">';
          out += '<span style="font-size:10px;color:var(--mut);font-weight:700;letter-spacing:.5px;margin-inline-end:4px;">PRESENT:</span>';
          ev.params.forEach(function (p) {
            var isReq = def.required.indexOf(p) > -1;
            var c = isReq ? '#46f1c5' : '#adc6ff';
            out += '<span style="font-size:10px;padding:2px 7px;border-radius:12px;background:' + c + '18;color:' + c + ';border:1px solid ' + c + '33;font-family:var(--font-mono);">✓ ' + _esc(p) + '</span>';
          });
          out += '</div>';
        } else {
          out += '<div style="padding:8px 13px 0;"><span style="font-size:10px;color:var(--mut);">⚠️ No params captured from network</span></div>';
        }

        // Missing required — with hints
        if (missingReq.length) {
          out += '<div style="padding:8px 13px 0;">';
          out += '<div style="font-size:10px;color:#ffb4ab;font-weight:800;margin-bottom:5px;letter-spacing:1px;">✗ MISSING REQUIRED (' + missingReq.length + ')</div>';
          missingReq.forEach(function (p) {
            var hint = HM_PARAM_HINTS[p] || 'أضف هذا الـ parameter في event tag أو الـ dataLayer';
            out += '<div style="display:flex;align-items:flex-start;gap:8px;padding:6px 8px;margin-bottom:4px;background:rgba(255,180,171,.06);border:1px solid rgba(255,180,171,.2);border-radius:8px;">'
              + '<span style="font-size:10px;padding:2px 7px;border-radius:12px;background:rgba(255,180,171,.15);color:#ffb4ab;border:1px solid rgba(255,180,171,.4);font-family:var(--font-mono);white-space:nowrap;flex-shrink:0;">' + _esc(p) + '</span>'
              + '<span style="font-size:11px;color:var(--mut2);line-height:1.4;">💡 ' + _esc(hint) + '</span>'
              + '</div>';
          });
          out += '</div>';
        }

        // Missing recommended — with hints (compact)
        if (missingRec.length) {
          out += '<div style="padding:6px 13px 0;">';
          out += '<div style="font-size:10px;color:#ffd680;font-weight:800;margin-bottom:5px;letter-spacing:1px;">? MISSING RECOMMENDED (' + missingRec.length + ')</div>';
          missingRec.forEach(function (p) {
            var hint = HM_PARAM_HINTS[p] || '';
            out += '<div style="display:flex;align-items:flex-start;gap:8px;padding:5px 8px;margin-bottom:3px;background:rgba(255,214,128,.04);border:1px solid rgba(255,214,128,.18);border-radius:8px;">'
              + '<span style="font-size:10px;padding:2px 7px;border-radius:12px;background:rgba(255,214,128,.12);color:#ffd680;border:1px solid rgba(255,214,128,.35);font-family:var(--font-mono);white-space:nowrap;flex-shrink:0;">' + _esc(p) + '</span>'
              + (hint ? '<span style="font-size:11px;color:var(--mut);line-height:1.4;">' + _esc(hint) + '</span>' : '')
              + '</div>';
          });
          out += '</div>';
        }

        if (hasSchema && !missingReq.length && !missingRec.length) {
          out += '<div style="padding:8px 13px;font-size:11px;color:#46f1c5;">✓ All required & recommended params are present</div>';
        }
        out += '<div style="padding-bottom:6px;"></div>';

        out += '</div>';
      });
      return out;
    }

    async function hmScanSite() {
      var urlInput = document.getElementById('hmScanUrl');
      var resultEl = document.getElementById('hmScanResult');
      var btn = document.getElementById('hmScanBtn');
      if (!urlInput || !resultEl) return;

      var url = urlInput.value.trim();
      if (!url) { urlInput.focus(); return; }

      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;animation:spin .7s linear infinite;display:inline-block;">sync</span> Scanning...';
      resultEl.style.display = 'block';
      resultEl.innerHTML = '<div style="color:var(--mut);font-size:13px;">⏳ Fetching page...</div>';

      try {
        var html = '';
        var fullUrl = url.startsWith('http') ? url : 'https://' + url;
        var resolvedUrl = fullUrl; // will be updated if server returns redirect URL

        // Step 1: Try own server first (works on localhost & Railway & any Node host)
        var serverOk = false;
        if (location.protocol !== 'file:') {
          try {
            var resp = await fetch('/api/scan-url', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ url: fullUrl })
            });
            var respText = await resp.text();
            var data;
            try { data = JSON.parse(respText); } catch (e) { data = null; }
            if (resp.ok && data && !data.error && data.html) {
              html = data.html;
              resolvedUrl = data.url || fullUrl;
              serverOk = true;
            }
          } catch (e) { /* server not available — fall through to proxy */ }
        }

        // Step 2: Fallback to CORS proxy (GitHub Pages / static hosting / file://)
        if (!serverOk) {
          resultEl.style.display = 'block';
          resultEl.innerHTML = '<div style="color:var(--mut);font-size:12px;">⏳ Using CORS proxy...</div>';
          try {
            var proxyResp = await fetch('https://api.allorigins.win/get?url=' + encodeURIComponent(fullUrl));
            var proxyData = await proxyResp.json();
            if (!proxyData.contents) throw new Error('Empty response');
            html = proxyData.contents;
          } catch (e1) {
            try {
              var p2Resp = await fetch('https://corsproxy.io/?' + encodeURIComponent(fullUrl));
              if (!p2Resp.ok) throw new Error('Status ' + p2Resp.status);
              html = await p2Resp.text();
            } catch (e2) {
              resultEl.innerHTML = '<div style="color:#ffb4ab;font-size:13px;">❌ Could not fetch the page — the site may block external requests.<br><span style="color:var(--mut);">' + _esc(e2.message) + '</span></div>';
              btn.disabled = false; btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">radar</span> Scan'; return;
            }
          }
        }
        // ── Use Puppeteer pixels if backend returned them ──────────────────────
        var puppeteerPixels = (data && Array.isArray(data.pixels) && data.pixels.length) ? data.pixels : null;
        var scanMethod = (data && data.method) ? data.method : 'http';

        if (puppeteerPixels) {
          // ── PUPPETEER RESULT PATH ─────────────────────────────────────────
          var configured = S.pixelIds || {};
          var html2 = '';

          // Cross-platform aggregate health
          var agg = { events: 0, missingReq: 0, missingRec: 0, pixelsWithEvents: 0, missingCriticalEvents: 0, missingImportantEvents: 0 };
          puppeteerPixels.forEach(function (px) {
            var core = HM_CORE_EVENTS[px.key];
            var evNames = (px.events || []).map(function (e) { return (e.name || '').toLowerCase(); });
            if (core && core.length) {
              core.forEach(function (ce) {
                if (evNames.indexOf(ce.name.toLowerCase()) === -1) {
                  if (ce.priority === 'critical') agg.missingCriticalEvents++;
                  else if (ce.priority === 'important') agg.missingImportantEvents++;
                }
              });
            }
            if (!px.events || !px.events.length) return;
            agg.pixelsWithEvents++;
            agg.events += px.events.length;
            var sch = HM_EVENT_SCHEMAS[px.key] || {};
            px.events.forEach(function (ev) {
              var def = sch[ev.name];
              if (!def) return;
              agg.missingReq += def.required.filter(function (p) { return ev.params.indexOf(p) === -1; }).length;
              agg.missingRec += def.recommended.filter(function (p) { return ev.params.indexOf(p) === -1; }).length;
            });
          });

          // Header banner
          html2 += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:6px;">'
            + '<div style="font-size:12px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;">'
            + 'Detected on ' + _esc(resolvedUrl) + ' — ' + puppeteerPixels.length + ' pixel(s) found</div>'
            + '<span style="font-size:10px;padding:2px 8px;border-radius:20px;background:rgba(70,241,197,.1);color:var(--acc);border:1px solid rgba(70,241,197,.2);">🔬 Headless Chrome Scan</span>'
            + '</div>';

          // Cross-platform health summary banner
          var hasAnyData = agg.events || agg.missingCriticalEvents || agg.missingImportantEvents;
          if (hasAnyData) {
            var hasCritical = agg.missingReq > 0 || agg.missingCriticalEvents > 0;
            var hasWarn = agg.missingRec > 0 || agg.missingImportantEvents > 0;
            var overallColor = hasCritical ? '#ffb4ab' : (hasWarn ? '#ffd680' : '#46f1c5');
            var overallLabel = hasCritical ? 'Critical issues' : (hasWarn ? 'Minor gaps' : 'All clean');
            html2 += '<div style="padding:14px 16px;margin-bottom:14px;background:linear-gradient(135deg,' + overallColor + '0f,' + overallColor + '03);border:1px solid ' + overallColor + '33;border-radius:12px;">'
              + '<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;margin-bottom:8px;">'
              + '<div style="font-size:13px;font-weight:800;color:var(--wht);">🎯 Pixel Health Overview</div>'
              + '<span style="font-size:11px;font-weight:800;padding:3px 10px;border-radius:20px;background:' + overallColor + '22;color:' + overallColor + ';border:1px solid ' + overallColor + '55;">' + overallLabel + '</span>'
              + '</div>'
              + '<div style="display:flex;gap:14px;flex-wrap:wrap;font-size:12px;color:var(--mut);">'
              + '<div>📡 <b style="color:var(--wht);">' + agg.events + '</b> event' + (agg.events !== 1 ? 's' : '') + ' captured</div>'
              + (agg.missingCriticalEvents ? '<div style="color:#ffb4ab;">🔴 <b>' + agg.missingCriticalEvents + '</b> critical event' + (agg.missingCriticalEvents > 1 ? 's' : '') + ' missing</div>' : '')
              + (agg.missingImportantEvents ? '<div style="color:#ffd680;">🟡 <b>' + agg.missingImportantEvents + '</b> important event' + (agg.missingImportantEvents > 1 ? 's' : '') + ' missing</div>' : '')
              + (agg.missingReq ? '<div style="color:#ffb4ab;">✗ <b>' + agg.missingReq + '</b> required param' + (agg.missingReq > 1 ? 's' : '') + ' missing</div>' : (agg.events ? '<div style="color:#46f1c5;">✓ All required params present</div>' : ''))
              + (agg.missingRec ? '<div style="color:#ffd680;">? <b>' + agg.missingRec + '</b> recommended param' + (agg.missingRec > 1 ? 's' : '') + ' missing</div>' : '')
              + '</div>'
              + '</div>';
          }

          if (!puppeteerPixels.length) {
            html2 += '<div style="color:var(--mut);font-size:13px;padding:12px;background:var(--sur3);border-radius:10px;">No known tracking pixels detected via network requests.</div>';
          }

          // Cross-platform intelligent analysis (inconsistencies between pixels)
          var crossIssues = hmCrossAnalyze(puppeteerPixels);
          if (crossIssues.length) {
            html2 += '<div style="padding:12px 14px;margin-bottom:14px;background:linear-gradient(135deg,rgba(173,198,255,.08),rgba(173,198,255,.02));border:1px solid rgba(173,198,255,.25);border-radius:12px;">'
              + '<div style="font-size:12px;font-weight:800;color:#adc6ff;letter-spacing:.5px;margin-bottom:10px;">🔗 CROSS-PLATFORM ANALYSIS — ' + crossIssues.length + ' inconsistenc' + (crossIssues.length > 1 ? 'ies' : 'y') + ' found</div>'
              + hmRenderIssues(crossIssues)
              + '</div>';
          }

          puppeteerPixels.forEach(function (px) {
            var configuredId = typeof configured[px.key] === 'object' ? configured[px.key].id : configured[px.key];
            configuredId = (configuredId || '').trim();

            var idMatch = px.ids.length && configuredId && px.ids.indexOf(configuredId) > -1;
            var idMismatch = px.ids.length && configuredId && !idMatch;
            var statusColor = idMatch ? '#46f1c5' : idMismatch ? '#ffb4ab' : '#adc6ff';
            var statusLabel = idMatch ? '✓ ID Match' : idMismatch ? '⚠ ID Mismatch' : '● Detected';
            var methodBadge = px.isServerSide
              ? '<span style="font-size:10px;padding:2px 7px;border-radius:20px;background:rgba(173,198,255,.1);color:#adc6ff;border:1px solid rgba(173,198,255,.3);">🖥️ Server-side</span>'
              : '<span style="font-size:10px;padding:2px 7px;border-radius:20px;background:rgba(255,214,128,.1);color:#ffd680;border:1px solid rgba(255,214,128,.3);">🌐 Client-side</span>';

            // Filter out generic "event fired — name not parseable" markers from the
            // parameter audit (they can't be audited) — but keep them for status display
            var realEvents = (px.events || []).filter(function (e) { return !e.generic; });
            var evReport = hmBuildEventReport(px.key, realEvents);
            var uid = 'pxev_' + px.key + '_' + Date.now();

            html2 += '<div style="background:var(--sur3);border-radius:12px;margin-bottom:10px;overflow:hidden;border:1px solid var(--bdr2);">';

            // Pixel header
            html2 += '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;flex-wrap:wrap;gap:8px;">'
              + '<div style="display:flex;align-items:center;gap:9px;">'
              + '<span style="font-size:22px;">' + (px.icon || '📌') + '</span>'
              + '<div>'
              + '<div style="font-size:14px;font-weight:800;color:var(--wht);">' + _esc(px.name) + '</div>'
              + '<div style="font-size:11px;color:var(--mut);font-family:var(--font-mono);margin-top:2px;">'
              + (px.ids.length ? 'ID: ' + px.ids.map(function (i) { return _esc(i); }).join(', ') : 'ID not extracted') + '</div>'
              + '</div>'
              + '</div>'
              + '<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">'
              + methodBadge
              + '<span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;background:' + statusColor + '22;color:' + statusColor + ';border:1px solid ' + statusColor + '44;">'
              + statusLabel + '</span>'
              + ((px.events && px.events.length) ? '<button onclick="(function(){var el=document.getElementById(\'' + uid + '\');var isOpen=el.style.display!==\'none\';el.style.display=isOpen?\'none\':\'block\';this.innerHTML=(isOpen?\'▸\':\'▾\')+\' \'+(this.dataset.count)+\' event' + (px.events.length > 1 ? 's' : '') + '\';}).call(this)" data-count="' + px.events.length + '" style="font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid var(--bdr2);background:var(--sur4);color:var(--mut);cursor:pointer;">▾ ' + px.events.length + ' event' + (px.events.length > 1 ? 's' : '') + '</button>' : '')
              + '</div>'
              + '</div>';

            // Request count bar — show both total requests and event-endpoint hits
            var reqStr = (px.requestCount || 0) + ' network request' + ((px.requestCount || 0) !== 1 ? 's' : '') + ' intercepted';
            var hitStr = (typeof px.eventHitCount === 'number' && px.eventHitCount > 0)
              ? ' • <span style="color:#46f1c5;">' + px.eventHitCount + ' event endpoint hit' + (px.eventHitCount > 1 ? 's' : '') + '</span>'
              : '';
            html2 += '<div style="padding:0 14px 10px;font-size:11px;color:var(--mut);">📡 ' + reqStr + hitStr + '</div>';

            // Events health report — OPEN BY DEFAULT
            var pxIssues = hmAnalyzePixel(px);
            if (px.events && px.events.length) {
              html2 += '<div id="' + uid + '" style="display:block;padding:0 12px 12px;">';
              html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">EVENT PARAMETER AUDIT</div>';
              html2 += evReport;
              // Intelligent analysis section (only if we found real issues)
              if (pxIssues.length) {
                html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin:14px 0 8px;">🔍 SMART ANALYSIS (' + pxIssues.length + ' issue' + (pxIssues.length > 1 ? 's' : '') + ')</div>';
                html2 += hmRenderIssues(pxIssues);
              } else {
                html2 += '<div style="font-size:11px;color:#46f1c5;padding:10px 12px;margin-top:10px;background:rgba(70,241,197,.06);border:1px solid rgba(70,241,197,.2);border-radius:10px;">✓ Smart analysis: ما فيش مشاكل اتكتشفت في الـ events الموجودة</div>';
              }
              html2 += '</div>';
            } else if (pxIssues.length) {
              // No events but analyzer flagged issues (e.g. pixel loaded with no events)
              html2 += '<div style="padding:0 12px 12px;">';
              html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">🔍 SMART ANALYSIS</div>';
              html2 += hmRenderIssues(pxIssues);
              html2 += '</div>';
            } else if (HM_EVENT_SCHEMAS[px.key]) {
              html2 += '<div style="padding:0 14px 11px;">'
                + '<div style="font-size:11px;color:var(--mut);padding:8px 10px;border-radius:8px;background:rgba(255,255,255,.03);border:1px dashed var(--bdr2);">'
                + '⚠️ الـ Pixel موجود في الـ network بس مفيش Events اتبعتت — يمكن الـ events بتتبعت server-side أو عبر GTM على صفحات تانية</div>'
                + '</div>';
            }

            html2 += '</div>';
          });

          // Check for configured pixels not found on page
          var configuredNotFound = [];
          HM_PLATFORMS_DEF.forEach(function (plat) {
            var cfgId = typeof (S.pixelIds || {})[plat.key] === 'object' ? (S.pixelIds || {})[plat.key].id : (S.pixelIds || {})[plat.key];
            cfgId = (cfgId || '').trim();
            if (!cfgId) return;
            var wasFound = puppeteerPixels.some(function (p) { return p.key === plat.key; });
            if (!wasFound) configuredNotFound.push({ plat: plat, configuredId: cfgId });
          });
          if (configuredNotFound.length) {
            html2 += '<div style="margin-top:10px;margin-bottom:6px;font-size:12px;font-weight:700;color:#ffb4ab;letter-spacing:1px;text-transform:uppercase;">Configured but NOT found via network</div>';
            configuredNotFound.forEach(function (m) {
              html2 += '<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,180,171,.05);border:1px solid rgba(255,180,171,.2);border-radius:10px;margin-bottom:6px;">'
                + '<span style="font-size:18px;">' + m.plat.icon + '</span>'
                + '<div>'
                + '<div style="font-size:13px;font-weight:700;color:#ffb4ab;">' + m.plat.name + '</div>'
                + '<div style="font-size:11px;color:var(--mut);">Expected ID: ' + _esc(m.configuredId) + ' — no network request detected on page load</div>'
                + '</div></div>';
            });
          }

          resultEl.innerHTML = html2;

        } else {
          // ── FALLBACK: HTML REGEX PATH (no Puppeteer) ──────────────────────
          var found = [];
          var missing = [];
          var configured = S.pixelIds || {};

          HM_PLATFORMS_DEF.forEach(function (plat) {
            var detected = plat.detect(html);
            var ids = hmExtractIds(html, plat.patterns);
            var configuredId = typeof configured[plat.key] === 'object' ? configured[plat.key].id : configured[plat.key];
            configuredId = (configuredId || '').trim();

            if (detected || ids.length) {
              var match = ids.length && configuredId && ids.indexOf(configuredId) > -1;
              var mismatch = ids.length && configuredId && !match;
              var events = hmExtractEvents(html, plat.key);
              found.push({ plat: plat, ids: ids, match: match, mismatch: mismatch, configuredId: configuredId, events: events });
            } else if (configuredId) {
              missing.push({ plat: plat, configuredId: configuredId });
            }
          });

          var html2 = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:6px;">'
            + '<div style="font-size:12px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;">'
            + 'Detected on ' + _esc(resolvedUrl) + ' — ' + found.length + ' pixel(s) found</div>'
            + '<span style="font-size:10px;padding:2px 8px;border-radius:20px;background:rgba(255,214,128,.1);color:#ffd680;border:1px solid rgba(255,214,128,.2);">⚡ HTML Scan (limited)</span>'
            + '</div>';

          if (!found.length && !missing.length) {
            html2 += '<div style="color:var(--mut);font-size:13px;">No known tracking pixels detected on this page.</div>';
          }

          found.forEach(function (f) {
            var statusColor = f.match ? '#46f1c5' : f.mismatch ? '#ffb4ab' : '#adc6ff';
            var statusLabel = f.match ? '✓ ID Match' : f.mismatch ? '⚠ ID Mismatch' : '● Detected';
            var evReport = hmBuildEventReport(f.plat.key, f.events);
            var uid = 'ev_' + f.plat.key + '_' + Date.now();

            html2 += '<div style="background:var(--sur3);border-radius:12px;margin-bottom:10px;overflow:hidden;border:1px solid var(--bdr2);">';
            html2 += '<div style="display:flex;align-items:center;justify-content:space-between;padding:11px 14px;flex-wrap:wrap;gap:8px;">'
              + '<div style="display:flex;align-items:center;gap:8px;">'
              + '<span style="font-size:20px;">' + f.plat.icon + '</span>'
              + '<div>'
              + '<div style="font-size:14px;font-weight:800;color:var(--wht);">' + f.plat.name + '</div>'
              + '<div style="font-size:11px;color:var(--mut);font-family:var(--font-mono);margin-top:1px;">'
              + (f.ids.length ? 'ID: ' + f.ids.join(', ') : 'ID not extracted') + '</div>'
              + '</div>'
              + '</div>'
              + '<div style="display:flex;align-items:center;gap:8px;">'
              + '<span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;background:' + statusColor + '22;color:' + statusColor + ';border:1px solid ' + statusColor + '44;">'
              + statusLabel + '</span>'
              + (f.events.length ? '<button onclick="(function(){var el=document.getElementById(\'' + uid + '\');var isOpen=el.style.display!==\'none\';el.style.display=isOpen?\'none\':\'block\';this.innerHTML=(isOpen?\'▸\':\'▾\')+\' \'+this.dataset.count+\' events\';}).call(this)" data-count="' + f.events.length + '" style="font-size:11px;padding:3px 10px;border-radius:20px;border:1px solid var(--bdr2);background:var(--sur4);color:var(--mut);cursor:pointer;">▾ ' + f.events.length + ' events</button>' : '')
              + '</div>'
              + '</div>';

            // Intelligent analysis wrapper — treat HTML-fallback "found" like a pixel
            var fPseudoPixel = { key: f.plat.key, name: f.plat.name, events: f.events };
            var fIssues = hmAnalyzePixel(fPseudoPixel);
            if (f.events.length) {
              html2 += '<div id="' + uid + '" style="display:block;padding:0 12px 12px;">';
              html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;padding-top:4px;">EVENT HEALTH REPORT</div>';
              html2 += evReport;
              if (fIssues.length) {
                html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin:14px 0 8px;">🔍 SMART ANALYSIS (' + fIssues.length + ' issue' + (fIssues.length > 1 ? 's' : '') + ')</div>';
                html2 += hmRenderIssues(fIssues);
              }
              html2 += '</div>';
            } else if (fIssues.length) {
              html2 += '<div style="padding:0 12px 12px;">';
              html2 += '<div style="font-size:10px;font-weight:700;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;">🔍 SMART ANALYSIS</div>';
              html2 += hmRenderIssues(fIssues);
              html2 += '</div>';
            } else if (HM_EVENT_SCHEMAS[f.plat.key]) {
              html2 += '<div style="padding:0 14px 11px;">'
                + '<div style="font-size:11px;color:var(--mut);padding:8px 10px;border-radius:8px;background:rgba(255,255,255,.03);border:1px dashed var(--bdr2);">'
                + '⚠️ الـ Pixel موجود بس مفيش Events في الـ HTML — install Puppeteer for full network scan</div>'
                + '</div>';
            }

            html2 += '</div>';
          });

          if (missing.length) {
            html2 += '<div style="margin-top:10px;margin-bottom:6px;font-size:12px;font-weight:700;color:#ffb4ab;letter-spacing:1px;text-transform:uppercase;">Configured but NOT found on page</div>';
            missing.forEach(function (m) {
              html2 += '<div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:rgba(255,180,171,.05);border:1px solid rgba(255,180,171,.2);border-radius:10px;margin-bottom:6px;">'
                + '<span style="font-size:18px;">' + m.plat.icon + '</span>'
                + '<div>'
                + '<div style="font-size:13px;font-weight:700;color:#ffb4ab;">' + m.plat.name + '</div>'
                + '<div style="font-size:11px;color:var(--mut);">Expected ID: ' + _esc(m.configuredId) + ' — not detected on page</div>'
                + '</div></div>';
            });
          }

          resultEl.innerHTML = html2;
        }

      } catch (e) {
        resultEl.innerHTML = '<div style="color:#ffb4ab;font-size:13px;">❌ Error: ' + _esc(e.message) + '</div>';
      }

      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:16px;">radar</span> Scan';
    }



    // ══════ PAYLOAD TESTER ══════
    var _payloadData = { vars: [], trigs: [], tags: [], raw: '' };
    var _activePayloadTab = 'vars';

    function gtmPreviewPayload() {
      var src = (typeof _cachedGtmStr !== 'undefined' && _cachedGtmStr) || '';
      if (!src.trim()) {
        alert('اعمل Generate للـ Config الأول من Pixel Config ثم ارجع هنا');
        return;
      }
      var gtmJson;
      try { gtmJson = JSON.parse(src); } catch (e) { alert('GTM JSON غير صحيح'); return; }
      var cv = gtmJson.containerVersion ? gtmJson.containerVersion : gtmJson;
      _payloadData.vars = cv.variable || [];
      _payloadData.trigs = cv.trigger || [];
      _payloadData.tags = cv.tag || [];
      _payloadData.raw = JSON.stringify(cv, null, 2);

      var total = _payloadData.vars.length + _payloadData.trigs.length + _payloadData.tags.length;
      document.getElementById('payloadBadge').textContent =
        _payloadData.tags.length + ' Tags · ' + _payloadData.trigs.length + ' Triggers · ' + _payloadData.vars.length + ' Variables';

      showPayloadTab('vars');
      document.getElementById('payloadModal').style.display = 'flex';
    }

    function showPayloadTab(tab) {
      _activePayloadTab = tab;
      var tabs = ['vars', 'trigs', 'tags', 'raw'];
      tabs.forEach(function (t) {
        var btn = document.getElementById('ptab-' + t);
        if (!btn) return;
        if (t === tab) {
          btn.style.cssText = 'padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;background:rgba(70,241,197,.1);color:#46f1c5;border-bottom:2px solid #46f1c5;';
        } else {
          btn.style.cssText = 'padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;background:transparent;color:#6b7280;';
        }
      });
      var content = document.getElementById('payloadTabContent');
      if (!content) return;

      if (tab === 'raw') {
        content.innerHTML = '<pre style="margin:0;font-family:monospace;font-size:12px;color:#bacac2;line-height:1.6;white-space:pre-wrap;word-break:break-all;">' + _esc(_payloadData.raw) + '</pre>';
        return;
      }

      var items = tab === 'vars' ? _payloadData.vars : tab === 'trigs' ? _payloadData.trigs : _payloadData.tags;
      var typeKey = tab === 'vars' ? 'type' : tab === 'trigs' ? 'type' : 'type';
      var icon = tab === 'vars' ? 'code' : tab === 'trigs' ? 'bolt' : 'label';
      var color = tab === 'vars' ? '#adc6ff' : tab === 'trigs' ? '#d4d4ff' : '#46f1c5';

      if (!items.length) {
        content.innerHTML = '<div style="text-align:center;padding:40px;color:#6b7280;font-size:14px;">لا يوجد ' + (tab === 'vars' ? 'Variables' : tab === 'trigs' ? 'Triggers' : 'Tags') + ' في الـ Config الحالي</div>';
        return;
      }

      var html = '<div style="display:flex;flex-direction:column;gap:8px;">';
      items.forEach(function (item, i) {
        var name = item.name || '(بدون اسم)';
        var type = item.type || '—';
        var jsonStr = JSON.stringify(item, null, 2);
        html += '<div style="border:1px solid rgba(255,255,255,.07);border-radius:12px;overflow:hidden;">'
          + '<div onclick="togglePayloadItem(\'pi' + tab + i + '\')" style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;cursor:pointer;background:rgba(255,255,255,.03);">'
          + '<div style="display:flex;align-items:center;gap:10px;">'
          + '<span class="material-symbols-outlined" style="font-size:16px;color:' + color + ';">' + icon + '</span>'
          + '<span style="font-weight:700;font-size:13px;color:#e1e2eb;">' + _esc(name) + '</span>'
          + '</div>'
          + '<div style="display:flex;align-items:center;gap:8px;">'
          + '<span style="font-size:11px;padding:2px 8px;border-radius:6px;background:rgba(255,255,255,.06);color:#6b7280;">' + _esc(type) + '</span>'
          + '<span class="material-symbols-outlined" style="font-size:16px;color:#6b7280;">expand_more</span>'
          + '</div>'
          + '</div>'
          + '<pre id="pi' + tab + i + '" style="display:none;margin:0;padding:14px 16px;font-family:monospace;font-size:11.5px;color:#bacac2;line-height:1.6;border-top:1px solid rgba(255,255,255,.05);background:#0b0e14;white-space:pre-wrap;word-break:break-all;">'
          + _esc(jsonStr) + '</pre>'
          + '</div>';
      });
      html += '</div>';
      content.innerHTML = html;
    }

    function togglePayloadItem(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }

    function copyPayloadRaw() {
      try {
        navigator.clipboard.writeText(_payloadData.raw);
        var btn = event.currentTarget;
        var orig = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:15px;">check</span> Copied!';
        setTimeout(function () { btn.innerHTML = orig; }, 1800);
      } catch (e) { alert('Copy failed'); }
    }

    function _esc(str) {
      return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

  </script>

  <!-- ══════ PAYLOAD TESTER MODAL ══════ -->
  <div id="payloadModal"
    style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:20px;">
    <div
      style="background:#15181f;border:1.5px solid rgba(70,241,197,.2);border-radius:20px;width:100%;max-width:760px;max-height:88vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.6);">

      <!-- Header -->
      <div
        style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;border-bottom:1px solid rgba(255,255,255,.06);">
        <div style="display:flex;align-items:center;gap:10px;">
          <span class="material-symbols-outlined" style="color:#adc6ff;font-size:20px;">preview</span>
          <span style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:16px;color:#e1e2eb;">Payload
            Preview</span>
          <span id="payloadBadge"
            style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:rgba(70,241,197,.1);color:#46f1c5;border:1px solid rgba(70,241,197,.2);"></span>
        </div>
        <button onclick="document.getElementById('payloadModal').style.display='none'"
          style="background:rgba(255,255,255,.05);border:none;border-radius:8px;width:32px;height:32px;cursor:pointer;color:#bacac2;font-size:18px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>

      <!-- Tabs -->
      <div style="display:flex;gap:4px;padding:12px 22px 0;border-bottom:1px solid rgba(255,255,255,.06);">
        <button id="ptab-vars" onclick="showPayloadTab('vars')"
          style="padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s;">Variables</button>
        <button id="ptab-trigs" onclick="showPayloadTab('trigs')"
          style="padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s;">Triggers</button>
        <button id="ptab-tags" onclick="showPayloadTab('tags')"
          style="padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s;">Tags</button>
        <button id="ptab-raw" onclick="showPayloadTab('raw')"
          style="padding:8px 16px;border-radius:8px 8px 0 0;border:none;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s;">Raw
          JSON</button>
      </div>

      <!-- Content -->
      <div id="payloadTabContent" style="flex:1;overflow-y:auto;padding:18px 22px;">
        <!-- filled by JS -->
      </div>

      <!-- Footer -->
      <div
        style="padding:14px 22px;border-top:1px solid rgba(255,255,255,.06);display:flex;justify-content:flex-end;gap:10px;">
        <button onclick="copyPayloadRaw()"
          style="padding:9px 18px;border-radius:10px;border:1.5px solid rgba(173,198,255,.25);background:transparent;color:#adc6ff;font-weight:700;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;">
          <span class="material-symbols-outlined" style="font-size:15px;">content_copy</span> Copy JSON
        </button>
        <button
          onclick="document.getElementById('payloadModal').style.display='none';document.getElementById('pubGtm').click()"
          style="padding:9px 20px;border-radius:10px;border:none;background:#00d4aa;color:#00382b;font-weight:800;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;">
          <span class="material-symbols-outlined" style="font-size:15px;">rocket_launch</span> Deploy Now
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       EASY TRACK — Complete Marketing Data Infrastructure Engine
       DataLayer Normalizer · Attribution · Deduplication · Server-Side
  ════════════════════════════════════════════════════════════════ -->
  <script>
    (function () {
      'use strict';

      // ══════════════════════════════════════════════════════
      // 1. PLATFORM REGISTRY (Isolation Map)
      // ══════════════════════════════════════════════════════
      var ET_PLATFORMS = {
        ga4: { name: 'GA4', icon: '📊', color: '#F9AB00', type: 'analytics' },
        mixpanel: { name: 'Mixpanel', icon: '📈', color: '#7856FF', type: 'analytics' },
        meta: { name: 'Meta CAPI', icon: '👥', color: '#1877F2', type: 'ads' },
        tiktok: { name: 'TikTok Events', icon: '🎵', color: '#69C9D0', type: 'ads' },
        snapchat: { name: 'Snapchat CAPI', icon: '👻', color: '#FFFC00', type: 'ads' },
        google: { name: 'Google Ads', icon: '🎯', color: '#4285F4', type: 'ads' },
      };

      // ── Event name mapping: GA4 → platform native name ──
      var ET_EVENT_MAP = {
        ga4: {
          view_item: 'view_item', view_item_list: 'view_item_list',
          add_to_cart: 'add_to_cart', view_cart: 'view_cart',
          begin_checkout: 'begin_checkout', purchase: 'purchase',
          remove_from_cart: 'remove_from_cart', add_to_wishlist: 'add_to_wishlist',
          search: 'search', login: 'login', sign_up: 'sign_up'
        },
        meta: {
          view_item: 'ViewContent', view_item_list: 'ViewContent',
          add_to_cart: 'AddToCart', view_cart: 'ViewContent',
          begin_checkout: 'InitiateCheckout', purchase: 'Purchase',
          add_to_wishlist: 'AddToWishlist', search: 'Search',
          login: 'CompleteRegistration', sign_up: 'CompleteRegistration'
        },
        tiktok: {
          view_item: 'ViewContent', view_item_list: 'ViewContent',
          add_to_cart: 'AddToCart', view_cart: 'ViewContent',
          begin_checkout: 'InitiateCheckout', purchase: 'CompletePayment',
          add_to_wishlist: 'AddToWishlist', search: 'Search',
          login: 'CompleteRegistration', sign_up: 'CompleteRegistration'
        },
        snapchat: {
          view_item: 'VIEW_CONTENT', view_item_list: 'VIEW_CONTENT',
          add_to_cart: 'ADD_CART', view_cart: 'VIEW_CONTENT',
          begin_checkout: 'START_CHECKOUT', purchase: 'PURCHASE',
          add_to_wishlist: 'ADD_TO_WISHLIST', search: 'SEARCH',
          login: 'SIGN_UP', sign_up: 'SIGN_UP'
        },
        google: {
          view_item: 'remarketing', view_item_list: 'remarketing',
          add_to_cart: 'conversion', begin_checkout: 'conversion',
          purchase: 'conversion', sign_up: 'conversion'
        },
        mixpanel: {
          view_item: 'Product Viewed', view_item_list: 'Product List Viewed',
          add_to_cart: 'Product Added', view_cart: 'Cart Viewed',
          begin_checkout: 'Checkout Started', purchase: 'Order Completed',
          remove_from_cart: 'Product Removed', add_to_wishlist: 'Product Added to Wishlist',
          search: 'Products Searched', login: 'Signed In', sign_up: 'Signed Up'
        }
      };

      // ══════════════════════════════════════════════════════
      // 2. DATALAYER NORMALIZER — Salla & Zid → GA4
      // ══════════════════════════════════════════════════════

      // Salla raw event → GA4 event name
      var SALLA_UA_TO_GA4 = {
        'Product Viewed': 'view_item', 'product_viewed': 'view_item',
        'Product List Viewed': 'view_item_list', 'product_list_viewed': 'view_item_list',
        'addToCart': 'add_to_cart', 'Add To Cart': 'add_to_cart', 'product_added_to_cart': 'add_to_cart',
        'Cart Viewed': 'view_cart', 'cart_viewed': 'view_cart',
        'Product Removed': 'remove_from_cart', 'product_removed_from_cart': 'remove_from_cart',
        'Product Added to Wishlist': 'add_to_wishlist', 'product_added_to_wishlist': 'add_to_wishlist',
        'cart::submitted': 'begin_checkout', 'checkout_started': 'begin_checkout',
        'purchase': 'purchase', 'order_completed': 'purchase',
        'search': 'search', 'Search': 'search',
        'Signed In': 'login', 'signed_in': 'login', 'login': 'login',
        'sign_up': 'sign_up', 'Signed Up': 'sign_up'
      };

      // Zid event names (already close to GA4)
      var ZID_TO_GA4 = {
        'view_item': 'view_item', 'view_item_list': 'view_item_list',
        'add_to_cart': 'add_to_cart', 'view_cart': 'view_cart',
        'begin_checkout': 'begin_checkout', 'purchase': 'purchase',
        'remove_from_cart': 'remove_from_cart', 'add_to_wishlist': 'add_to_wishlist',
        'search': 'search', 'login': 'login', 'sign_up': 'sign_up'
      };

      function normalizeSallaItems(raw) {
        var prods = [];
        if (!raw) return prods;
        if (Array.isArray(raw)) { prods = raw; }
        else if (raw.id || raw.sku) { prods = [raw]; }
        else if (raw[0] && (raw[0].id || raw[0].sku)) { prods = Object.values(raw); }
        return prods.map(function (p, i) {
          if (!p || typeof p !== 'object') return null;
          var cat = p.category;
          if (cat && typeof cat === 'object') cat = cat.name || cat.title || '';
          var qty = parseInt(p.quantity || p.qty, 10);
          if (isNaN(qty) || qty < 1) qty = 1;
          return {
            item_id: String(p.id || p.sku || p.product_id || ''),
            item_name: p.name || p.title || '',
            item_brand: p.brand || '',
            item_category: cat || p.type || '',
            item_variant: p.variant || p.variation || '',
            price: Math.round(parseFloat(p.price || p.regular_price || p.unit_price || 0) * 100) / 100,
            quantity: qty,
            index: i
          };
        }).filter(function (x) { return x && x.item_id; });
      }

      // ── Dynamic product extractor — detects shape by MEANING, not fixed paths ──
      function extractSallaProducts(raw) {
        var out = [];
        var ec = raw.ecommerce || {};
        var slot0 = raw[0] || raw['0'];
        [ec.add, ec.remove, ec.purchase, ec.checkout, ec.detail].forEach(function (box) {
          if (box && Array.isArray(box.products) && box.products.length) out.push(box.products);
        });
        if (Array.isArray(ec.impressions) && ec.impressions.length) out.push(ec.impressions);
        if (Array.isArray(ec.products) && ec.products.length) out.push(ec.products);
        if (Array.isArray(raw.data) && raw.data.length) out.push(raw.data);
        if (Array.isArray(raw.items) && raw.items.length) out.push(raw.items);
        if (Array.isArray(raw.products) && raw.products.length) out.push(raw.products);
        if (slot0 && typeof slot0 === 'object') {
          if (Array.isArray(slot0.products) && slot0.products.length) out.push(slot0.products);
          else if (slot0.id || slot0.sku || slot0.name) out.push([slot0]);
        }
        if (!out.length) {
          Object.keys(raw).forEach(function (k) {
            if (/^\d+$/.test(k) && raw[k] && (raw[k].id || raw[k].sku || raw[k].name)) {
              out.push([raw[k]]);
            }
          });
        }
        for (var i = 0; i < out.length; i++) if (out[i] && out[i].length) return out[i];
        return [];
      }

      function normalizeZidItems(rawItems) {
        if (!Array.isArray(rawItems)) return [];
        return rawItems.map(function (p, i) {
          var qty = parseInt(p.quantity || p.qty || 1, 10);
          if (isNaN(qty) || qty < 1) qty = 1;
          return {
            item_id: String(p.id || p.product_id || p.sku || ''),
            item_name: p.name || p.title || '',
            item_brand: p.brand || '',
            item_category: p.category || '',
            price: parseFloat(p.price || p.unit_price || 0),
            quantity: qty,
            index: i
          };
        });
      }

      // ── Value logic: meaning over name ──
      function extractValue(ga4Event, items, ec, raw) {
        var val = 0;
        switch (ga4Event) {
          case 'view_item':
            val = items.length ? items[0].price : parseFloat(raw.price || ec.value || 0);
            break;
          case 'view_item_list':
            val = 0; // optional for list views
            break;
          case 'add_to_cart':
            val = items.reduce(function (s, it) { return s + (it.price * it.quantity); }, 0);
            break;
          case 'view_cart':
            val = items.reduce(function (s, it) { return s + (it.price * it.quantity); }, 0);
            break;
          case 'remove_from_cart':
            val = items.reduce(function (s, it) { return s + (it.price * it.quantity); }, 0);
            break;
          case 'begin_checkout':
            val = parseFloat(ec.value || raw.total || raw.subtotal || 0)
              || items.reduce(function (s, it) { return s + (it.price * it.quantity); }, 0);
            break;
          case 'purchase':
            var af = (ec.purchase && ec.purchase.actionField) ||
              (ec.checkout && ec.checkout.actionField) || ec || {};
            val = parseFloat(af.revenue || af.total || ec.revenue || raw.revenue || 0)
              || items.reduce(function (s, it) { return s + (it.price * it.quantity); }, 0);
            break;
          default:
            val = parseFloat(ec.value || raw.value || 0);
        }
        return Math.round(val * 100) / 100;
      }

      // ── Normalize Salla raw push to GA4 structure (shape-agnostic) ──
      function normalizeSalla(raw) {
        if (!raw || !raw.event) return null;
        var ga4Ev = SALLA_UA_TO_GA4[raw.event];
        if (!ga4Ev) return null;

        var ec = raw.ecommerce || {};
        var prod0 = (raw[0] && typeof raw[0] === 'object') ? raw[0] : {};

        // Dynamic extraction — works with data[] / [0] / [0].products / ecommerce.*.products
        var prods = extractSallaProducts(raw);

        var items = normalizeSallaItems(prods);
        var currency = ec.currencyCode || ec.currency || prod0.currency || 'SAR';

        // Monetary field semantics — per-event, NOT generalized:
        //   purchase          → ecommerce.value  (final order revenue / total)
        //   view_item         → ecommerce.price  (single product price)
        //   add_to_wishlist   → ecommerce.price  (single product price)
        //   add_to_cart       → ecommerce.price  (unit price × quantity — line total)
        //   remove_from_cart  → ecommerce.price  (line total of removed item)
        //   view_cart         → ecommerce.price  (sum across all line items)
        //   begin_checkout    → ecommerce.price  (sum across all line items at checkout)
        //   view_item_list    → (no monetary field)
        var ecBlock = { currency: currency, items: items };
        var sumQty = items.reduce(function (s, it) { return s + (parseInt(it.quantity, 10) || 0); }, 0);
        if (ga4Ev === 'purchase') {
          ecBlock.value     = extractValue('purchase', items, ec, raw);
          ecBlock.num_items = sumQty;
        } else if (ga4Ev === 'view_item' || ga4Ev === 'add_to_wishlist') {
          ecBlock.price     = extractValue(ga4Ev, items, ec, raw);
          ecBlock.num_items = items.length ? (parseInt(items[0].quantity, 10) || 1) : 0;
        } else if (ga4Ev === 'add_to_cart' || ga4Ev === 'remove_from_cart' ||
                   ga4Ev === 'view_cart'   || ga4Ev === 'begin_checkout') {
          ecBlock.price     = extractValue(ga4Ev, items, ec, raw);
          ecBlock.num_items = sumQty;
        }

        var payload = {
          event: ga4Ev,
          event_id: generateEventId(raw, ga4Ev),
          ecommerce: ecBlock
        };

        // purchase extras
        if (ga4Ev === 'purchase') {
          var af2 = (ec.purchase && ec.purchase.actionField) || {};
          payload.ecommerce.transaction_id = String(af2.id || ec.event_id || raw.order_id || payload.event_id);
          payload.ecommerce.tax = parseFloat(af2.tax || 0) || 0;
          payload.ecommerce.shipping = parseFloat(af2.shipping || 0) || 0;
          if (af2.coupon) payload.ecommerce.coupon = String(af2.coupon);
        }
        if (ga4Ev === 'view_item_list') {
          payload.ecommerce.item_list_name = raw.title
            ? String(raw.title).replace(/<[^>]+>/g, '').trim() : '';
        }
        if (ga4Ev === 'search') { payload.search_term = raw.searchTerm || raw.search_term || ''; delete payload.ecommerce; }
        if (ga4Ev === 'login') { delete payload.ecommerce; payload.method = 'salla'; }
        if (ga4Ev === 'sign_up') { delete payload.ecommerce; payload.method = 'salla'; }

        if (raw.customer) payload.customer = raw.customer;
        return payload;
      }

      // ── Normalize Zid raw push to GA4 structure ──
      function normalizeZid(raw) {
        if (!raw || !raw.event) return null;
        var ga4Ev = ZID_TO_GA4[raw.event];
        if (!ga4Ev) return null;

