                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:52px;height:52px;">
                  <rect x="8" y="8" width="84" height="84" rx="20" stroke="#1B5E5A" stroke-width="7" fill="none"/>
                  <path d="M 30 67 Q 50 81 70 67" stroke="#1B5E5A" stroke-width="7" stroke-linecap="round" fill="none"/>
                </svg>
